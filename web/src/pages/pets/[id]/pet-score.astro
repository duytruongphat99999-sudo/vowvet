          </div>

          <!-- Inline stat row -->
          <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 text-[13px] mt-3">
            <span class="inline-flex items-center gap-1.5 font-medium" style="color: #ecb921">
              <span class="w-4 h-4 inline-flex shrink-0" x-html="iconSvg(tierIconKey())"></span>
              <span x-text="`${score.level.name_vi} Tier`"></span>
            </span>
            <template x-if="percentile">
              <span class="inline-flex items-center gap-4">
                <span style="color: rgba(236,185,33,0.35)">·</span>
                <span style="color: rgba(255,255,255,0.75)" x-text="`Top ${100 - percentile.percentile}% HCM`"></span>
              </span>
            </template>
            <template x-if="trend">
              <span class="inline-flex items-center gap-4">
                <span style="color: rgba(236,185,33,0.35)">·</span>
                <span class="inline-flex items-center gap-1.5 font-medium" style="color: #ecb921">
                  <span class="w-4 h-4 inline-flex shrink-0" :style="trend.delta_30d < 0 ? 'transform: scaleY(-1)' : ''" x-html="iconSvg('trend-up')"></span>
                  <span x-text="`${trend.delta_30d >= 0 ? '+' : ''}${trend.delta_30d} / 30d`"></span>
                </span>
              </span>
            </template>
          </div>

          <!-- Divider -->
          <div class="mx-auto mt-5 mb-4" style="max-width: 360px; height: 1px; background: rgba(236,185,33,0.25)"></div>

          <!-- Tagline -->
