      async fetchVaccineCalendar() {
        this.vaccine.loading = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/vaccine-calendar`);
          if (res.ok) {
            const j = await res.json();
            this.vaccine.calendar = j.calendar || [];
            // Compute summary
            const cal = this.vaccine.calendar;
            this.vaccine.summary = {
              completed: cal.filter(v => v.status === "completed").length,
              due_soon: cal.filter(v => v.status === "scheduled" && v.days_to_due != null && v.days_to_due <= 14 && v.days_to_due >= 0).length,
              overdue: cal.filter(v => v.status === "overdue").length,
              scheduled: cal.filter(v => v.status === "scheduled" && (v.days_to_due == null || v.days_to_due > 14)).length,
            };
          }
        } catch {} finally {
          this.vaccine.loading = false;
        }
      },
      get vaccineGroups() {
        const cal = this.vaccine.calendar;
        return [
          { key: "overdue", label: "⚠️ Trễ hạn", items: cal.filter(v => v.status === "overdue") },
          { key: "due_soon", label: "🟡 Sắp đến hạn", items: cal.filter(v => v.status === "scheduled" && v.days_to_due != null && v.days_to_due <= 14 && v.days_to_due >= 0) },
          { key: "scheduled", label: "📅 Sắp tới", items: cal.filter(v => v.status === "scheduled" && (v.days_to_due == null || v.days_to_due > 14)) },
          { key: "completed", label: "✓ Đã tiêm", items: cal.filter(v => v.status === "completed") },
          { key: "skipped", label: "❌ Đã bỏ qua", items: cal.filter(v => v.status === "skipped") },
        ];
      },
      // Timeline math
      get todayMarkerX() {
        return this.vaccineDotX(new Date().toISOString().slice(0,10));
      },
      vaccineDotX(dateIso) {
        if (!dateIso) return 50;
        // Map dates trong 12 tháng tới today: today-6 months đến today+6 months
        const today = new Date();
        const minDate = new Date(today); minDate.setMonth(minDate.getMonth() - 6);
        const maxDate = new Date(today); maxDate.setMonth(maxDate.getMonth() + 6);
        const target = new Date(dateIso);
        const total = maxDate.getTime() - minDate.getTime();
        const offset = target.getTime() - minDate.getTime();
        const pct = Math.max(0, Math.min(1, offset / total));
        return 50 + pct * 660;  // 50 left margin, 660 width (12 * 55)
      },
      vaccineRowOffset(vaccineCode) {
        // Spread dots vertically by hash code → tránh overlap
        const codes = ["dhppl_5in1","dhppl_7in1","rabies","rabies_cat","bordetella","lepto","fvrcp","felv","fiv","corona","parvo","distemper"];
        const idx = codes.indexOf(vaccineCode);
        if (idx < 0) return 0;
        const positions = [-15, 0, 15, -10, 5, 10, -20, 20, -5, 25, -25, 15];
        return positions[idx % positions.length];
      },
      vaccineDotColor(status) {
        return {
          completed: "#16a34a",  // green-600
          scheduled: "#3b82f6",  // blue-500
          overdue: "#dc2626",    // red-600
          skipped: "#cbd5e1",    // slate-300
        }[status] || "#94a3b8";
