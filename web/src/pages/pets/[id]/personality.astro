---
/**
 * /pets/[id]/personality — Pet Personality Atelier (M15 + Hybrid Engine v106).
 *
 * KIẾN TRÚC LAI (Hybrid Personality Engine):
 *   • CORE — 20 câu hỏi 1 lần đầu → xác định 1 trong 12 types (k_factor 0.7-1.6)
 *   • STATE — Daily Mood tick (3 cảm xúc/ngày) + Quarterly micro-quiz (3 câu/90 ngày)
 *
 * GIÁ TRỊ:
 *   PetScore = (sum action points) × k_personality
 *   Mỗi type unlock 1 psychological badge + 30-day Action Plan
 *
 * UX:
 *   • Atelier hero brand-synced (gold ink + cream)
 *   • Lucide icons (paw/sparkles/target/brain/heart) thay emoji chrome
 *   • Quiz cards: ink border + gold accent + cream tap state
 *   • Result card: ink portrait + gold k_factor badge + radar màu vàng
 *   • Daily Mood: 3 button (Vui/Lo âu/Lừ đừ) — gắn vào behavioral state
 *   • Quarterly Refresh: hiện sau 90 ngày, 3 câu nhanh detect behavior shift
 */
import Layout from "../../../layouts/Layout.astro";
import FeatureIcon from "../../../components/FeatureIcon.astro";
import { fetchPet } from "../../../lib/api-client.ts";
import QRCode from "qrcode";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";
const APP_DOMAIN =
  import.meta.env.APP_DOMAIN ||
  process.env.APP_DOMAIN ||
  "https://vowvet.monminpet.com";

let questions: any[] = [];
let allTypes: any[] = [];
let existingResult: any = null;

try {
  const [qRes, tRes, pRes] = await Promise.all([
    fetch(`${API_INTERNAL}/api/v1/personality/questions`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/personality/types`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/pets/${petId}/personality`, { headers: { cookie: cookieHeader } }),
  ]);
  if (qRes.ok) questions = (await qRes.json()).questions || [];
  if (tRes.ok) allTypes = (await tRes.json()).types || [];
  if (pRes.ok) {
    const p = await pRes.json();
    if (p.completed) existingResult = p;
  }
} catch (_) {}

// v140 — SSR QR for Wow Card (Task #8). Encode personality public page URL
// (Task #9 sẽ tạo trang /personality-card/[slug]). Pet thiếu public_slug → fallback home.
const personalityCardUrl = pet.public_slug
  ? `${APP_DOMAIN}/personality-card/${pet.public_slug}`
  : `${APP_DOMAIN}/?ref=wowcard`;
let qrDataUrl = "";
try {
  qrDataUrl = await QRCode.toDataURL(personalityCardUrl, {
    width: 240,
    margin: 1,
    errorCorrectionLevel: "M",
    color: { dark: "#0a0a0a", light: "#FFFFFF" },
  });
} catch (_) {
  // Silent — wow card sẽ ẩn QR nếu generate fail
}

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name, photo_url: pet.photo_url, species: pet.species, public_slug: pet.public_slug || null },
  questions,
  allTypes,
  existingResult,
  qrDataUrl,
  personalityCardUrl,
});

// v136: SEO data — title/description đổi theo trạng thái (chưa làm vs đã có result)
const canonicalUrl = `${APP_DOMAIN}/pets/${petId}/personality`;
const speciesViLabel = pet.species === "dog" ? "chó" : pet.species === "cat" ? "mèo" : "thú cưng";
const seoTitle = existingResult?.type
  ? `${pet.name} — ${existingResult.type} · Tính cách thú cưng · VowVet`
  : `Tính cách ${pet.name} · 12 personality types · VowVet`;
const seoDescription = existingResult?.description
  ? String(existingResult.description).replace(/\s+/g, " ").trim().slice(0, 200)
  : `Khám phá tính cách của ${pet.name} — quiz 20 câu hỏi xác định 1 trong 12 personality types, kèm chỉ số k-factor và kế hoạch chăm sóc 30 ngày dành riêng cho ${speciesViLabel} của bạn.`;
const ogImage = pet.photo_url || `${APP_DOMAIN}/og-image.svg`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: canonicalUrl,
  name: seoTitle,
  description: seoDescription,
  inLanguage: "vi-VN",
  isPartOf: {
    "@type": "WebSite",
    name: "VowVet by Mon Min Pet",
    url: APP_DOMAIN,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: ogImage,
  },
  about: {
    "@type": pet.species === "dog" ? "Animal" : pet.species === "cat" ? "Animal" : "Animal",
    name: pet.name,
    image: ogImage,
    additionalType: "https://schema.org/Pet",
    ...(pet.species && {
      animalSpecies: pet.species === "dog" ? "Canis lupus familiaris" : pet.species === "cat" ? "Felis catus" : pet.species,
    }),
    ...(existingResult?.type && {
      description: `Personality type: ${existingResult.type}`,
    }),
  },
};
---

<Layout title={seoTitle} description={seoDescription}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${pet.name} — tính cách thú cưng`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <style is:inline>{`
    @keyframes slideInRight {
      from { opacity: 0; transform: translateX(20px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.96); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes goldShine {
      0%, 100% { transform: scale(1); filter: brightness(1); }
      50% { transform: scale(1.04); filter: brightness(1.15); }
    }
    @keyframes pulseRing {
      0%, 100% { box-shadow: 0 0 0 0 rgba(180,134,8,0.25); }
      50% { box-shadow: 0 0 0 14px rgba(180,134,8,0); }
    }
    @keyframes typeReveal {
      0% { opacity: 0; transform: translateY(20px) scale(0.92); }
      60% { opacity: 1; transform: translateY(-4px) scale(1.02); }
      100% { opacity: 1; transform: translateY(0) scale(1); }
    }
    .question-enter { animation: slideInRight 0.32s ease-out forwards; }
    .result-card-enter { animation: fadeInScale 0.6s ease-out forwards; }
    .type-reveal { animation: typeReveal 0.85s cubic-bezier(.2,.9,.3,1.1) forwards; }
    .k-badge { animation: goldShine 2.4s ease-in-out infinite; }
    .pulse-ring { animation: pulseRing 2.2s ease-out infinite; }
    .atelier-bg {
      background:
        radial-gradient(800px 380px at 12% -10%, rgba(180,134,8,0.10), transparent 55%),
        radial-gradient(700px 340px at 95% 8%, rgba(180,134,8,0.07), transparent 55%),
        linear-gradient(180deg, #fff 0%, #FAF6EC 100%);
    }
    /* DEEP gold (#B48608) — primary accent on light bg */
    .text-gold-deep { color: #B48608 !important; }
    .bg-gold-deep { background-color: #B48608 !important; }
    .border-gold-deep { border-color: #B48608 !important; }
    .gold-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(180,134,8,0.55), transparent);
    }

    /* ═══════════════════════════════════════════════════════
       APPROVED CERTIFICATE CARD — paper feel + visual diagrams
       Tất cả data → gauge / quadrant / timeline / network graph
       ═══════════════════════════════════════════════════════ */
    /* ═══════════════════════════════════════════════════════
       PROFILE BANNER + AVATAR OVERLAP (LinkedIn-style depth)
       Dark banner with massive serif type name → photo overlaps
       bottom edge → K-factor as separate hero stat circle.
       3D depth via stacked shadows + parallax layers.
       ═══════════════════════════════════════════════════════ */

    /* OUTER hero shell — holds banner + overlap photo + caption */
    .pp-shell {
      position: relative;
      margin-bottom: 16px;
    }
    /* Layer 1: dark ink banner with type name as massive watermark */
    .pp-banner {
      position: relative;
      background:
        radial-gradient(120% 100% at 50% 100%, rgba(236,185,33,0.22) 0%, transparent 65%),
        linear-gradient(160deg, #0a0a0a 0%, #1a1612 55%, #251a08 100%);
      border-radius: 24px;
      padding: 22px 22px 56px;
      overflow: hidden;
      box-shadow: 0 22px 50px -20px rgba(0,0,0,0.5), 0 8px 22px -8px rgba(180,134,8,0.32);
    }
    /* Watermark: huge type name in serif-display, slightly offset */
    .pp-watermark {
      font-size: clamp(38px, 9vw, 56px);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 0.92;
      background: linear-gradient(180deg, #ecb921 0%, #B48608 70%, #8B6705 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 6px 24px rgba(236,185,33,0.25);
      filter: drop-shadow(0 2px 0 rgba(0,0,0,0.15));
    }
    .pp-banner-strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .pp-tag {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 800;
      color: #ecb921;
    }

    /* Pet avatar — inside banner bottom-left */
    .pp-avatar-wrap {
      position: relative;
      width: 88px; height: 88px;
      flex-shrink: 0;
    }
    .pp-avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      box-shadow:
        0 0 0 3px #ecb921,
        0 0 0 5px rgba(180,134,8,0.35),
        0 10px 22px -6px rgba(236,185,33,0.5);
    }
    .pp-avatar-crest {
      position: absolute;
      bottom: -2px; right: -2px;
      width: 32px; height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 70%);
      color: #0a0a0a;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 0 2.5px #0a0a0a, 0 4px 10px rgba(0,0,0,0.4);
    }
    .pp-meta-name {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
      font-weight: 800;
    }
    .pp-meta-group {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 800;
      color: #ecb921;
      margin-top: 2px;
    }
    .pp-meta-sub {
      font-size: 11px;
      color: rgba(255,255,255,0.55);
      margin-top: 4px;
    }

    /* ═══ K-FACTOR HERO STAT — the BIG focal circle ═══ */
    .pp-k-hero {
      position: relative;
      background: #fff;
      border-radius: 22px;
      padding: 18px 20px;
      box-shadow:
        0 16px 36px -16px rgba(180,134,8,0.30),
        0 4px 12px -4px rgba(0,0,0,0.08),
        inset 0 0 0 1px rgba(180,134,8,0.22);
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .pp-k-disc {
      position: relative;
      width: 96px; height: 96px;
      flex-shrink: 0;
      border-radius: 50%;
      background:
        radial-gradient(circle at 30% 30%, #ffd95a 0%, #ecb921 35%, #B48608 75%, #8B6705 100%);
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #0a0a0a;
      box-shadow:
        inset 0 -6px 14px rgba(0,0,0,0.18),
        inset 0 6px 14px rgba(255,255,255,0.5),
        0 8px 22px -6px rgba(180,134,8,0.55),
        0 0 0 4px #fff,
        0 0 0 5.5px #B48608;
    }
    .pp-k-disc::before {
      /* Ring of dots circling — orbital decoration */
      content: "";
      position: absolute;
      inset: -14px;
      border-radius: 50%;
      background:
        radial-gradient(circle at 50% 0%, #B48608 1.5px, transparent 2px),
        radial-gradient(circle at 100% 50%, #B48608 1.5px, transparent 2px),
        radial-gradient(circle at 50% 100%, #B48608 1.5px, transparent 2px),
        radial-gradient(circle at 0% 50%, #B48608 1.5px, transparent 2px);
      animation: ppOrbit 18s linear infinite;
      pointer-events: none;
    }
    @keyframes ppOrbit { to { transform: rotate(360deg); } }
    .pp-k-value {
      font-size: 26px;
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .pp-k-mini {
      font-size: 8px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 800;
      margin-top: 3px;
      color: rgba(10,10,10,0.65);
    }
    .pp-k-info {
      flex: 1;
      min-width: 0;
    }
    .pp-k-info-label {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 800;
      color: #B48608;
    }
    .pp-k-info-name {
      font-size: 17px;
      font-weight: 900;
      color: #0a0a0a;
      margin-top: 2px;
      letter-spacing: -0.01em;
    }
    .pp-k-info-sub {
      font-size: 11px;
      color: rgba(10,10,10,0.62);
      margin-top: 4px;
    }

    /* Smaller secondary stats — 3 horizontal tiles below k-hero */
    .pp-tile {
      background: #fff;
      border: 1px solid rgba(180,134,8,0.18);
      border-radius: 14px;
      padding: 10px 12px;
      transition: all .18s ease;
    }
    .pp-tile:hover { transform: translateY(-1px); box-shadow: 0 6px 14px rgba(180,134,8,0.18); }
    .pp-tile-label {
      font-size: 9px;
      letter-spacing: 0.20em;
      text-transform: uppercase;
      font-weight: 800;
      color: #B48608;
    }
    .pp-tile-value {
      font-size: 13px;
      font-weight: 800;
      color: #0a0a0a;
      margin-top: 2px;
      line-height: 1.2;
    }
    .pp-tile-sub {
      font-size: 10px;
      color: rgba(10,10,10,0.55);
      margin-top: 1px;
    }

    /* Light section card */
    .pv-card {
      background: #fff;
      border: 1px solid rgba(180,134,8,0.18);
      border-radius: 18px;
      padding: 16px 18px;
      box-shadow: 0 8px 22px -12px rgba(180,134,8,0.18);
    }
    .pv-card-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #B48608;
      margin-bottom: 10px;
    }
    .pv-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 11px 5px 5px;
      border-radius: 999px;
      background: #FAF6EC;
      border: 1px solid rgba(180,134,8,0.4);
      color: #0a0a0a;
      font-weight: 600;
      font-size: 12px;
    }
    .pv-chip-icon {
      width: 22px; height: 22px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 70%);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .quiz-opt {
      transition: all .18s ease;
    }
    .quiz-opt:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(180,134,8,0.18);
    }
    .mood-pill {
      transition: all .18s ease;
      color: #0a0a0a;
    }
    .mood-pill:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(180,134,8,0.18);
    }
    .mood-pill:active {
      transform: scale(0.96);
    }
    .mood-pill.active {
      background: linear-gradient(135deg, #ecb921, #B48608) !important;
      color: #fff !important;
      border-color: #B48608 !important;
      box-shadow: 0 8px 24px rgba(180,134,8,0.55), inset 0 1px 0 rgba(255,255,255,0.3) !important;
      transform: translateY(-2px) scale(1.03);
      animation: moodPop 0.45s cubic-bezier(.2,.9,.3,1.3);
    }
    .mood-pill.active p,
    .mood-pill.active svg { color: #fff !important; stroke: #fff !important; }
    @keyframes moodPop {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.15); }
      100% { transform: translateY(-2px) scale(1.03); }
    }

    /* Drop cap on description first letter */
    .desc-text::first-letter {
      float: left;
      font-size: 44px;
      line-height: 0.9;
      font-weight: 900;
      color: #B48608;
      padding: 6px 10px 0 0;
      font-family: Georgia, "Times New Roman", serif;
    }

    /* ═══════════════════════════════════════════════════════
       TECH AI ANIMATIONS — Page-wide motion VISIBLE + PERSISTENT
       ═══════════════════════════════════════════════════════ */

    /* Scan line — MORE VISIBLE: wider, brighter, faster */
    @keyframes aiScan {
      0%   { transform: translateX(-110%); }
      100% { transform: translateX(210%); }
    }
    .ai-scan {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      border-radius: 24px;
    }
    .ai-scan::before {
      content: "";
      position: absolute;
      top: 0; bottom: 0;
      width: 35%;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(236,185,33,0.18) 30%,
        rgba(236,185,33,0.55) 50%,
        rgba(236,185,33,0.18) 70%,
        transparent 100%);
      animation: aiScan 4s linear infinite;
      filter: blur(2px);
    }

    /* Gold particles — bigger, brighter, slower drift */
    @keyframes aiFloat {
      0%   { transform: translate(0, 0) scale(1); opacity: 0.6; }
      50%  { transform: translate(12px, -20px) scale(1.4); opacity: 1; }
      100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
    }
    .ai-particle {
      position: absolute;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #ecb921;
      box-shadow: 0 0 12px rgba(236,185,33,0.95), 0 0 24px rgba(236,185,33,0.5);
      pointer-events: none;
      animation: aiFloat 5s ease-in-out infinite;
    }

    /* LIVE indicator — pulsing dot saying "AI online" */
    @keyframes liveDot {
      0%, 100% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 0 rgba(236,185,33,0.7); }
      50%      { transform: scale(1.1); opacity: 0.9; box-shadow: 0 0 0 6px rgba(236,185,33,0); }
    }
    .live-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #ecb921;
      box-shadow: 0 0 8px rgba(236,185,33,0.8);
      display: inline-block;
      animation: liveDot 1.4s ease-in-out infinite;
    }

    /* K-factor disc gentle rotation hint */
    @keyframes discWobble {
      0%, 100% { transform: rotate(0deg); }
      50%      { transform: rotate(2deg); }
    }
    .k-badge { animation: discWobble 3s ease-in-out infinite; }

    /* ═══════════════════════════════════════════════════════
       BIG SURPRISE EFFECTS — Phải-Thấy-Liền
       ═══════════════════════════════════════════════════════ */

    /* 3D tilt on hero card — perspective + mouse follow */
    .tilt-3d {
      transform-style: preserve-3d;
      transition: transform .15s ease-out;
      perspective: 1000px;
    }
    .tilt-3d.tilting { transition: transform .05s ease-out; }

    /* Type name shimmer scan — gold sweep across letters */
    @keyframes nameShine {
      0%   { background-position: -150% 0; }
      40%  { background-position: 150% 0; }
      100% { background-position: 150% 0; }
    }
    .name-shine {
      background: linear-gradient(90deg,
        #fff 0%,
        #fff 40%,
        #ecb921 50%,
        #fff 60%,
        #fff 100%);
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      animation: nameShine 4s ease-in-out infinite;
    }

    /* Confetti pieces falling */
    @keyframes confettiFall {
      0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
      100% { transform: translateY(80vh) rotate(720deg); opacity: 0; }
    }
    .confetti-piece {
      position: fixed;
      top: 0;
      width: 10px; height: 14px;
      pointer-events: none;
      z-index: 9999;
      animation: confettiFall 2.2s cubic-bezier(.2,.6,.4,1) forwards;
    }

    /* Pet photo zoom + glow on hover */
    .pet-photo-zoom {
      transition: all .4s cubic-bezier(.2,.9,.3,1.2);
      cursor: pointer;
    }
    .pet-photo-zoom:hover {
      transform: scale(1.08) rotate(-2deg);
      filter: brightness(1.05);
    }

    /* HUGE k-factor counter — visible big number with shimmer + scale on mount */
    @keyframes kPulseBig {
      0%   { transform: scale(0.3); opacity: 0; }
      60%  { transform: scale(1.25); opacity: 1; }
      80%  { transform: scale(0.95); }
      100% { transform: scale(1); opacity: 1; }
    }
    .k-pulse-mount { animation: kPulseBig 1.2s cubic-bezier(.2,.9,.3,1.4) both; }

    /* Radar polygon reveal expand */
    @keyframes radarReveal {
      0%   { transform-origin: 160px 140px; transform: scale(0.1); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
    /* v136: .dim6-poly duplicate removed — full declaration at line ~1062 (v135 block) takes over */
    @keyframes dotPulse {
      0%, 100% { r: 4; opacity: 1; }
      50%      { r: 5.5; opacity: 0.7; }
    }
    .radar-dot { animation: dotPulse 2.2s ease-in-out infinite; transform-origin: center; }

    /* Number count-up shimmer */
    @keyframes numShimmer {
      0%   { background-position: -100% 0; }
      100% { background-position: 200% 0; }
    }
    .num-glow {
      background: linear-gradient(90deg, #ecb921 0%, #fff 40%, #ecb921 60%, #ecb921 100%);
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      animation: numShimmer 3s linear infinite;
    }

    /* ═══════════════════════════════════════════════════════
       JOURNEY V3 — SUBWAY MAP (Tuyến Atelier)
       Horizontal track + 4 stations + pet "train" moving + ETA card
       ═══════════════════════════════════════════════════════ */
    .jt-card {
      position: relative;
      overflow: hidden;
      background: linear-gradient(165deg, #fff 0%, #FFFCF3 100%);
    }
    /* Top edge shimmer ribbon */
    .jt-card::before {
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, transparent, #B48608, #ecb921, #B48608, transparent);
      background-size: 200% 100%;
      animation: jtShimmer 3s linear infinite;
      z-index: 1;
    }
    @keyframes jtShimmer {
      0%   { background-position: -100% 0; }
      100% { background-position: 200% 0; }
    }

    /* v139 — Growth Journey: Vellum Editorial Timeline (pure Tailwind, không cần custom CSS).
       Vertical gold thread + 4 vellum cards với watermark Fraunces 7xl mờ.
       Active card full color + scale 1.02 trên hover; còn lại opacity-40 grayscale. */


    /* ═══════════════════════════════════════════════════════
       RADAR 6D — AI SCANNER VIEW (light + corner brackets + scan beams)
       ═══════════════════════════════════════════════════════ */
    .ai-scanner-card {
      position: relative;
      overflow: hidden;
      background: linear-gradient(165deg, #FFFCF3 0%, #ffffff 60%, #FAF6EC 100%);
      color: #0a0a0a;
      border: 1px solid rgba(180,134,8,0.30) !important;
    }

    /* Top-left and top-right corner L-brackets */
    .ai-corner {
      position: absolute;
      width: 22px; height: 22px;
      border: 1.8px solid #B48608;
      opacity: 0.9;
      z-index: 4;
      pointer-events: none;
    }
    .ai-corner.tl { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
    .ai-corner.tr { top: 10px; right: 10px; border-left: 0; border-bottom: 0; }
    .ai-corner.bl { bottom: 10px; left: 10px; border-right: 0; border-top: 0; }
    .ai-corner.br { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }

    /* Edge tick marks */
    .ai-tick {
      position: absolute;
      background: #B48608;
      opacity: 0.5;
      pointer-events: none;
      z-index: 3;
    }
    .ai-tick.horiz { width: 10px; height: 1.2px; }
    .ai-tick.vert  { width: 1.2px; height: 10px; }

    /* ★ v135: ICONIC ROTATING RADAR SWEEP — classic radar conical beam, 360° */
    @keyframes radarSweepRotate {
      0%   { transform: translate(-50%, -50%) rotate(0deg); }
      100% { transform: translate(-50%, -50%) rotate(360deg); }
    }
    .radar-sweep {
      position: absolute;
      top: 50%; left: 50%;
      width: 320px; height: 320px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 2;
      background: conic-gradient(from 0deg,
        rgba(236,185,33,0) 0deg,
        rgba(236,185,33,0) 280deg,
        rgba(236,185,33,0.18) 320deg,
        rgba(236,185,33,0.55) 350deg,
        #ecb921 360deg);
      mask: radial-gradient(circle, transparent 0%, transparent 8%, #000 14%, #000 60%, transparent 78%);
      -webkit-mask: radial-gradient(circle, transparent 0%, transparent 8%, #000 14%, #000 60%, transparent 78%);
      transform: translate(-50%, -50%);
      animation: radarSweepRotate 3.6s linear infinite;
      filter: blur(0.5px);
      opacity: 0.85;
    }

    /* ★ v135: BRIGHTER + THICKER scan beams */
    @keyframes aiScanBeamH {
      0%   { transform: translateY(-110px); opacity: 0; }
      10%  { opacity: 1; }
      50%  { transform: translateY(110px); opacity: 1; }
      60%  { opacity: 0; }
      100% { transform: translateY(-110px); opacity: 0; }
    }
    .ai-scan-h {
      position: absolute;
      left: 6%; right: 6%;
      top: 50%;
      height: 3px;
      background: linear-gradient(90deg,
        transparent,
        rgba(236,185,33,0.85) 20%,
        #ffd86a 50%,
        rgba(236,185,33,0.85) 80%,
        transparent);
      box-shadow: 0 0 18px #ffd86a, 0 0 36px rgba(236,185,33,0.7);
      filter: blur(0.6px);
      pointer-events: none;
      animation: aiScanBeamH 3s ease-in-out infinite;
      z-index: 3;
    }
    @keyframes aiScanBeamV {
      0%   { transform: translateX(-140px); opacity: 0; }
      15%  { opacity: 1; }
      50%  { transform: translateX(140px); opacity: 1; }
      65%  { opacity: 0; }
      100% { transform: translateX(-140px); opacity: 0; }
    }
    .ai-scan-v {
      position: absolute;
      top: 6%; bottom: 6%;
      left: 50%;
      width: 2.6px;
      background: linear-gradient(180deg,
        transparent,
        rgba(236,185,33,0.85) 20%,
        #ffd86a 50%,
        rgba(236,185,33,0.85) 80%,
        transparent);
      box-shadow: 0 0 18px #ffd86a, 0 0 36px rgba(236,185,33,0.7);
      filter: blur(0.6px);
      pointer-events: none;
      animation: aiScanBeamV 4s ease-in-out infinite 0.5s;
      z-index: 3;
    }

    /* ★ v135: THICKER + LARGER pulse rings */
    @keyframes aiPulseRing {
      0%   { transform: translate(-50%, -50%) scale(0.4); opacity: 1; }
      80%  { opacity: 0.15; }
      100% { transform: translate(-50%, -50%) scale(2.8); opacity: 0; }
    }
    .ai-pulse-ring {
      position: absolute;
      top: 50%; left: 50%;
      width: 110px; height: 110px;
      border-radius: 50%;
      border: 2.2px solid #ecb921;
      box-shadow: 0 0 20px rgba(236,185,33,0.55), inset 0 0 12px rgba(236,185,33,0.35);
      transform: translate(-50%, -50%);
      pointer-events: none;
      animation: aiPulseRing 2.4s ease-out infinite;
      z-index: 2;
    }
    .ai-pulse-ring.delay-1 { animation-delay: 0.8s; }
    .ai-pulse-ring.delay-2 { animation-delay: 1.6s; }

    /* ★ v135: BIGGER + BRIGHTER neurons */
    .neuron {
      position: absolute;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #ecb921;
      box-shadow: 0 0 14px #ecb921, 0 0 26px #B48608, 0 0 40px rgba(236,185,33,0.45);
      pointer-events: none;
      z-index: 3;
    }
    @keyframes neuronFly1 {
      0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
      25%      { transform: translate(60px, -40px) scale(1.4); opacity: 1; }
      50%      { transform: translate(20px, -80px) scale(0.7); opacity: 0.6; }
      75%      { transform: translate(-50px, -30px) scale(1.3); opacity: 1; }
    }
    @keyframes neuronFly2 {
      0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.7; }
      33%      { transform: translate(-70px, 30px) scale(0.6); opacity: 0.4; }
      66%      { transform: translate(40px, 60px) scale(1.5); opacity: 1; }
    }
    @keyframes neuronFly3 {
      0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
      40%      { transform: translate(50px, 70px) scale(1.2); opacity: 1; }
      80%      { transform: translate(-30px, -40px) scale(0.9); opacity: 0.7; }
    }

    /* ★ v135: Polygon — strong breathing + color pulse */
    .dim6-poly {
      fill: rgba(180,134,8,0.30);
      stroke: #B48608;
      stroke-width: 3;
      filter: drop-shadow(0 0 14px rgba(236,185,33,0.6));
      transform-origin: 160px 140px;
      animation: radarReveal 1.2s cubic-bezier(.2,.9,.3,1.2) 0.4s both,
                 polyBreath 2.8s ease-in-out 1.6s infinite;
    }
    @keyframes polyBreath {
      0%, 100% {
        transform: scale(1) rotate(0deg);
        fill: rgba(180,134,8,0.30);
        stroke-width: 3;
        filter: drop-shadow(0 0 14px rgba(236,185,33,0.6));
      }
      33% {
        transform: scale(1.07) rotate(3deg);
        fill: rgba(236,185,33,0.55);
        stroke-width: 4;
        filter: drop-shadow(0 0 28px rgba(236,185,33,0.95));
      }
      66% {
        transform: scale(0.94) rotate(-3deg);
        fill: rgba(180,134,8,0.38);
        stroke-width: 3.4;
        filter: drop-shadow(0 0 20px rgba(180,134,8,0.8));
      }
    }

    /* Radar vertex dots — gold-deep with glow on light bg */
    .radar-dot-galaxy {
      transform-origin: center;
      filter: drop-shadow(0 0 3px rgba(180,134,8,0.7));
    }
    @keyframes radarDotGalaxyPulse {
      0%, 100% { r: 4; opacity: 1; }
      50%      { r: 6; opacity: 0.7; }
    }
    .radar-dot-galaxy { animation: radarDotGalaxyPulse 2s ease-in-out infinite; }

    /* ★ v135: Synapse arcs — brighter, faster dash flow */
    @keyframes synapseFlow {
      0%, 100% { stroke-dashoffset: 0; opacity: 0.65; }
      50%      { stroke-dashoffset: -28; opacity: 1; }
    }
    .synapse {
      stroke: #ecb921;
      stroke-width: 1.6;
      stroke-dasharray: 5 5;
      opacity: 0.8;
      fill: none;
      filter: drop-shadow(0 0 4px rgba(236,185,33,0.7));
      animation: synapseFlow 2s ease-in-out infinite;
    }
    /* Quiz option SELECTED — gold-deep ring on white card */
    .quiz-opt.selected {
      border-color: #B48608 !important;
      background: #FAF6EC !important;
      box-shadow: 0 0 0 3px rgba(180,134,8,0.22), 0 8px 18px rgba(180,134,8,0.18);
    }
  `}</style>

  <main class="atelier-bg min-h-screen px-4 sm:px-6 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`personalityPage(${initialData})`} x-init="onMount()">

      <!-- ───── Header ───── -->
      <header class="flex items-center justify-between mb-6 gap-3">
        <a href={`/pets/${pet.id}`} class="text-sm text-mmp-ink/70 hover:text-mmp-ink font-medium inline-flex items-center gap-1">
          ← <span>{pet.name}</span>
        </a>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-mmp-cream text-gold-deep">
            <FeatureIcon name="brain" class="w-5 h-5" />
          </span>
          <h1 class="text-base sm:text-lg font-extrabold text-mmp-ink tracking-tight">Personality Atelier</h1>
        </div>
        <button x-show="(step === 'result' || step === 'existing')" @click="confirmReset()"
          class="text-xs font-medium text-mmp-ink/70 hover:text-gold-deep inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
          Làm lại
        </button>
        <span x-show="step !== 'result' && step !== 'existing'" class="w-12"></span>
      </header>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!--  STEP: existing (đã có kết quả — show portrait + tools)   -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <div x-show="step === 'existing'" class="ai-enter">

        <!-- ═════ 1. HERO + WOW LAYERS — gold blobs + scan line + particles + watermark + date ═════ -->
        <section id="result-card-existing" class="relative rounded-3xl bg-mmp-ink text-white overflow-hidden mb-4 shadow-md result-card-enter">
          <!-- Radial gold blobs (background atmosphere) -->
          <div aria-hidden="true" class="absolute -top-16 -right-16 w-56 h-56 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(236,185,33,0.4) 0%, transparent 70%);"></div>
          <div aria-hidden="true" class="absolute -bottom-12 -left-12 w-40 h-40 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(180,134,8,0.28) 0%, transparent 70%);"></div>

          <!-- Tech-AI scan line slowly moving across -->
          <div aria-hidden="true" class="ai-scan"></div>

          <!-- Floating gold particles (decorative ambience) -->
          <div aria-hidden="true" class="ai-particle" style="top:18%;left:12%;"></div>
          <div aria-hidden="true" class="ai-particle" style="top:32%;left:78%;animation-delay:.6s;"></div>
          <div aria-hidden="true" class="ai-particle" style="top:62%;left:22%;animation-delay:1.3s;"></div>
          <div aria-hidden="true" class="ai-particle" style="top:78%;left:88%;animation-delay:2.0s;"></div>
          <div aria-hidden="true" class="ai-particle" style="top:46%;left:54%;animation-delay:2.8s;"></div>

          <!-- HUGE type icon watermark — fills right side with identity -->
          <div aria-hidden="true" class="absolute -top-4 -right-2 pointer-events-none"
            style="width:180px;height:180px;color:#ecb921;opacity:0.12;transform:rotate(-12deg)"
            x-html="typeIcon(activeTypeId, 'w-full h-full')"></div>

          <!-- Top-right date + type number stamp -->
          <div class="absolute top-4 right-4 text-right z-10">
            <p class="text-[9px] uppercase tracking-[0.22em] font-extrabold" style="color:#ecb921">№ <span x-text="String(pet.id).padStart(3,'0')"></span></p>
            <p class="text-[9px] tracking-widest mt-0.5" style="color:rgba(255,255,255,0.45)" x-text="certDate"></p>
          </div>

          <div class="relative p-5 sm:p-6 z-[1]">
            <div class="flex items-center gap-4 mb-4">
              {/* Pet photo — clean, just gold ring */}
              {pet.photo_url ? (
                <img src={pet.photo_url} alt={pet.name} class="w-[88px] h-[88px] rounded-full object-cover shrink-0 pet-photo-zoom" style="box-shadow:0 0 0 3px #ecb921, 0 0 0 5px rgba(180,134,8,0.3), 0 8px 18px -4px rgba(236,185,33,0.5);" />
              ) : (
                <div class="w-[88px] h-[88px] rounded-full bg-mmp-ink flex items-center justify-center shrink-0" style="box-shadow:0 0 0 3px #ecb921, 0 0 0 5px rgba(180,134,8,0.3);">
                  <FeatureIcon name={pet.species === "cat" ? "cat" : "dog"} class="w-10 h-10" style="color:#ecb921" />
