---
/**
 * /account/reset-password?token=XXX — public reset password page.
 * Token comes from email link (mock console log in dev).
 */
import Layout from "../../layouts/Layout.astro";

const url = new URL(Astro.request.url);
const token = url.searchParams.get("token") || "";
---

<Layout title="Đặt lại mật khẩu · VowVet" description="Đặt lại mật khẩu VowVet">
  <main class="min-h-screen flex items-center justify-center px-4 py-8 bg-gradient-to-b from-sky-50 to-white">
    <div class="w-full max-w-md">
      <div class="text-center mb-6">
        <h1 class="text-4xl font-bold tracking-tight text-mmp-ink">
          VowVet
        </h1>
        <p class="mt-2 text-sm text-slate-600">Đặt lại mật khẩu</p>
      </div>

      <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 sm:p-8" x-data={`resetPasswordPage(${JSON.stringify({ token })})`}>

        <template x-if="!token">
          <div class="text-center py-6">
            <p class="text-4xl mb-3">⚠️</p>
            <p class="font-bold text-slate-900 mb-1">Thiếu token</p>
            <p class="text-sm text-slate-500 mb-4">Link không hợp lệ. Vui lòng yêu cầu link mới từ trang đăng nhập.</p>
            <a href="/login" class="inline-block bg-mmp-ink hover:bg-slate-800 text-white font-bold px-5 py-2.5 rounded-xl text-sm">
              ← Quay về đăng nhập
            </a>
          </div>
        </template>

        <template x-if="token && !done">
          <div>
            <h2 class="text-xl font-bold text-slate-900 mb-1">Mật khẩu mới</h2>
            <p class="text-sm text-slate-500 mb-5">Nhập mật khẩu mới cho tài khoản của bạn</p>

            <label class="block text-xs font-semibold text-slate-700 mb-1.5">Mật khẩu mới <span class="text-slate-400 font-normal">(≥8 ký tự, có chữ + số)</span></label>
            <input type="password" x-model="newPassword" placeholder="••••••••" autocomplete="new-password"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:border-mmp-ink focus:ring-2 focus:ring-mmp-gold outline-none mb-3" />

            <label class="block text-xs font-semibold text-slate-700 mb-1.5">Nhập lại mật khẩu</label>
            <input type="password" x-model="confirmPassword" placeholder="••••••••" autocomplete="new-password"
              @keydown.enter="submit()"
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:border-mmp-ink focus:ring-2 focus:ring-mmp-gold outline-none" />

            <template x-if="error">
              <div class="mt-3 bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700" x-text="error"></div>
            </template>

            <button @click="submit()" :disabled="loading || !canSubmit"
              class="w-full mt-4 py-3 rounded-xl bg-mmp-ink hover:opacity-95 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold">
              <span x-show="!loading">Đặt lại mật khẩu</span>
              <span x-show="loading">Đang cập nhật…</span>
            </button>
          </div>
        </template>

        <template x-if="done">
          <div class="text-center py-6">
            <p class="text-5xl mb-3">✅</p>
            <p class="font-bold text-slate-900 mb-1">Đã đặt lại!</p>
            <p class="text-sm text-slate-500 mb-4">Mật khẩu đã được cập nhật. Bạn đã được đăng nhập tự động.</p>
            <a href="/dashboard" class="inline-block bg-mmp-ink hover:bg-slate-800 text-white font-bold px-6 py-3 rounded-xl text-sm">
              Vào Dashboard →
            </a>
          </div>
        </template>
      </div>
    </div>
  </main>

  <script is:inline>
    function resetPasswordPage(initial) {
      return {
        token: initial.token,
        newPassword: "",
        confirmPassword: "",
        loading: false,
        error: "",
        done: false,

        get canSubmit() {
          if (!this.newPassword || !this.confirmPassword) return false;
          if (this.newPassword !== this.confirmPassword) return false;
          if (this.newPassword.length < 8) return false;
          if (!/[A-Za-z]/.test(this.newPassword) || !/\d/.test(this.newPassword)) return false;
          return true;
        },

        async submit() {
          if (!this.canSubmit) {
            this.error = "Mật khẩu chưa đáp ứng yêu cầu (≥8 ký tự, có chữ + số, 2 ô trùng)";
            return;
          }
          this.error = "";
          this.loading = true;
          try {
            const res = await fetch("/api/v1/auth/email/reset-password", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ token: this.token, new_password: this.newPassword }),
            });
            const json = await res.json();
            if (!res.ok) {
              this.error = json.error?.message || "Lỗi đặt lại";
              return;
            }
            this.done = true;
          } catch (err) {
            this.error = "Lỗi kết nối. Thử lại sau.";
          } finally {
            this.loading = false;
          }
        },
      };
    }
  </script>
</Layout>
