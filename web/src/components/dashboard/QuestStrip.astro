---
/**
 * ZONE 3 — Daily Quest strip (Expandable WOW edition).
 *
 * Two interactions, single widget:
 *   1. Tap **header** → collapse/expand toàn widget (tiết kiệm space)
 *   2. Tap **quest card** → expand inline detail card bên dưới (description +
 *      why_text + CTA button hoặc completion message)
 *
 * Replaces the old "2 surfaces" UX (header click → /quests page + card click →
 * feature direct). Now /pets/[id]/quests redirects to /dashboard?focus=quests
 * which auto-scrolls + flashes the widget.
 *
 * Concept (unchanged from #137):
 *   3 quests/day from 15-template pool (1 easy + 1 medium + 1 hard)
 *   Trifecta bonus +50 Pet Score khi 3/3
 *   Difficulty stripe colour: emerald (easy) / amber (medium) / rose (hard)
 *
 * Brand: ink/cream/gold tokens only. Zero blue/sky/cyan.
 */
import FeatureIcon from "../FeatureIcon.astro";
import { getQuestIcon } from "@shared/quest-icons.ts";

interface Props {
  quests: any[];
  completed_count: number;
  petId: number;
  trifecta_bonus?: number;
}
const { quests = [], completed_count = 0, petId, trifecta_bonus = 50 } = Astro.props;

const DIFF = {
  easy:   {
    label: "Dễ",
    stripe: "bg-emerald-400",
    softBg: "bg-emerald-50",
    softBorder: "border-emerald-200",
    softText: "text-emerald-700",
    chip:   "bg-emerald-50 text-emerald-700 border-emerald-200",
  },
  medium: {
    label: "TB",
    stripe: "bg-amber-400",
    softBg: "bg-amber-50",
    softBorder: "border-amber-200",
    softText: "text-amber-700",
    chip:   "bg-amber-50 text-amber-700 border-amber-200",
  },
  hard:   {
    label: "Khó",
    stripe: "bg-rose-500",
    softBg: "bg-rose-50",
    softBorder: "border-rose-200",
    softText: "text-rose-700",
    chip:   "bg-rose-50 text-rose-700 border-rose-200",
  },
} as const;
type Diff = keyof typeof DIFF;

const total = Math.max(quests.length || 0, 3);
const progressPct = total > 0 ? Math.round((completed_count / total) * 100) : 0;
const isTrifecta = completed_count === 3 && quests.length === 3;
const isPartial = quests.length > 0 && quests.length < 3;

// Pre-compute card metadata for Alpine (avoid re-reading props in client loop).
// We resolve the icon meta SERVER-SIDE so the loop body below can render <FeatureIcon>
// directly (Astro components don't work inside Alpine x-for loops, but here we use
// SSR .map() — the SVG markup is fully baked into the HTML).
const cardData = quests.map((q) => {
  const def = q.definition || {};
  const code = q.quest_code || def.code || "";
  const iconMeta = getQuestIcon(code);
  return {
    code,
    name: def.name || code || "Quest",
    description: def.description || "",
    // emoji intentionally OMITTED — replaced by iconName from QUEST_ICON_MAP
    iconName: iconMeta.iconName,
    iconColor: iconMeta.iconColor,
    iconBg: iconMeta.iconBg,
    bonus: def.pet_score_bonus || 0,
    difficulty: (def.difficulty as Diff) || "easy",
    completed: !!q.completed,
    completed_at: q.completed_at || null,
    cta_link: q.cta_link || `/pets/${petId}`,
    why_text: q.why_text || "Giúp chăm sóc bé tốt hơn.",
    cta_button_label: q.cta_button_label || "Bắt đầu →",
    completion_message: q.completion_message || "✓ Hoàn thành!",
  };
});
const cardDataJson = JSON.stringify(cardData);
---

<section
  id="daily-quests-section"
  data-widget="quests"
  x-data={`questStripExpandable(${cardDataJson}, { completed: ${completed_count}, trifecta: ${trifecta_bonus} })`}
  x-init="onMount()"
  class="space-y-3 scroll-mt-20"
>

  <!-- HEADER (clickable: collapses/expands the whole widget) -->
  <button type="button" @click="widgetOpen = !widgetOpen"
    class="w-full flex items-center justify-between gap-3 group hover:opacity-90 transition text-left"
    :aria-expanded="widgetOpen"
    aria-controls="quest-widget-body">
    <div class="inline-flex items-center gap-2 min-w-0">
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-mmp-cream shrink-0">
        <FeatureIcon name="target" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
      </span>
      <div class="min-w-0">
        <h2 class="font-bold text-mmp-ink leading-tight">Hoạt động tích điểm</h2>
        <p class="text-[10px] text-mmp-ink/55 leading-tight">Tăng Pet Score · khám phá tính năng</p>
      </div>
    </div>

    <div class="flex items-center gap-2 shrink-0">
      <!-- Counter pill -->
      <span class="inline-flex items-center gap-1 text-sm font-bold tabular-nums px-2.5 py-1 rounded-full bg-white border border-mmp-cream">
        <span class="text-mmp-ink">{completed_count}</span>
        <span class="text-mmp-ink/25 font-normal">/</span>
        <span style="color: var(--c-gold);">3</span>
      </span>

      {/* Trifecta status pill */}
      {isTrifecta ? (
        <span class="inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200 font-bold animate-pulse">
          <FeatureIcon name="sparkles" class="w-3 h-3" strokeWidth={2.4} />
          Trifecta +{trifecta_bonus}đ
        </span>
      ) : (
        <span class="hidden sm:inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full bg-mmp-cream text-mmp-ink border border-amber-200 font-bold">
          <FeatureIcon name="trophy" class="w-3 h-3" strokeWidth={2} style="color: var(--c-gold);" />
          +{trifecta_bonus} khi 3/3
        </span>
      )}

      {/* Chevron — rotates 180° when widget collapsed */}
      <span class="inline-flex items-center justify-center w-7 h-7 rounded-lg text-mmp-ink/45 group-hover:text-mmp-ink transition">
        <svg class="w-4 h-4 transition-transform duration-200"
             :class="!widgetOpen && '-rotate-90'"
             viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"/>
        </svg>
      </span>
    </div>
  </button>

  <!-- BODY (collapses on header chevron click) -->
  <div id="quest-widget-body"
       x-show="widgetOpen"
       x-cloak
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0 -translate-y-1"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-1"
       class="space-y-3">

    <!-- Progress bar — solid brand gold (v30: synced với toàn site, không gradient nhạt giữa) -->
    <div class="h-1.5 bg-mmp-ink/[0.06] rounded-full overflow-hidden">
      <div class="h-full rounded-full transition-all duration-700"
           style={`width: ${progressPct}%; background-color: var(--c-gold);`}>
      </div>
    </div>

    {quests.length === 0 ? (
      <!-- Empty state (rare after API top-up) -->
      <div class="bg-white border border-mmp-cream rounded-3xl p-6 text-center">
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-mmp-cream mx-auto mb-3">
          <FeatureIcon name="clock" class="w-6 h-6" strokeWidth={1.7} style="color: var(--c-gold);" />
        </span>
        <p class="text-sm font-bold text-mmp-ink">Quest hôm nay sắp tới</p>
        <p class="text-xs text-mmp-ink/55 mt-1">Tự động assign mỗi 7h sáng</p>
      </div>
    ) : (
      <!-- 3-card grid (tap a card to expand inline detail below) -->
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        {cardData.map((c, idx) => {
          const meta = DIFF[c.difficulty as Diff] || DIFF.easy;
          return (
            <div class="relative">
              <button type="button"
                      @click={`toggleCard(${idx})`}
                      :class={`expandedIdx === ${idx} ? 'ring-2 ring-mmp-ink ring-offset-2' : ''`}
                      class={`group relative block w-full h-full bg-white border rounded-2xl p-3 text-center overflow-hidden transition-all ${
                        c.completed
                          ? "border-emerald-200"
                          : "border-mmp-cream hover:border-mmp-ink hover:shadow-md active:scale-95"
                      }`}
                      :aria-expanded={`expandedIdx === ${idx}`}>
                {/* Top difficulty stripe */}
                <span aria-hidden="true" class={`absolute left-0 right-0 top-0 h-1 ${meta.stripe} ${c.completed ? "opacity-50" : ""}`}></span>

                {/* SVG icon in colored chip (replaces def.emoji from Baserow) */}
                <div class={`w-11 h-11 mx-auto mt-1.5 mb-2 rounded-xl ${c.iconBg} flex items-center justify-center transition-transform ${c.completed ? "opacity-50" : "group-hover:scale-110"}`}>
                  <FeatureIcon name={c.iconName} class={`w-6 h-6 ${c.iconColor}`} strokeWidth={1.7} />
                </div>

                <p class={`text-[11px] font-medium leading-tight line-clamp-2 min-h-[2.1em] bg-transparent ${
                  c.completed ? "text-mmp-ink/35 opacity-40" : "text-mmp-ink"
                }`}>
                  {c.name}
                </p>

                <span class={`mt-1.5 inline-flex items-center text-[10px] font-bold px-2 py-0.5 rounded-full border ${meta.chip}`}>
                  {meta.label} · +{c.bonus}
                </span>
              </button>

              {/* Completed checkmark — sibling of button (escapes button's overflow-hidden;
                  pop-out effect via -top-2 -right-2; pointer-events-none preserves card clickability) */}
              {c.completed && (
                <span class="absolute -top-2 -right-2 z-10 inline-flex items-center justify-center w-6 h-6 rounded-full bg-emerald-500 text-white shadow ring-2 ring-white pointer-events-none" aria-hidden="true">
                  <FeatureIcon name="check" class="w-3.5 h-3.5" strokeWidth={3} />
                </span>
              )}
            </div>
          );
        })}
      </div>
    )}

    {/* INLINE DETAIL CARD — shows selected quest's description + why + CTA */}
    {cardData.map((c, idx) => {
      const meta = DIFF[c.difficulty as Diff] || DIFF.easy;
      return (
        <div
          x-show={`expandedIdx === ${idx}`}
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class={`relative rounded-2xl ${meta.softBg} border ${meta.softBorder} p-4 overflow-hidden`}>
          <span aria-hidden="true" class={`absolute left-0 top-0 bottom-0 w-1 ${meta.stripe}`}></span>

          <div class="flex items-start gap-3 pl-2 mb-3">
            {/* Larger SVG icon in colored chip — matches grid card but bigger */}
            <div class={`w-14 h-14 rounded-2xl ${c.iconBg} flex items-center justify-center shrink-0`}>
              <FeatureIcon name={c.iconName} class={`w-7 h-7 ${c.iconColor}`} strokeWidth={1.7} />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <h3 class="font-bold text-mmp-ink leading-tight">{c.name}</h3>
                <span class={`inline-flex items-center text-[10px] font-bold px-2 py-0.5 rounded-full border ${meta.chip}`}>
                  {meta.label} · +{c.bonus}đ
                </span>
              </div>
              {c.description && (
                <p class={`text-xs ${meta.softText} leading-relaxed`}>{c.description}</p>
              )}
            </div>
            <button type="button" @click="expandedIdx = null"
                    class="text-mmp-ink/45 hover:text-mmp-ink shrink-0 -mt-1 -mr-1 p-1" aria-label="Đóng">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M6 6l12 12M6 18L18 6"/>
              </svg>
            </button>
          </div>

          {/* Why-this-quest box */}
          <div class="bg-white/70 rounded-xl p-3 mb-3 border border-white pl-2">
            <p class="text-[10px] uppercase tracking-widest text-mmp-ink font-bold mb-1 inline-flex items-center gap-1">
              <FeatureIcon name="info" class="w-3 h-3" strokeWidth={2} style="color: var(--c-gold);" />
              Tại sao quest này?
            </p>
            <p class="text-xs text-mmp-ink/70 leading-relaxed">{c.why_text}</p>
          </div>

          {/* CTA or completed state */}
          {c.completed ? (
            <div class="flex items-start justify-between gap-2 p-3 rounded-xl bg-emerald-100 border border-emerald-300">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-bold text-emerald-800">{c.completion_message}</p>
                {c.completed_at && (
                  <p class="text-[10px] text-emerald-700 mt-0.5">
                    Hoàn thành lúc {new Date(c.completed_at).toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit" })}
                  </p>
                )}
              </div>
              <FeatureIcon name="sparkles" class="w-5 h-5 text-emerald-600 shrink-0" strokeWidth={2} />
            </div>
          ) : (
            <a href={c.cta_link}
               class="inline-flex items-center justify-center w-full gap-2 bg-mmp-ink text-white px-4 py-3 rounded-xl text-sm font-bold hover:bg-mmp-ink/90 active:scale-[0.99] transition">
              <span>{c.cta_button_label}</span>
            </a>
          )}
        </div>
      );
    })}

    {/* Pedagogical hint when 0/3 done */}
    {completed_count === 0 && quests.length === 3 && (
      <p class="text-center text-[11px] text-mmp-ink/55 italic">
        Hoàn thành cả 3 quest → <strong class="not-italic" style="color: var(--c-gold);">+{trifecta_bonus} Pet Score bonus</strong>
      </p>
    )}

    {/* Trifecta progress nudge — only when 1-2 done */}
    {completed_count > 0 && !isTrifecta && (
      <div class="inline-flex items-start gap-2 w-full p-3 rounded-xl border" style="background: rgba(236, 185, 33, 0.10); border-color: rgba(236, 185, 33, 0.35);">
        <FeatureIcon name="trophy" class="w-4 h-4 shrink-0 mt-0.5" strokeWidth={2} style="color: var(--c-gold);" />
        <p class="text-xs text-mmp-ink font-medium flex-1">
          Còn <strong style="color: var(--c-gold);">{3 - completed_count}</strong> quest nữa để +{trifecta_bonus}đ <strong>Trifecta</strong>!
        </p>
      </div>
    )}

    {/* Celebration card when all 3 done */}
    {isTrifecta && (
      <div class="relative rounded-2xl bg-mmp-ink text-white p-4 text-center overflow-hidden">
        <span aria-hidden="true" class="absolute -top-12 -right-12 w-32 h-32 rounded-full blur-3xl"
              style="background: rgba(236, 185, 33, 0.22);"></span>
        <div class="relative">
          <FeatureIcon name="sparkles" class="w-7 h-7 mx-auto mb-1" strokeWidth={2} style="color: var(--c-gold);" />
          <p class="font-display italic text-base font-semibold" style="color: var(--c-gold);">Trifecta hoàn hảo!</p>
          <p class="text-xs text-white/70 mt-0.5">+{trifecta_bonus}đ Pet Score bonus đã được cộng</p>
        </div>
      </div>
    )}

    {/* Partial-pool warning (very rare after top-up) */}
    {isPartial && (
      <p class="inline-flex items-start gap-1.5 w-full text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2">
        <FeatureIcon name="alert-triangle" class="w-3.5 h-3.5 shrink-0 mt-0.5" strokeWidth={2} />
        <span>Chỉ assign được <strong>{quests.length}/3</strong> quest hôm nay (pool ngắn). Tự động bù lúc 7h sáng mai.</span>
      </p>
    )}
  </div>
</section>

<script is:inline>
  function questStripExpandable(cards, opts) {
    return {
      cards,
      widgetOpen: true,
      expandedIdx: null,

      onMount() {
        // ?focus=quests in URL = highlight + auto-open first un-completed card
        try {
          const params = new URLSearchParams(window.location.search);
          if (params.get("focus") === "quests") {
            this.widgetOpen = true;
            // Open the first un-completed card if any
            const firstPending = this.cards.findIndex((c) => !c.completed);
            if (firstPending !== -1) this.expandedIdx = firstPending;
          }
        } catch (_) {}
      },

      toggleCard(idx) {
        this.expandedIdx = this.expandedIdx === idx ? null : idx;
        if (this.expandedIdx !== null && navigator.vibrate) {
          try { navigator.vibrate(5); } catch (_) {}
        }
      },
    };
  }
</script>
