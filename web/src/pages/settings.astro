---
import Layout from "../layouts/Layout.astro";
import FeatureIcon from "../components/FeatureIcon.astro";
import { CITIES_BY_REGION, REGION_ORDER, REGION_LABEL_VN, getCityDisplayLabel } from "../../../shared/cities.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let settings: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/users/me/settings`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) settings = await res.json();
} catch (_) {}

if (!settings) return Astro.redirect("/login");

// N9: link "Khu bác sĩ" chỉ hiện cho vet. /me KHÔNG expose is_vet → probe /vet/threads/queue
// (200=vet, 403=non-vet), giống dashboard.astro. Gate SERVER-SIDE (omit markup, KHÔNG x-show).
let isVet = false;
try {
  const vetProbe = await fetch(`${API_INTERNAL}/api/v1/vet/threads/queue?limit=1`, {
    headers: { cookie: cookieHeader },
  });
  if (vetProbe.status === 200) isVet = true;
} catch (_) {}

const initialJson = JSON.stringify(settings);
---

<Layout title="Cài đặt · VowVet">
  <main class="min-h-screen px-4 sm:px-6 py-6 bg-slate-50">
    <div class="max-w-2xl mx-auto" x-data={`settingsPage(${initialJson})`}>
      <header class="mb-6 flex items-center justify-between gap-3">
        <a href="/dashboard" class="text-sm text-slate-500 hover:text-mmp-ink">← Dashboard</a>
        <h1 class="font-display italic text-xl font-semibold text-mmp-ink">Cài đặt</h1>
        <span class="w-16"></span>
      </header>

      {/* N9: Khu bác sĩ telehealth — chỉ RENDER cho vet (gate SERVER-SIDE, omit markup nếu non-vet;
          KHÔNG x-show vì view-source vẫn lộ). Probe is_vet qua /vet/threads/queue ở frontmatter. */}
      {isVet && (
        <a href="/vet/dashboard"
          class="relative flex items-center gap-3 bg-mmp-ink text-white rounded-3xl p-5 mb-4 shadow-md hover:bg-slate-800 transition">
          <span class="shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl bg-white/10 ring-1 ring-white/20" aria-hidden="true">
            <svg class="w-6 h-6 text-[#ecb921]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l2 5 4-10 2 5h6"/></svg>
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold">Khu bác sĩ (Vet workspace)</p>
            <p class="text-xs text-white/75">Hàng đợi telehealth — nhận và trả lời câu hỏi khám từ xa</p>
          </div>
          <svg class="w-5 h-5 text-white/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      )}

      <!-- M11: PWA install (only show khi browser support + chưa installed) -->
      <section x-data="pwaInstallSection()" x-show="canInstall || installed"
        class="relative bg-mmp-ink text-white rounded-3xl p-5 mb-4 shadow-md overflow-hidden">
        <span aria-hidden="true"
              class="absolute -top-16 -right-16 w-48 h-48 rounded-full opacity-20 pointer-events-none"
              style="background: radial-gradient(circle, #ecb921 0%, transparent 70%);"></span>
        <div class="relative flex items-center gap-3">
          <span class="shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl bg-white/10 ring-1 ring-white/20" aria-hidden="true">
            <svg class="w-6 h-6 text-[#ecb921]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold">Cài VowVet như app</p>
            <p class="text-xs text-white/75" x-show="!installed">Truy cập nhanh + dùng offline + notification ổn định</p>
            <p class="text-xs text-white/75" x-show="installed">✓ Đã cài — mở từ home screen của bạn</p>
          </div>
          <button x-show="canInstall && !installed" @click="installNow()" :disabled="installing"
            class="bg-[#ecb921] hover:bg-[#d4a417] text-mmp-ink font-semibold px-4 py-2 rounded-lg shrink-0 transition">
            <span x-show="!installing">Cài</span>
            <span x-show="installing">…</span>
          </button>
        </div>
      </section>

      <!-- City -->
      <section class="bg-white rounded-2xl border border-slate-100 p-6 mb-4">
        <h2 class="text-base font-semibold text-mmp-ink mb-1 inline-flex items-center gap-2">
          <FeatureIcon name="map-pin" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          Vị trí
        </h2>
        <p class="text-xs text-slate-500 mb-3">
          Thời tiết và cảnh báo sẽ dựa trên thành phố này — chọn nơi bạn đang sống.
        </p>
        <select
          x-model="city"
          @change="saveCity()"
          class="w-full px-3 py-2.5 rounded-xl border border-slate-200 bg-white text-mmp-ink focus:border-mmp-ink focus:outline-none text-sm transition"
        >
          {REGION_ORDER.map((region) => (
            <optgroup label={REGION_LABEL_VN[region]}>
              {CITIES_BY_REGION[region].map((c) => (
                <option value={c.slug}>{getCityDisplayLabel(c.slug)}</option>
              ))}
            </optgroup>
          ))}
        </select>
        <p class="text-[11px] text-slate-400 mt-2">
          Hỗ trợ <strong class="text-mmp-ink">32 tỉnh/thành</strong> · trải khắp Bắc Trung Nam.
          Chưa thấy nơi bạn ở? <a href="/chat/new?subject=Yêu cầu thêm tỉnh/thành phố"
            class="font-semibold hover:underline" style="color: var(--c-gold);">Yêu cầu thêm →</a>
        </p>
        <p x-show="cityStatus" class="mt-2 text-xs" :class="cityStatus === 'saved' ? 'text-emerald-600' : 'text-red-600'" x-text="cityStatus === 'saved' ? '✓ Đã lưu' : cityStatusMsg"></p>
      </section>

      <!-- Notifications -->
      <section class="bg-white rounded-2xl border border-slate-100 p-6 mb-4">
        <h2 class="text-base font-semibold text-mmp-ink mb-3 inline-flex items-center gap-2">
          <FeatureIcon name="bell" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          Thông báo
        </h2>

        <!-- Master toggle: enable push -->
        <div class="flex items-center justify-between py-2 border-b border-slate-100 mb-3">
          <div class="flex-1">
            <p class="font-medium text-slate-900">Thông báo trình duyệt</p>
            <p class="text-xs text-slate-500" x-text="pushStatusText"></p>
          </div>
          <button
            type="button"
            @click="togglePush()"
            :disabled="pushLoading"
            :class="hasPushSubscription ? 'bg-emerald-600 hover:bg-emerald-700' : 'bg-mmp-ink hover:bg-slate-800'"
            class="text-sm text-white font-semibold px-4 py-2 rounded-lg transition disabled:opacity-50"
          >
            <span x-show="!pushLoading && !hasPushSubscription">Bật</span>
            <span x-show="!pushLoading && hasPushSubscription">Tắt</span>
            <span x-show="pushLoading">…</span>
          </button>
        </div>

        <!-- Sub-toggles -->
        <div class="space-y-2 mb-3" :class="!hasPushSubscription ? 'opacity-50' : ''">
          {/* Sub-toggles rendered SSR (Astro) so Astro <FeatureIcon> works inside the loop */}
          {([
            { key: "heat_warning",        icon: "flame",           label: "Cảnh báo sốc nhiệt" },
            { key: "aqi_warning",         icon: "wind",            label: "Chất lượng không khí" },
            { key: "storm_warning",       icon: "cloud-lightning", label: "Bão và sấm sét" },
            { key: "vaccine_reminders",   icon: "shield",          label: "Nhắc tiêm vaccine (14d / 7d / 1d / quá hạn)" },
            { key: "care_plan_reminders", icon: "clipboard-check", label: "Care Plan hằng ngày (7:15 sáng)" },
            { key: "daily_summary",       icon: "clipboard",       label: "Tóm tắt hàng ngày" },
          ] as const).map((opt) => (
            <label class="flex items-center justify-between py-2 cursor-pointer">
              <span class="inline-flex items-center gap-2.5 text-sm text-mmp-ink">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-mmp-cream shrink-0">
                  <FeatureIcon name={opt.icon} class="w-4 h-4 text-mmp-ink" strokeWidth={1.8} />
                </span>
                {opt.label}
              </span>
              <input type="checkbox" x-model={`prefs.${opt.key}`} @change="savePrefs()" :disabled="!hasPushSubscription" class="rounded" />
            </label>
          ))}
        </div>
        <p x-show="prefsStatus" class="text-xs" :class="prefsStatus === 'saved' ? 'text-green-600' : 'text-red-600'" x-text="prefsStatus === 'saved' ? '✓ Đã lưu' : prefsStatusMsg"></p>

        <!-- Test button -->
        <button
          type="button"
          @click="sendTest()"
          :disabled="!hasPushSubscription || testLoading"
          class="mt-4 w-full text-sm bg-slate-100 hover:bg-slate-200 disabled:opacity-50 text-slate-700 font-medium py-2 rounded-lg"
        >
          <span x-show="!testLoading" class="inline-flex items-center justify-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Gửi thông báo test
          </span>
          <span x-show="testLoading">Đang gửi…</span>
        </button>
        <p x-show="testStatus" class="mt-2 text-xs" :class="testStatus === 'sent' ? 'text-green-600' : 'text-red-600'" x-text="testStatus === 'sent' ? '✓ Đã gửi (kiểm tra notification tray)' : testStatusMsg"></p>
      </section>

      <!-- M8: Banner cho ?linked=google / ?error=* trả về từ OAuth callback -->
      <template x-if="banner.message">
        <div :class="banner.tone === 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-900' : 'bg-red-50 border-red-200 text-red-900'"
             class="border rounded-xl px-4 py-3 mb-4 flex items-center justify-between gap-3">
          <p class="text-sm" x-text="banner.message"></p>
          <button @click="banner.message = ''" class="text-slate-400 hover:text-slate-600">✕</button>
        </div>
      </template>

      <!-- Profile -->
      <section class="bg-white rounded-2xl border border-slate-100 p-6 mb-4">
        <h2 class="text-base font-semibold text-mmp-ink mb-3 inline-flex items-center gap-2">
          <FeatureIcon name="user" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          Hồ sơ
        </h2>
        <div class="space-y-3">
          <div>
            <label class="text-xs text-slate-600 block mb-1">Tên hiển thị</label>
            <div class="flex gap-2">
              <input type="text" x-model="profileForm.name" maxlength="100"
                class="flex-1 px-3 py-2 rounded-lg border border-slate-200 focus:border-mmp-ink focus:outline-none text-sm"
                placeholder="(chưa đặt)" />
              <button type="button" @click="saveProfile()" :disabled="profileSaving || profileForm.name === user.name"
                class="text-sm bg-mmp-ink hover:bg-slate-800 disabled:bg-slate-300 text-white font-semibold px-4 py-2 rounded-lg">
                <span x-show="!profileSaving">Lưu</span>
                <span x-show="profileSaving">…</span>
              </button>
            </div>
          </div>
          <p x-show="profileStatus" class="text-xs" :class="profileStatus === 'saved' ? 'text-green-600' : 'text-red-600'" x-text="profileStatus === 'saved' ? '✓ Đã lưu' : profileStatusMsg"></p>
        </div>
      </section>

      <!-- Account -->
      <section class="bg-white rounded-2xl border border-slate-100 p-6 mb-4">
        <h2 class="text-base font-semibold text-mmp-ink mb-3 inline-flex items-center gap-2">
          <FeatureIcon name="lock" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          Tài khoản
        </h2>

        <!-- Auth methods badges -->
        <div class="flex flex-wrap gap-2 mb-4">
          <template x-if="auth.has_phone">
            <span class="inline-flex items-center gap-1.5 bg-mmp-cream border border-amber-200 text-mmp-ink text-xs font-semibold px-2.5 py-1 rounded-full">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>
              Phone OTP
            </span>
          </template>
          <template x-if="auth.has_google">
            <span class="inline-flex items-center gap-1.5 bg-red-50 border border-red-200 text-red-800 text-xs font-semibold px-2.5 py-1 rounded-full">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              Google
            </span>
          </template>
        </div>

        <dl class="space-y-2 text-sm mb-4">
          <template x-if="user.phone">
            <div class="flex justify-between gap-2">
              <dt class="text-slate-500 shrink-0">Số điện thoại</dt>
              <dd class="font-mono text-slate-900 truncate" x-text="user.phone"></dd>
            </div>
          </template>
          <template x-if="user.email">
            <div class="flex justify-between gap-2">
              <dt class="text-slate-500 shrink-0">Email</dt>
              <dd class="text-slate-900 truncate" x-text="user.email"></dd>
            </div>
          </template>
        </dl>

        <!-- Link / Unlink Google -->
        <div class="space-y-2 mb-4">
          <template x-if="!auth.has_google">
            <a href="/api/v1/users/me/link-google"
               class="inline-flex items-center justify-center gap-2 w-full text-sm bg-white border border-slate-300 hover:border-mmp-ink text-slate-700 hover:text-mmp-ink font-semibold px-4 py-2.5 rounded-lg transition">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              Liên kết với Google
            </a>
          </template>
          <template x-if="auth.has_google && auth.can_unlink_google">
            <button type="button" @click="unlinkGoogle()" :disabled="unlinkLoading"
              class="block w-full text-center text-sm bg-white border border-red-200 hover:bg-red-50 text-red-700 font-semibold px-4 py-2.5 rounded-lg transition disabled:opacity-50">
              <span x-show="!unlinkLoading">Bỏ liên kết Google</span>
              <span x-show="unlinkLoading">…</span>
            </button>
          </template>
          <template x-if="auth.has_google && !auth.can_unlink_google">
            <p class="inline-flex items-start gap-1.5 text-xs text-slate-500 px-2">
              <svg class="w-3.5 h-3.5 shrink-0 mt-0.5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <span>Không thể bỏ liên kết Google vì đây là phương thức đăng nhập duy nhất. Thêm số điện thoại trước.</span>
            </p>
          </template>
        </div>

        <!-- Account management hub -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-4 mb-3 border-t border-slate-100">
          <a href="/account/connections"
             class="group flex items-center gap-2 text-sm bg-white border border-slate-200 hover:border-mmp-ink hover:shadow-sm rounded-xl px-3 py-2.5 transition">
            <svg class="w-4 h-4 text-mmp-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span class="font-medium text-mmp-ink flex-1">Liên kết tài khoản</span>
            <svg class="w-3.5 h-3.5 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
          <template x-if="auth.has_phone || auth.has_email">
            <a href="/account/reset-password"
               class="group flex items-center gap-2 text-sm bg-white border border-slate-200 hover:border-mmp-ink hover:shadow-sm rounded-xl px-3 py-2.5 transition">
              <svg class="w-4 h-4 text-mmp-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="font-medium text-mmp-ink flex-1">Đổi mật khẩu</span>
              <svg class="w-3.5 h-3.5 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </template>
          <template x-if="!auth.has_phone && !auth.has_email">
            <a href="/account/setup-password"
               class="group flex items-center gap-2 text-sm bg-mmp-cream border border-amber-200 hover:border-[#ecb921] hover:shadow-sm rounded-xl px-3 py-2.5 transition">
              <svg class="w-4 h-4" style="color: var(--c-gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="font-medium text-mmp-ink flex-1">Đặt mật khẩu</span>
              <svg class="w-3.5 h-3.5 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </template>
        </div>

        <a href="/logout" class="inline-block text-sm text-slate-600 hover:text-mmp-ink font-medium">Đăng xuất khỏi thiết bị này →</a>
      </section>

      <!-- Session C: Sound + Haptic toggles (client-side localStorage) -->
      <section class="bg-white rounded-2xl border border-slate-100 p-6 mb-4" x-data="feedbackToggles()" x-init="load()">
        <h2 class="text-base font-semibold text-mmp-ink mb-3 inline-flex items-center gap-2">
          <FeatureIcon name="volume" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          Phản hồi cảm ứng
        </h2>
        <p class="text-xs text-slate-500 mb-4">Bật âm thanh + rung khi unlock huy hiệu, lên cấp, hoàn thành quest.</p>

        <label class="flex items-center justify-between gap-3 py-2 cursor-pointer">
          <div class="flex-1">
            <p class="text-sm font-medium text-mmp-ink inline-flex items-center gap-2">
              <FeatureIcon name="bell" class="w-4 h-4 text-mmp-ink" strokeWidth={2} />
              Âm thanh
            </p>
            <p class="text-xs text-slate-500">Ding khi unlock, tada khi tier-up (5 sounds)</p>
          </div>
          <button @click="toggleSnd()" type="button"
            :class="soundsEnabled ? 'bg-mmp-ink' : 'bg-slate-300'"
            class="relative inline-flex h-6 w-11 items-center rounded-full transition shrink-0">
            <span :class="soundsEnabled ? 'translate-x-6' : 'translate-x-1'"
              class="inline-block h-4 w-4 transform rounded-full bg-white transition"></span>
          </button>
        </label>

        <label class="flex items-center justify-between gap-3 py-2 cursor-pointer">
          <div class="flex-1">
            <p class="text-sm font-medium text-mmp-ink inline-flex items-center gap-2">
              <FeatureIcon name="smartphone" class="w-4 h-4 text-mmp-ink" strokeWidth={2} />
              Rung haptic
            </p>
            <p class="text-xs text-slate-500">Phản hồi rung khi tap button (mobile only)</p>
          </div>
          <button @click="toggleHap()" type="button"
            :class="hapticsEnabled ? 'bg-mmp-ink' : 'bg-slate-300'"
            class="relative inline-flex h-6 w-11 items-center rounded-full transition shrink-0">
            <span :class="hapticsEnabled ? 'translate-x-6' : 'translate-x-1'"
              class="inline-block h-4 w-4 transform rounded-full bg-white transition"></span>
          </button>
        </label>

        <p class="text-[10px] text-slate-400 mt-2 italic">
          Sound files có thể chưa tồn tại — toggle sẽ silent no-op nếu thiếu file. Haptic chỉ hoạt động trên Android (iOS Safari không hỗ trợ Vibration API).
        </p>
      </section>

      <!-- Danger zone: delete account -->
      <section class="bg-white rounded-2xl border border-red-100 p-6">
        <h2 class="text-base font-semibold text-red-900 mb-1 inline-flex items-center gap-2">
          <FeatureIcon name="alert-triangle" class="w-4 h-4 text-red-700" strokeWidth={2} />
          Vùng nguy hiểm
        </h2>
        <p class="text-xs text-slate-500 mb-3">Xoá tài khoản sẽ ẩn dữ liệu khỏi hệ thống. Dữ liệu pet được giữ 30 ngày trước khi xoá vĩnh viễn.</p>
        <template x-if="deleteStep === 0">
          <button type="button" @click="deleteStep = 1" class="text-sm bg-red-50 hover:bg-red-100 text-red-700 font-semibold px-4 py-2 rounded-lg">
            <span class="inline-flex items-center justify-center gap-1.5">
              <FeatureIcon name="trash" class="w-3.5 h-3.5" strokeWidth={2} />
              Xoá tài khoản…
            </span>
          </button>
        </template>
        <template x-if="deleteStep === 1">
          <div class="bg-red-50 border-2 border-red-200 rounded-xl p-4 space-y-3">
            <p class="text-sm text-red-900 font-semibold">Bạn chắc chắn muốn xoá tài khoản?</p>
            <ul class="text-xs text-red-800 list-disc pl-5 space-y-0.5">
              <li>Bạn sẽ KHÔNG đăng nhập lại được</li>
              <li>Pets + check-ins + care plans được giữ 30 ngày phòng case khôi phục</li>
              <li>Sau 30 ngày xoá vĩnh viễn theo GDPR</li>
            </ul>
            <p class="text-sm text-red-900">Gõ <code class="bg-red-100 px-1.5 py-0.5 rounded font-mono font-bold">XOA</code> để xác nhận:</p>
            <input type="text" x-model="deleteConfirm" placeholder="XOA"
              class="w-full px-3 py-2 border-2 border-red-200 focus:border-red-500 rounded-lg text-sm font-mono" />
            <div class="flex gap-2">
              <button @click="deleteStep = 0; deleteConfirm = ''" :disabled="deleteLoading"
                class="flex-1 text-sm bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 font-medium px-3 py-2 rounded-lg">Huỷ</button>
              <button @click="doDelete()" :disabled="deleteLoading || deleteConfirm !== 'XOA'"
                class="flex-1 text-sm bg-red-600 hover:bg-red-700 disabled:bg-red-300 text-white font-semibold px-3 py-2 rounded-lg">
                <span x-show="!deleteLoading">Xoá vĩnh viễn</span>
                <span x-show="deleteLoading">Đang xoá…</span>
              </button>
            </div>
            <p x-show="deleteError" class="text-xs text-red-700" x-text="deleteError"></p>
          </div>
        </template>
      </section>
    </div>
  </main>
</Layout>

<script is:inline>
  // M11: PWA install section state (Alpine reads window.__pwa set in Layout)
  function pwaInstallSection() {
    return {
      canInstall: false,
      installed: false,
      installing: false,
      init() {
        // Check tracking từ Layout
        if (window.__pwa?.installed) this.installed = true;
        if (window.__pwa?.deferredPrompt) this.canInstall = true;
        // Listen for events
        window.addEventListener("pwa-installable", () => (this.canInstall = true));
        window.addEventListener("pwa-installed", () => {
          this.installed = true;
          this.canInstall = false;
          this.installing = false;
        });
        // Detect already-installed (display-mode standalone)
        try {
          if (window.matchMedia && window.matchMedia("(display-mode: standalone)").matches) {
            this.installed = true;
          }
        } catch (_) {}
      },
      async installNow() {
        const p = window.__pwa?.deferredPrompt;
        if (!p) return;
        this.installing = true;
        try {
          p.prompt();
          const { outcome } = await p.userChoice;
          if (outcome === "accepted") {
            this.installed = true;
            this.canInstall = false;
          }
          window.__pwa.deferredPrompt = null;
        } catch (_) {} finally {
          this.installing = false;
        }
      },
    };
  }

  function settingsPage(initial) {
    return {
      user: initial.user,
      auth: initial.auth || { method: "phone_otp", has_phone: !!initial.user?.phone, has_google: false, can_unlink_google: false },
      city: initial.city,
      cityStatus: "",
      cityStatusMsg: "",
      prefs: initial.notification_preferences || { heat_warning: true, aqi_warning: true, storm_warning: true, vaccine_reminders: true, care_plan_reminders: true, daily_summary: false },
      // Session C placeholder — feedbackToggles is defined inline below
      prefsStatus: "",
      prefsStatusMsg: "",
      hasPushSubscription: initial.has_push_subscription,
      vapidPublicKey: initial.vapid_public_key,
      pushLoading: false,
      pushStatus: "",
      testLoading: false,
      testStatus: "",
      testStatusMsg: "",

      // M8 — Profile + account state
      profileForm: { name: initial.user?.name || "" },
      profileSaving: false,
      profileStatus: "",
      profileStatusMsg: "",
      unlinkLoading: false,
      deleteStep: 0,
      deleteConfirm: "",
      deleteLoading: false,
      deleteError: "",
      banner: { message: "", tone: "" },

      init() {
        // Parse query string ?linked=google / ?error=*
        try {
          const url = new URL(window.location.href);
          if (url.searchParams.get("linked") === "google") {
            this.banner = { message: "✓ Đã liên kết Google thành công.", tone: "success" };
          }
          const err = url.searchParams.get("error");
          const errorMap = {
            email_taken: "Email Google đã được dùng bởi tài khoản khác.",
            google_linked_other: "Tài khoản Google này đã liên kết với user khác.",
            link_failed: "Liên kết thất bại. Thử lại sau.",
            link_no_session: "Phiên hết hạn. Đăng nhập lại để liên kết.",
            session_invalid: "Phiên không hợp lệ.",
          };
          if (err && errorMap[err]) {
            this.banner = { message: errorMap[err], tone: "error" };
          }
          // Cleanup URL
          if (url.searchParams.has("linked") || url.searchParams.has("error")) {
            url.searchParams.delete("linked");
            url.searchParams.delete("error");
            window.history.replaceState({}, "", url.pathname + (url.search || ""));
          }
        } catch (_) {}
      },

      get pushStatusText() {
        if (!("Notification" in window)) return "Trình duyệt không hỗ trợ thông báo";
        if (!this.vapidPublicKey) return "Server chưa cấu hình VAPID — báo dev";
        if (this.hasPushSubscription) return "✓ Đã bật cho thiết bị này";
        if (Notification.permission === "denied") return "Đã từ chối quyền — bật trong trình duyệt settings";
        return "Tắt — Bật để nhận cảnh báo khẩn cấp";
      },

      async saveCity() {
        this.cityStatus = ""; this.cityStatusMsg = "";
        try {
          const res = await fetch("/api/v1/users/me/city", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ city: this.city }),
          });
          const j = await res.json();
          if (res.ok) {
            this.cityStatus = "saved";
            setTimeout(() => (this.cityStatus = ""), 2000);
          } else {
            this.cityStatus = "error";
            this.cityStatusMsg = j.error?.message || "Lỗi";
          }
        } catch {
          this.cityStatus = "error"; this.cityStatusMsg = "Lỗi mạng";
        }
      },

      async savePrefs() {
        this.prefsStatus = ""; this.prefsStatusMsg = "";
        try {
          const res = await fetch("/api/v1/users/me/notification-preferences", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(this.prefs),
          });
          if (res.ok) {
            this.prefsStatus = "saved";
            setTimeout(() => (this.prefsStatus = ""), 2000);
          } else {
            this.prefsStatus = "error";
            this.prefsStatusMsg = "Lỗi lưu";
          }
        } catch {
          this.prefsStatus = "error"; this.prefsStatusMsg = "Lỗi mạng";
        }
      },

      async togglePush() {
        if (this.hasPushSubscription) {
          await this.unsubscribePush();
        } else {
          await this.subscribePush();
        }
      },

      async subscribePush() {
        if (!("Notification" in window) || !("serviceWorker" in navigator)) {
          alert("Trình duyệt không hỗ trợ");
          return;
        }
        if (!this.vapidPublicKey) {
          alert("VAPID chưa cấu hình ở server");
          return;
        }
        this.pushLoading = true;
        try {
          const perm = await Notification.requestPermission();
          if (perm !== "granted") {
            alert("Bạn đã từ chối quyền thông báo. Bật lại trong settings trình duyệt.");
            return;
          }

          // Register SW
          const reg = await navigator.serviceWorker.register("/sw.js", { scope: "/" });
          await navigator.serviceWorker.ready;

          // Convert VAPID public key
          const appServerKey = this._urlBase64ToUint8Array(this.vapidPublicKey);
          const sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: appServerKey,
          });

          // Send to server
          const res = await fetch("/api/v1/users/me/push-subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ subscription: sub.toJSON() }),
          });
          if (res.ok) {
            this.hasPushSubscription = true;
          } else {
            const j = await res.json();
            alert("Lỗi: " + (j.error?.message || res.status));
          }
        } catch (err) {
          console.error("subscribe failed", err);
          alert("Subscribe thất bại: " + err.message);
        } finally {
          this.pushLoading = false;
        }
      },

      async unsubscribePush() {
        this.pushLoading = true;
        try {
          const reg = await navigator.serviceWorker.getRegistration("/");
          if (reg) {
            const sub = await reg.pushManager.getSubscription();
            if (sub) await sub.unsubscribe();
          }
          await fetch("/api/v1/users/me/push-unsubscribe", { method: "POST" });
          this.hasPushSubscription = false;
        } catch (err) {
          console.error("unsubscribe failed", err);
        } finally {
          this.pushLoading = false;
        }
      },

      async sendTest() {
        this.testLoading = true; this.testStatus = ""; this.testStatusMsg = "";
        try {
          const res = await fetch("/api/v1/push/test", { method: "POST" });
          const j = await res.json();
          if (res.ok && j.success) {
            this.testStatus = "sent";
            setTimeout(() => (this.testStatus = ""), 5000);
          } else {
            this.testStatus = "error";
            this.testStatusMsg = j.error?.message || j.result?.reason || "Lỗi";
          }
        } catch {
          this.testStatus = "error"; this.testStatusMsg = "Lỗi mạng";
        } finally {
          this.testLoading = false;
        }
      },

      // logout() removed — now uses <a href="/logout"> (server-side atomic clear + redirect).


      // M8 — Profile save
      async saveProfile() {
        this.profileStatus = ""; this.profileStatusMsg = ""; this.profileSaving = true;
        try {
          const res = await fetch("/api/v1/users/me/update-profile", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ name: this.profileForm.name || null }),
          });
          const j = await res.json();
          if (res.ok) {
            this.user.name = this.profileForm.name;
            this.profileStatus = "saved";
            setTimeout(() => (this.profileStatus = ""), 2500);
          } else {
            this.profileStatus = "error";
            this.profileStatusMsg = j.error?.message || "Lỗi lưu";
          }
        } catch {
          this.profileStatus = "error"; this.profileStatusMsg = "Lỗi mạng";
        } finally {
          this.profileSaving = false;
        }
      },

      // M8 — Unlink Google
      async unlinkGoogle() {
        if (!confirm("Bỏ liên kết Google? Bạn vẫn login được bằng phone OTP.")) return;
        this.unlinkLoading = true;
        try {
          const res = await fetch("/api/v1/users/me/unlink-google", { method: "POST" });
          const j = await res.json();
          if (res.ok) {
            this.auth.has_google = false;
            this.auth.can_unlink_google = false;
            this.auth.method = "phone_otp";
            this.user.email = null;
            this.banner = { message: "✓ Đã bỏ liên kết Google.", tone: "success" };
          } else {
            this.banner = { message: j.error?.message || "Lỗi bỏ liên kết", tone: "error" };
          }
        } catch {
          this.banner = { message: "Lỗi mạng", tone: "error" };
        } finally {
          this.unlinkLoading = false;
        }
      },

      // M8 — Delete account (soft)
      async doDelete() {
        this.deleteError = "";
        if (this.deleteConfirm !== "XOA") {
          this.deleteError = "Gõ 'XOA' để xác nhận";
          return;
        }
        this.deleteLoading = true;
        try {
          const res = await fetch("/api/v1/users/me/delete-account", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ confirm: "XOA" }),
          });
          const j = await res.json();
          if (res.ok) {
            // API đã clear cookie, redirect login
            window.location.href = "/login?deleted=1";
          } else {
            this.deleteError = j.error?.message || "Lỗi xoá";
          }
        } catch {
          this.deleteError = "Lỗi mạng";
        } finally {
          this.deleteLoading = false;
        }
      },

      _urlBase64ToUint8Array(base64String) {
        const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
        const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
        const raw = window.atob(base64);
        const arr = new Uint8Array(raw.length);
        for (let i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
        return arr;
      },
    };
  }

  // Session C: sound + haptic toggles (client-side localStorage)
  function feedbackToggles() {
    return {
      soundsEnabled: false,
      hapticsEnabled: true,
      load() {
        try {
          this.soundsEnabled = localStorage.getItem("vowvet_sounds_enabled") === "true";
          const h = localStorage.getItem("vowvet_haptics_enabled");
          this.hapticsEnabled = h === null ? true : h === "true";
        } catch (_) {}
      },
      toggleSnd() {
        this.soundsEnabled = !this.soundsEnabled;
        try { localStorage.setItem("vowvet_sounds_enabled", this.soundsEnabled ? "true" : "false"); } catch (_) {}
        // Light feedback
        if (this.soundsEnabled) {
          try {
            const a = new Audio("/sounds/pop.mp3");
            a.volume = 0.3;
            a.play().catch(() => {});
          } catch (_) {}
        }
      },
      toggleHap() {
        this.hapticsEnabled = !this.hapticsEnabled;
        try { localStorage.setItem("vowvet_haptics_enabled", this.hapticsEnabled ? "true" : "false"); } catch (_) {}
        if (this.hapticsEnabled && navigator.vibrate) {
          try { navigator.vibrate([10, 50, 10]); } catch (_) {}
        }
      },
    };
  }
</script>
