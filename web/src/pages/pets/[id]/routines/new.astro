<script is:inline define:vars={{ BLUEPRINTS_JSON: JSON.stringify(BLUEPRINTS) }}>
  window.__VOWVET_BLUEPRINTS = JSON.parse(BLUEPRINTS_JSON);
</script>

<Layout title={`Tạo routine · ${pet.name}`} description="Routine builder 3 bước">
