---
/**
 * /pets/[id]/diary/[entryId] — Diary entry detail (M14).
 *
 * Full pet_diary with serif typography, audio playback, edit/delete/regenerate.
 */
import Layout from "../../../../layouts/Layout.astro";
import { fetchPet } from "../../../../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const entryId = Number(Astro.params.entryId);

if (!Number.isFinite(petId) || !Number.isFinite(entryId)) {
  return Astro.redirect(`/pets/${petId}/diary`);
}

const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let entry: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/diary/${entryId}`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) entry = await res.json();
} catch (_) {}

if (!entry) return Astro.redirect(`/pets/${petId}/diary`);

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name, photo_url: pet.photo_url, species: pet.species },
  entry,
});
---

<Layout title={`${entry.pet_diary_title} · ${pet.name}`} description={entry.pet_diary?.slice(0, 140) || ""}>
  <style is:inline>{`
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .diary-paragraph { animation: fadeInUp 0.6s ease-out forwards; opacity: 0; }
    .diary-body p { font-family: Georgia, "Times New Roman", serif; line-height: 1.85; }
  `}</style>

  <main class="min-h-screen bg-gradient-to-b from-amber-50 to-rose-50 px-4 sm:px-6 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`diaryDetail(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href={`/pets/${petId}/diary`} class="text-sm text-slate-500 hover:text-slate-700">← Nhật ký</a>
        <h1 class="text-base font-bold text-slate-900 truncate">📔 Chi tiết</h1>
        <button @click="confirmDelete()" class="text-xs text-red-500 hover:text-red-700">🗑️ Xoá</button>
      </header>

      <!-- Hero card -->
      <article class="bg-white rounded-3xl border border-slate-100 shadow-md overflow-hidden mb-4">

        <!-- Hero image / mood band -->
        <div class="relative h-40 bg-gradient-to-br from-mmp-cream via-mmp-cream to-amber-200">
          {pet.photo_url && (
            <img src={pet.photo_url} alt={pet.name} class="absolute inset-0 w-full h-full object-cover opacity-50 mix-blend-multiply" />
          )}
          <div class="absolute bottom-3 left-3 right-3 flex items-end justify-between gap-3">
            <span class="text-6xl drop-shadow" x-text="moodEmoji[entry.mood_detected] || '📔'"></span>
            <span class="bg-white/85 backdrop-blur rounded-full px-3 py-1 text-xs font-bold text-slate-700" x-text="fmtDate(entry.entry_date)"></span>
          </div>
        </div>

        <!-- Title + meta -->
        <div class="p-5 sm:p-6">
          <h2 class="text-2xl font-extrabold text-slate-900 mb-2" style="font-family: Georgia, serif" x-text="entry.pet_diary_title"></h2>
          <p class="text-xs text-slate-500 mb-5">
            <span x-text="moodLabel[entry.mood_detected] || 'Một ngày bình thường'"></span> ·
            <span x-text="entry.word_count + ' từ'"></span>
            <template x-if="entry.duration_seconds">
              <span> · <span x-text="entry.duration_seconds + 's ghi'"></span></span>
            </template>
          </p>

          <!-- Body — paragraphs from pet_diary -->
          <div class="diary-body space-y-4">
            <template x-for="(p, idx) in (entry.pet_diary || '').split('\\n\\n')" :key="idx">
              <p class="text-slate-800 diary-paragraph"
                :style="`animation-delay: ${idx * 180}ms`"
                x-text="p"></p>
            </template>
          </div>

          <!-- Audio player -->
          <template x-if="entry.audio_url">
            <div class="mt-6 pt-5 border-t border-slate-100">
              <p class="text-xs text-slate-500 mb-2">🔊 Ghi âm gốc</p>
              <audio :src="entry.audio_url" controls class="w-full h-10"></audio>
            </div>
          </template>
        </div>
      </article>

      <!-- Owner transcript (collapsible) -->
      <div class="bg-white/60 backdrop-blur rounded-2xl border border-slate-100 p-4 mb-4">
        <button @click="showTranscript = !showTranscript"
          class="w-full text-left flex items-center justify-between text-sm font-semibold text-slate-700">
          <span>📝 Câu chuyện gốc từ chủ</span>
          <span class="text-xs text-slate-400" x-text="showTranscript ? '▼' : '▶'"></span>
        </button>
        <div x-show="showTranscript" x-transition class="mt-3 bg-slate-50 rounded-xl p-3">
          <p class="text-xs text-slate-700 leading-relaxed whitespace-pre-line" x-text="entry.owner_transcript"></p>
          <button @click="startEdit()" class="mt-3 text-xs text-mmp-ink hover:underline font-medium">
            ✏️ Sửa transcript & tạo lại
          </button>
        </div>
      </div>

      <!-- Edit mode -->
      <div x-show="editing" class="bg-white rounded-2xl border-2 border-mmp-cream p-5 mb-4">
        <h3 class="text-base font-bold text-mmp-ink mb-3">✏️ Sửa câu chuyện</h3>
        <textarea x-model="editTranscript" rows="6" maxlength="3000"
          class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-mmp-gold resize-none"></textarea>
        <p class="text-xs text-slate-500 mt-2"><span x-text="wordCount(editTranscript) + ' từ'"></span></p>
        <template x-if="editError">
          <p class="text-xs text-red-600 mt-2" x-text="editError"></p>
        </template>
        <div class="flex gap-2 mt-3">
          <button @click="editing = false; editError = null"
            class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold py-2 rounded-xl text-sm">
            Huỷ
          </button>
          <button @click="saveEdit()" :disabled="saving"
            class="flex-[2] bg-mmp-ink hover:bg-slate-800 disabled:opacity-50 text-white font-bold py-2 rounded-xl text-sm">
            <span x-show="!saving">✨ Tạo lại nhật ký</span>
            <span x-show="saving">Đang tạo...</span>
          </button>
        </div>
      </div>

      <!-- Footer actions -->
      <div class="flex gap-2 mt-4">
        <a :href="`/pets/${pet.id}/diary`"
          class="flex-1 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 text-center font-semibold py-2.5 rounded-xl text-sm">
          📜 Tất cả nhật ký
        </a>
        <a :href="`/pets/${pet.id}/diary`"
          class="flex-1 bg-mmp-ink hover:bg-slate-800 text-white text-center font-semibold py-2.5 rounded-xl text-sm">
          🎙️ Ghi mới
        </a>
      </div>

    </div>
  </main>

  <script is:inline>
    function diaryDetail(initial) {
      return {
        pet: initial.pet,
        entry: initial.entry,
        showTranscript: false,
        editing: false,
        editTranscript: "",
        editError: null,
        saving: false,

        moodEmoji: { happy: "😊", sad: "😢", funny: "😄", exciting: "🎉", ordinary: "🐾" },
        moodLabel: { happy: "Một ngày vui 😊", sad: "Một ngày buồn 😢", funny: "Một ngày thú vị 😄", exciting: "Một ngày đặc biệt 🎉", ordinary: "Một ngày bình thường 🐾" },

        startEdit() {
          this.editTranscript = this.entry.owner_transcript || "";
          this.editing = true;
          this.editError = null;
        },

        wordCount(t) {
          return (t || "").trim().split(/\s+/).filter(Boolean).length;
        },

        async saveEdit() {
          this.editError = null;
          if (this.wordCount(this.editTranscript) < 5) {
            this.editError = "Cần ít nhất 5 từ.";
            return;
          }
          this.saving = true;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/diary/${this.entry.id}`, {
              method: "PUT",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ owner_transcript: this.editTranscript }),
            });
            if (!res.ok) {
              const j = await res.json().catch(() => ({}));
              this.editError = j?.error?.message || "Lỗi cập nhật.";
              return;
            }
            this.entry = await res.json();
            this.editing = false;
          } catch (err) {
            this.editError = "Không kết nối được server.";
          } finally {
            this.saving = false;
          }
        },

        async confirmDelete() {
          if (!confirm("Xoá nhật ký này? Hành động không hoàn tác.")) return;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/diary/${this.entry.id}`, {
              method: "DELETE",
              credentials: "include",
            });
            if (res.ok) {
              window.location.href = `/pets/${this.pet.id}/diary`;
            }
          } catch (_) {}
        },

        fmtDate(iso) {
          if (!iso) return "";
          try {
            return new Date(iso + "T00:00:00").toLocaleDateString("vi-VN", {
              weekday: "short", day: "2-digit", month: "2-digit", year: "numeric",
            });
          } catch { return iso; }
        },
      };
    }
  </script>
</Layout>
