---
/**
 * /map — Pet-friendly places explorer (M26).
 *
 * PUBLIC page. Leaflet + OpenStreetMap tiles (no API key required).
 * Filter by category, search by name, geolocation "near me".
 * Click marker → bottom sheet with place detail + check-in link.
 */
import Layout from "../layouts/Layout.astro";
import FeatureIcon from "../components/FeatureIcon.astro";

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// SSR fetch initial places (broad query — frontend can re-filter)
let places: any[] = [];
let categories: any[] = [];
try {
  const [pRes, cRes] = await Promise.all([
    fetch(`${API_INTERNAL}/api/v1/places`),
    fetch(`${API_INTERNAL}/api/v1/places/categories`),
  ]);
  if (pRes.ok) places = (await pRes.json()).places || [];
  if (cRes.ok) categories = (await cRes.json()).categories || [];
} catch (_) {}

const initialData = JSON.stringify({ places, categories });
---

<Layout title="Bản đồ pet-friendly · VowVet" description="Khám phá địa điểm pet-friendly ở HCMC: công viên, cafe, vet, grooming">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <style is:inline>
    #leaflet-map { height: calc(100vh - 64px); width: 100%; }
    .place-marker {
      background: white; border: 2px solid var(--color-mmp-ink, #0a0a0a); border-radius: 50%;
      width: 38px !important; height: 38px !important;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; box-shadow: 0 3px 10px rgba(0,0,0,0.15);
      transition: transform 0.15s;
    }
    .place-marker:hover { transform: scale(1.15); }
    .place-marker.verified { border-color: #10b981; }
    /* GĐ4.2 Map-Lai: marker gợi ý OSM — NỔI BẬT hẳn (nền gold đặc + to + viền ink dày + glow + pop) */
    .place-marker.suggest {
      background: var(--color-mmp-gold, #ecb921);
      border: 3px dashed var(--color-mmp-ink, #0a0a0a);
      width: 46px !important; height: 46px !important;
      font-size: 22px;
      opacity: 1;
      box-shadow: 0 0 0 4px rgba(236, 185, 33, 0.30), 0 4px 14px rgba(0, 0, 0, 0.30);
      animation: suggest-pop 0.45s cubic-bezier(0.2, 0.8, 0.3, 1.25), suggest-glow 1.3s ease-in-out 0.45s 2;
    }
    .place-marker.suggest::after {
      content: "+";
      position: absolute;
      top: -6px; right: -6px;
      width: 18px; height: 18px;
      background: var(--color-mmp-ink, #0a0a0a);
      color: #fff;
      border: 2px solid #fff;
      border-radius: 50%;
      font-size: 13px; font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.35);
    }
    @keyframes suggest-pop {
      0%   { transform: scale(0.3); opacity: 0; }
      60%  { transform: scale(1.18); opacity: 1; }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes suggest-glow {
      0%, 100% { box-shadow: 0 0 0 4px rgba(236, 185, 33, 0.30), 0 4px 14px rgba(0, 0, 0, 0.30); }
      50%      { box-shadow: 0 0 0 10px rgba(236, 185, 33, 0.55), 0 4px 14px rgba(0, 0, 0, 0.30); }
    }
    @media (prefers-reduced-motion: reduce) {
      .place-marker.suggest { animation: none; }
    }
  </style>

  <main class="relative" x-data={`mapPage(${initialData})`} x-init="onMount()">

    <!-- Top filter bar -->
    <div class="absolute top-3 left-3 right-3 z-[1000] pointer-events-none">
      <div class="bg-white/95 backdrop-blur rounded-2xl shadow-lg p-3 pointer-events-auto">
        <!-- Header row -->
        <div class="flex items-center gap-3 mb-2">
          <a href="/dashboard" class="text-sm text-slate-500 hover:text-slate-700 shrink-0">← Dashboard</a>
          <h1 class="text-sm font-bold text-slate-900 flex-1 min-w-0 inline-flex items-center gap-1.5"><FeatureIcon name="map-pin" class="w-4 h-4 shrink-0" /><span class="truncate">Pet-friendly Places</span></h1>
          <span class="text-[10px] text-slate-400 shrink-0" x-text="`${filteredPlaces.length} địa điểm`"></span>
        </div>

        <!-- Search -->
        <input type="search" x-model="search" @input.debounce.300ms="render()"
          placeholder="Tìm theo tên..."
          class="w-full px-3 py-1.5 rounded-lg border border-slate-200 text-sm mb-2 focus:outline-none focus:ring-2 focus:ring-mmp-gold" />

        <!-- Category chips -->
        <div class="flex gap-1.5 overflow-x-auto pb-1 -mx-1 px-1">
          <button @click="selectedCat = null; render()"
            :class="selectedCat === null ? 'bg-mmp-ink text-white' : 'bg-slate-100 text-slate-700'"
            class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold whitespace-nowrap">
            Tất cả
          </button>
          <template x-for="c in categories" :key="c.key">
            <button @click="selectedCat = c.key; render()"
              :class="selectedCat === c.key ? 'bg-mmp-ink text-white' : 'bg-slate-100 text-slate-700'"
              class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold whitespace-nowrap inline-flex items-center gap-1">
              <span class="inline-flex shrink-0" x-html="catIconSvg(c.key, catColor(c.key), 14)"></span>
              <span x-text="c.label_vi"></span>
              <span class="opacity-60" x-text="`(${c.count})`"></span>
            </button>
          </template>
        </div>

        <!-- GĐ2 Map-Lai: nút gợi ý OSM (chỉ render, chưa promote) -->
        <button @click="toggleSuggest()" :disabled="loadingSuggest"
          :class="showSuggest ? 'bg-mmp-gold text-mmp-ink' : 'bg-white text-mmp-ink border border-mmp-cream'"
          class="w-full mt-1 px-3 py-1.5 rounded-lg text-xs font-semibold transition disabled:opacity-60 inline-flex items-center justify-center gap-1.5">
          <span x-show="loadingSuggest" x-cloak class="w-3 h-3 border-2 border-mmp-ink/30 border-t-mmp-ink rounded-full animate-spin"></span>
          <span x-text="loadingSuggest ? 'Đang tìm…' : (showSuggest ? 'Ẩn gợi ý OSM' : 'Tìm gần đây (OSM)')"></span>
        </button>
        <p x-show="suggestMsg" x-text="suggestMsg" x-cloak class="text-xs text-mmp-ink/80 bg-mmp-cream rounded-lg px-2 py-1.5 mt-1.5 text-center"></p>
      </div>
    </div>

    <!-- Map -->
    <div id="leaflet-map"></div>

    <!-- "Gần tôi" FAB -->
    <button @click="locateMe()"
      class="absolute bottom-24 right-4 z-[999] w-12 h-12 rounded-full bg-white shadow-xl border-2 border-mmp-cream hover:bg-mmp-cream flex items-center justify-center text-mmp-ink"
      title="Vị trí của tôi">
      <FeatureIcon name="map-pin" class="w-5 h-5" />
    </button>

    <!-- Submit new place FAB -->
    <a href="/places/new"
      class="absolute bottom-8 right-4 z-[999] w-14 h-14 rounded-full bg-mmp-ink hover:bg-slate-800 shadow-2xl text-white flex items-center justify-center text-3xl active:scale-95"
      title="Thêm địa điểm">
      +
    </a>

    <!-- GĐ4.3: toast kết quả promote (giữa-dưới map, gần tầm mắt — không như <p> đỉnh) -->
    <div x-show="promoteToast.show" x-cloak
      class="absolute bottom-28 left-1/2 -translate-x-1/2 z-[1002] px-4 py-2.5 rounded-xl shadow-2xl text-sm font-semibold text-center max-w-[88vw] pointer-events-none"
      :class="promoteToast.ok ? 'bg-mmp-ink text-white' : 'bg-white text-mmp-ink border-2 border-mmp-gold'"
      x-text="promoteToast.msg">
    </div>

    <!-- Bottom sheet for selected place -->
    <div x-show="selectedPlace"
      x-transition:enter="transition transform duration-300"
      x-transition:enter-start="translate-y-full"
      x-transition:enter-end="translate-y-0"
      class="absolute bottom-0 left-0 right-0 z-[1001] bg-white rounded-t-3xl shadow-2xl max-h-[60vh] overflow-y-auto">
      <template x-if="selectedPlace">
        <div class="p-5">
          <button @click="closeSheet()" class="float-right text-slate-400 hover:text-slate-700"><FeatureIcon name="close" class="w-5 h-5" /></button>

          <div class="flex items-start gap-3 mb-3">
            <span class="shrink-0" x-html="catIconSvg(selectedPlace.category, catColor(selectedPlace.category), 36)"></span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <h2 class="text-lg font-bold text-slate-900" x-text="selectedPlace.name"></h2>
                <template x-if="selectedPlace.verified">
                  <span class="text-emerald-600 text-xs font-bold">✓ Verified</span>
                </template>
              </div>
              <p class="text-xs text-slate-500 mt-0.5" x-text="catLabel(selectedPlace.category)"></p>
            </div>
          </div>

          <p class="text-sm text-slate-700 mb-2" x-text="selectedPlace.address"></p>

          <div class="flex flex-wrap gap-2 mb-3 text-xs">
            <span class="bg-amber-50 text-amber-800 px-2 py-1 rounded-full"
              x-text="policyLabel(selectedPlace.pet_policy)"></span>
            <template x-for="a in selectedPlace.amenities" :key="a">
              <span class="bg-slate-100 text-slate-700 px-2 py-1 rounded-full" x-text="amenityLabel(a)"></span>
            </template>
          </div>

          <template x-if="selectedPlace.distance_km != null">
            <p class="text-xs text-mmp-ink font-semibold mb-3 inline-flex items-center gap-1">
              <FeatureIcon name="map-pin" class="w-3.5 h-3.5 shrink-0" /><span>Cách bạn <span x-text="fmtDistance(selectedPlace.distance_km)"></span></span>
            </p>
          </template>

          <template x-if="selectedPlace.total_checkins > 0">
            <p class="text-xs text-slate-500 mb-3 inline-flex items-center gap-1">
              <FeatureIcon name="star" class="w-3.5 h-3.5 shrink-0 text-mmp-gold" /><span><span x-text="selectedPlace.avg_rating.toFixed(1)"></span> · <span x-text="selectedPlace.total_checkins"></span> check-in</span>
            </p>
          </template>

          <div class="flex flex-wrap gap-2">
            <a :href="`/places/${selectedPlace.id}`"
              class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold text-sm py-2.5 rounded-xl inline-flex items-center justify-center gap-1.5">
              <FeatureIcon name="book-open" class="w-4 h-4" />Chi tiết
            </a>
            <a :href="`/places/checkin?placeId=${selectedPlace.id}`"
              class="flex-1 bg-mmp-ink hover:bg-slate-800 text-white font-semibold text-sm py-2.5 rounded-xl inline-flex items-center justify-center gap-1.5">
              <FeatureIcon name="map-pin" class="w-4 h-4" />Check-in
            </a>
            <a :href="googleMapsUrl(selectedPlace)" target="_blank"
              class="bg-mmp-ink hover:bg-mmp-ink text-white font-semibold text-sm px-3 py-2.5 rounded-xl inline-flex items-center justify-center">
              <FeatureIcon name="compass" class="w-4 h-4" />
            </a>
            <template x-if="selectedPlace.contact_phone">
              <a :href="`tel:${selectedPlace.contact_phone}`"
                class="bg-emerald-500 hover:bg-emerald-600 text-white font-semibold text-sm px-3 py-2.5 rounded-xl">
                📞
              </a>
            </template>
          </div>
        </div>
      </template>
    </div>

  </main>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script is:inline>
    function mapPage(initial) {
      return {
        places: initial.places,
        categories: initial.categories,
        selectedCat: null,
        search: "",
        selectedPlace: null,
        map: null,
        markers: [],
        userMarker: null,
        suggestions: [],
        suggestMarkers: [],
        showSuggest: false,
        loadingSuggest: false,
        suggestMsg: "",
        _promoting: false,
        promoteToast: { show: false, msg: "", ok: false },
        _toastTimer: null,
        catMap: Object.fromEntries(initial.categories.map((c) => [c.key, c])),

        catEmoji(k) { return this.catMap[k]?.emoji || "📍"; },
        catLabel(k) { return this.catMap[k]?.label_vi || k; },

        // Việc B: icon + màu theo loại (giữ phân biệt loại như emoji cũ). Path copy từ FeatureIcon.
        catIconPaths(k) {
          return ({
            park: '<path d="M8 19a4 4 0 0 1-2.24-7.32A3.5 3.5 0 0 1 9 6.03V6a3 3 0 1 1 6 0v.04a3.5 3.5 0 0 1 3.24 5.65A4 4 0 0 1 16 19Z"/><path d="M12 19v3"/>',
            cafe: '<path d="M10 2v2"/><path d="M14 2v2"/><path d="M6 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/>',
            vet: '<path d="M6 3v6a4 4 0 0 0 8 0V3"/><path d="M6 3h2"/><path d="M12 3h2"/><path d="M10 13v3a5 5 0 0 0 10 0v-1"/><circle cx="20" cy="12" r="2"/>',
            restaurant: '<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>',
            hotel: '<path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/>',
            grooming: '<circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/>',
            pet_shop: '<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>',
            beach: '<path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5s2.5 2 5 2 2.5-2 5-2c1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1s2.5-2 5-2 2.5 2 5 2 2.5-2 5-2c1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1s2.5-2 5-2 2.5 2 5 2 2.5-2 5-2c1.3 0 1.9.5 2.5 1"/>',
            other: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
          })[k] || '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>';
        },
        catColor(k) {
          return ({
            park: "#16a34a", cafe: "#b45309", vet: "#dc2626", restaurant: "#ea580c",
            hotel: "#4f46e5", grooming: "#db2777", pet_shop: "#0d9488", beach: "#0284c7", other: "#64748b",
          })[k] || "#64748b";
        },
        catIconSvg(k, color, size) {
          const s = size || 20;
          return '<svg width="' + s + '" height="' + s + '" viewBox="0 0 24 24" fill="none" stroke="' + (color || "currentColor") + '" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + this.catIconPaths(k) + "</svg>";
        },

        policyLabel(p) {
          return ({
            allowed: "🐾 Pet welcome", leash_only: "🦮 Có dây xích",
            small_pets_only: "🐱 Chỉ pet nhỏ", private_only: "🔒 Đặt trước",
            by_request: "❓ Hỏi trước"
          })[p] || p;
        },

        amenityLabel(a) {
          return ({
            water_bowl: "💧 Bowl nước", outdoor_seating: "🌤️ Ngoài trời",
            indoor: "🏠 Trong nhà", off_leash_area: "🦮 Off-leash",
            shade: "🌳 Có bóng mát", poop_bag: "🛍️ Bag rác"
          })[a] || a;
        },

        get filteredPlaces() {
          let f = this.places;
          if (this.selectedCat) f = f.filter((p) => p.category === this.selectedCat);
          if (this.search.trim()) {
            const q = this.search.trim().toLowerCase();
            f = f.filter((p) => p.name.toLowerCase().includes(q) || p.address.toLowerCase().includes(q));
          }
          return f;
        },

        fmtDistance(km) {
          if (km < 1) return Math.round(km * 1000) + " m";
          return km.toFixed(1) + " km";
        },

        googleMapsUrl(p) {
          return `https://www.google.com/maps/dir/?api=1&destination=${p.lat},${p.lng}`;
        },

        onMount() {
          this.initMap();
          this.render();
        },

        initMap() {
          // Center HCM
          this.map = L.map("leaflet-map", { zoomControl: true }).setView([10.7769, 106.7009], 13);
          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: "© OpenStreetMap contributors",
            maxZoom: 19,
          }).addTo(this.map);
        },

        clearMarkers() {
          for (const m of this.markers) this.map.removeLayer(m);
          this.markers = [];
        },

        render() {
          if (!this.map) return;
          this.clearMarkers();
          for (const place of this.filteredPlaces) {
            const html = this.catIconSvg(place.category, this.catColor(place.category), 20);
            const icon = L.divIcon({
              className: place.verified ? "place-marker verified" : "place-marker",
              html: html,
              iconSize: [38, 38],
              iconAnchor: [19, 19],
            });
            const m = L.marker([place.lat, place.lng], { icon }).addTo(this.map);
            m.on("click", () => { this.selectedPlace = place; });
            this.markers.push(m);
          }
        },

        async locateMe() {
          if (!navigator.geolocation) {
            alert("Trình duyệt không hỗ trợ vị trí");
            return;
          }
          navigator.geolocation.getCurrentPosition(
            async (pos) => {
              const { latitude, longitude } = pos.coords;
              this.map.setView([latitude, longitude], 15);
              if (this.userMarker) this.map.removeLayer(this.userMarker);
              const userIcon = L.divIcon({
                className: "",
                html: `<div style="background:#0a0a0a;border:3px solid white;width:18px;height:18px;border-radius:50%;box-shadow:0 0 0 4px rgba(10,10,10,0.3)"></div>`,
                iconSize: [18, 18],
                iconAnchor: [9, 9],
              });
              this.userMarker = L.marker([latitude, longitude], { icon: userIcon }).addTo(this.map);
              // Re-fetch with geo filter to include distance_km
              try {
                const res = await fetch(`/api/v1/places?lat=${latitude}&lng=${longitude}&radius=20`);
                if (res.ok) {
                  this.places = (await res.json()).places || [];
                  this.render();
                }
              } catch (_) {}
            },
            (err) => alert("Không lấy được vị trí: " + err.message),
            { enableHighAccuracy: false, timeout: 10000 }
          );
        },

        closeSheet() { this.selectedPlace = null; },

        // ── GĐ2 Map-Lai: layer gợi ý OSM (Overpass) — layer RIÊNG, KHÔNG đụng render()/markers chính thức ──
        toggleSuggest() {
          this.showSuggest = !this.showSuggest;
          if (this.showSuggest) {
            this.fetchSuggest();
          } else {
            this.suggestions = [];
            this.suggestMsg = "";
            this.clearSuggestMarkers();
          }
        },

        async fetchSuggest() {
          if (!this.map || this.loadingSuggest) return; // guard double-click / chưa có map
          this.loadingSuggest = true;
          this.suggestMsg = "";
          try {
            const b = this.map.getBounds();
            const bbox = [b.getSouth(), b.getWest(), b.getNorth(), b.getEast()]
              .map((n) => n.toFixed(5))
              .join(",");
            const res = await fetch("/api/v1/places/suggest?bbox=" + bbox);
            if (!res.ok) {
              const j = await res.json().catch(() => ({}));
              this.suggestMsg = (j.error && j.error.message) || "Không tìm được gợi ý";
              this.suggestions = [];
              this.clearSuggestMarkers();
              return;
            }
            const data = await res.json();
            if (data.degraded) {
              this.suggestMsg = "OSM không phản hồi, thử lại sau";
              this.suggestions = [];
              this.clearSuggestMarkers();
              return;
            }
            this.suggestions = data.suggestions || [];
            this.suggestMsg = this.suggestions.length ? "" : "Khu này chưa có gợi ý OSM — thử pan sang khu khác";
            this.renderSuggestions();
          } catch (e) {
            this.suggestMsg = "Lỗi tải gợi ý";
            this.suggestions = [];
            this.clearSuggestMarkers();
          } finally {
            this.loadingSuggest = false;
          }
        },

        renderSuggestions() {
          if (!this.map) return;
          this.clearSuggestMarkers();
          for (const s of this.suggestions) {
            const html = this.catIconSvg(s.category, "#0a0a0a", 24);
            const icon = L.divIcon({
              className: "place-marker suggest",
              html: html,
              iconSize: [46, 46],
              iconAnchor: [23, 23],
            });
            const m = L.marker([s.lat, s.lng], { icon }).addTo(this.map);
            m.bindPopup(() => this._suggestPopupEl(s, m)); // GĐ3: popup kèm nút "Thêm vào map"
            this.suggestMarkers.push(m);
          }
          // GĐ4.1: backend pad +3km → POI có thể nằm NGOÀI viewport (nhất là zoom chặt) → marker tạo ra nhưng off-screen.
          // fitBounds để map tự gom hiện các gợi ý vừa tìm (đúng kỳ vọng "tìm gần đây").
          if (this.suggestMarkers.length) {
            try {
              this.map.fitBounds(L.featureGroup(this.suggestMarkers).getBounds(), { padding: [40, 40], maxZoom: 15 });
            } catch (e) {}
          }
        },

        clearSuggestMarkers() {
          for (const m of this.suggestMarkers) this.map.removeLayer(m);
          this.suggestMarkers = [];
        },

        // GĐ3: popup DOM cho marker gợi ý (textContent → an toàn XSS) + nút promote
        _suggestPopupEl(s, m) {
          const self = this;
          const wrap = document.createElement("div");
          wrap.style.minWidth = "160px";
          const title = document.createElement("b");
          title.textContent = s.name || "Địa điểm";
          const meta = document.createElement("div");
          meta.style.cssText = "color:var(--color-mmp-brown,#8b6f47);font-size:12px;margin:3px 0 6px";
          meta.textContent = this.catLabel(s.category) + " · Gợi ý OSM";
          const btn = document.createElement("button");
          btn.textContent = "+ Thêm vào map";
          btn.style.cssText = "width:100%;padding:6px 8px;border-radius:8px;border:none;cursor:pointer;font-size:12px;font-weight:700;background:var(--color-mmp-ink,#0a0a0a);color:#fff";
          btn.onclick = function () { self.promoteSuggestion(s, m, btn); };
          wrap.appendChild(title);
          wrap.appendChild(meta);
          wrap.appendChild(btn);
          return wrap;
        },

        // GĐ4.3: toast kết quả promote — hiện giữa-dưới map (gần tầm mắt, KHÁC <p> đỉnh), auto ẩn 3.5s
        _toast(msg, ok) {
          this.promoteToast = { show: true, msg: msg, ok: !!ok };
          if (this._toastTimer) clearTimeout(this._toastTimer);
          this._toastTimer = setTimeout(() => { this.promoteToast.show = false; }, 3500);
        },

        // GĐ3: promote gợi ý OSM → place chính thức qua POST /places (tái dùng endpoint submit, gate Pet Score ≥200 giữ nguyên)
        async promoteSuggestion(s, m, btn) {
          if (this._promoting) return; // guard double-click toàn cục
          this._promoting = true;
          if (btn) { btn.disabled = true; btn.textContent = "Đang thêm…"; }
          try {
            const payload = {
              name: s.name,
              // OSM hay thiếu address → fallback dùng name để qua validate ADDRESS_REQUIRED (place verified=false, owner/admin sửa sau)
              address: (s.address && s.address.trim()) ? s.address : s.name,
              lat: s.lat,
              lng: s.lng,
              category: s.category,
              pet_policy: "by_request", // OSM không có pet_policy → default trung tính (hợp lệ)
            };
            const res = await fetch("/api/v1/places", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            if (res.status === 201) {
              const place = await res.json();
              this.map.removeLayer(m); // gỡ marker gợi ý vừa thêm (tránh promote lần 2 → trùng)
              this.suggestMarkers = this.suggestMarkers.filter((x) => x !== m);
              this.suggestions = this.suggestions.filter((x) => x !== s);
              this.places.push(place); // thêm vào layer chính thức + vẽ lại (verified=false → marker thường)
              this.render();
              this.suggestMsg = "Đã thêm “" + (s.name || "địa điểm") + "” vào map (chờ duyệt)";
              this._toast("✓ Đã thêm “" + (s.name || "địa điểm") + "” (chờ duyệt)", true);
              return;
            }
            if (res.status === 401) {
              this.suggestMsg = "Cần đăng nhập để thêm địa điểm";
            } else if (res.status === 403) {
              this.suggestMsg = "Cần Pet Score ≥ 200 để thêm địa điểm";
            } else {
              const j = await res.json().catch(() => ({}));
              this.suggestMsg = (j.error && j.error.message) || "Không thêm được, thử lại sau";
            }
            this._toast(this.suggestMsg, false);
            if (btn) { btn.disabled = false; btn.textContent = "+ Thêm vào map"; }
          } catch (e) {
            this.suggestMsg = "Lỗi mạng, thử lại sau";
            this._toast("Lỗi mạng, thử lại sau", false);
            if (btn) { btn.disabled = false; btn.textContent = "+ Thêm vào map"; }
          } finally {
            this._promoting = false;
          }
        },
      };
    }
  </script>
</Layout>
