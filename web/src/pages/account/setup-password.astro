---
/**
 * /account/setup-password — UX speed-up for OTP-only users (M21).
 *
 * Sau khi user cũ login OTP, nếu họ chưa có password + chưa có Google,
 * verify-otp returns `redirect_to: "/account/setup-password"` → trang này hiện.
 *
 * Submit form → POST /api/v1/auth/email/set-password (existing endpoint từ M20-auth).
 * "Skip" → set localStorage `vv_setup_password_skipped_at` (30d snooze, frontend tự bypass).
 */
import Layout from "../../layouts/Layout.astro";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// SSR: nếu user đã có password rồi → bỏ qua, về dashboard
let userDetail: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/users/me/settings`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) userDetail = await res.json();
} catch (_) {}

const hasPassword = !!(userDetail?.auth?.has_password);
const hasGoogle = !!(userDetail?.auth?.has_google);
const existingEmail = userDetail?.user?.email || "";

if (hasPassword || hasGoogle) {
  return Astro.redirect("/dashboard");
}

const initialData = JSON.stringify({
  existingEmail,
  phone: userDetail?.user?.phone || user.phone || "",
});
---

<Layout title="Setup login nhanh · VowVet" description="Đặt email + mật khẩu để login dễ hơn">
  <main class="min-h-screen flex items-center justify-center px-4 py-8 bg-mmp-cream via-mmp-cream to-amber-50">
    <div class="w-full max-w-md">

      <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-6 sm:p-8" x-data={`setupPasswordPage(${initialData})`}>

        <!-- Hero -->
        <div class="text-center mb-6">
          <div class="text-6xl mb-3">🔐</div>
          <h1 class="text-xl sm:text-2xl font-bold text-slate-900 mb-1">Setup nhanh để login dễ hơn</h1>
          <p class="text-sm text-slate-500">
            Lần sau bạn có thể đăng nhập bằng <strong>email + mật khẩu</strong> thay vì chờ OTP SĐT
          </p>
        </div>

        <div x-show="!done">
          <div class="space-y-3">
            <div>
              <label class="block text-xs font-semibold text-slate-700 mb-1.5">Email</label>
              <input type="email" x-model="email" placeholder="ban@gmail.com"
                autocomplete="email"
                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:border-mmp-ink focus:ring-2 focus:ring-mmp-gold outline-none" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-700 mb-1.5">Mật khẩu mới <span class="text-slate-400 font-normal">(≥8 ký tự, có chữ + số)</span></label>
              <div class="relative">
                <input :type="showPassword ? 'text' : 'password'" x-model="password"
                  autocomplete="new-password" placeholder="••••••••"
                  class="w-full px-4 py-2.5 pr-12 rounded-xl border border-slate-200 focus:border-mmp-ink focus:ring-2 focus:ring-mmp-gold outline-none" />
                <button type="button" @click="showPassword = !showPassword"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-700 text-lg">
                  <span x-text="showPassword ? '🙈' : '👁️'"></span>
                </button>
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-slate-700 mb-1.5">Nhập lại mật khẩu</label>
              <input type="password" x-model="confirmPassword"
                autocomplete="new-password" placeholder="••••••••"
                @keydown.enter="submit()"
                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:border-mmp-ink focus:ring-2 focus:ring-mmp-gold outline-none" />
            </div>
          </div>

          <template x-if="error">
            <p class="mt-3 bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700" x-text="error"></p>
          </template>

          <div class="mt-5 space-y-2">
            <button @click="submit()" :disabled="loading || !canSubmit"
              class="w-full py-3 rounded-xl bg-mmp-ink hover:opacity-95 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold shadow-lg">
              <span x-show="!loading">💾 Lưu và tiếp tục</span>
              <span x-show="loading">Đang lưu…</span>
            </button>

            <button @click="skip()" type="button"
              class="w-full py-2.5 text-sm text-slate-500 hover:text-slate-700">
              Để sau (tiếp tục dùng OTP SĐT, hỏi lại sau 30 ngày)
            </button>
          </div>

          <p class="text-[11px] text-slate-400 text-center mt-4 italic">
            Bạn vẫn login được bằng SĐT/OTP sau khi setup. Đây chỉ là thêm cách nhanh.
          </p>
        </div>

        <!-- Done state (server already redirects but fallback) -->
        <div x-show="done" class="text-center py-6">
          <p class="text-5xl mb-3">✅</p>
          <p class="font-bold text-slate-900 mb-1">Đã setup thành công!</p>
          <p class="text-sm text-slate-500">Đang chuyển hướng…</p>
        </div>
      </div>

      <p class="text-center text-xs text-slate-400 mt-4">
        🐾 Mon Min Pet · Bảo mật bằng argon2id
      </p>
    </div>
  </main>

  <script is:inline>
    function setupPasswordPage(initial) {
      return {
        email: initial.existingEmail || "",
        phone: initial.phone || "",
        password: "",
        confirmPassword: "",
        showPassword: false,
        loading: false,
        done: false,
        error: "",

        get canSubmit() {
          if (!this.email || !this.password || !this.confirmPassword) return false;
          if (this.password !== this.confirmPassword) return false;
          if (this.password.length < 8) return false;
          if (!/[A-Za-z]/.test(this.password) || !/\d/.test(this.password)) return false;
          return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email);
        },

        async submit() {
          this.error = "";
          if (!this.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email)) {
            this.error = "Email không hợp lệ";
            return;
          }
          if (this.password !== this.confirmPassword) {
            this.error = "Mật khẩu xác nhận không khớp";
            return;
          }
          if (this.password.length < 8) {
            this.error = "Mật khẩu cần ít nhất 8 ký tự";
            return;
          }
          if (!/[A-Za-z]/.test(this.password) || !/\d/.test(this.password)) {
            this.error = "Mật khẩu cần ít nhất 1 chữ cái và 1 số";
            return;
          }

          this.loading = true;
          try {
            const res = await fetch("/api/v1/auth/email/set-password", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ email: this.email, password: this.password }),
            });
            const json = await res.json().catch(() => ({}));
            if (!res.ok) {
              this.error = json?.error?.message || "Lỗi setup";
              return;
            }
            // Clear any "skipped" flag so we don't re-suggest
            try { localStorage.removeItem("vv_setup_password_skipped_at"); } catch (_) {}
            // Remember preferred login method
            try { localStorage.setItem("vv_last_login_method", "email"); } catch (_) {}
            this.done = true;
            setTimeout(() => { window.location.href = "/dashboard?setup=success"; }, 500);
          } catch (err) {
            this.error = "Lỗi kết nối server.";
          } finally {
            this.loading = false;
          }
        },

        skip() {
          // Snooze 30 days — frontend login flow tự honor flag này
          try { localStorage.setItem("vv_setup_password_skipped_at", String(Date.now())); } catch (_) {}
          window.location.href = "/dashboard";
        },
      };
    }
  </script>
</Layout>
