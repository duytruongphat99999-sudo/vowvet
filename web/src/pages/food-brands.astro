        // v36: BCS 9-level matrix
        BCS_MATRIX: [
          { score: 1, tier: "under-critical", label: "BCS 1 · Rất gầy",            description: "Lộ rõ xương sườn, sống lưng, xương chậu từ xa. Cơ teo nghiêm trọng, da bọc xương." },
          { score: 2, tier: "under",          label: "BCS 2 · Gầy",                 description: "Xương sườn thấy rõ, eo thắt sâu hình chữ V nhọn, mỡ đệm mỏng dính." },
          { score: 3, tier: "under",          label: "BCS 3 · Hơi gầy",             description: "Sườn hơi lộ bóng khi thở, bụng hóp cao, vuốt nhẹ thấy rõ cọng sườn." },
          { score: 4, tier: "ideal",          label: "BCS 4 · Cân đối nhẹ",         description: "Eo thắt gọn gàng từ trên xuống, lớp mỡ mỏng lý tưởng bao phủ." },
          { score: 5, tier: "ideal",          label: "BCS 5 · Lý tưởng tuyệt đối",  description: "Phom dáng đồng hồ cát, bụng hóp nghiêng mượt mà về háng. (Mèo có túi mỡ bụng Primordial Pouch lỏng thòng nhẹ nhưng không căng mỡ)." },
          { score: 6, tier: "over",           label: "BCS 6 · Thừa cân nhẹ",        description: "Eo bị bốc hơi thẳng đuột, bụng ít hóp, ấn nhẹ mới thấy sườn." },
          { score: 7, tier: "over",           label: "BCS 7 · Thừa cân nặng",       description: "Hông nở nhẹ, bụng xệ song song mặt đất. Mèo có túi mỡ bụng căng phồng lắc lư khi đi." },
          { score: 8, tier: "obese",          label: "BCS 8 · Béo phì",             description: "Thân hình phình to, mỡ tích tụ dày ở gốc đuôi, sống lưng và nọng cổ. Ấn sâu không thấy sườn." },
          { score: 9, tier: "obese-critical", label: "BCS 9 · Béo phì nguy kịch",   description: "Thân hình trụ tròn như quả bóng di động, bụng xệ sát đất, đi lại nặng nề, khó thở." },
        ],

        // v36: Allergen risk matrix (3 tiers: red/orange/yellow)
        ALLERGEN_MATRIX: {
          red: [
            { code: "ALLERGEN_CHICKEN", emoji: "🚨", label: "Dị ứng Thịt gà",          brandKey: "chicken" },
            { code: "ALLERGEN_BEEF",    emoji: "🚨", label: "Dị ứng Thịt bò",          brandKey: "beef" },
            { code: "ALLERGEN_DAIRY",   emoji: "🚨", label: "Bất dung nạp Sữa/Lactose", brandKey: "dairy" },
            { code: "ALLERGEN_FISH",    emoji: "🚨", label: "Dị ứng Đạm cá",           brandKey: "fish" },
          ],
          orange: [
            { code: "SENSITIVITY_FAT",   emoji: "⚠️", label: "Nhạy cảm béo cao",        trigger: "high_fat" },
            { code: "SENSITIVITY_GRAIN", emoji: "⚠️", label: "Kém hấp thu ngũ cốc",     trigger: "grain" },
          ],
          // v45: Dark Yellow tier — yếu tố môi trường sống (user toggle thủ công)
          darkYellow: [
            { code: "ENV_URBAN_POLLUTION", emoji: "🌫️", label: "Ô nhiễm đô thị (PM2.5)" },
            { code: "ENV_HUMIDITY",        emoji: "💧", label: "Khí hậu ẩm nóng VN" },
            { code: "ENV_APARTMENT",       emoji: "🏢", label: "Sống chung cư kín" },
            { code: "ENV_DUST_MITES",      emoji: "🦠", label: "Mạt bụi / Dander" },
          ],
        },

        // v36: NLP + UI state
        freeText: "",
        nlpSuggestions: [],
        odorFilterActive: false,

        // v36: Prescription Card state
        fedToday: false,
        dietStartDate: null,
        homeScanMode: false,
        homeKcal: 0,
        homeIngredients: "",    // v46: free-text ingredients for OCR allergen check
        poopScore: 0,           // v46: weekly stool quality 1-5 (0 = chưa đánh giá)
        DRY_FOOD_AVG_KCAL: 360,
        WET_FOOD_AVG_KCAL: 85,

        init() {
          if (this.userPets.length > 0) {
            this.selectPet(this.userPets[0].id);
            // v39: initialBcsScore (từ BCS history API) chỉ áp dụng khi pet record không có bcs_score riêng
            const pet0 = this.userPets[0];
            const hasOwnBcs = Number(pet0?.bcs_score) > 0;
            if (!hasOwnBcs && initialBcsScore != null) {
              this.profile.bcs = Math.max(1, Math.min(9, Number(initialBcsScore)));
            }
          }
          this.$watch("profile.species", () => {
            if (!this.isProfileLocked) this.filters.breed = "";
          });
          this.$watch("profile.selectedPetId", () => {
            this.loadDietTimeline();
          });
          this.$watch("profile.bcs", (val) => {
            const bcs = Number(val);
            if (bcs >= 8) {
              if (!this.profile.sensitivities.includes("SENSITIVITY_FAT")) {
                this.profile.sensitivities.push("SENSITIVITY_FAT");
              }
            } else {
              this.profile.sensitivities = this.profile.sensitivities.filter(s => s !== "SENSITIVITY_FAT");
            }
          });
          this.loadDietTimeline();
        },

        selectPet(petId) {
          const id = Number(petId);
          if (!id) {
            this.profile.selectedPetId = null;
            this.profile.petName = "";
            this.profile.petImage = "";    // v40: reset avatar khi vào manual mode
            this.profile.breed = "";
            this.filters.breed = "";
            return;
          }
          const p = this.userPets.find((x) => Number(x.id) === id);
          if (!p) return;
          // v39: STRICT pet sync — single source of truth từ pet record thật
          const breedCode = this.mapBreedFromPet(p.breed || p.breed_raw);

          // v41: Pet Name resolver — check-list ưu tiên qua nhiều schema khả thi (trim + type-check để không nhả "bé" khi field tồn tại nhưng là " " hoặc null)
          const pickName = (...candidates) => {
            for (const c of candidates) {
              if (typeof c === "string" && c.trim()) return c.trim();
            }
            return "bé";
          };
          // v41: Pet Avatar resolver — tương tự, ưu tiên photo_url theo /users/me schema thực
          const pickImage = (...candidates) => {
            for (const c of candidates) {
              if (typeof c === "string" && c.trim()) return c.trim();
            }
            return "";
          };

          this.profile.selectedPetId = p.id;
          this.profile.petName  = pickName(p.name, p.pet_name, p.nickname, p.display_name);
          this.profile.petImage = pickImage(p.photo_url, p.avatar_url, p.image);
          // v47: Origin certificate + verification status
          this.profile.origin_certificate_url = (typeof p.origin_certificate_url === "string" ? p.origin_certificate_url : "") || "";
          this.profile.is_verified = Boolean(p.is_verified);
          this.profile.species = (typeof p.species === "object" ? p.species?.value : p.species) || "dog";
          this.profile.weight  = Number(p.weight_kg ?? p.weight) || 5;
          this.profile.breed   = breedCode;                   // v39: mapped code (đồng bộ với filters.breed + breedSticker)
          this.filters.breed   = breedCode;
          this.profile.bcs     = Number(p.bcs_score) || this.profile.bcs || 5;   // v39: pet.bcs_score là primary
          // v49: full profile sync — các field mới từ /auth/me (backend v49 extended)
          this.poopScore = Number(p.poop_score) || 0;
          this.profile.allergens = Array.isArray(p.allergens) ? p.allergens
                                  : Array.isArray(p.allergies_diet) ? p.allergies_diet
                                  : [];
          this.profile.sensitivities = Array.isArray(p.sensitivities) ? p.sensitivities : [];
          this.profile.environmentals = Array.isArray(p.environmentals) ? p.environmentals : [];
          // v49: Sync excludeAllergens filter với profile.allergens (Tier 1 Red ↔ brand filter)
          for (const a of this.profile.allergens) {
            if (!this.filters.excludeAllergens.includes(a)) this.filters.excludeAllergens.push(a);
          }
        },

        get isProfileLocked() {
          return this.profile.selectedPetId !== null;
        },

        // v49: Push current profile state về backend qua PATCH /api/v1/pets/:id
        // Dùng từ Profile page (shared utility); food-brands hiện tại read-only nên ít gọi
        async saveProfile() {
          if (!this.profile.selectedPetId) {
            console.warn('[saveProfile] no pet selected — skip');
            return { ok: false, error: 'NO_PET' };
          }
          try {
            const res = await fetch(`/api/v1/pets/${this.profile.selectedPetId}`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'same-origin',
              body: JSON.stringify({
                name: this.profile.petName,
                breed: this.profile.breed,
                weight_kg: this.profile.weight,
                bcs_score: this.profile.bcs,
                poop_score: this.poopScore,
                allergens: this.profile.allergens,
                sensitivities: this.profile.sensitivities,
                environmentals: this.profile.environmentals,
              }),
            });
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              console.error('[saveProfile] failed:', res.status, err);
              return { ok: false, status: res.status, error: err };
            }
            return { ok: true };
          } catch (err) {
            console.error('[saveProfile] network error:', err);
            return { ok: false, error: 'NETWORK' };
          }
        },

        get currentBreedOptions() {
          return this.BREED_OPTIONS[this.profile.species] || [];
        },

        // v36: Current BCS entry from matrix
        get currentBcs() {
          const bcs = Number(this.profile.bcs) || 5;
          return this.BCS_MATRIX.find((b) => b.score === bcs) || this.BCS_MATRIX[4];
        },

        // v36: Map raw DB breed string → 29-breed knowledge-base code
        mapBreedFromPet(breedRaw) {
          const s = String(breedRaw || "").toLowerCase();
          if (!s) return "";
          if (s.includes("anh lông ngắn") || s.includes("british shorthair")) return "ALN";
          if (s.includes("anh lông dài") || s.includes("british longhair"))  return "ALD";
          if (s.includes("tai cụp") || s.includes("scottish fold"))           return "TaiCup";
          if (s.includes("munchkin") || s.includes("chân ngắn"))              return "Munchkin";
          if (s.includes("ragdoll"))                                          return "Ragdoll";
          if (s.includes("ba tư") || s.includes("persian"))                   return "Persian";
          if (s.includes("sphynx"))                                           return "Sphynx";
          if (s.includes("maine coon") || s.includes("mainecoon"))            return "MaineCoon";
          if (s.includes("bengal"))                                           return "Bengal";
          if (s.includes("mèo ta") || s.includes("domestic shorthair"))       return "MeoTa";
          if (s.includes("phú quốc") || s.includes("phu quoc"))               return "PhuQuoc";
          if (s.includes("h'mông") || s.includes("hmong"))                    return "HMong";
          if (s.includes("bắc hà") || s.includes("bac ha"))                   return "BacHa";
          if (s.includes("lài") || s.includes("dingo"))                       return "Lai";
          if (s.includes("poodle"))                                           return "Poodle";
          if (s.includes("pomeranian") || s.includes("phốc sóc"))             return "Pomeranian";
          if (s.includes("chihuahua"))                                        return "Chihuahua";
          if (s.includes("french bulldog") || s.includes("frenchie"))         return "FrenchBulldog";
          if (s.includes("pug"))                                              return "Pug";
          if (s.includes("corgi"))                                            return "Corgi";
          if (s.includes("golden"))                                           return "Golden";
          if (s.includes("labrador"))                                         return "Labrador";
          if (s.includes("samoyed"))                                          return "Samoyed";
          if (s.includes("husky"))                                            return "Husky";
          if (s.includes("alaskan") || s.includes("malamute"))                return "Alaskan";
          if (s.includes("shiba"))                                            return "Shiba";
          if (s.includes("german shepherd") || s.includes("béc-giê") || s.includes("becgie")) return "BecGie";
          if (s.includes("rottweiler"))                                       return "Rottweiler";
          if (s.includes("bully") || s.includes("american bully"))            return "Bully";
          return "khac";
        },

        get breedWeightHint() {
          if (!this.filters.breed || this.filters.breed === "khac") return "";
          const opt = this.currentBreedOptions.find((b) => b.code === this.filters.breed);
          if (!opt || opt.min == null) return "";
          return `💡 Chuẩn giống ${opt.name}: ${opt.min}kg – ${opt.max}kg`;
        },

        btnClass(active, locked) {
          if (locked) {
            return active ? 'bg-mmp-ink/60 text-white cursor-not-allowed' : 'bg-slate-100 text-slate-400 cursor-not-allowed';
          }
          return active ? 'bg-mmp-ink text-white' : 'bg-slate-50 text-slate-600 hover:bg-slate-100';
        },

        // === RER / DER (v36: 9-level BCS switch) ===
        get rer() {
          return Math.round(70 * Math.pow(Math.max(0.5, this.profile.weight), 0.75));
        },
        get der() {
          const bcs = Number(this.profile.bcs) || 5;
          let mult;
          switch (bcs) {
            case 1: mult = 1.8; break;
            case 2: mult = 1.7; break;
            case 3: mult = 1.5; break;
            case 4: mult = 1.4; break;
            case 5: mult = 1.4; break;
            case 6: mult = 1.2; break;
            case 7: mult = 1.0; break;
            case 8: mult = 0.9; break;
            case 9: mult = 0.8; break;
            default: mult = 1.4; break;
          }
          return Math.round(this.rer * mult);
        },
        get derMultiplierLabel() {
          const bcs = Number(this.profile.bcs) || 5;
          const entry = this.BCS_MATRIX.find((b) => b.score === bcs);
          const tierLabel = entry ? (entry.label.split(" · ")[1] || "Lý tưởng") : "Lý tưởng";
          const m = (this.der / this.rer).toFixed(1);
          return `RER ${this.rer} × ${m} (${tierLabel})`;
        },

        // === v38: BCS Visual Avatar ===
        get bcsAvatar() {
          const bcs = Number(this.profile.bcs) || 5;
          const isCat = this.profile.species === "cat";
          if (bcs <= 2) return {
            emoji: isCat ? "😿" : "🦴",
            bg: "bg-slate-100", ring: "ring-slate-300", anim: "",
            warn: "🦴 Suy dinh dưỡng nghiêm trọng", warnColor: "text-slate-500",
            shapeW: "26px", shapeH: "44px", shapeColor: "#94a3b8",
          };
          if (bcs <= 4) return {
            emoji: isCat ? "🐱" : "🐶",
            bg: "bg-slate-50", ring: "ring-slate-200", anim: "",
            warn: "", warnColor: "",
            shapeW: "30px", shapeH: "40px", shapeColor: "#94a3b8",
          };
          if (bcs === 5) return {
            emoji: isCat ? "😸" : "🐶",
            bg: "bg-emerald-50", ring: "ring-emerald-300", anim: "animate-pulse",
            warn: "✨ Phom dáng lý tưởng — tiếp tục duy trì!", warnColor: "text-emerald-700",
            shapeW: "36px", shapeH: "36px", shapeColor: "#22c55e",
          };
          if (bcs <= 7) return {
            emoji: isCat ? "😾" : "🐕",
            bg: "bg-orange-50", ring: "ring-orange-300", anim: "",
            warn: "⚠️ Đang thừa cân — giảm khẩu phần béo", warnColor: "text-orange-700",
            shapeW: "42px", shapeH: "36px", shapeColor: "#f97316",
          };
          return {
            emoji: "🎈",
            bg: "bg-red-50", ring: "ring-red-400", anim: "animate-bounce",
            warn: "🚨 Béo phì nguy hiểm — đang áp chế độ low-fat", warnColor: "text-red-700",
            shapeW: "48px", shapeH: "40px", shapeColor: "#ef4444",
          };
        },
        get bcsAvatarShapeStyle() {
          const av = this.bcsAvatar;
          return `width:${av.shapeW};height:${av.shapeH};background:${av.shapeColor};border-radius:50%;opacity:0.18;transition:all 0.5s ease;`;
        },

        // === v40: Lookup tên giống từ BREED_OPTIONS (cat + dog code unique → gộp OK) ===
        getBreedName(code) {
          if (!code || code === "khac") return "";
          const all = [...this.BREED_OPTIONS.cat, ...this.BREED_OPTIONS.dog];
          const opt = all.find((b) => b.code === code);
          return opt?.name || "";
        },

        // === v38: Breed sticker emoji map (29 breeds) ===
        get breedSticker() {
          const code = this.filters.breed;
          if (!code || code === "khac") return "";
          const map = {
            ALN:"🐱", ALD:"🐈", TaiCup:"🐱", Munchkin:"🐈",
            Ragdoll:"🐈‍⬛", Persian:"😸", Sphynx:"🫥", MaineCoon:"🦁",
            Bengal:"🐆", MeoTa:"🐱",
            PhuQuoc:"🐕", HMong:"🐕", BacHa:"🐺", Lai:"🐕",
            Poodle:"🐩", Pomeranian:"🦊", Chihuahua:"🐕", Pug:"😤",
            FrenchBulldog:"🐶", Corgi:"🐕", Golden:"🦮", Labrador:"🦮",
            Samoyed:"🐻‍❄️", Husky:"🐺", Alaskan:"🐺", Shiba:"🦊",
            BecGie:"🦺", Rottweiler:"🐕‍🦺", Bully:"💪",
          };
          return map[code] || "";
        },

        // === v36: Prescription Card computed ===
        get dryFoodGrams() {
          return Math.round(((this.der * 0.7) / this.DRY_FOOD_AVG_KCAL) * 100);
        },
        get wetFoodGrams() {
          return Math.round(((this.der * 0.3) / this.WET_FOOD_AVG_KCAL) * 100);
        },
        get dayProgress() {
          if (!this.dietStartDate) return 1;
          const start = new Date(this.dietStartDate);
          const now = new Date();
          const diff = Math.floor((now - start) / (1000 * 60 * 60 * 24)) + 1;
          return Math.max(1, Math.min(30, diff));
        },
        get marketSearchKeywords() {
          // v48: SEPARATION OF CONCERNS — Keywords KHÔNG bao gồm dị ứng (đó là filter/cảnh báo).
          // Chỉ dùng chủng loại + giai đoạn + đặc tính sản phẩm để tìm hạt phù hợp.
          const parts = [];
          const bcs = Number(this.profile.bcs) || 5;
          const speciesLabel = this.profile.species === "cat" ? "mèo" : "chó";
          parts.push("Hạt");
          // BCS hint (thuộc tính sản phẩm, không phải bệnh lý)
          if (bcs >= 6) parts.push("low-fat low-calorie");
          if (bcs <= 3) parts.push("high-energy weight-gain");
          // Life stage (giai đoạn phát triển)
          if (this.filters.lifeStage) {
            const lsMap = { puppy: "puppy", adult: "trưởng thành", senior: "senior", kitten: "kitten" };
            const ls = lsMap[this.filters.lifeStage];
            if (ls) parts.push(ls);
          }
          parts.push("cho " + speciesLabel);
          // Breed (chủng loại)
          if (this.filters.breed && this.filters.breed !== "khac") {
            const opt = this.currentBreedOptions.find((b) => b.code === this.filters.breed);
            if (opt) parts.push(opt.name);
          }
          // Fallback: bare result → medical-grade template (vẫn không nhắc allergen)
          if (parts.length <= 2) {
            return `Hạt cao cấp giàu dinh dưỡng, hỗ trợ tiêu hóa và đẹp lông cho ${speciesLabel}`;
          }
          return parts.join(" ");
        },

        // === v36: Allergen Matrix computed (3 tiers) ===
        get activeAllergenTags() {
          const tags = [];
          for (const a of this.profile.allergens) {
            const entry = this.ALLERGEN_MATRIX.red.find((r) => r.brandKey === a);
            if (entry) tags.push({ tier: "red", code: entry.code, emoji: entry.emoji, label: entry.label });
          }
          for (const s of (this.profile.sensitivities || [])) {
            const entry = this.ALLERGEN_MATRIX.orange.find((o) => o.code === s);
            if (entry) tags.push({ tier: "orange", code: entry.code, emoji: entry.emoji, label: entry.label });
          }
          const opt = this.currentBreedOptions.find((b) => b.code === this.filters.breed);
          if (opt && Array.isArray(opt.risks)) {
            for (const r of opt.risks) {
              tags.push({ tier: "yellow", code: `RISK_${r}`, emoji: "🧬", label: r });
            }
          }
          // v45: Dark Yellow tier — environmental factors user đã chọn
          for (const e of (this.profile.environmentals || [])) {
            const entry = this.ALLERGEN_MATRIX.darkYellow.find((d) => d.code === e);
            if (entry) tags.push({ tier: "darkYellow", code: entry.code, emoji: entry.emoji, label: entry.label });
          }
          return tags;
        },
        get hasAnyAllergen() {
          return this.activeAllergenTags.length > 0;
        },

        // === v36: Free-text NLP parser (regex-based) ===
        parseFreeText(text) {
          this.nlpSuggestions = [];
          if (!text || text.length < 4) return;
          const t = text.toLowerCase();
          if (/(ăn|cho).{0,15}(hạt|đồ ăn).{0,15}gà/.test(t) || /gãi|ngứa|mẩn đỏ/.test(t)) {
            if (!this.profile.allergens.includes("chicken")) {
              this.nlpSuggestions.push({ code: "ALLERGEN_CHICKEN", brandKey: "chicken", label: "❌ Dị ứng Thịt gà", type: "allergen" });
            }
          }
          if (/(ăn|cho).{0,15}(thịt|hạt).{0,15}bò/.test(t) && /(nôn|tiêu chảy|đi ngoài)/.test(t)) {
            if (!this.profile.allergens.includes("beef")) {
              this.nlpSuggestions.push({ code: "ALLERGEN_BEEF", brandKey: "beef", label: "❌ Dị ứng Thịt bò", type: "allergen" });
            }
          }
          if (/(sữa|sữa bò|sữa tươi|lactose)/.test(t) && /(tiêu chảy|nôn|đầy hơi)/.test(t)) {
            if (!this.profile.allergens.includes("dairy")) {
              this.nlpSuggestions.push({ code: "ALLERGEN_DAIRY", brandKey: "dairy", label: "❌ Bất dung nạp Lactose", type: "allergen" });
            }
          }
          if (/cá ngừ|cá hồi|cá biển/.test(t) && /(gãi|ngứa|mẩn|đỏ da)/.test(t)) {
            if (!this.profile.allergens.includes("fish")) {
              this.nlpSuggestions.push({ code: "ALLERGEN_FISH", brandKey: "fish", label: "❌ Dị ứng Đạm cá", type: "allergen" });
            }
          }
          if (/(chung cư|phòng kín|mùi thối|mùi chất thải|mùi phân|hôi)/.test(t)) {
            this.nlpSuggestions.push({ code: "FILTER_YUCCA_BACILLUS", label: "🏢 Bật bộ lọc khử mùi Yucca + Bacillus subtilis", type: "filter" });
          }
          if (/(béo phì|béo nặng|thừa cân|đang giảm cân|ăn nhiều mỡ)/.test(t)) {
            if (!this.profile.sensitivities.includes("SENSITIVITY_FAT")) {
              this.nlpSuggestions.push({ code: "SENSITIVITY_FAT", label: "⚠️ Nhạy cảm béo cao", type: "sensitivity" });
            }
          }
          if (/(tiêu chảy|lỏng phân|đi ngoài).{0,25}(ngũ cốc|tinh bột|bắp|lúa mì|gluten)/.test(t) ||
              /(không dung nạp|kém hấp thu).{0,15}(tinh bột|ngũ cốc)/.test(t)) {
            if (!this.profile.sensitivities.includes("SENSITIVITY_GRAIN")) {
              this.nlpSuggestions.push({ code: "SENSITIVITY_GRAIN", label: "⚠️ Kém hấp thu ngũ cốc", type: "sensitivity" });
            }
          }
        },
        applySuggestion(sug) {
          if (sug.type === "allergen" && sug.brandKey) {
            if (!this.profile.allergens.includes(sug.brandKey)) {
              this.profile.allergens.push(sug.brandKey);
            }
          }
          if (sug.type === "filter" && sug.code === "FILTER_YUCCA_BACILLUS") {
            this.odorFilterActive = true;
          }
          if (sug.type === "sensitivity" && sug.code) {
            if (!this.profile.sensitivities.includes(sug.code)) {
              this.profile.sensitivities.push(sug.code);
            }
          }
          this.nlpSuggestions = this.nlpSuggestions.filter((s) => s.code !== sug.code);
        },

        // === v36: Diet timeline (localStorage per pet ID) ===
        loadDietTimeline() {
          if (!this.profile.selectedPetId) {
            this.dietStartDate = null;
            this.fedToday = false;
            return;
          }
          try {
            const startKey = `vv_pet_${this.profile.selectedPetId}_diet_start`;
            const fedKey   = `vv_pet_${this.profile.selectedPetId}_fed_dates`;
            const stored = localStorage.getItem(startKey);
            if (stored) {
              this.dietStartDate = stored;
            } else {
              const today = new Date().toISOString().slice(0, 10);
              localStorage.setItem(startKey, today);
              this.dietStartDate = today;
            }
            const fedDates = JSON.parse(localStorage.getItem(fedKey) || "[]");
            const todayIso = new Date().toISOString().slice(0, 10);
            this.fedToday = fedDates.includes(todayIso);
          } catch (e) { /* localStorage disabled — silent fallback */ }
        },
        markFedToday() {
          if (!this.profile.selectedPetId) return;
          if (this.fedToday) return;
          try {
            const fedKey = `vv_pet_${this.profile.selectedPetId}_fed_dates`;
            const fedDates = JSON.parse(localStorage.getItem(fedKey) || "[]");
            const todayIso = new Date().toISOString().slice(0, 10);
            if (!fedDates.includes(todayIso)) {
              fedDates.push(todayIso);
              localStorage.setItem(fedKey, JSON.stringify(fedDates));
            }
            this.fedToday = true;
          } catch (e) { /* silent */ }
        },
        async copyToClipboard(text) {
          try {
            await navigator.clipboard.writeText(text);
          } catch (e) { /* silent */ }
        },

        // === Outcome metrics per brand ===
        gramsPerDay(b) {
          if (!b.calories_per_100g) return null;
          return Math.round((this.der / b.calories_per_100g) * 100);
        },
        costPerDay(b) {
          const g = this.gramsPerDay(b);
          if (g == null || !b.price_vnd_per_kg) return null;
          return Math.round((g / 1000) * b.price_vnd_per_kg);
        },
        estimatedCarb(b) {
          return Math.max(0, 100 - (b.protein_pct || 0) - (b.fat_pct || 0) - 12);
        },

        // === v36: Compat score (numeric BCS) ===
        compatScore(b) {
          let s = 100;
          const allergens = b.contains_allergens || [];
          const hits = allergens.filter((a) => this.profile.allergens.includes(a));
          s -= hits.length * 40;
          if (this.profile.species === "cat" && this.estimatedCarb(b) > 20) s -= 25;
          if (b.species !== "both" && b.species !== this.profile.species) s -= 50;
          const bcs = Number(this.profile.bcs) || 5;
          if (bcs >= 6 && b.fat_pct > 14) s -= 25;
          if (bcs >= 8 && b.fat_pct > 12) s -= 15;
          if (bcs <= 3 && (b.calories_per_100g || 0) < 350) s -= 15;
          if (bcs >= 4 && bcs <= 5 && (b.fat_pct < 10 || b.fat_pct > 18)) s -= 10;
          return Math.max(0, s);
        },
        compatTone(b) {
          const s = this.compatScore(b);
          if (s >= 80) return "emerald";
          if (s >= 60) return "amber";
          return "rose";
        },

        isMismatch(b) {
          const allergens = b.contains_allergens || [];
          if (allergens.some((a) => this.profile.allergens.includes(a))) return true;
          if (this.profile.species === "cat" && this.estimatedCarb(b) > 20) return true;
          return false;
        },
        mismatchReason(b) {
          const allergens = b.contains_allergens || [];
          const hits = allergens.filter((a) => this.profile.allergens.includes(a));
          if (hits.length > 0) {
            const names = hits.map((a) => this.allergenLabel(a)).join(", ");
            return `Chứa thành phần dị ứng (${names}) với bé ${this.profile.petName || "bạn"}`;
          }
          if (this.profile.species === "cat" && this.estimatedCarb(b) > 20) {
            return `Hàm lượng tinh bột ~${Math.round(this.estimatedCarb(b))}% vượt ngưỡng sinh học của mèo`;
          }
          return "";
        },

        // === v36: Dynamic tagline (numeric BCS) ===
        compatTagline(b) {
          const p = b.protein_pct || 0;
          const f = b.fat_pct || 0;
          const cal = b.calories_per_100g || 0;
          const bcs = Number(this.profile.bcs) || 5;
          if (bcs >= 6 && f < 12) return "Hỗ trợ kiểm soát cân";
          if (bcs <= 3 && cal > 400) return "Tăng cân lành mạnh";
          if (p > 30) return "Phát triển cơ bắp";
          if (bcs >= 4 && bcs <= 5) return "Duy trì cân bằng";
          return "Phù hợp dinh dưỡng";
        },

        monMinSwapUrl(b) {
          return "https://monminpet.com/sanpham";
        },
        shouldShowSwapCta(b) {
          return !b.mon_min_recommended && this.compatScore(b) < 60;
        },

        toggleRawSpecs(idx) {
          this.expandedRawIdx = this.expandedRawIdx === idx ? null : idx;
        },

        // === Filter logic (v36: profile.species + breed + numeric BCS-aware) ===
        // v46: Smart Label Scanner — real-time allergen match against profile.allergens
        get homeIngredientAlerts() {
          const text = (this.homeIngredients || "").toLowerCase();
          if (text.length < 5) return [];
          // Keyword map từ ALLERGEN_MATRIX.red (brandKey → VN keywords)
          const matchers = [
            { key: "chicken", words: ["gà", "thịt gà", "chicken"], label: "Thịt gà" },
            { key: "beef",    words: ["bò", "thịt bò", "beef"],   label: "Thịt bò" },
            { key: "dairy",   words: ["sữa", "lactose", "milk", "whey", "casein"], label: "Sữa / Lactose" },
            { key: "fish",    words: ["cá", "fish", "salmon", "tuna", "cá hồi", "cá ngừ"], label: "Đạm cá" },
            { key: "egg",     words: ["trứng", "egg", "albumin"], label: "Trứng" },
            { key: "grain",   words: ["ngũ cốc", "lúa mì", "wheat", "corn", "bắp"], label: "Ngũ cốc" },
            { key: "soy",     words: ["đậu nành", "soy"],         label: "Đậu nành" },
          ];
          const alerts = [];
          for (const m of matchers) {
            if (!this.profile.allergens.includes(m.key)) continue;
            const hit = m.words.find((w) => text.includes(w));
            if (hit) alerts.push(`${m.label} (phát hiện "${hit}") — bé bị dị ứng đã ghi nhận`);
          }
          return alerts;
        },

        // v46: Poop Score AI helpers
        get poopScoreLabel() {
          const map = {
            0: { text: "Chưa đánh giá", tone: "text-slate-400" },
            1: { text: "Cứng (táo bón)", tone: "text-amber-700" },
            2: { text: "Chắc, có hình", tone: "text-emerald-600" },
            3: { text: "Lý tưởng", tone: "text-emerald-700" },
            4: { text: "Mềm, hơi nhão", tone: "text-orange-600" },
            5: { text: "Lỏng (GI distress)", tone: "text-red-600" },
          };
          return map[Number(this.poopScore) || 0];
        },
        poopScoreTooltip(n) {
          const tips = {
            1: "Cứng, khô — khả năng táo bón",
            2: "Chắc, có hình — bình thường",
            3: "Lý tưởng — dạng xúc xích mềm",
            4: "Mềm, hơi nhão — chú ý béo cao",
            5: "Lỏng, nước — cảnh báo GI cấp",
          };
          return tips[n] || "";
        },
        get poopFatCap() {
          if (Number(this.poopScore) === 5) return 10;  // watery → very low fat
          if (Number(this.poopScore) === 4) return 13;  // soft → low fat
          return 22;  // default no constraint
        },

        get filtered() {
          const _list = this.brands.filter((b) => {
            if (this.profile.species && b.species !== this.profile.species && b.species !== "both") return false;
            if (this.filters.lifeStage && b.life_stage !== this.filters.lifeStage && b.life_stage !== "all") return false;
            if (this.filters.monMin && !b.mon_min_recommended) return false;
            if (this.filters.maxPrice && b.price_vnd_per_kg > this.filters.maxPrice) return false;
            // v46: Poop Score AI — auto cap fat% khi phân lỏng
            if (Number(this.poopScore) >= 4 && b.fat_pct != null && Number(b.fat_pct) > this.poopFatCap) return false;
            if (this.filters.excludeAllergens.length > 0) {
              for (const a of this.filters.excludeAllergens) {
                if ((b.contains_allergens || []).includes(a)) return false;
              }
            }
            if (this.filters.breed && this.filters.breed !== "khac") {
              const allBreedNames = [...(this.BREED_OPTIONS.cat || []), ...(this.BREED_OPTIONS.dog || [])]
                .filter((o) => o.code !== "khac")
                .map((o) => o.name.toLowerCase());
              const myBreedOpt = this.currentBreedOptions.find((o) => o.code === this.filters.breed);
              const myBreedName = (myBreedOpt && myBreedOpt.name) ? myBreedOpt.name.toLowerCase() : "";
              const text = ((b.brand_name || "") + " " + (b.product_line || "")).toLowerCase();
              const mentioned = allBreedNames.find((bn) => text.includes(bn));
              if (mentioned && mentioned !== myBreedName) return false;
            }
            return true;
          });
          // v47: Sort MonMin recommended lên trên cùng (stable secondary sort)
          return _list.sort((a, b) => (b.mon_min_recommended ? 1 : 0) - (a.mon_min_recommended ? 1 : 0));
        },
        resetFilters() {
          this.filters = { lifeStage: "", excludeAllergens: [], monMin: false, maxPrice: 1000000, breed: "" };
        },
        formatVnd(v) {
          if (!v) return "—";
          if (v >= 1000000) return (v / 1000000).toFixed(1) + "tr";
          if (v >= 1000) return (v / 1000).toFixed(0) + "k";
          return String(v);
        },
        speciesLabel(s) {
          return s === "dog" ? "Chó" : s === "cat" ? "Mèo" : "Chó & Mèo";
        },
        lifeStageLabel(s) {
          const map = { puppy: "Thú non", adult: "Trưởng thành", senior: "Lớn tuổi", all: "Mọi lứa tuổi" };
          return map[s] || s;
        },
        allergenLabel(code) {
          const found = this.allergenList.find((a) => a.code === code);
          return found?.label || code;
        },
      };
    }
  </script>
</Layout>
