    function personalityPage(initial) {
      return {
        pet: initial.pet,
        questions: initial.questions,
        allTypes: initial.allTypes,
        existingResult: initial.existingResult,
        // v140 — Wow Card data (SSR-generated QR + target URL)
        qrDataUrl: initial.qrDataUrl || "",
        personalityCardUrl: initial.personalityCardUrl || "",
        result: null,
        savingImage: false,
        moodTodayValue: null,

        step: "intro",
        qIndex: 0,
        answers: {},
        resumeAvailable: false,

        get currentQuestion() {
          return this.questions[this.qIndex];
        },

        get lsKey() {
          return LS_KEY_PREFIX + this.pet.id;
        },

        get lsMoodKey() {
          return LS_MOOD_PREFIX + this.pet.id;
        },

        // === Derived meta from result ===
        get activeTypeId() {
          // Defensive — backend uses `.primary` (submit) hoặc `.type` (existing GET)
          // và type_meta object có .id field
          return (
            this.result?.primary ||
            this.result?.primary_meta?.id ||
            this.existingResult?.type ||
            this.existingResult?.type_meta?.id ||
            null
          );
        },
        get activeSecondaryId() {
          return (
            this.result?.secondary ||
            this.result?.secondary_meta?.id ||
            this.existingResult?.secondary_type ||
            this.existingResult?.secondary_meta?.id ||
            null
          );
        },
        get kMeta() {
          return getKMeta(this.activeTypeId);
        },
        get kFactor() { return this.kMeta.k; },
        get badgeName() { return this.kMeta.badge; },
        get actionPlanLabel() { return this.kMeta.plan; },
        get voucherCategory() { return this.kMeta.voucher; },

        // === Quarterly refresh check ===
        get daysSinceQuiz() {
          const ts = this.existingResult?.completed_at || this.existingResult?.created_at;
          if (!ts) return 0;
          const then = new Date(ts).getTime();
          if (Number.isNaN(then)) return 0;
          return Math.floor((Date.now() - then) / 86400000);
        },
        get quarterlyDue() { return this.daysSinceQuiz >= 90; },

        onMount() {
          if (this.existingResult) {
            this.step = "existing";
          } else {
            try {
              const saved = localStorage.getItem(this.lsKey);
              if (saved) {
                const parsed = JSON.parse(saved);
                if (parsed && parsed.answers && Object.keys(parsed.answers).length > 0) {
                  this.resumeAvailable = true;
                }
              }
            } catch (_) {}
          }
          this.loadMoodToday();
          this.loadJourney();
          // v140 — auto-sync milestones từ backend (silent, idempotent)
          this.journeyAutoSync();
          // BIG SURPRISE: init tilt + count-up + confetti listener
          this.$nextTick(() => this.initBigEffects());
          // v147 — Wow WAAPI animations cho phần ngoài radar (đồng bộ aesthetic).
          // Delay 250ms để DOM của result step render xong.
          setTimeout(() => this.applyWowAnimations(), 250);
        },

        // ============ v147 — WAAPI WOW ANIMATIONS ============
        // Tại sao WAAPI thay vì CSS animation? Trên page này CSS keyframes có vấn đề
        // chưa rõ root cause (radar phải dùng SMIL mới chạy được). WAAPI là JS API
        // gọi trực tiếp browser animation engine — bulletproof, không phụ thuộc CSS.
        applyWowAnimations() {
          if (typeof window === "undefined" || !document.body.animate) return;
          // Respect OS reduce-motion
          if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

          const $$ = (sel) => Array.from(document.querySelectorAll(sel));
          const $1 = (sel) => document.querySelector(sel);

          // 1) HERO PET PHOTO — gold halo breathing pulse
          const photo = $1("#result-card-existing img.pet-photo-zoom, #result-card-existing div[style*='box-shadow']");
          if (photo) {
            photo.animate(
              [
                { boxShadow: "0 0 0 3px #ecb921, 0 0 0 5px rgba(180,134,8,0.3), 0 8px 18px -4px rgba(236,185,33,0.5)" },
                { boxShadow: "0 0 0 3px #ecb921, 0 0 0 10px rgba(236,185,33,0.55), 0 14px 28px -4px rgba(236,185,33,0.8)" },
                { boxShadow: "0 0 0 3px #ecb921, 0 0 0 5px rgba(180,134,8,0.3), 0 8px 18px -4px rgba(236,185,33,0.5)" },
              ],
              { duration: 3200, iterations: Infinity, easing: "ease-in-out" }
            );
          }

          // 2) K-FACTOR NUMBER — scale + glow pulse (×1.30 v.v.)
          $$("#result-card-existing .k-pulse-mount").forEach((el) => {
            el.animate(
              [
                { transform: "scale(1)",     textShadow: "0 0 0 rgba(236,185,33,0)" },
                { transform: "scale(1.08)",  textShadow: "0 0 18px rgba(236,185,33,0.95)" },
                { transform: "scale(1)",     textShadow: "0 0 0 rgba(236,185,33,0)" },
              ],
              { duration: 2400, iterations: Infinity, easing: "ease-in-out" }
            );
          });

          // 3) HERO NAME — gold shimmer sweep (replaces CSS name-shine in case CSS dead)
          const nameEl = $1("#result-card-existing .name-shine");
          if (nameEl) {
            // Force the gradient bg in case CSS chưa apply
            nameEl.style.backgroundImage = "linear-gradient(90deg, #fff 0%, #fff 35%, #ecb921 50%, #fff 65%, #fff 100%)";
            nameEl.style.backgroundSize = "200% 100%";
            nameEl.style.webkitBackgroundClip = "text";
            nameEl.style.backgroundClip = "text";
            nameEl.style.color = "transparent";
            nameEl.style.webkitTextFillColor = "transparent";
            nameEl.animate(
              [
                { backgroundPosition: "-150% 0" },
                { backgroundPosition: "250% 0" },
              ],
              { duration: 3800, iterations: Infinity, easing: "linear" }
            );
          }

          // 4) AI PARTICLES (5 dots trên hero) — float trôi với scale
          $$("#result-card-existing .ai-particle").forEach((el, i) => {
            const dx = [40, -50, 30, -45, 60][i] || 30;
            const dy = [-32, 38, -48, 36, -40][i] || -30;
            el.animate(
              [
                { transform: "translate(0,0) scale(1)",                 opacity: 0.45 },
                { transform: `translate(${dx}px,${dy}px) scale(1.35)`,  opacity: 1 },
                { transform: "translate(0,0) scale(1)",                 opacity: 0.45 },
              ],
              {
                duration: 5500 + i * 800,
                iterations: Infinity,
                easing: "ease-in-out",
                delay: i * 350,
              }
            );
          });

          // 5) AI SCAN LINE — horizontal sweep across hero
          const scan = $1("#result-card-existing .ai-scan");
          if (scan) {
            scan.animate(
              [
                { transform: "translateX(-110%)", opacity: 0 },
                { transform: "translateX(-20%)",  opacity: 1, offset: 0.2 },
                { transform: "translateX(110%)",  opacity: 1, offset: 0.7 },
                { transform: "translateX(210%)",  opacity: 0 },
              ],
              { duration: 4800, iterations: Infinity, easing: "ease-in-out" }
            );
          }

          // 6) ALL .live-dot indicators — gold pulse halo (đồng bộ với radar)
          $$(".live-dot").forEach((el) => {
            el.animate(
              [
                { transform: "scale(1)",    boxShadow: "0 0 0 0 rgba(236,185,33,0.85)" },
                { transform: "scale(1.18)", boxShadow: "0 0 0 7px rgba(236,185,33,0)" },
                { transform: "scale(1)",    boxShadow: "0 0 0 0 rgba(236,185,33,0)" },
              ],
              { duration: 1600, iterations: Infinity, easing: "ease-out" }
            );
          });

          // 7) GROWTH JOURNEY active step CTA — gentle scale pulse (focus magnet)
          // Selector: .growth-step.is-ready button.growth-step-cta (vellum timeline)
          const ctaInterval = setInterval(() => {
            const cta = $1(".growth-step .growth-step-cta");
            if (!cta) return;
            clearInterval(ctaInterval);
            cta.animate(
              [
                { transform: "translateY(0) scale(1)",       boxShadow: "0 0 0 0 rgba(10,10,10,0)" },
                { transform: "translateY(-1.5px) scale(1.03)", boxShadow: "0 6px 14px -4px rgba(10,10,10,0.35)" },
                { transform: "translateY(0) scale(1)",       boxShadow: "0 0 0 0 rgba(10,10,10,0)" },
              ],
              { duration: 2400, iterations: Infinity, easing: "ease-in-out" }
            );
          }, 200);
          // Stop probing sau 3s nếu CTA chưa render (user chưa scroll tới)
          setTimeout(() => clearInterval(ctaInterval), 3000);

          // 8) SECTION ICON BADGES — 8x8/9x9 rounded squares ở header các section (Điểm mạnh / Bé cần / Tomorrow / Mood) — float bob
          $$("section .inline-flex.items-center.justify-center.rounded-xl[style*='ecb921']").forEach((el, i) => {
            el.animate(
              [
                { transform: "translateY(0) rotate(0deg)" },
                { transform: "translateY(-2.5px) rotate(2deg)" },
                { transform: "translateY(0) rotate(0deg)" },
                { transform: "translateY(-1.5px) rotate(-2deg)" },
                { transform: "translateY(0) rotate(0deg)" },
              ],
              {
                duration: 4500 + i * 350,
                iterations: Infinity,
                easing: "ease-in-out",
                delay: i * 200,
              }
            );
          });
        },

        // === BIG SURPRISE EFFECTS ===
        initBigEffects() {
          // 1) 3D tilt trên hero card
          const card = document.getElementById("result-card-existing");
          if (card) {
            card.classList.add("tilt-3d");
            card.addEventListener("mousemove", (e) => {
              const rect = card.getBoundingClientRect();
              const x = (e.clientX - rect.left) / rect.width - 0.5;
              const y = (e.clientY - rect.top) / rect.height - 0.5;
              card.classList.add("tilting");
              card.style.transform = `perspective(1000px) rotateX(${-y * 6}deg) rotateY(${x * 8}deg) scale(1.01)`;
            });
            card.addEventListener("mouseleave", () => {
              card.classList.remove("tilting");
              card.style.transform = "";
            });
            // Touch device tilt-on-scroll fallback
            if ("ontouchstart" in window) {
              let raf = null;
              const onScroll = () => {
                if (raf) return;
                raf = requestAnimationFrame(() => {
                  const rect = card.getBoundingClientRect();
                  const center = rect.top + rect.height / 2;
                  const offset = (center - window.innerHeight / 2) / window.innerHeight;
                  card.style.transform = `perspective(1000px) rotateX(${offset * -4}deg)`;
                  raf = null;
                });
              };
              window.addEventListener("scroll", onScroll, { passive: true });
            }
          }
        },

        // === Confetti burst — called on milestone tick ===
        burstConfetti(originX, originY) {
          const colors = ["#ecb921", "#B48608", "#fff", "#8B6705"];
          const n = 32;
          for (let i = 0; i < n; i++) {
            const p = document.createElement("div");
            p.className = "confetti-piece";
            const c = colors[i % colors.length];
            const angle = (Math.PI * 2 * i) / n + Math.random() * 0.4;
            const dist = 80 + Math.random() * 120;
            const dx = Math.cos(angle) * dist;
            const dy = Math.sin(angle) * dist;
            p.style.background = c;
            p.style.left = (originX || window.innerWidth / 2) + "px";
            p.style.top = (originY || 100) + "px";
            p.style.transform = `translate(${dx}px, ${dy}px) rotate(${Math.random() * 360}deg)`;
            p.style.borderRadius = Math.random() > 0.5 ? "2px" : "50%";
            p.style.animationDelay = (i * 8) + "ms";
            document.body.appendChild(p);
            setTimeout(() => p.remove(), 2400);
          }
        },

        moodHistory: [],   // [{ date: "YYYY-MM-DD", mood: "happy" }, ...]
        moodToast: null,    // hiện text tạm vài giây

        loadMoodToday() {
          try {
            const raw = localStorage.getItem(this.lsMoodKey);
            if (!raw) return;
            const data = JSON.parse(raw);
            // Old format compatibility
            if (data.date && data.mood && !data.history) {
              this.moodHistory = [{ date: data.date, mood: data.mood }];
            } else if (Array.isArray(data.history)) {
              this.moodHistory = data.history;
            }
            const today = new Date().toISOString().slice(0, 10);
            const todayEntry = this.moodHistory.find((m) => m.date === today);
            if (todayEntry) this.moodTodayValue = todayEntry.mood;
          } catch (_) {}
        },

        setMood(mood) {
          this.moodTodayValue = mood;
          const today = new Date().toISOString().slice(0, 10);
          // Update history — replace today if exists, else append
          this.moodHistory = (this.moodHistory || []).filter((m) => m.date !== today);
          this.moodHistory.push({ date: today, mood });
          // Keep only last 14 days
          this.moodHistory = this.moodHistory.slice(-14);
          try {
            localStorage.setItem(this.lsMoodKey, JSON.stringify({
              history: this.moodHistory,
            }));
          } catch (_) {}
          // Visual confirm toast
          this.moodToast = `Đã ghi: ${mood === "happy" ? "Vui vẻ" : mood === "anxious" ? "Lo âu" : "Lừ đừ"} cho hôm nay`;
          setTimeout(() => { this.moodToast = null; }, 2200);
          // Fire-and-forget mood log (backend endpoint optional — silently ignore failure)
          fetch(`/api/v1/pets/${this.pet.id}/personality/mood`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ mood }),
          }).catch(() => {});
        },

        // === Mood helpers for the 7-day strip + auto-suggest ===
        // Returns last 7 day-keys [-6d ... today] with their mood (or null)
        get last7Days() {
          const arr = [];
          const now = new Date();
          for (let i = 6; i >= 0; i--) {
            const d = new Date(now);
            d.setDate(now.getDate() - i);
            const key = d.toISOString().slice(0, 10);
            const entry = (this.moodHistory || []).find((m) => m.date === key);
            arr.push({
              key,
              i,
              isToday: i === 0,
              mood: entry ? entry.mood : null,
              dayLabel: i === 0 ? "HÔM NAY" : `-${i}d`,
            });
          }
          return arr;
        },
        moodColor(mood) {
          if (mood === "happy")     return "linear-gradient(90deg, #ecb921, #B48608)"; // gold
          if (mood === "anxious")   return "linear-gradient(90deg, #d97706, #92400e)"; // amber-deep
          if (mood === "lethargic") return "linear-gradient(90deg, #94a3b8, #475569)"; // slate
          return null;
        },
        // Auto suggest based on personality type group — heuristic, không cần backend
        get suggestedMood() {
          if (this.moodTodayValue) return null; // đã chọn rồi → không gợi ý
          const g = (this.kMeta && this.kMeta.group) || "BALANCED";
          if (g === "OUTGOING") return { mood: "happy",     reason: `${g} type — thường năng động ban đầu` };
          if (g === "INTROVERT") return { mood: "lethargic", reason: `${g} type — hay yên tĩnh, ngủ nhiều` };
          if (g === "SPECIAL")   return { mood: "happy",     reason: `${g} type — sáng tạo, tích cực` };
          return { mood: "happy", reason: `${g} type — cân bằng, ưu tiên Vui vẻ` };
        },

        startQuiz() {
          this.step = "quiz";
          this.qIndex = 0;
          this.answers = {};
          try { localStorage.removeItem(this.lsKey); } catch (_) {}
        },

        resume() {
          try {
            const parsed = JSON.parse(localStorage.getItem(this.lsKey) || "{}");
            this.answers = parsed.answers || {};
            const firstMissing = this.questions.findIndex((q) => !this.answers[q.id]);
            this.qIndex = firstMissing === -1 ? this.questions.length - 1 : firstMissing;
            this.step = "quiz";
            this.resumeAvailable = false;
          } catch (_) {
            this.startQuiz();
          }
        },

        choose(optId) {
          if (!this.currentQuestion) return;
          this.answers[this.currentQuestion.id] = optId;
          try {
            localStorage.setItem(this.lsKey, JSON.stringify({ qIndex: this.qIndex, answers: this.answers, ts: Date.now() }));
          } catch (_) {}
          if (this.qIndex < this.questions.length - 1) {
            // Smooth delay so user sees selected state before transition
            setTimeout(() => { this.qIndex++; }, 220);
          } else {
            setTimeout(() => this.submit(), 220);
          }
        },

        back() {
          if (this.qIndex > 0) this.qIndex--;
        },

        async submit() {
          this.step = "loading";
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/personality/submit`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ answers: this.answers }),
            });
            if (!res.ok) {
              const j = await res.json().catch(() => ({}));
              alert("Lỗi: " + (j?.error?.message || res.status));
              this.step = "quiz";
              return;
            }
            const data = await res.json();
            this.result = data;
            try { localStorage.removeItem(this.lsKey); } catch (_) {}
            this.step = "result";
          } catch (err) {
            alert("Không kết nối được server.");
            this.step = "quiz";
          }
        },

        async confirmReset() {
          if (!confirm("Làm lại personality quiz cho bé? Kết quả cũ sẽ bị xoá.")) return;
          try {
            await fetch(`/api/v1/pets/${this.pet.id}/personality/reset`, {
              method: "POST",
              credentials: "include",
            });
          } catch (_) {}
          try { localStorage.removeItem(this.lsKey); } catch (_) {}
          this.existingResult = null;
          this.result = null;
          this.answers = {};
          this.qIndex = 0;
          this.step = "intro";
        },

        getTypeMeta(typeId) {
          return this.allTypes.find((t) => t.id === typeId) || null;
        },
        // Public for templates — render Lucide SVG thay emoji sticker từ backend
        typeIcon(typeId, sizeClass) {
          return getTypeIcon(typeId, sizeClass);
        },

        // === M15.2 — 6-dimension radar from type scores ===
        get dim6Scores() {
          const raw = (this.existingResult && this.existingResult.scores) || (this.result && this.result.scores) || {};
          const dims = { energy: 0, social: 0, food: 0, independence: 0, communication: 0, emotion: 0 };
          for (const [type, score] of Object.entries(raw)) {
            const w = DIMENSION_WEIGHTS[type] || {};
            for (const [d, weight] of Object.entries(w)) {
              dims[d] += Number(score) * weight;
            }
          }
          // Normalize cap at 25 raw → 100%
          const out = {};
          for (const k of Object.keys(dims)) {
            out[k] = Math.min(100, Math.round((dims[k] / 25) * 100));
          }
          return out;
        },
        get dim6Axes() {
          return [
            { key: "energy",        label: "Năng lượng",   icon: "lightning" },
            { key: "social",        label: "Xã hội",       icon: "handshake" },
            { key: "food",          label: "Đồ ăn",         icon: "utensils" },
            { key: "communication", label: "Giao tiếp",     icon: "message-circle" },
            { key: "independence",  label: "Độc lập",       icon: "home" },
            { key: "emotion",       label: "Cảm xúc",       icon: "heart" },
          ];
        },
        // 6-dim radar: dots, polygon, labels
        get dim6Dots() {
          const cx = 160, cy = 140, radius = 100;
          const scores = this.dim6Scores;
          return this.dim6Axes.map((ax, i) => {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            const r = radius * ((scores[ax.key] || 0) / 100);
            return { x: cx + Math.cos(ang) * r, y: cy + Math.sin(ang) * r, pct: scores[ax.key] || 0 };
          });
        },
        get dim6Points() {
          return this.dim6Dots.map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
        },
        get dim6Labels() {
          const cx = 160, cy = 140, radius = 118;
          return this.dim6Axes.map((ax, i) => {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            const x = cx + Math.cos(ang) * radius;
            let y = cy + Math.sin(ang) * radius;
            if (y < 18) y = 18;
            const score = this.dim6Scores[ax.key] || 0;
            return { x, y, label: ax.label, score };
          });
        },
        // v141 — tách inline `dim6Labels.slice().sort(...).slice(0,3)` ra getter
        // để Alpine không phải eval arrow function trong x-for expression (safer scope).
        get topDim6Labels() {
          return this.dim6Labels
            .slice()
            .sort((a, b) => b.score - a.score)
            .slice(0, 3);
        },
        // v141 — guard: chỉ render radar khi đã có scores (existingResult HOẶC result).
        get hasRadarData() {
          return !!((this.existingResult && this.existingResult.scores) ||
                    (this.result && this.result.scores));
        },

        // v143 — LIVING RADAR. Bỏ x-html. Real SVG elements via createElementNS.
        // x-effect track this.dim6Dots / this.dim6Labels / this.dim6Points dependencies
        // → khi quiz submit, getter recompute, x-effect re-run, SVG rebuild → reactive thật.
        radarVisible: false,
        setupRadarObserver(rootEl) {
          if (!rootEl) return;
          // No-IO browser → fallback show ngay
          if (typeof IntersectionObserver === "undefined") {
            this.radarVisible = true;
            return;
          }
          const obs = new IntersectionObserver(
            ([entry]) => {
              if (entry.isIntersecting) {
                this.radarVisible = true;
                obs.disconnect(); // one-shot
              }
            },
            { threshold: 0.25, rootMargin: "0px 0px -10% 0px" }
          );
          obs.observe(rootEl);
        },
        renderRadar6dSvg(svg) {
          if (!svg) return;
          // Đọc deps TRƯỚC để Alpine x-effect track changes
          const dots = this.dim6Dots;
          const labels = this.dim6Labels;
          const polyPoints = this.dim6Points;
          const NS = "http://www.w3.org/2000/svg";
          const cx = 160, cy = 140;
          const RADIUS = 100;

          // CLEAN — giữ <defs>, xoá mọi children khác (để x-effect re-render mượt)
          const defs = svg.querySelector("defs");
          while (svg.firstChild) svg.removeChild(svg.firstChild);
          if (defs) svg.appendChild(defs);

          // Helper: create namespaced element with attrs
          const make = (tag, attrs, text) => {
            const el = document.createElementNS(NS, tag);
            for (const [k, v] of Object.entries(attrs || {})) {
              if (v == null) continue;
              el.setAttribute(k, String(v));
            }
            if (text != null) el.textContent = text;
            return el;
          };

          // 1) 4 hex rings — class radar-hex + --i stagger
          const HEX = [
            { r: 100, op: 0.25 },
            { r: 75,  op: 0.32 },
            { r: 50,  op: 0.40 },
            { r: 25,  op: 0.50 },
          ];
          HEX.forEach((ring, i) => {
            svg.appendChild(make("polygon", {
              points: this.hexPoints6(ring.r, cx, cy),
              fill: "none",
              stroke: `rgba(180,134,8,${ring.op})`,
              "stroke-width": 1,
              class: "radar-hex",
              style: `--i:${i}`,
            }));
          });

          // 2) 6 axis lines — stroke draw stagger
          for (let i = 0; i < 6; i++) {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            const x2 = (cx + Math.cos(ang) * RADIUS).toFixed(1);
            const y2 = (cy + Math.sin(ang) * RADIUS).toFixed(1);
            svg.appendChild(make("line", {
              x1: cx, y1: cy, x2, y2,
              stroke: "rgba(180,134,8,0.28)",
              "stroke-width": 1,
              class: "radar-axis",
              style: `--i:${i}`,
            }));
          }

          // 3) 6 synapse arcs — SMIL native (stroke-dashoffset flow, không cần CSS)
          dots.forEach((d, i) => {
            const begin = (i * 0.25).toFixed(2);
            const line = make("line", {
              x1: cx, y1: cy,
              x2: d.x.toFixed(1), y2: d.y.toFixed(1),
              class: "synapse",
              stroke: "#ecb921",
              "stroke-width": 1.6,
              "stroke-dasharray": "5 5",
              fill: "none",
              style: "filter: drop-shadow(0 0 4px rgba(236,185,33,0.7));",
            });
            line.appendChild(make("animate", {
              attributeName: "stroke-dashoffset",
              values: "0; -28; 0",
              dur: "2s",
              begin: `${begin}s`,
              repeatCount: "indefinite",
            }));
            line.appendChild(make("animate", {
              attributeName: "opacity",
              values: "0.65; 1; 0.65",
              dur: "2s",
              begin: `${begin}s`,
              repeatCount: "indefinite",
            }));
            svg.appendChild(line);
          });

          // 4) Sweep wedge — SMIL native animateTransform rotate 360° (bulletproof)
          const wedgeStart = { x: cx, y: cy - RADIUS };
          const wedgeAng = ((-90 + 60) * Math.PI) / 180;
          const wedgeEnd = {
            x: (cx + Math.cos(wedgeAng) * RADIUS).toFixed(1),
            y: (cy + Math.sin(wedgeAng) * RADIUS).toFixed(1),
          };
          const wedge = make("path", {
            d: `M ${cx} ${cy} L ${wedgeStart.x} ${wedgeStart.y} A ${RADIUS} ${RADIUS} 0 0 1 ${wedgeEnd.x} ${wedgeEnd.y} Z`,
            fill: "url(#radar6dSweepGrad)",
            class: "radar-wedge",
            opacity: "0.55",
            style: "mix-blend-mode: multiply;",
          });
          // SMIL animateTransform — built-in browser, không cần CSS, không cần transform-box
          wedge.appendChild(make("animateTransform", {
            attributeName: "transform",
            type: "rotate",
            from: `0 ${cx} ${cy}`,
            to: `360 ${cx} ${cy}`,
            dur: "3.6s",
            repeatCount: "indefinite",
          }));
          svg.appendChild(wedge);

          // 5) Data polygon — SMIL animateTransform scale around center (additive translate trick)
          // Để scale quanh (cx,cy) cần: translate(cx,cy) → scale → translate(-cx,-cy)
          // SMIL hỗ trợ additive="sum" để compose transforms
          const poly = make("polygon", {
            points: polyPoints,
            class: "dim6-poly",
            fill: "rgba(180,134,8,0.30)",
            stroke: "#B48608",
            "stroke-width": 3,
            style: "filter: drop-shadow(0 0 14px rgba(236,185,33,0.6));",
          });
          // Translate to origin
          poly.appendChild(make("animateTransform", {
            attributeName: "transform", type: "translate",
            values: `${cx} ${cy}`, dur: "3.5s", repeatCount: "indefinite",
          }));
          // Scale (additive)
          poly.appendChild(make("animateTransform", {
            attributeName: "transform", type: "scale",
            values: "1; 1.08; 0.94; 1",
            keyTimes: "0; 0.33; 0.66; 1",
            dur: "3.5s", repeatCount: "indefinite", additive: "sum",
          }));
          // Translate back (additive)
          poly.appendChild(make("animateTransform", {
            attributeName: "transform", type: "translate",
            values: `${-cx} ${-cy}`, dur: "3.5s", repeatCount: "indefinite", additive: "sum",
          }));
          svg.appendChild(poly);

          // 6) 6 vertex dots — SMIL animate r attribute (native SVG, no CSS)
          dots.forEach((d, i) => {
            const begin = (i * 0.2).toFixed(2);
            const dot = make("circle", {
              cx: d.x.toFixed(1), cy: d.y.toFixed(1),
              r: 4,
              fill: "#B48608",
              stroke: "#fff",
              "stroke-width": 2,
              class: "radar-dot-galaxy",
              style: "filter: drop-shadow(0 0 3px rgba(180,134,8,0.7));",
            });
            dot.appendChild(make("animate", {
              attributeName: "r",
              values: "4; 6; 4",
              dur: "2s",
              begin: `${begin}s`,
              repeatCount: "indefinite",
            }));
            dot.appendChild(make("animate", {
              attributeName: "opacity",
              values: "1; 0.75; 1",
              dur: "2s",
              begin: `${begin}s`,
              repeatCount: "indefinite",
            }));
            svg.appendChild(dot);
          });

          // 7) 6 labels (group with label text + score text)
          labels.forEach((lab, i) => {
            const g = make("g", { class: "radar-label" });
            g.appendChild(make("text", {
              x: lab.x.toFixed(1), y: lab.y.toFixed(1),
              fill: "#0a0a0a",
              "font-size": 11,
              "font-weight": 800,
              "text-anchor": "middle",
            }, lab.label));
            g.appendChild(make("text", {
              x: lab.x.toFixed(1), y: (lab.y + 13).toFixed(1),
              fill: "#B48608",
              "font-size": 10,
              "font-weight": 900,
              "text-anchor": "middle",
            }, `${lab.score}%`));
            svg.appendChild(g);
          });
        },
        get radar5dHtml() {
          const cx = 160, cy = 140;
          const hexRings = [
            { r: 120, op: 0.25 }, { r: 80, op: 0.35 }, { r: 40, op: 0.45 },
          ].map(({ r, op }) =>
            `<polygon points="${this.hexagonPoints(r, cx, cy)}" fill="none" stroke="rgba(180,134,8,${op})" stroke-width="1"/>`
          ).join("");

          let axisLines = "";
          for (let i = 0; i < 6; i++) {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            const x2 = (cx + Math.cos(ang) * 120).toFixed(1);
            const y2 = (cy + Math.sin(ang) * 120).toFixed(1);
            axisLines += `<line x1="${cx}" y1="${cy}" x2="${x2}" y2="${y2}" stroke="rgba(180,134,8,0.3)" stroke-width="1"/>`;
          }

          const dotEls = this.radarDots.map((pt) =>
            `<circle cx="${pt.x.toFixed(1)}" cy="${pt.y.toFixed(1)}" r="4" fill="#B48608" stroke="#fff" stroke-width="2"/>`
          ).join("");

          const labelEls = this.radarLabels.map((lab) =>
            `<text x="${lab.x.toFixed(1)}" y="${lab.y.toFixed(1)}" fill="#0a0a0a" font-size="11" font-weight="700" text-anchor="middle">${this._escSvg(lab.label)}</text>`
          ).join("");

          return `<svg viewBox="0 0 320 280" class="w-full max-w-xs mx-auto">${hexRings}${axisLines}<polygon points="${this.radarPoints}" fill="rgba(180,134,8,0.30)" stroke="#B48608" stroke-width="2.5"/>${dotEls}${labelEls}</svg>`;
        },

        // v142 — certDate getter (was undefined → x-text="certDate" throw ReferenceError)
        get certDate() {
          const d = new Date();
          const pad = (n) => String(n).padStart(2, "0");
          return `${pad(d.getDate())}.${pad(d.getMonth() + 1)}.${d.getFullYear()}`;
        },
        hexPoints6(radius, cx, cy) {
          const pts = [];
          for (let i = 0; i < 6; i++) {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            pts.push(`${cx + Math.cos(ang) * radius},${cy + Math.sin(ang) * radius}`);
          }
          return pts.join(" ");
        },

        // === M15.3 — Behavioral Insight "Ngày mai của bé" ===
        get behaviorInsight() {
          const tid = this.activeTypeId;
          if (!tid) return null;
          return INSIGHT_MAP[tid] || null;
        },

        // === M15.4 — Mood × Routine smart suggestion ===
        get moodRoutineSuggestion() {
          if (!this.moodTodayValue) return null;
          return MOOD_SUGGESTION_MAP[this.moodTodayValue] || null;
        },

        // === M15.5 — Journey Timeline (4 milestones) ===
        // v140 — Auto-detect from backend, manual click chỉ còn cho step 4 (share).
        completedMilestones: [],
        // Backend-driven state (populated by journeyAutoSync trên init)
        routinesTotal: null,         // null = chưa fetch, 0 = fetched no routines
        routineStreakDays: 0,
        petScoreTotal: 0,
        claimedRewardsCount: 0,
        // Wow Card modal state (v140 — Task #8). qrDataUrl + personalityCardUrl đã set ở top.
        wowCardOpen: false,
        openWowCard() {
          if (this.petScoreTotal <= 0) {
            this.moodToast = "Cần Pet Score > 0 mới mở thẻ chia sẻ";
            setTimeout(() => { this.moodToast = null; }, 3000);
            return;
          }
          this.wowCardOpen = true;
          document.body.style.overflow = "hidden";
        },
        closeWowCard() {
          this.wowCardOpen = false;
          document.body.style.overflow = "";
        },
        get lsJourneyKey() { return `vowvet_journey_${this.pet.id}`; },
        loadJourney() {
          try {
            const raw = localStorage.getItem(this.lsJourneyKey);
            if (raw) this.completedMilestones = JSON.parse(raw);
          } catch (_) {}
        },
        // v140: silent auto-sync với 3 API. Idempotent — gọi nhiều lần OK.
        async journeyAutoSync() {
          if (!this.pet || !this.pet.id) return;
          const petId = this.pet.id;
          try {
            const [routinesRes, scoreRes, claimedRes] = await Promise.allSettled([
              fetch(`/api/v1/pets/${petId}/routines`, { credentials: "same-origin" }).then((r) => (r.ok ? r.json() : null)),
              fetch(`/api/v1/pets/${petId}/pet-score`, { credentials: "same-origin" }).then((r) => (r.ok ? r.json() : null)),
              fetch(`/api/v1/rewards/pets/${petId}/claimed`, { credentials: "same-origin" }).then((r) => (r.ok ? r.json() : null)),
            ]);

            // Routines total
            const routinesData = routinesRes.status === "fulfilled" ? routinesRes.value : null;
            this.routinesTotal = routinesData?.total ?? (Array.isArray(routinesData?.routines) ? routinesData.routines.length : 0);

            // Pet score + streak
            const scoreData = scoreRes.status === "fulfilled" ? scoreRes.value : null;
            this.petScoreTotal = Number(scoreData?.score ?? scoreData?.pet_score ?? 0) || 0;
            this.routineStreakDays = Number(scoreData?.routine_streak_days ?? scoreData?.inputs?.routine_streak_days ?? 0) || 0;

            // Claimed rewards count
            const claimedData = claimedRes.status === "fulfilled" ? claimedRes.value : null;
            const claimedList = claimedData?.rewards || claimedData?.claimed || claimedData?.claims || [];
            this.claimedRewardsCount = Array.isArray(claimedList) ? claimedList.length : Number(claimedData?.total ?? 0) || 0;

            // Auto-mark milestones (idempotent — sẽ skip nếu đã có)
            if (this.routinesTotal > 0)            this._addMilestone("routine");
            if (this.routineStreakDays >= 3)       this._addMilestone("score");
            if (this.claimedRewardsCount > 0)      this._addMilestone("voucher");
            // Step 4 (share) vẫn manual — chỉ done khi user thực sự bấm "Khoe ngay"
          } catch (_) {
            // Silent — journey vẫn fallback về localStorage state
          }
        },
        // Internal — push without confetti (dùng cho auto-sync)
        _addMilestone(id) {
          if (!this.completedMilestones.includes(id)) {
            this.completedMilestones.push(id);
            try { localStorage.setItem(this.lsJourneyKey, JSON.stringify(this.completedMilestones)); } catch (_) {}
          }
        },
        markMilestone(id) {
          const wasNew = !this.completedMilestones.includes(id);
          this._addMilestone(id);
          if (wasNew) {
            // BIG SURPRISE: confetti burst when complete a milestone!
            const evt = (window.event || {});
            const x = evt.clientX || window.innerWidth / 2;
            const y = evt.clientY || 200;
            this.burstConfetti(x, y);
            // EXTRA bonus: if just hit 100% → MEGA burst
            if (this.completedMilestones.length === 4) {
              setTimeout(() => {
                this.burstConfetti(window.innerWidth * 0.25, 100);
                this.burstConfetti(window.innerWidth * 0.75, 100);
                this.burstConfetti(window.innerWidth * 0.5, 200);
              }, 250);
            }
          }
        },
        // v140 — Step 4 gating: cần petScore > 0 mới mở
        isStepGated(stepId) {
          if (stepId === "share") return this.petScoreTotal <= 0;
          return false;
        },
        get journeyPct() {
          return Math.round((this.completedMilestones.length / 4) * 100);
        },
        get journeyAllDone() {
          return this.completedMilestones.length >= 4;
        },
        // Steps definition + status helpers (v138 — Growth Journey Checklist)
        // `title` = clean numbered step name (sang trọng, ngắn gọn)
        // `lead`  = 1-sentence Fraunces italic description (luxury feel)
        // `label`/`subtitle` giữ lại để backward compat với chỗ khác đọc journeySteps
        get journeySteps() {
          const all = [
            { id: "routine", num: 1, label: "Routines",  icon: "target", title: "Lên lịch trình",       lead: "Bộ thói quen 30 ngày được điều chỉnh riêng theo type của bé.",      subtitle: this.actionPlanLabel + " · Smart Blueprint match",                  href: `/pets/${this.pet.id}/routines`, cta: "Khởi hành" },
            { id: "score",   num: 2, label: "Pet Score", icon: "home",   title: "Kiểm tra sức khoẻ",   lead: "Pet Score tính lại với hệ số k-factor cá nhân hoá của bé.",         subtitle: "Dashboard gauge — k-factor đã được áp ×" + this.kFactor.toFixed(2), href: "/dashboard",                    cta: "Khởi hành" },
            { id: "voucher", num: 3, label: "Voucher",   icon: "gift",   title: "Nhận quà tặng",        lead: "Voucher hợp tính cách được đẩy lên đầu danh sách đổi thưởng.",      subtitle: "Danh mục: " + this.voucherCategory,                                 href: `/pets/${this.pet.id}/rewards`,  cta: "Khởi hành" },
            { id: "share",   num: 4, label: "Chia sẻ",   icon: "share",  title: "Chia sẻ tính cách",    lead: "Thẻ tính cách lan toả qua Zalo, Messenger hoặc copy link.",         subtitle: "Khoe trên Zalo / Messenger / Copy link",                            href: null,                            cta: "Khởi hành" },
          ];
          return all.map((s) => ({ ...s, done: this.completedMilestones.includes(s.id) }));
        },
        // v140 — Active = first undone, non-gated step. Trả sentinel khi không có
        // step nào actionable (vd. 1-3 done nhưng share đang gated bởi petScore=0).
        get journeyActiveStep() {
          for (const s of this.journeySteps) {
            if (s.done) continue;
            if (this.isStepGated(s.id)) continue;
            return s;
          }
          // Fallback: nếu thực sự all done, trả step cuối để header/seal render OK.
          // Còn nếu chỉ gated, trả sentinel để HTML không hiển thị active state cho gated step.
          if (this.completedMilestones.length >= 4) return this.journeySteps[this.journeySteps.length - 1];
          return { id: "__none__", num: 0, label: "", title: "", lead: "", subtitle: "", href: null };
        },

        // ============ Radar chart ============
        get dimensionScores() {
          const dims = { energy: 0, social: 0, food: 0, independence: 0, communication: 0, stress: 0 };
          const counts = { energy: 0, social: 0, food: 0, independence: 0, communication: 0, stress: 0 };
          if (!this.result || !this.questions) return dims;
          for (const q of this.questions) {
            const optId = this.answers[q.id];
            if (!optId) continue;
            const opt = q.options.find((o) => o.id === optId);
            if (!opt) continue;
            const sumPts = Object.values(opt.scores || {}).reduce((s, n) => s + (Number(n) || 0), 0);
            dims[q.dimension] = (dims[q.dimension] || 0) + sumPts;
            counts[q.dimension] = (counts[q.dimension] || 0) + 1;
          }
          const out = {};
          for (const k of Object.keys(dims)) {
            const maxPerQ = 8;
            const cap = (counts[k] || 1) * maxPerQ;
            out[k] = Math.min(1, dims[k] / cap);
          }
          return out;
        },

        get radarAxes() {
          return [
            { key: "energy", label: "Năng lượng" },
            { key: "social", label: "Xã hội" },
            { key: "food", label: "Đồ ăn" },
            { key: "stress", label: "Cảm xúc" },
            { key: "independence", label: "Độc lập" },
            { key: "communication", label: "Giao tiếp" },
          ];
        },

        get radarDots() {
          const cx = 160, cy = 140, radius = 120;
          const scores = this.dimensionScores;
          return this.radarAxes.map((ax, i) => {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            const r = radius * (scores[ax.key] || 0);
            return { x: cx + Math.cos(ang) * r, y: cy + Math.sin(ang) * r };
          });
        },

        get radarPoints() {
          return this.radarDots.map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
        },

        get radarLabels() {
          const cx = 160, cy = 140, radius = 138;
          return this.radarAxes.map((ax, i) => {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            const x = cx + Math.cos(ang) * radius;
            let y = cy + Math.sin(ang) * radius;
            if (y < 16) y = 16;
            return { x, y, label: ax.label };
          });
        },

        hexagonPoints(radius, cx, cy) {
          const pts = [];
          for (let i = 0; i < 6; i++) {
            const ang = ((i * 60 - 90) * Math.PI) / 180;
            pts.push(`${cx + Math.cos(ang) * radius},${cy + Math.sin(ang) * radius}`);
          }
          return pts.join(" ");
        },

        // ============ Share / save ============
        // Web Share API (mobile có Zalo/FB/etc) → fallback copy clipboard.
        // Zalo KHÔNG có public URL share endpoint (zalo.me/share/url là 404).
        async shareZalo() {
          const data = this.result || this.existingResult;
          if (!data) return;
          const shareUrl = (data.share && data.share.url) || `https://vowvet.monminpet.com/personality/${this.pet.public_slug || this.pet.id}`;
          const meta = data.primary_meta || data.type_meta;
          const k = getKMeta(meta && meta.id).k;
          const shareTitle = `Tính cách của bé ${this.pet.name}`;
          const shareText = (data.share && data.share.text) ||
            `Bé ${this.pet.name} là ${meta && meta.name_vi} · Bộ nhân Pet Score ×${k.toFixed(2)}. Test thử ngay:`;

          // 1) Web Share API (iOS Safari + Android Chrome → menu hiện Zalo nếu cài app)
          if (navigator.share) {
            try {
              await navigator.share({ title: shareTitle, text: shareText, url: shareUrl });
              return;
            } catch (e) {
              // User huỷ — không sao
              if (e && e.name === "AbortError") return;
            }
          }

          // 2) Fallback — copy link vào clipboard + toast
          const fullText = `${shareText} ${shareUrl}`;
          try {
            await navigator.clipboard.writeText(fullText);
            this.moodToast = "✓ Đã copy link · Dán vào Zalo để chia sẻ";
            setTimeout(() => { this.moodToast = null; }, 2800);
          } catch (e) {
            // 3) Last resort — prompt
            window.prompt("Copy link này và dán vào Zalo:", fullText);
          }
        },

        async saveImage(elementId, opts = {}) {
          // v140 — accept opts.bgColor (cream cho Wow Card) + opts.filenameBase
          const captureBg = opts.bgColor || "#0a0a0a";
          const filenameBase = opts.filenameBase || "personality";
          if (this.savingImage) return;
          this.savingImage = true;
          this.moodToast = "Đang chuẩn bị ảnh...";
          const watchdog = setTimeout(() => {
            if (this.savingImage) {
              this.savingImage = false;
              this.moodToast = "Lưu ảnh timeout — thử lại sau";
              setTimeout(() => { this.moodToast = null; }, 3500);
            }
          }, 20000);

          // Helper: prefetch cross-origin image → data URI để bypass CORS taint
          const toDataURI = async (url) => {
            try {
              const res = await fetch(url, { mode: "cors", credentials: "omit" });
              if (!res.ok) throw new Error("fetch fail");
              const blob = await res.blob();
              return await new Promise((resolve, reject) => {
                const r = new FileReader();
                r.onload = () => resolve(r.result);
                r.onerror = reject;
                r.readAsDataURL(blob);
              });
            } catch (_) {
              return null;
            }
          };

          try {
            // 1) Load html2canvas
            if (!window.html2canvas) {
              await new Promise((resolve, reject) => {
                const s = document.createElement("script");
                s.src = "https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js";
                s.onload = resolve;
                s.onerror = () => reject(new Error("Không tải được thư viện ảnh"));
                document.body.appendChild(s);
                setTimeout(() => reject(new Error("Tải thư viện quá lâu")), 10000);
              });
            }
            const card = document.getElementById(elementId);
            if (!card) throw new Error("Không tìm thấy thẻ");

            // 2) PRE-CAPTURE — replace cross-origin <img> với data URI (R2 không có CORS header)
            const imgs = Array.from(card.querySelectorAll("img"));
            const originals = [];
            for (const img of imgs) {
              originals.push({ img, src: img.src, crossorigin: img.getAttribute("crossorigin") });
              if (!img.src || img.src.startsWith("data:")) continue;
              this.moodToast = "Đang tải ảnh pet...";
              const dataUri = await toDataURI(img.src);
              if (dataUri) {
                img.src = dataUri;
                img.removeAttribute("crossorigin");
              } else {
                // Photo CORS fail → ẩn ảnh trong capture để tránh canvas tainted
                img.style.visibility = "hidden";
              }
            }

            // 3) Force inline bg (capture-specific — dark cho result card, cream cho wow card)
            const oldBg = card.style.backgroundColor;
            card.style.backgroundColor = captureBg;

            this.moodToast = "Đang render ảnh...";
            const canvas = await window.html2canvas(card, {
              backgroundColor: captureBg,
              scale: 2,
              useCORS: true,
              allowTaint: false,
              logging: false,
              foreignObjectRendering: false,
              imageTimeout: 12000,
              onclone: (clonedDoc) => {
                const cloned = clonedDoc.getElementById(elementId);
                if (cloned) {
                  cloned.style.backgroundColor = captureBg;
                  // Đảm bảo text inline color không bị lost trong html2canvas
                  cloned.querySelectorAll('[style*="color:rgba"]').forEach((el) => {
                    el.style.color = el.style.color; // force inline
                  });
                }
              },
            });

            // 4) Restore
            for (const { img, src, crossorigin } of originals) {
              img.src = src;
              img.style.visibility = "";
              if (crossorigin) img.setAttribute("crossorigin", crossorigin);
            }
            card.style.backgroundColor = oldBg;

            if (!canvas || canvas.width === 0 || canvas.height === 0) {
              throw new Error("Canvas rỗng");
            }

            const dataUrl = canvas.toDataURL("image/png");
            if (!dataUrl || dataUrl.length < 1000) {
              throw new Error("Ảnh quá nhỏ — có thể do CORS hoặc element rỗng");
            }

            // 5) Download / iOS open-in-tab
            const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
            if (isIOS) {
              const win = window.open();
              if (win) {
                win.document.write(`<title>${this.pet.name} · Personality</title><body style="margin:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#0a0a0a;min-height:100vh;padding:16px"><img src="${dataUrl}" style="max-width:100%;height:auto;border-radius:16px"/><p style="color:#ecb921;font-family:sans-serif;font-size:13px;margin-top:14px;text-align:center">Nhấn giữ ảnh → <b>Save to Photos</b></p></body>`);
                win.document.close();
              } else {
                throw new Error("Cho phép pop-up để lưu ảnh");
              }
            } else {
              const link = document.createElement("a");
              link.download = `${filenameBase}-${this.pet.name || "pet"}.png`;
              link.href = dataUrl;
              document.body.appendChild(link);
              link.click();
              document.body.removeChild(link);
            }

            // Không hiện toast thành công — file đã tải xuống là đủ tín hiệu
            this.moodToast = null;
          } catch (err) {
            console.error("[saveImage] error:", err);
            this.moodToast = "Lỗi: " + ((err && err.message) || "không xác định");
            setTimeout(() => { this.moodToast = null; }, 4500);
          } finally {
            clearTimeout(watchdog);
            this.savingImage = false;
          }
        },
      };
    }
  </script>
</Layout>
