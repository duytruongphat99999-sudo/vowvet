---
/**
 * /pets/[id]/achievements — Huy hiệu (v104 brand-sync + WOW).
 *
 * Hero ring progress + Lucide tabs + brand tier colors + Lucide emoji map.
 */
import Layout from "../../../layouts/Layout.astro";
import FeatureIcon from "../../../components/FeatureIcon.astro";
import { fetchPet } from "../../../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let achievements: any[] = [];
let summary: any = { total: 0, unlocked_count: 0, by_category: {}, by_tier: {}, total_bonus_earned: 0 };
try {
  const r = await fetch(`${API_INTERNAL}/api/v1/achievements/pets/${petId}`, { headers: { cookie: cookieHeader } });
  if (r.ok) {
    const j = await r.json();
    achievements = j.achievements || [];
    summary = j.summary || summary;
  }
} catch (_) {}

const unlockedPct = summary.total > 0 ? Math.round((summary.unlocked_count / summary.total) * 100) : 0;

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name },
  achievements,
  summary,
  unlockedPct,
});
---

<Layout title={`Huy hiệu · ${pet.name}`} description={`Huy hiệu unlocked cho ${pet.name}`}>
  <main class="min-h-screen bg-mmp-cream px-4 sm:px-6 py-6 pb-16">
    <div class="max-w-3xl mx-auto" x-data={`achievementsPage(${initialData})`} x-init="loadSocialProof()">

      {/* v104: Brand-synced header */}
      <header class="flex items-center justify-between mb-5 gap-3">
        <a href={`/pets/${pet.id}`} class="text-sm italic text-[var(--c-ink-54)] hover:text-mmp-ink inline-flex items-center gap-1.5 transition">
          <FeatureIcon name="arrow" class="w-3.5 h-3.5 rotate-180" />
          <span>{pet.name}</span>
        </a>
        <h1 class="font-display italic text-lg sm:text-xl font-semibold text-mmp-ink inline-flex items-center gap-2">
          <FeatureIcon name="trophy" class="w-4 h-4" style="color: #B48608;" />
          <span>Huy hiệu</span>
        </h1>
        <a href={`/pets/${pet.id}/rewards`} class="inline-flex items-center gap-1 text-xs italic font-semibold px-2.5 py-1.5 rounded-lg transition" style="background: rgba(180,134,8,0.08); color: #B48608; border: 1px solid rgba(180,134,8,0.25);">
          <FeatureIcon name="gift" class="w-3 h-3" />
          <span class="hidden sm:inline">Thưởng</span>
        </a>
      </header>

      {/* v104: HERO TROPHY VAULT — ring + stats + Pet Score bonus */}
      <section class="relative rounded-3xl bg-mmp-ink text-white overflow-hidden mb-5 shadow-md">
        <div aria-hidden="true" class="absolute -top-16 -right-16 w-56 h-56 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(236,185,33,0.4) 0%, transparent 70%);"></div>
        <div aria-hidden="true" class="absolute -bottom-12 -left-12 w-40 h-40 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(180,134,8,0.25) 0%, transparent 70%);"></div>

        <div class="relative p-5 sm:p-6">
          <div class="flex items-center gap-4 mb-4">
            {/* Trophy progress ring */}
            <div class="relative shrink-0" style="width: 100px; height: 100px;">
              <svg viewBox="0 0 100 100" style="position: absolute; inset: 0; width: 100%; height: 100%; transform: rotate(-90deg);">
                <circle cx="50" cy="50" r="44" fill="none" stroke="rgba(236,185,33,0.18)" stroke-width="6"/>
                <circle cx="50" cy="50" r="44" fill="none" stroke="#ecb921" stroke-width="6" stroke-linecap="round"
                  stroke-dasharray={`${(unlockedPct / 100) * 276} 276`}
                  style="transition: stroke-dasharray 0.8s cubic-bezier(0.22, 0.61, 0.36, 1); filter: drop-shadow(0 0 6px rgba(236,185,33,0.5));"/>
              </svg>
              <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
                <p class="font-display italic font-bold tabular-nums leading-none" style="color: #ffffff; font-size: 28px;">
                  <span x-text="summary.unlocked_count"></span>
                </p>
                <p class="text-[10px] italic leading-none mt-0.5 text-white/65">
                  / <span x-text="summary.total"></span>
                </p>
                <p class="text-[9px] uppercase italic tracking-wider font-bold leading-none mt-1" style="color: #ecb921;">Huy hiệu</p>
              </div>
            </div>

            <div class="flex-1 min-w-0">
              <p class="text-[10px] uppercase italic tracking-[0.22em] font-bold" style="color: #ecb921;">Bộ sưu tập</p>
              <h2 class="font-display italic text-xl sm:text-2xl font-semibold mt-0.5 leading-tight">Bé {pet.name}</h2>
              <p class="text-xs italic text-white/70 mt-1.5">{unlockedPct}% hoàn thành bộ sưu tập</p>
              <p class="text-xs italic mt-1.5 inline-flex items-center gap-1.5">
                <FeatureIcon name="trophy" class="w-3 h-3" style="color: #ecb921;" />
                <span style="color: #ecb921;">+<span x-text="summary.total_bonus_earned"></span> điểm bonus Pet Score</span>
              </p>
            </div>
          </div>

          {/* Tier breakdown — count by tier (small pills) */}
          <div class="grid grid-cols-4 gap-2">
            <div class="rounded-xl py-2 text-center" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(180,134,8,0.32);">
              <div class="flex items-center justify-center mb-0.5">
                <span class="w-2.5 h-2.5 rounded-full" style="background: linear-gradient(135deg, #d4a615 0%, #B48608 100%);"></span>
              </div>
              <p class="text-[9px] uppercase italic tracking-wider text-white/55">Đồng</p>
              <p class="font-display italic font-bold text-base tabular-nums" style="color: #ecb921;" x-text="(summary.by_tier && summary.by_tier.bronze && summary.by_tier.bronze.unlocked) || 0"></p>
            </div>
            <div class="rounded-xl py-2 text-center" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.18);">
              <div class="flex items-center justify-center mb-0.5">
                <span class="w-2.5 h-2.5 rounded-full" style="background: linear-gradient(135deg, #cbd5e1 0%, #94a3b8 100%);"></span>
              </div>
              <p class="text-[9px] uppercase italic tracking-wider text-white/55">Bạc</p>
              <p class="font-display italic font-bold text-base tabular-nums text-white" x-text="(summary.by_tier && summary.by_tier.silver && summary.by_tier.silver.unlocked) || 0"></p>
            </div>
            <div class="rounded-xl py-2 text-center" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(236,185,33,0.4);">
              <div class="flex items-center justify-center mb-0.5">
                <span class="w-2.5 h-2.5 rounded-full" style="background: linear-gradient(135deg, #ecb921 0%, #d4a615 100%); box-shadow: 0 0 6px rgba(236,185,33,0.6);"></span>
              </div>
              <p class="text-[9px] uppercase italic tracking-wider text-white/55">Vàng</p>
              <p class="font-display italic font-bold text-base tabular-nums" style="color: #ecb921;" x-text="(summary.by_tier && summary.by_tier.gold && summary.by_tier.gold.unlocked) || 0"></p>
            </div>
            <div class="rounded-xl py-2 text-center" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.25);">
              <div class="flex items-center justify-center mb-0.5">
                <span class="w-2.5 h-2.5 rounded-full" style="background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%); box-shadow: 0 0 6px rgba(255,255,255,0.5);"></span>
              </div>
              <p class="text-[9px] uppercase italic tracking-wider text-white/55">Bạch kim</p>
              <p class="font-display italic font-bold text-base tabular-nums text-white" x-text="(summary.by_tier && summary.by_tier.platinum && summary.by_tier.platinum.unlocked) || 0"></p>
            </div>
          </div>
        </div>
      </section>

      {/* v104: Filter tabs — sticky, Lucide icons */}
      <div class="sticky top-0 z-10 -mx-4 px-4 sm:-mx-6 sm:px-6 py-2 mb-3 overflow-x-auto" style="background: rgba(245, 241, 235, 0.95); backdrop-filter: blur(8px);">
        <div class="flex gap-2 min-w-max">
          <template x-for="cat in categories" :key="cat.key">
            <button @click="filter = cat.key"
              :class="filter === cat.key ? 'ach-tab--active' : ''"
              class="ach-tab inline-flex items-center gap-1.5 text-xs italic font-bold px-3 py-1.5 rounded-full whitespace-nowrap transition">
              <span x-html="renderCatIcon(cat.key)"></span>
              <span x-text="cat.label"></span>
              <span class="opacity-70 tabular-nums">(<span x-text="categoryCounts[cat.key] || 0"></span>)</span>
            </button>
          </template>
        </div>
      </div>

      {/* v104: Grid — brand tier colors, Lucide via emoji map */}
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2 sm:gap-3">
        <template x-for="ach in filteredAchievements" :key="ach.code">
          <div :class="cardClasses(ach)"
            class="ach-card aspect-square rounded-2xl p-2 sm:p-3 flex flex-col items-center justify-center text-center border-2 transition relative overflow-hidden">
            <template x-if="!ach.viewed && ach.unlocked">
              <span class="absolute top-1 right-1 w-2.5 h-2.5 rounded-full animate-pulse-gold z-10" style="background: #ecb921; box-shadow: 0 0 6px rgba(236,185,33,0.8);"></span>
            </template>
            <span class="ach-icon inline-flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 z-10"
              :class="ach.unlocked ? '' : 'grayscale opacity-40'"
              x-html="renderIcon(ach.emoji, '24px')"></span>
            <p class="text-[10px] sm:text-xs italic font-bold leading-tight mt-1.5 z-10"
              :class="ach.unlocked ? '' : 'opacity-50'"
              x-text="ach.name"></p>
            <p class="text-[9px] mt-0.5 opacity-70 italic tabular-nums z-10"
              x-text="ach.unlocked ? fmtDate(ach.unlocked_at) : `+${ach.pet_score_bonus}đ`"></p>
            {/* Social proof for locked non-secret */}
            <template x-if="!ach.unlocked && !ach.is_secret && socialProof[ach.code] && socialProof[ach.code].recent_count_7d > 0">
              <p class="text-[8px] mt-0.5 italic font-bold z-10" style="color: #B48608;" x-text="`${socialProof[ach.code].recent_count_7d} bé unlock tuần qua`"></p>
            </template>
          </div>
        </template>
      </div>

      <template x-if="filteredAchievements.length === 0">
        <div class="bg-white rounded-2xl border-2 border-dashed p-8 text-center" style="border-color: rgba(180,134,8,0.3);">
          <span class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-3" style="background: rgba(180,134,8,0.08); color: #B48608;">
            <FeatureIcon name="trophy" class="w-6 h-6" strokeWidth={1.5} />
          </span>
          <p class="text-sm italic text-[var(--c-ink-54)]">Chưa có huy hiệu trong category này</p>
        </div>
      </template>

      {/* v104: Tier legend — brand gold spectrum */}
      <div class="mt-6 bg-white rounded-2xl p-4" style="border: 1px solid rgba(180, 134, 8, 0.22);">
        <p class="text-[10px] uppercase italic tracking-[0.22em] font-bold mb-3 inline-flex items-center gap-1.5" style="color: #B48608;">
          <FeatureIcon name="sparkles" class="w-3.5 h-3.5" />
          <span>Cấp bậc huy hiệu</span>
        </p>
        <div class="grid grid-cols-2 gap-2.5">
          <div class="flex items-center gap-2 text-xs italic text-mmp-ink">
            <span class="w-5 h-5 rounded-full shadow-inner" style="background: linear-gradient(135deg, #d4a615 0%, #B48608 100%);"></span>
            <span><strong>Đồng</strong> · bắt đầu</span>
          </div>
          <div class="flex items-center gap-2 text-xs italic text-mmp-ink">
            <span class="w-5 h-5 rounded-full shadow-inner" style="background: linear-gradient(135deg, #cbd5e1 0%, #94a3b8 100%);"></span>
            <span><strong>Bạc</strong> · ổn định</span>
          </div>
          <div class="flex items-center gap-2 text-xs italic text-mmp-ink">
            <span class="w-5 h-5 rounded-full" style="background: linear-gradient(135deg, #ecb921 0%, #d4a615 100%); box-shadow: 0 0 8px rgba(236,185,33,0.5);"></span>
            <span><strong>Vàng</strong> · xuất sắc</span>
          </div>
          <div class="flex items-center gap-2 text-xs italic text-mmp-ink">
            <span class="w-5 h-5 rounded-full" style="background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 60%, #B48608 100%); box-shadow: 0 0 10px rgba(255,255,255,0.4);"></span>
            <span><strong>Bạch kim</strong> · huyền thoại</span>
          </div>
        </div>
      </div>

      {/* Pet Score footer link */}
      <a href={`/pets/${pet.id}/pet-score`} class="mt-4 block rounded-xl text-center p-3 transition hover:opacity-95" style="background: rgba(180,134,8,0.08); border: 1px solid rgba(180,134,8,0.28);">
        <p class="text-xs italic inline-flex items-center gap-2" style="color: var(--c-ink-72);">
          <FeatureIcon name="trophy" class="w-3.5 h-3.5" style="color: #B48608;" />
          <span>Mỗi huy hiệu cộng <strong style="color: #B48608;">+điểm Pet Score</strong> · đổi voucher</span>
          <FeatureIcon name="arrow" class="w-3 h-3" style="color: #B48608;" />
        </p>
      </a>

    </div>
  </main>

  <script is:inline>
    // v104: Reward emoji → Lucide SVG map (shared with rewards page)
    const ACH_LUCIDE_ICONS = {
      "🏆": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z"/><path d="M7 4H5a2 2 0 0 0-2 2v1a3 3 0 0 0 3 3M17 4h2a2 2 0 0 1 2 2v1a3 3 0 0 1-3 3"/></svg>',
