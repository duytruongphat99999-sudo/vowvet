---
/**
 * /pets/[id]/pet-score — Mon Min Pet Score (M12).
 *
 * Layout: ink-dark hero passport (gauge + identity rows) → recommendations → breakdown → trend → community → Hụi Pet → tier levels.
 */
import Layout from "../../../layouts/Layout.astro";
import { fetchPet } from "../../../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let scoreData: any = null;
let levels: any[] = [];
try {
  const [sRes, lRes] = await Promise.all([
    fetch(`${API_INTERNAL}/api/v1/pets/${petId}/pet-score`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/pets/score-levels`, { headers: { cookie: cookieHeader } }),
  ]);
  if (sRes.ok) scoreData = await sRes.json();
  if (lRes.ok) levels = (await lRes.json()).levels || [];
} catch (_) {}

if (!scoreData) {
  return new Response("Score not available", { status: 500 });
}

const TIER_HEX: Record<string, string> = {
  bronze:   "#A0826D",
  silver:   "#9CA3AF",
  gold:     "#ECB921",
  platinum: "#3B82F6",
  diamond:  "#7C3AED",
};
const tierHex = TIER_HEX[scoreData.level.id] || "#ECB921";

// Gauge geometry — SMIL stroke-dashoffset, server-computed from score
const GAUGE_R = 125;
const GAUGE_C2 = Math.round(2 * Math.PI * GAUGE_R * 100) / 100; // ~785.4
const gaugeOffset = Math.round(GAUGE_C2 * (1 - scoreData.score / 1000) * 100) / 100;
const issuedDate = (() => {
  try {
    const d = new Date(scoreData.computed_at);
    const p = (n: number) => String(n).padStart(2, "0");
    return `${p(d.getDate())}.${p(d.getMonth() + 1)}.${d.getFullYear()}`;
  } catch {
    return "";
  }
})();

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name, dob: pet.dob ?? null },
  score: scoreData,
  levels,
  tierHex,
});

// ── Phase 5: Constellation Star Map — SSR-rendered (avoids Alpine-x-for-in-SVG pitfall) ──
const STAR_POSITIONS: Record<string, { x: number; y: number }> = {
  no_chronic_conditions: { x: 60, y: 50 },
  bcs_optimal: { x: 100, y: 75 },
  age_modifier: { x: 75, y: 100 },
  recent_emergency: { x: 45, y: 130 },
  pain_status: { x: 105, y: 130 },
  allergies: { x: 70, y: 160 },
  vaccine_compliance: { x: 240, y: 55 },
  vet_visit_recent: { x: 270, y: 95 },
  water_intake: { x: 220, y: 130 },
  checkin_streak: { x: 240, y: 200 },
  routine_consistency: { x: 270, y: 235 },
  mobility: { x: 215, y: 250 },
  cognitive_status: { x: 255, y: 275 },
  personality_modifier: { x: 70, y: 220 },
  pet_hero_bonus: { x: 100, y: 260 },
};
function psStarBucket(value: number, max: number): "sm" | "md" | "lg" {
  if (!max || max === 0) return "sm";
  const ratio = Math.abs(value) / max;
  if (ratio < 0.33) return "sm";
  if (ratio < 0.66) return "md";
  return "lg";
}
function psStarStateClass(v: number, m: number): string {
  if (v < 0) return "star-penalty";
  if (v === 0) return "star-neutral";
  if (m > 0 && v / m > 0.5) return "star-bright";
  return "star-faint";
}
const stars = (scoreData.breakdown?.components || []).map((c: any) => {
  const pos = STAR_POSITIONS[c.key] || { x: 160, y: 160 };
  const bucket = psStarBucket(c.current_value, c.max_possible);
  const r = bucket === "sm" ? 4 : bucket === "md" ? 7 : 10;
  return {
    key: c.key,
    enterExpr: `hoveredComponent = score.breakdown.components.find(s => s.key === '${c.key}')`,
    x: pos.x,
    y: pos.y,
    r,
    bucket,
    stateClass: psStarStateClass(c.current_value, c.max_possible),
    label_vi: c.label_vi,
    current_value: c.current_value,
    max_possible: c.max_possible,
    description: c.description || "",
    tipX: Math.max(4, Math.min(320 - 184, pos.x - 90)),
    tipY: Math.max(4, pos.y - 70),
  };
});
---

<Layout title={`Pet Score ${pet.name} · VowVet`} description={`Mon Min Pet Score ${scoreData.score}/1000 - ${scoreData.level.name_vi}`}>
  <style is:inline>{`
    @keyframes scoreCount {
      from { opacity: 0; transform: scale(0.8); }
      to   { opacity: 1; transform: scale(1); }
    }
    .gauge-arc {
      transition: stroke-dasharray 1.5s cubic-bezier(0.25, 0.1, 0.25, 1);
    }
    .score-number {
      animation: scoreCount 0.8s ease-out forwards;
    }
    .bar-fill {
      transition: width 1.2s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    @keyframes pulse-glow {
      0%, 100% { filter: drop-shadow(0 0 0 currentColor); }
      50%      { filter: drop-shadow(0 0 16px currentColor); }
    }
    .pulse-glow-animation { animation: pulse-glow 2s ease-in-out infinite; }

    @keyframes diamond-shimmer {
      0%, 100% { background-position: 0% 50%; }
      50%      { background-position: 100% 50%; }
    }
    .diamond-text {
      background: linear-gradient(45deg, #B48608, #ecb921, #f4c842, #B48608);
      background-size: 300% 300%;
      animation: diamond-shimmer 3s ease infinite;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    @keyframes confetti-fall {
      0%   { opacity: 1; transform: translate(0, 0) rotate(0deg); }
      100% { opacity: 0; transform: translate(var(--dx), 100vh) rotate(720deg); }
    }
    .confetti {
      position: fixed; top: -10px; left: 50%;
      width: 10px; height: 18px; border-radius: 2px;
      pointer-events: none; z-index: 60;
      animation: confetti-fall 3s ease-in forwards;
    }

    /* ── Constellation v3.1: palette + keyframes + classes (Phase 1) ── */
    :root {
      --ps-gold-deep: #B48608;
      --ps-gold: #ecb921;
      --ps-gold-light: #f4c842;
      --ps-cream: #FAF6EC;
      --ps-cream-soft: #FFFEF9;
      --ps-ink: #0a0a0a;
      --ps-ink-soft: #1a1a1a;
      --ps-slate: #475569;
      --ps-slate-2: #64748b;
      --ps-slate-dim: #94a3b8;
    }

    /* Bar palette — replaces emerald/red/amber (gold / ink / slate) */
    .ps-fill-pos { background: linear-gradient(90deg, var(--ps-gold-deep), var(--ps-gold)); }
    .ps-fill-neg { background: var(--ps-ink); }
    .ps-fill-neu { background: #cbd5e1; }
    .ps-wrap-pos { background: rgba(236,185,33,0.06); }
    .ps-wrap-neg { background: #FAFAF7; }
    .ps-wrap-neu { background: #FAFAF7; }

    @keyframes ringRotate { to { transform: rotate(360deg); } }
    .gauge-outer { transform-origin: 50% 50%; animation: ringRotate 80s linear infinite; }

    @keyframes dotPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(236,185,33,0.55); }
      50%      { box-shadow: 0 0 0 10px rgba(236,185,33,0); }
    }
    .cur-dot { animation: dotPulse 2s ease-in-out infinite; }

    @keyframes starTwinkle {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.55; }
    }
    .star-bright { animation: starTwinkle 2.5s ease-in-out infinite; }

    @keyframes starTwinkleSm {
      0%, 100% { opacity: 0.55; }
      50%      { opacity: 0.2; }
    }
    .star-faint { animation: starTwinkleSm 3.5s ease-in-out infinite; }

    @keyframes shimmerSweep {
      0%   { transform: translateX(-120%); }
      100% { transform: translateX(220%); }
    }
    .shimmer-bar { position: relative; overflow: hidden; }
    .shimmer-bar::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
      transform: translateX(-120%);
      animation: shimmerSweep 4s ease-in-out infinite;
    }

    @keyframes badgeFloat {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-4px); }
    }
    .badge-float { animation: badgeFloat 3s ease-in-out infinite; }

    @keyframes textGlow {
      0%, 100% { text-shadow: 0 0 8px rgba(236,185,33,0.25); }
      50%      { text-shadow: 0 0 22px rgba(236,185,33,0.55); }
    }
    .text-glow { animation: textGlow 3s ease-in-out infinite; }

    @media (prefers-reduced-motion: reduce) {
      .gauge-outer { animation-duration: 240s; }
      .cur-dot, .star-bright, .star-faint, .badge-float, .text-glow { animation: none !important; }
      .shimmer-bar::after { animation: none !important; display: none; }
    }

    [x-cloak] { display: none !important; }
  `}
    /* Phase 2 patch: scope monogram + flourish hide for Pet Certificate XL */
    .ps-cert-hero .hero-vv-monogram { display: none !important; }
    div.ps-cert-hero h2.font-display::after, .hero-passport.ps-cert-hero h2.font-display::after { display: none !important; content: none !important; }

    /* ── Phase 3: Achievement Strip (horizontal scroll, gold-themed) ── */
    .ach-scroll { overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; -ms-overflow-style: none; }
    .ach-scroll::-webkit-scrollbar { display: none; }
    .ach-scroll-wrapper { position: relative; }
    .ach-scroll-wrapper::after { content: ""; position: absolute; top: 0; right: -4px; bottom: 8px; width: 32px; background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.95) 100%); pointer-events: none; border-radius: 0 12px 12px 0; }
    .ach-strip-inner { display: flex; gap: 12px; padding: 4px 4px 4px; min-width: min-content; justify-content: safe center; }
    .ach-badge {
      flex: 0 0 110px; width: 110px; scroll-snap-align: start;
      border-radius: 16px; border: 1px solid rgba(180,134,8,0.18);
      background: linear-gradient(160deg, #FAF6EC 0%, #ffffff 100%);
      transition: transform .22s cubic-bezier(.22,.61,.36,1), box-shadow .22s ease, border-color .22s ease;
      animation: ach-fade-in .5s cubic-bezier(.22,.61,.36,1) backwards;
    }
    .ach-badge:hover { transform: translateY(-3px); border-color: #B48608; box-shadow: 0 10px 24px -8px rgba(180,134,8,0.45); }
    .ach-badge__inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 7px; padding: 12px 8px; }
    .ach-badge__icon {
      width: 44px; height: 44px; padding: 9px; border-radius: 9999px; color: #0a0a0a;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 2px 6px -2px rgba(180,134,8,0.5);
      transition: transform .22s cubic-bezier(.22,.61,.36,1);
      animation: ach-icon-breath 3s ease-in-out infinite;
    }
    .ach-badge:hover .ach-badge__icon { transform: scale(1.08) rotate(-3deg); animation-play-state: paused; }
    .ach-badge__label { font-family: var(--font-sans, 'Inter', system-ui, sans-serif); font-style: italic; font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: #0a0a0a; line-height: 1.2; }
    .ach-badge__subtitle { font-size: 10px; font-style: italic; color: rgba(10,10,10,0.55); line-height: 1.2; }
    @keyframes ach-fade-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes ach-icon-breath {
      0%, 100% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 2px 6px -2px rgba(180,134,8,0.5), 0 0 0 0 rgba(236,185,33,0); }
      50% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 4px 12px -2px rgba(180,134,8,0.6), 0 0 0 6px rgba(236,185,33,0.12); }
    }
    @media (prefers-reduced-motion: reduce) {
      .ach-badge, .ach-badge__icon { animation: none !important; transition: none !important; }
      .ach-badge:hover, .ach-badge:hover .ach-badge__icon { transform: none; }
    }

    /* ── Phase 4: Recommendations (top 3 việc cần làm) ── */
    .rec-card {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 14px 14px 14px 16px;
      background: linear-gradient(160deg, #ffffff 0%, #FAF6EC 100%);
      border: 1px solid rgba(180,134,8,0.15); border-left: 3px solid #B48608;
      border-radius: 0 12px 12px 0; text-decoration: none;
      transition: transform .22s cubic-bezier(.22,.61,.36,1), box-shadow .22s ease, border-color .22s ease;
      animation: rec-fade-in .4s cubic-bezier(.22,.61,.36,1) backwards;
    }
    .rec-card:hover { transform: translateX(2px); border-color: #B48608; box-shadow: 0 8px 22px -8px rgba(180,134,8,0.4); }
    .rec-card__icon {
      flex-shrink: 0; width: 40px; height: 40px; border-radius: 9999px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; color: #0a0a0a;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 2px 6px -2px rgba(180,134,8,0.5);
    }
    .rec-card__content { flex: 1; min-width: 0; }
    .rec-card__title { font-weight: 700; font-size: 14px; color: #0a0a0a; margin-bottom: 2px; }
    .rec-card__advice { font-size: 12px; color: rgba(10,10,10,0.65); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .rec-card__points { margin-top: 6px; display: flex; align-items: center; gap: 6px; }
    .rec-card__points > span:first-child { background: linear-gradient(135deg, #ecb921 0%, #B48608 100%); color: #0a0a0a; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 2px 8px; border-radius: 9999px; }
    .rec-card__points > span:last-child { font-size: 10px; font-style: italic; color: rgba(10,10,10,0.45); }
    .rec-card__chevron { flex-shrink: 0; align-self: center; width: 16px; height: 16px; color: rgba(10,10,10,0.4); transition: transform .22s cubic-bezier(.22,.61,.36,1), color .22s ease; }
    .rec-card:hover .rec-card__chevron { transform: translateX(3px); color: #ecb921; }
    .rec-counter-pill {
      position: relative; display: inline-block; padding: 4px 12px;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 100%);
      color: #0a0a0a; font-family: var(--font-mono, ui-monospace);
      font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em;
      border-radius: 9999px;
      box-shadow: 0 4px 12px -2px rgba(236,185,33,0.5), inset 0 1px 0 rgba(255,255,255,0.35);
      overflow: hidden; white-space: nowrap;
    }
    .rec-counter-pill::after {
      content: ""; position: absolute; top: 0; left: 0; bottom: 0; width: 60%;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.55) 50%, transparent 100%);
      transform: translateX(-100%);
      animation: rec-counter-shimmer 3.5s ease-in-out infinite;
    }
    @keyframes rec-counter-shimmer { 0%, 100% { transform: translateX(-100%); } 60% { transform: translateX(220%); } }
    @media (prefers-reduced-motion: reduce) { .rec-counter-pill::after { animation: none; display: none; } }
    @keyframes rec-priority-pulse {
      0%, 100% { border-left-width: 3px; box-shadow: 0 0 0 0 rgba(180,134,8,0); }
      50% { border-left-width: 4px; box-shadow: -2px 0 12px -4px rgba(180,134,8,0.4); }
    }
    .rec-list .rec-card:first-child { animation: rec-priority-pulse 2.4s ease-in-out infinite, rec-fade-in .4s cubic-bezier(.22,.61,.36,1) backwards; }
    .rec-list .rec-card:first-child:hover { animation: rec-fade-in .4s cubic-bezier(.22,.61,.36,1) backwards; }
    @keyframes rec-fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) {
      .rec-card, .rec-card__chevron { animation: none !important; transition: none !important; }
      .rec-card:hover, .rec-card:hover .rec-card__chevron { transform: none; }
    }

    /* ── Phase 4.5: gold thread (Hero ↔ Strip ↔ Recommendations visual connection) ── */
    .achievement-strip, .recommendations-strip { position: relative; overflow: hidden; }
    .achievement-strip::before, .recommendations-strip::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent 0%, #ecb921 30%, #B48608 50%, #ecb921 70%, transparent 100%);
      background-size: 200% 100%;
      animation: gold-thread 4s linear infinite;
      opacity: 0.6;
    }
    @keyframes gold-thread { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    @media (prefers-reduced-motion: reduce) {
      .achievement-strip::before, .recommendations-strip::before { animation: none; }
      .ach-badge__icon { animation: none; }
      .rec-list .rec-card:first-child { animation: rec-fade-in .4s cubic-bezier(.22,.61,.36,1) backwards; }
    }

    /* ── Phase 4.5.1: Pet Score h1 header accent ── */
    .ps-header-title {
      position: relative;
      font-family: var(--font-display, 'Fraunces', Georgia, serif);
      font-style: italic; font-weight: 600; font-size: 18px;
      letter-spacing: -0.01em; color: #0a0a0a; padding-bottom: 4px;
    }
    .ps-header-title::after {
      content: ""; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%);
      width: 28px; height: 1.5px;
      background: linear-gradient(90deg, transparent 0%, #B48608 50%, transparent 100%);
      border-radius: 1px;
    }

    /* ── Phase 5.1: Galaxy Constellation (palette strict gold) ── */
    .constellation-section {
      background: radial-gradient(ellipse at center, #1a1a1a 0%, #0a0a0a 70%, #050505 100%);
      border: 1px solid rgba(236,185,33,0.25);
      border-radius: 16px; padding: 20px; margin-bottom: 16px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.3); position: relative; overflow: hidden;
    }
    .constellation-svg-wrapper { width: 100%; max-width: 420px; margin: 0 auto; aspect-ratio: 1; position: relative; }
    @media (max-width: 640px) { .constellation-svg-wrapper { max-width: 320px; } }
    .star-dust circle { fill: rgba(255,255,255,0.7); animation: dust-twinkle 5s ease-in-out infinite; }
    .star-dust .dust-1  { animation-delay: 0s;   animation-duration: 4s; }
    .star-dust .dust-2  { animation-delay: 0.4s; animation-duration: 5.5s; }
    .star-dust .dust-3  { animation-delay: 0.8s; animation-duration: 4.5s; }
    .star-dust .dust-4  { animation-delay: 1.2s; animation-duration: 6s; }
    .star-dust .dust-5  { animation-delay: 1.6s; animation-duration: 5s; }
    .star-dust .dust-6  { animation-delay: 2s;   animation-duration: 7s; }
    .star-dust .dust-7  { animation-delay: 2.4s; animation-duration: 4s; }
    .star-dust .dust-8  { animation-delay: 2.8s; animation-duration: 5.5s; }
    .star-dust .dust-9  { animation-delay: 0.2s; animation-duration: 6.5s; }
    .star-dust .dust-10 { animation-delay: 0.6s; animation-duration: 4.5s; }
    .star-dust .dust-11 { animation-delay: 1s;   animation-duration: 5s; }
    .star-dust .dust-12 { animation-delay: 1.4s; animation-duration: 6s; }
    .star-dust .dust-13 { animation-delay: 1.8s; animation-duration: 4s; }
    .star-dust .dust-14 { animation-delay: 2.2s; animation-duration: 7s; }
    .star-dust .dust-15 { animation-delay: 2.6s; animation-duration: 5.5s; }
    .star-dust .dust-16 { animation-delay: 3s;   animation-duration: 4.5s; }
    .star-dust .dust-17 { animation-delay: 3.4s; animation-duration: 6s; }
    .star-dust .dust-18 { animation-delay: 3.8s; animation-duration: 5s; }
    .star-dust .dust-19 { animation-delay: 0.3s; animation-duration: 4.5s; }
    .star-dust .dust-20 { animation-delay: 0.7s; animation-duration: 6.5s; }
    @keyframes dust-twinkle { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.85; } }
    .const-rings { transform-box: fill-box; transform-origin: center; animation: ringRotate 80s linear infinite; }
    .star-wrapper { cursor: pointer; }
    .star-dot { transform-box: fill-box; transform-origin: center; transition: transform 0.3s ease, filter 0.3s ease; }
    .star-bright .star-dot { fill: #ecb921; filter: drop-shadow(0 0 6px rgba(236,185,33,0.75)); animation: star-twinkle 2.5s ease-in-out infinite; }
    .star-faint .star-dot { fill: rgba(236,185,33,0.4); }
    .star-penalty .star-dot { fill: rgba(255,255,255,0.25); stroke: #B48608; stroke-width: 1; }
    .star-neutral .star-dot { fill: rgba(255,255,255,0.2); }
    .star-wrapper:hover .star-dot { transform: scale(1.4); filter: drop-shadow(0 0 12px rgba(236,185,33,0.95)); }
    @keyframes star-twinkle { 0%, 100% { opacity: 1; } 50% { opacity: 0.55; } }
    .star-tooltip { opacity: 0; pointer-events: none; transition: opacity 0.2s ease; overflow: visible; }
    .star-wrapper:hover .star-tooltip { opacity: 1; pointer-events: auto; }
    .star-tooltip-inner { background: rgba(10,10,10,0.95); border: 1px solid rgba(236,185,33,0.4); border-radius: 8px; padding: 8px 10px; color: white; font-size: 11px; line-height: 1.3; text-align: left; box-shadow: 0 4px 14px rgba(0,0,0,0.5); }
    .star-tooltip-inner strong { display: block; color: #ecb921; font-size: 11px; margin-bottom: 2px; }
    .star-tooltip-inner span { display: block; font-family: var(--font-mono); font-size: 10px; color: rgba(255,255,255,0.7); }
    .star-tooltip-inner p { font-size: 10px; color: rgba(255,255,255,0.55); margin-top: 4px; font-style: italic; }
    .ticker-panel { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 2px; padding: 4px; }
    .ticker-panel.ticker-auto { animation: ticker-fade-in 0.6s ease-out; }
    .ticker-panel.ticker-hovered { animation: ticker-pop 0.2s ease-out; }
