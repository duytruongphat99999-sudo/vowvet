            <div class="bg-white rounded-xl border p-3 flex items-center gap-3 transition hover:shadow-sm" style="border-color: rgba(180,134,8,0.2);">
              <span class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-lg" style="background: rgba(180,134,8,0.1); color: #B48608;" x-html="renderIcon(r.icon)"></span>
              <div class="flex-1 min-w-0">
                <p class="font-display italic font-semibold text-sm text-mmp-ink truncate" x-text="r.name"></p>
                <p class="text-[11px] italic text-[var(--c-ink-54)] inline-flex items-center gap-1.5 mt-0.5">
                  <span x-text="scheduleLabel(r.schedule_type)"></span>
                  <span class="opacity-50">·</span>
                  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span x-text="r.start_time"></span>
