---
/**
 * /admin/zalo-status — Zalo ZNS integration status + test sender.
 *
 * Admin-only (whitelist by phone via ADMIN_PHONES env). Page itself doesn't
 * enforce — relies on backend `/admin/*` returning 403 if not admin.
 */
import Layout from "../../layouts/Layout.astro";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let status: any = null;
let unauthorized = false;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/admin/zalo-status`, {
    headers: { cookie: cookieHeader },
  });
  if (res.status === 403) {
    unauthorized = true;
  } else if (res.ok) {
    status = await res.json();
  }
} catch (_) {}

const initialData = JSON.stringify({ status });
---

<Layout title="Zalo ZNS Status · VowVet Admin" description="Trạng thái tích hợp Zalo OTP">
  <main class="min-h-screen bg-gradient-to-b from-slate-50 to-slate-800 px-4 py-6 pb-16">
    <div class="max-w-3xl mx-auto" x-data={`zaloStatusPage(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href="/admin" class="text-sm text-slate-500 hover:text-slate-700">← Admin</a>
        <h1 class="text-lg font-bold text-slate-900">📲 Zalo ZNS Status</h1>
        <button @click="reload()" class="text-xs bg-slate-100 hover:bg-slate-200 px-3 py-1.5 rounded-lg">🔄 Reload</button>
      </header>

      {unauthorized && (
        <div class="bg-red-50 border-2 border-red-300 rounded-2xl p-6 text-center">
          <p class="text-4xl mb-2">🚫</p>
          <p class="font-bold text-red-900">Không có quyền admin</p>
          <p class="text-xs text-red-700 mt-1">Trang này chỉ truy cập được bởi SĐT trong whitelist ADMIN_PHONES env.</p>
        </div>
      )}

      <template x-if="!status">
        <div x-show="!unauthorized" class="bg-amber-50 border border-amber-200 rounded-2xl p-4 text-sm text-amber-800">
          Không load được status. Kiểm tra container vowvet-api có alive không.
        </div>
      </template>

      <template x-if="status">
        <div class="space-y-4">

          <!-- Mode card -->
          <section class="bg-white rounded-2xl border-2 p-5 shadow-sm"
            :class="status.status.ready_for_real
              ? 'border-emerald-300'
              : status.status.mode === 'zns_real' ? 'border-amber-200' : 'border-slate-200'">
            <div class="flex items-center justify-between gap-3 mb-3">
              <h2 class="text-base font-bold text-slate-900">Chế độ hiện tại</h2>
              <span class="text-xs font-mono uppercase px-3 py-1 rounded-full"
                :class="status.status.ready_for_real
                  ? 'bg-emerald-100 text-emerald-800'
                  : status.status.mode === 'zns_real' ? 'bg-orange-100 text-amber-700' : 'bg-slate-100 text-slate-700'"
                x-text="status.status.mode"></span>
            </div>
            <p class="text-sm text-slate-700 mb-3" x-text="status.status.mode_label"></p>

            <dl class="text-sm space-y-1.5">
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500">OA ID:</dt>
                <dd class="font-mono text-xs text-slate-800" x-text="status.status.oa_id || '(chưa cấu hình)'"></dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500">Access token:</dt>
                <dd>
                  <span x-show="status.status.has_access_token" class="text-emerald-600">✓ đã có</span>
                  <span x-show="!status.status.has_access_token" class="text-red-600">✗ chưa có</span>
                </dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500">Template ID:</dt>
                <dd>
                  <span x-show="status.status.has_template_id" class="text-emerald-600">✓ đã có</span>
                  <span x-show="!status.status.has_template_id" class="text-red-600">✗ chưa có</span>
                </dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-500">App ID:</dt>
                <dd>
                  <span x-show="status.status.has_app_id" class="text-emerald-600">✓ đã có</span>
                  <span x-show="!status.status.has_app_id" class="text-slate-400">— (optional)</span>
                </dd>
              </div>
            </dl>
          </section>

          <!-- Usage today -->
          <section class="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
            <h2 class="text-base font-bold text-slate-900 mb-3">📊 Usage hôm nay (<span x-text="status.usage_today.date"></span>)</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              <div class="bg-mmp-cream rounded-xl p-3 text-center">
                <p class="text-2xl font-extrabold text-mmp-ink" x-text="status.usage_today.otps_sent_zalo"></p>
                <p class="text-[10px] text-mmp-ink uppercase">OTP gửi qua Zalo</p>
              </div>
              <div class="bg-slate-50 rounded-xl p-3 text-center">
                <p class="text-2xl font-extrabold text-slate-900" x-text="status.usage_today.total_notifications"></p>
                <p class="text-[10px] text-slate-600 uppercase">Tổng notification</p>
              </div>
              <div class="bg-amber-50 rounded-xl p-3 text-center col-span-2 sm:col-span-1">
                <p class="text-2xl font-extrabold text-amber-900" x-text="status.usage_today.estimated_cost_formatted"></p>
                <p class="text-[10px] text-amber-700 uppercase">Chi phí ước tính</p>
              </div>
            </div>
            <p class="text-[11px] text-slate-400 mt-3 italic">
              Phí: <span x-text="status.pricing.per_otp_vnd"></span>đ/OTP. <span x-text="status.pricing.note"></span>
            </p>
          </section>

          <!-- Test sender -->
          <section class="bg-white rounded-2xl border border-mmp-cream p-5 shadow-sm">
            <h2 class="text-base font-bold text-slate-900 mb-2">🧪 Gửi OTP thử</h2>
            <p class="text-xs text-slate-500 mb-3">Test pipeline hiện tại — nếu mode=mock thì code chỉ hiện trong response/log; nếu zns_real thì SĐT đích sẽ nhận thật.</p>
            <div class="flex gap-2">
              <input type="tel" x-model="testPhone" placeholder="0901234567"
                class="flex-1 border border-slate-200 rounded-lg px-3 py-2 text-sm font-mono" />
              <button @click="sendTest()" :disabled="testing || !testPhone"
                class="bg-mmp-ink hover:bg-slate-800 disabled:opacity-50 text-white text-sm font-bold px-4 py-2 rounded-lg">
                <span x-show="!testing">Gửi test</span>
                <span x-show="testing">Đang gửi…</span>
              </button>
            </div>
            <template x-if="testResult">
              <div class="mt-3 bg-slate-50 rounded-xl p-3">
                <p class="text-xs font-semibold mb-1" :class="testResult.result?.via === 'zns' ? 'text-emerald-700' : 'text-amber-700'">
                  ✓ Test gửi xong
                </p>
                <p class="text-[11px] text-slate-600" x-text="testResult.hint"></p>
                <p class="text-xs font-mono mt-1.5 text-slate-800">
                  Code: <strong x-text="testResult.code_sent"></strong> · Mode: <strong x-text="testResult.result.mode"></strong> · Via: <strong x-text="testResult.result.via"></strong>
                </p>
                <template x-if="testResult.result?.error">
                  <p class="text-[11px] text-red-600 mt-1.5">⚠️ <span x-text="testResult.result.error"></span></p>
                </template>
              </div>
            </template>
            <template x-if="testError">
              <p class="mt-3 bg-red-50 border border-red-200 rounded-xl p-3 text-xs text-red-700" x-text="testError"></p>
            </template>
          </section>

          <!-- How to flip to real -->
          <section class="bg-mmp-cream border border-mmp-cream rounded-2xl p-5">
            <h2 class="text-base font-bold text-mmp-ink mb-2">🚀 Bật real ZNS</h2>
            <ol class="text-xs text-slate-700 space-y-1.5 list-decimal pl-4">
              <li>Verify OA tại <a class="underline" target="_blank" href="https://oa.zalo.me">oa.zalo.me</a> (OA ID đã có: <span class="font-mono" x-text="status.status.oa_id"></span>)</li>
              <li>Tạo app + template ZNS tại <a class="underline" target="_blank" href="https://developers.zalo.me/">developers.zalo.me</a></li>
              <li>Nạp credit Zalo (~300đ/OTP)</li>
              <li>Set 4 env vars: <code class="text-[10px]">ZALO_ZNS_APP_ID</code>, <code class="text-[10px]">ZALO_ZNS_SECRET_KEY</code>, <code class="text-[10px]">ZALO_ZNS_ACCESS_TOKEN</code>, <code class="text-[10px]">ZALO_ZNS_TEMPLATE_ID</code></li>
              <li>Flip <code class="text-[10px]">ZALO_MODE=zns_real</code></li>
              <li>Restart vowvet-api → reload trang này → mode chuyển sang green "Real ZNS active"</li>
            </ol>
            <p class="text-[11px] text-mmp-ink mt-3 italic">
              Hướng dẫn chi tiết: <strong>ZALO_ZNS_SETUP.md</strong> trong project root
            </p>
          </section>

        </div>
      </template>

    </div>
  </main>

  <script is:inline>
    function zaloStatusPage(initial) {
      return {
        status: initial.status,
        testPhone: "",
        testing: false,
        testResult: null,
        testError: "",

        async reload() {
          try {
            const res = await fetch("/api/v1/admin/zalo-status", { credentials: "include" });
            if (res.ok) this.status = await res.json();
          } catch (_) {}
        },

        async sendTest() {
          this.testError = "";
          this.testResult = null;
          this.testing = true;
          try {
            const res = await fetch("/api/v1/admin/zalo-test", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ phone: this.testPhone }),
            });
            const j = await res.json();
            if (!res.ok) {
              this.testError = j?.error?.message || "Lỗi gửi test";
              return;
            }
            this.testResult = j;
            // Reload usage counts after a sec
            setTimeout(() => this.reload(), 1500);
          } catch (err) {
            this.testError = "Không kết nối được server.";
          } finally {
            this.testing = false;
          }
        },
      };
    }
  </script>
</Layout>
