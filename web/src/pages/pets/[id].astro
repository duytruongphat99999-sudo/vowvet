      async initNutritionTab() {
        if (this.nutrition.loaded) return;
        this.nutrition.loaded = true;
        const speciesEN = this.pet.species === "Chó" ? "dog" : this.pet.species === "Mèo" ? "cat" : null;
        await Promise.all([
          this.fetchCalorieTarget(),
          this.fetchNutritionPlan(),
          this.fetchCompatibleBrands(),
          this.fetchInsights(),
          this.fetchForbiddenFoods(speciesEN),
        ]);
      },

      async fetchCalorieTarget() {
        this.nutrition.loading.calorie = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/nutrition/calorie-target`);
          if (res.status === 400) {
            this.nutrition.noWeight = true;
            this.nutrition.calorie = null;
          } else if (res.ok) {
            this.nutrition.calorie = await res.json();
            this.nutrition.noWeight = false;
          }
        } catch {} finally {
          this.nutrition.loading.calorie = false;
        }
      },

      async fetchNutritionPlan() {
        this.nutrition.loading.plan = true;
        try {
          const qs = new URLSearchParams({ meals: String(this.nutrition.mealsPerDay) });
          if (this.nutrition.selectedBrandId) qs.set("brand_id", String(this.nutrition.selectedBrandId));
          const res = await fetch(`/api/v1/pets/${this.pet.id}/nutrition/plan?${qs}`);
          if (res.ok) this.nutrition.plan = await res.json();
        } catch {} finally {
          this.nutrition.loading.plan = false;
        }
      },

      async fetchCompatibleBrands() {
        this.nutrition.loading.brands = true;
        try {
          const res = await fetch(`/api/v1/food-brands?pet_id=${this.pet.id}`);
          if (res.ok) {
            const j = await res.json();
            this.nutrition.brands = j.brands || [];
          }
        } catch {} finally {
          this.nutrition.loading.brands = false;
        }
      },

      async fetchInsights() {
        this.nutrition.loading.insights = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/nutrition/insights`);
          if (res.ok) this.nutrition.insights = await res.json();
        } catch {} finally {
          this.nutrition.loading.insights = false;
        }
      },

      async fetchForbiddenFoods(speciesEN) {
        this.nutrition.loading.forbidden = true;
        try {
          const qs = speciesEN ? `?species=${speciesEN}` : "";
          const res = await fetch(`/api/v1/forbidden-foods${qs}`);
          if (res.ok) {
            const j = await res.json();
            this.nutrition.forbidden = j.foods || [];
          }
        } catch {} finally {
          this.nutrition.loading.forbidden = false;
        }
      },

      async reloadPlan() {
        await this.fetchNutritionPlan();
      },

      setBrandForPlan(brandId) {
        this.nutrition.selectedBrandId = brandId;
        this.nutrition.showBrandPicker = false;
        this.fetchNutritionPlan();
      },

      // Từ verdict scan: chọn brand khớp làm loại hạt cho kế hoạch bữa ăn + cuộn tới khu dinh dưỡng.
      applyScanBrand(brandId) {
        if (brandId == null) return;
        this.activeTab = "nutrition";
        if (!this.nutrition.loaded) this.initNutritionTab();
        this.setBrandForPlan(brandId);
        this.$nextTick(() => document.getElementById("food-scan")?.scrollIntoView({ behavior: "smooth", block: "start" }));
      },

      async invalidateAndReload() {
        this.nutrition.loaded = false;
        this.nutrition.calorie = null;
        this.nutrition.plan = null;
        await this.initNutritionTab();
      },

      // Lớp 2: trạng thái banner nhắc cân — tính client từ insights.recent_logs (KHÔNG cần field mới)
      weighReminder() {
        const ins = this.nutrition.insights;
        if (!ins || this.nutrition.weighReminderDismissed) return { show: false };
        const logs = ins.recent_logs || [];
        if (logs.length === 0) {
          return { show: true, kind: "first", message: "Cân bé lần đầu để theo dõi sức khỏe theo thời gian." };
        }
        const last = logs[0] && logs[0].logged_at ? new Date(logs[0].logged_at).getTime() : null;
        if (last) {
          const days = Math.floor((Date.now() - last) / 86400000);
          if (days >= 30) return { show: true, kind: "stale", days, message: `Đã ${days} ngày chưa cân bé — cân lại để cập nhật khẩu phần nhé.` };
        }
        return { show: false };
      },

      // Lớp 2.1: nhắc theo xu hướng — tái dùng recommendations[].message; rỗng → trấn an theo trend
      weightNudge() {
        const ins = this.nutrition.insights;
        if (!ins) return { show: false };
        const recs = ins.recommendations || [];
        if (recs.length) {
          const order = { critical: 3, warning: 2, info: 1 };
          const top = recs.slice().sort((a, b) => (order[b.severity] || 0) - (order[a.severity] || 0))[0];
          return { show: true, severity: top.severity, message: top.message, needVet: top.severity === "critical" || top.severity === "warning" };
        }
        const t = ins.trend_30d && ins.trend_30d.direction;
        const dk = ins.trend_30d && ins.trend_30d.delta_kg;
        if (t === "stable") return { show: true, severity: "info", message: `Cân của bé đang ổn định (${dk > 0 ? "+" : ""}${dk ?? 0}kg/30 ngày). Tiếp tục khẩu phần hiện tại.` };
        if (t === "gain") return { show: true, severity: "info", message: `Bé tăng ${dk}kg/30 ngày — theo dõi khẩu phần.` };
        if (t === "loss") return { show: true, severity: "warning", message: `Bé giảm ${Math.abs(dk)}kg/30 ngày — kiểm tra nếu không cố ý giảm cân.`, needVet: true };
        return { show: false };
      },

      // Lớp 2.2: đề xuất — concern (bcs≥7 / gain / lệch target ≥15%) + nhánh hạ vận động hoặc set target
      rationSuggestion() {
        const ins = this.nutrition.insights, cal = this.nutrition.calorie;
        if (!ins) return { show: false };
        const ORDER = ["sedentary", "low", "moderate", "active", "very_active"];   // ENUM bậc (KHÔNG phải hệ số DER)
        const bcs = ins.bcs_current;
        const trend = ins.trend_30d && ins.trend_30d.direction;
        const overTarget = ins.target_weight_kg != null && ins.delta_to_target_kg != null && ins.target_weight_kg > 0 && ins.delta_to_target_kg > 0 && (ins.delta_to_target_kg / ins.target_weight_kg) >= 0.15;
        const concern = (bcs != null && bcs >= 7) || trend === "gain" || overTarget;
        const activity = cal && cal.breakdown ? cal.breakdown.activity_level : null;
        const idx = ORDER.indexOf(activity);
        const canLowerActivity = idx > 0;
        const nextLower = canLowerActivity ? ORDER[idx - 1] : null;
        const hasTarget = ins.target_weight_kg != null;
        return { show: concern || !hasTarget, concern, canLowerActivity, nextLower, activity, hasTarget, currentWeight: ins.current_weight_kg, targetWeight: ins.target_weight_kg };
      },

      startSetTarget() {
        this.nutrition.showTargetInput = true;
        this.nutrition.targetInput = Number(this.pet.weight_kg) || null;   // mặc định = cân hiện tại (app KHÔNG tự đoán đích)
      },
      askApply(kind) { this.nutrition.pendingApply = kind; this.nutrition.applyMsg = ""; },   // mở hộp xác nhận — CHƯA đổi gì
      cancelApply() { this.nutrition.pendingApply = null; },

      // GUARD: chỉ chạy khi user đã bấm "Xác nhận đổi". KHÔNG bao giờ tự PATCH.
      async confirmApply() {
        const kind = this.nutrition.pendingApply;
        if (!kind) return;
        this.nutrition.applying = true;
        try {
          if (kind === "target") {
            const t = Number(this.nutrition.targetInput);
            if (!t || t <= 0) { this.nutrition.applyMsg = "Cân mục tiêu không hợp lệ."; return; }
            const res = await fetch(`/api/v1/pets/${this.pet.id}`, { method: "PATCH", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ target_weight_kg: t }) });
            if (!res.ok) { this.nutrition.applyMsg = "Chưa lưu được, thử lại."; return; }
            const j = await res.json(); this.pet = j.pet || this.pet;
            await this.fetchInsights();
            // "Profile=thuốc": CHỈ báo thành công khi target THẬT đã lưu (đọc lại insights, không tin UI)
            const saved = this.nutrition.insights && Number(this.nutrition.insights.target_weight_kg) === t;
            if (saved) {
              this.nutrition.showTargetInput = false;
              this.nutrition.applyMsg = `Đã đặt cân mục tiêu ${t}kg.`;
            } else {
              this.nutrition.applyMsg = "Chưa lưu được, thử lại.";
            }
          } else if (kind === "activity") {
            const s = this.rationSuggestion();
            if (!s.canLowerActivity || !s.nextLower) { this.nutrition.applyMsg = "Vận động đã thấp nhất."; return; }
            const res = await fetch(`/api/v1/pets/${this.pet.id}`, { method: "PATCH", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ activity_level: s.nextLower }) });
            if (!res.ok) { this.nutrition.applyMsg = "Lỗi cập nhật vận động."; return; }
            const j = await res.json(); this.pet = j.pet || this.pet;
            await Promise.all([this.fetchCalorieTarget(), this.fetchNutritionPlan(), this.fetchInsights()]);
            this.nutrition.applyMsg = `Đã hạ vận động sang "${this.activityLevelLabel(s.nextLower)}" — khẩu phần đã tính lại.`;
          }
        } catch (e) {
          this.nutrition.applyMsg = "Lỗi kết nối.";
        } finally {
          this.nutrition.applying = false;
          this.nutrition.pendingApply = null;
        }
      },

      async submitWeightLog() {
        this.nutrition.logError = "";
        if (!this.nutrition.logForm.weight_kg || this.nutrition.logForm.weight_kg <= 0) {
          this.nutrition.logError = "Cần nhập cân nặng (kg)";
          return;
        }
        this.nutrition.logSubmitting = true;
        try {
          const payload = {
            weight_kg: this.nutrition.logForm.weight_kg,
            body_condition_score: this.nutrition.logForm.body_condition_score || null,
            notes: this.nutrition.logForm.notes || null,
          };
          const res = await fetch(`/api/v1/pets/${this.pet.id}/weight-log`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const j = await res.json();
          if (!res.ok) {
            this.nutrition.logError = j.error?.message || "Lỗi log cân";
            return;
          }
          // Sync pet weight + reset form
          this.pet.weight_kg = payload.weight_kg;
          this.nutrition.logForm = { weight_kg: null, body_condition_score: null, notes: "" };
          this.nutrition.showLogForm = false;
          // Reload calorie + plan + insights (weight changed → DER changed)
          await Promise.all([this.fetchCalorieTarget(), this.fetchNutritionPlan(), this.fetchInsights()]);
        } catch (err) {
          this.nutrition.logError = "Lỗi kết nối";
        } finally {
          this.nutrition.logSubmitting = false;
        }
      },

      // ---- VN labels ----
      lifeStageLabel(stage) {
        const labels = { puppy: "Con (puppy/kitten)", junior: "Trẻ", adult: "Trưởng thành", senior: "Cao tuổi", geriatric: "Lão" };
        return labels[stage] || stage || "—";
      },
      activityLevelLabel(level) {
        const labels = { sedentary: "Ít vận động", low: "Vận động nhẹ", moderate: "Vận động vừa", active: "Năng động", very_active: "Rất năng động" };
        return labels[level] || level || "—";
      },
      mealIcon(type) {
        // v219: trả chuỗi SVG (render x-html). meal.type là enum controlled → x-html an toàn. Path copy từ FeatureIcon.
        const wrap = (inner) => '<svg class="w-5 h-5 text-mmp-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + inner + '</svg>';
        if (type === "breakfast") return wrap('<path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 6 4-4 4 4"/><path d="M16 18a4 4 0 0 0-8 0"/>'); // sunrise
        if (type === "lunch") return wrap('<circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/>'); // sun
        if (type === "dinner") return wrap('<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>'); // mood-sleeping (moon)
        return wrap('<path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/>'); // cookie (snack/treat)
      },
      mealTypeLabel(type) {
        const labels = { breakfast: "Sáng", lunch: "Trưa", dinner: "Tối", snack: "Snack" };
        return labels[type] || type;
      },
      trendColor(direction) {
        if (direction === "gain") return "text-amber-700";
        if (direction === "loss") return "text-red-700";
        if (direction === "stable") return "text-emerald-700";
        return "text-slate-500";
      },
      trendIcon(direction) {
        if (direction === "gain") return "↗";
        if (direction === "loss") return "↘";
        if (direction === "stable") return "→";
        return "·";
      },
      formatVnd(v) {
        if (!v) return "—";
        if (v >= 1000000) return (v / 1000000).toFixed(1) + "tr";
        if (v >= 1000) return (v / 1000).toFixed(0) + "k";
        return String(v);
      },
      formatLogDate(iso) {
        if (!iso) return "—";
        const d = new Date(iso);
        if (isNaN(d)) return iso.slice(0, 10);
        return d.toLocaleDateString("vi-VN", { day: "2-digit", month: "2-digit", year: "2-digit" });
      },

      confirmDelete() { this.deleteStep = 1; this.deleteError = ""; },
      async doDelete() {
        this.deleteLoading = true;
        this.deleteError = "";
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}`, { method: "DELETE" });
          if (!res.ok) {
            const json = await res.json().catch(() => ({}));
            this.deleteError = json.error?.message || "Không xoá được";
            return;
          }
          window.location.href = "/dashboard";
        } catch (err) {
          this.deleteError = "Lỗi kết nối";
        } finally {
          this.deleteLoading = false;
        }
      },
    };
  }

  // Inline JS version of formatAge (mirror lib/age.ts)
  function formatAgeJs(dob) {
    if (!dob) return "—";
    const m = dob.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (!m) return "—";
    const birth = new Date(+m[1], +m[2] - 1, +m[3]);
    const now = new Date();
    if (isNaN(birth) || birth > now) return "—";
    let years = now.getFullYear() - birth.getFullYear();
    let months = now.getMonth() - birth.getMonth();
    if (now.getDate() < birth.getDate()) months--;
    if (months < 0) { years--; months += 12; }
    if (!years && !months) return "Mới sinh";
    if (!years) return `${months} tháng tuổi`;
    if (!months) return `${years} tuổi`;
    return `${years} tuổi ${months} tháng`;
  }
</script>
