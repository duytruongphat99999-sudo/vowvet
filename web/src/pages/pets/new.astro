---
import Layout from "../../layouts/Layout.astro";
import PledgeCertificate from "../../components/PledgeCertificate.astro";
import { DOG_BREEDS_VN, CAT_BREEDS_VN } from "../../lib/breeds.ts";

const dogBreedsJson = JSON.stringify(DOG_BREEDS_VN);
const catBreedsJson = JSON.stringify(CAT_BREEDS_VN);

// BƯỚC 2-fix: lấy tên người dùng cho khu chữ ký certificate
const cookieHeader = Astro.request.headers.get("cookie") || "";
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";
let userName = "";
try {
  const meRes = await fetch(`${API_INTERNAL}/api/v1/auth/me`, { headers: { cookie: cookieHeader } });
  if (meRes.ok) { const me = await meRes.json(); userName = (me.user && me.user.name) || ""; }
} catch (_) {}
const userNameJson = JSON.stringify(userName);
---

<Layout title="Lập hồ sơ bé · VowVet">
  <main class="min-h-screen px-4 sm:px-6 py-8 bg-mmp-cream">
    <div class="max-w-xl mx-auto" x-data={`newPetForm(${dogBreedsJson}, ${catBreedsJson}, ${userNameJson})`}>

      {/* ① MÀN CHÀO HỎI — lời chào mềm + ảnh bé (tuỳ chọn) + tên */}
      <div x-show="step === 'welcome'" class="text-center py-6">
        <div class="mb-3 flex justify-center">
          <svg width="56" height="56" viewBox="0 0 48 48" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M24 30v6M24 32.5c-1.8-1.1-4.3-1-5.9.5M24 34.5c1.8-1.1 4.3-1 5.9.5" stroke="#9bbf8f" stroke-width="1.8"/>
            <path d="M24 12c-4.3 0-7.5 3-7.5 7 0 5.3 4.3 10.1 7.5 12.6 3.2-2.5 7.5-7.3 7.5-12.6 0-4-3.2-7-7.5-7Z" fill="#f3dada" fill-opacity=".55" stroke="#c98b8b" stroke-width="1.7"/>
            <path d="M24 15.5c-2.5 0-4.3 1.9-4.3 4.1 0 2.8 2.2 5.4 4.3 7 2.1-1.6 4.3-4.2 4.3-7 0-2.2-1.8-4.1-4.3-4.1Z" stroke="#c98b8b" stroke-width="1.6"/>
            <circle cx="24" cy="20.5" r="2.1" fill="#e3a9a9"/>
          </svg>
        </div>
        <h1 class="font-display italic text-2xl sm:text-3xl font-semibold text-mmp-ink leading-tight">Chào mừng bạn đến với VowVet</h1>
        <p class="text-sm text-mmp-ink/75 leading-relaxed mt-3 max-w-md mx-auto">
          Có một sinh linh nhỏ đã chọn bạn làm cả thế giới của nó.<br class="hidden sm:block" />
          Mỗi bé cưng là một câu chuyện — hãy cùng VowVet mở trang đầu tiên:
          <strong class="text-mmp-ink">Hồ sơ Trọn đời</strong>, nơi tình yêu thương được ghi lại trọn vẹn.
        </p>

        {/* Ảnh bé (tuỳ chọn) — preview tròn ngay, dùng cho khung tròn certificate */}
        <div class="mt-6 flex flex-col items-center">
          <label class="relative cursor-pointer">
            <input type="file" accept="image/jpeg,image/png,image/webp" class="hidden" @change="pickPhoto($event)" />
            <span class="block w-24 h-24 rounded-full overflow-hidden flex items-center justify-center bg-white transition"
                  style="box-shadow: 0 0 0 3px #d8b25a, 0 0 0 4.5px rgba(236,199,199,.6);">
              <template x-if="photoPreview"><img :src="photoPreview" alt="" class="w-full h-full object-cover" /></template>
              <template x-if="!photoPreview">
                <span class="text-mmp-ink/40">
                  <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                </span>
              </template>
            </span>
            <span class="absolute -bottom-1 -right-1 w-7 h-7 rounded-full bg-mmp-ink text-white flex items-center justify-center text-sm shadow-md">+</span>
          </label>
          <p class="mt-2 text-xs text-mmp-ink/55" x-text="photoPreview ? 'Ảnh của bé 💛 (chạm để đổi)' : 'Thêm ảnh bé (tuỳ chọn)'"></p>
        </div>

        <div class="mt-5 max-w-xs mx-auto text-left">
          <label class="block text-sm font-medium text-mmp-ink/80 mb-1.5">Bé tên là gì?</label>
          <input type="text" x-model="pet.name" maxlength="100" placeholder="VD: Mun, Mít, Bông"
                 @keydown.enter="startPledge()"
                 class="w-full px-4 py-3 rounded-xl border border-mmp-ink/15 bg-white focus:outline-none focus:ring-2 focus:ring-amber-300 text-mmp-ink" />
        </div>
        <button type="button" @click="startPledge()" :disabled="!pet.name.trim()"
                class="mt-5 inline-flex items-center gap-2 px-6 py-3 rounded-2xl font-bold text-sm transition"
                :class="pet.name.trim() ? 'bg-mmp-ink text-white hover:bg-mmp-ink/90 shadow-lg' : 'bg-mmp-ink/15 text-mmp-ink/40 cursor-not-allowed'">
          Bắt đầu cam kết
          <span>→</span>
        </button>
        <div class="mt-4">
          <a href="/dashboard" class="text-xs text-mmp-ink/50 hover:text-mmp-ink">← Để sau, về Dashboard</a>
        </div>
      </div>

      {/* ② CERTIFICATE CAM KẾT */}
      <div x-show="step === 'pledge'" style="display:none;" class="py-2">
        <PledgeCertificate />
        <div class="text-center mt-3" x-show="!stamping && !stampDone">
          <button type="button" @click="step = 'welcome'" class="text-xs text-mmp-ink/50 hover:text-mmp-ink">← Đổi tên bé</button>
        </div>
      </div>

      {/* ③ FORM ĐIỀN CƠ BẢN */}
      <div x-show="step === 'form'" style="display:none;">
        <div class="mb-5 text-center">
          <p class="inline-flex items-center gap-1.5 text-[11px] font-semibold" style="color:#B48608;">
            <span>✓</span> Đã cam kết · Giờ điền hồ sơ cơ bản cho <strong class="text-mmp-ink" x-text="pet.name"></strong>
          </p>
        </div>
        <form @submit.prevent="submit()" class="bg-white rounded-2xl shadow-xl border border-mmp-ink/10 p-6 sm:p-8 space-y-6">
          {/* Tên (pre-fill, sửa được) */}
          <div>
            <label class="block text-sm font-medium text-mmp-ink/80 mb-2">Tên bé *</label>
            <input type="text" x-model="pet.name" maxlength="100"
                   class="w-full px-4 py-3 rounded-xl border border-mmp-ink/15 focus:outline-none focus:ring-2 focus:ring-amber-300 text-mmp-ink" required />
          </div>
          {/* Loài */}
          <div>
            <label class="block text-sm font-medium text-mmp-ink/80 mb-3">Loài *</label>
            <div class="grid grid-cols-2 gap-3">
              <button type="button" @click="pet.species = 'Chó'; pet.breed = ''"
                :class="pet.species === 'Chó' ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30' : 'border-mmp-ink/15 hover:border-mmp-gold/50'"
                class="border-2 rounded-xl py-5 px-4 transition flex flex-col items-center gap-2">
                <span class="text-4xl">🐶</span><span class="font-medium text-mmp-ink">Chó</span>
              </button>
              <button type="button" @click="pet.species = 'Mèo'; pet.breed = ''"
                :class="pet.species === 'Mèo' ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30' : 'border-mmp-ink/15 hover:border-mmp-gold/50'"
                class="border-2 rounded-xl py-5 px-4 transition flex flex-col items-center gap-2">
                <span class="text-4xl">🐱</span><span class="font-medium text-mmp-ink">Mèo</span>
              </button>
            </div>
          </div>
          {/* Giống */}
          <div>
            <label class="block text-sm font-medium text-mmp-ink/80 mb-2">Giống (không bắt buộc)</label>
            <input type="text" x-model="pet.breed" list="breed-list" maxlength="100" :disabled="!pet.species"
                   :placeholder="pet.species === 'Chó' ? 'VD: Phú Quốc' : pet.species === 'Mèo' ? 'VD: Mèo ta' : 'Chọn loài trước'"
                   class="w-full px-4 py-3 rounded-xl border border-mmp-ink/15 focus:outline-none focus:ring-2 focus:ring-amber-300 text-mmp-ink disabled:bg-mmp-cream/40 disabled:text-mmp-ink/40" />
            <datalist id="breed-list">
              <template x-for="b in breedOptions" :key="b"><option :value="b"></option></template>
            </datalist>
          </div>
          {/* DOB */}
          <div>
            <label class="block text-sm font-medium text-mmp-ink/80 mb-2">Ngày sinh (không bắt buộc)</label>
            <input type="date" x-model="pet.dob" :max="todayIso"
                   class="w-full px-4 py-3 rounded-xl border border-mmp-ink/15 focus:outline-none focus:ring-2 focus:ring-amber-300 text-mmp-ink" />
          </div>
          {/* Gender */}
          <div>
            <label class="block text-sm font-medium text-mmp-ink/80 mb-3">Giới tính (không bắt buộc)</label>
            <div class="grid grid-cols-2 gap-2">
              <template x-for="g in ['Đực', 'Cái']" :key="g">
                <button type="button" @click="pet.gender = (pet.gender === g ? '' : g)"
                  :class="pet.gender === g ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30' : 'border-mmp-ink/15 hover:border-mmp-gold/50'"
                  class="border-2 rounded-xl py-3 px-2 transition font-medium text-mmp-ink" x-text="g"></button>
              </template>
            </div>
          </div>
          {/* Weight */}
          <div>
            <label class="block text-sm font-medium text-mmp-ink/80 mb-2">Cân nặng kg (không bắt buộc)</label>
            <input type="number" inputmode="decimal" step="0.1" min="0" max="200" x-model.number="pet.weight_kg" placeholder="VD: 4.2"
                   class="w-full px-4 py-3 rounded-xl border border-mmp-ink/15 focus:outline-none focus:ring-2 focus:ring-amber-300 text-mmp-ink" />
          </div>
          <div x-show="error" class="text-sm text-red-600" x-text="error"></div>
          <div class="flex gap-3 pt-2">
            <button type="submit" :disabled="loading || !pet.name.trim() || !pet.species"
              class="flex-1 bg-mmp-ink hover:bg-mmp-ink/90 disabled:bg-mmp-ink/20 disabled:text-mmp-ink/40 text-white font-semibold py-3 rounded-xl transition">
              <span x-show="!loading">Hoàn tất hồ sơ</span>
              <span x-show="loading" style="display:none;">Đang lưu…</span>
            </button>
          </div>
        </form>
      </div>

    </div>
  </main>
</Layout>

<script is:inline src="/image-compress.js"></script>

<script is:inline>
  function newPetForm(dogBreeds, catBreeds, userName) {
    return {
      step: "welcome",       // welcome → pledge → form
      userName: userName || "",
      loading: false,
      error: "",
      pet: { name: "", species: "", breed: "", dob: "", gender: "", weight_kg: null },
      // Ảnh bé (tuỳ chọn) — nén rồi giữ File để upload lúc submit; preview cho khung tròn cert
      photoFile: null,
      photoPreview: "",
      photoError: "",
      // === Cam kết (bước 2) ===
      certTicked: false,
      stamping: false,
      stampDone: false,
      get certNumber() { return ""; },  // wizard chưa có id → cert ghi 'cấp sau khi hoàn tất'; #VV-{id} hiện ở passport sau
      get todayDisplay() {
        const d = new Date();
        return String(d.getDate()).padStart(2, "0") + "/" + String(d.getMonth() + 1).padStart(2, "0") + "/" + d.getFullYear();
      },
      startPledge() { if (this.pet.name.trim()) this.step = "pledge"; },
      async pickPhoto(event) {
        var input = event.target;
        var file = input && input.files && input.files[0];
        if (!file) return;
        this.photoError = "";
        try {
          var compressed = (window.compressImage ? await window.compressImage(file) : file) || file;
          this.photoFile = compressed;
          if (this.photoPreview) { try { URL.revokeObjectURL(this.photoPreview); } catch (e) {} }
          this.photoPreview = URL.createObjectURL(compressed);
        } catch (e) {
          this.photoFile = file;
          this.photoPreview = URL.createObjectURL(file);
        }
      },
      confirmPledge() {
        if (!this.certTicked || this.stamping) return;
        this.stamping = true;
        var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var self = this;
        setTimeout(function () {
          self.stampDone = true;
          setTimeout(function () { self.step = "form"; }, reduce ? 0 : 650);
        }, reduce ? 0 : 900);
      },
      get breedOptions() {
        if (this.pet.species === "Chó") return dogBreeds;
        if (this.pet.species === "Mèo") return catBreeds;
        return [];
      },
      get todayIso() { return new Date().toISOString().slice(0, 10); },
      async submit() {
        this.error = "";
        if (!this.pet.name.trim() || !this.pet.species) { this.error = "Vui lòng nhập tên và chọn loài"; return; }
        this.loading = true;
        var payload = {
          name: this.pet.name.trim(),
          species: this.pet.species,
          breed: this.pet.breed.trim() || null,
          dob: this.pet.dob || null,
          gender: this.pet.gender || null,
          weight_kg: this.pet.weight_kg || null,
        };
        try {
          var res = await fetch("/api/v1/pets", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
          var json = await res.json();
          if (!res.ok) { this.error = (json.error && json.error.message) || "Có lỗi xảy ra"; return; }
          var petId = json.pet.id;
          // User đã cam kết ở bước 2 → ghi pledge cho pet vừa tạo
          try { await fetch("/api/v1/pets/" + petId + "/pledge", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({}) }); } catch (e) { /* không chặn flow */ }
          // v270: upload ảnh bé nếu có — tái dùng cơ chế R2 (POST /pets/:id/photo, field 'photo')
          if (this.photoFile) {
            try {
              var photoForm = new FormData();
              photoForm.append("photo", this.photoFile);
              await fetch("/api/v1/pets/" + petId + "/photo", { method: "POST", body: photoForm });
            } catch (e) { /* không chặn flow */ }
            // v271 (mục 3): ghi 1 KỶ NIỆM vào gallery (pet_photos) — "Ngày cam kết Hồ sơ Trọn đời · [ngày]"
            try {
              var memForm = new FormData();
              memForm.append("photo", this.photoFile);
              memForm.append("type", "general");
              memForm.append("caption", "Ngày cam kết Hồ sơ Trọn đời · " + this.todayDisplay);
              await fetch("/api/v1/pets/" + petId + "/photos", { method: "POST", body: memForm });
            } catch (e) { /* không chặn flow */ }
          }
          // v269: đánh dấu onboarded (re-sign JWT) → vào /pets/[id] không bị middleware bounce về onboarding
          try { await fetch("/api/v1/users/me/complete-onboarding", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({}) }); } catch (e) { /* không chặn flow */ }
          window.location.href = "/pets/" + petId;
        } catch (err) {
          this.error = "Lỗi kết nối. Thử lại nhé";
        } finally {
          this.loading = false;
        }
      },
    };
  }
</script>
