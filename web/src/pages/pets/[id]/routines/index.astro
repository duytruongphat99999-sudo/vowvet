      "shield-check": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
      "brain": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M9.5 2a2.5 2.5 0 0 0-2.5 2.5v.5a2.5 2.5 0 0 0-2.5 2.5 2.5 2.5 0 0 0-1 4.5 2.5 2.5 0 0 0 1 4.5A2.5 2.5 0 0 0 7 18.5v.5a2.5 2.5 0 0 0 5 0V4.5A2.5 2.5 0 0 0 9.5 2z"/><path d="M14.5 2a2.5 2.5 0 0 1 2.5 2.5v.5a2.5 2.5 0 0 1 2.5 2.5 2.5 2.5 0 0 1 1 4.5 2.5 2.5 0 0 1-1 4.5A2.5 2.5 0 0 1 17 18.5v.5a2.5 2.5 0 0 1-5 0V4.5A2.5 2.5 0 0 1 14.5 2z"/></svg>',
      "lightbulb": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>',
      "trophy": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z"/><path d="M7 4H5a2 2 0 0 0-2 2v1a3 3 0 0 0 3 3M17 4h2a2 2 0 0 1 2 2v1a3 3 0 0 1-3 3"/></svg>',
      "target": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
      "sparkles": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/></svg>',
      "leaf": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.3 16.2-8.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>',
      "clipboard": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>',
      "home": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
      "star": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
      "cat": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3.1-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/></svg>',
      "dog": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.945-1.45-2.328-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/><path d="M4.5 13.5C4.5 12 5 11 6 11h12c1 0 1.5 1 1.5 2.5l-1 4c-.75 1.5-1.5 2.5-3 2.5h-1.25l-.75-1.5L12 21l-1.5-2.5-.75 1.5H8.5c-1.5 0-2.25-1-3-2.5z"/></svg>',
    };

    function routinesPage(initial) {
      return {
        pet: initial.pet,
        routines: initial.routines,
        today: initial.today.map((r) => ({ ...r, _expanded: false, _saving: false })),
        streak: initial.streak,
        badgesMeta: initial.badgesMeta,
        badgeToast: null,
        saveTimers: {},
        // v97: Smart Blueprint apply state
        applying: null,
        applyToast: null,

        // v97: 1-tap apply blueprint — POST routine + reload to refresh state
        async quickApply(blueprintId) {
          if (this.applying) return;
          const all = window.__VOWVET_BLUEPRINTS || [];
          const bp = all.find((b) => b.id === blueprintId);
          if (!bp) return;
          this.applying = blueprintId;
          try {
            const body = {
              name: bp.label,
              icon: bp.icon,
              color: "#B48608",
              schedule_type: bp.schedule_type || "daily",
              custom_days: [],
              start_time: bp.start_time || "08:00",
              push_reminder: true,
              tasks: bp.tasks.map((t) => ({
                id: "t" + Math.random().toString(36).slice(2, 10),
                title: t.title,
                emoji: t.emoji,
                duration_minutes: t.duration_minutes,
                points: t.points,
                category: t.category,
              })),
            };
            const res = await fetch(`/api/v1/pets/${this.pet.id}/routines`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify(body),
            });
            if (!res.ok) {
              this.applyToast = "Lỗi: " + (await res.text()).slice(0, 80);
              setTimeout(() => { this.applyToast = null; }, 4000);
              return;
            }
            this.applyToast = bp.label;
            this.launchConfetti();
            // Reload after toast to fetch new routines
            setTimeout(() => window.location.reload(), 1500);
          } catch (err) {
            this.applyToast = "Lỗi kết nối";
            setTimeout(() => { this.applyToast = null; }, 4000);
          } finally {
            // Keep applying state until reload
          }
        },

        // v100: Render r.icon — exact match → prefix fuzzy match → emoji fallback
        // Fuzzy needed because Baserow icon column truncates long Lucide names
        // (e.g., "activity-run" → "acti", "shield-check" → "shie").
        renderIcon(name) {
          if (!name) return '';
          const key = String(name).trim();
          // Exact match (full Lucide name OR legacy emoji that happens to be a key)
          if (LUCIDE_ROUTINE_ICONS[key]) return LUCIDE_ROUTINE_ICONS[key];
          // Fuzzy prefix match — recover from Baserow truncation
          const lower = key.toLowerCase();
          for (const k of Object.keys(LUCIDE_ROUTINE_ICONS)) {
            if (k.startsWith(lower) || lower.startsWith(k)) {
              return LUCIDE_ROUTINE_ICONS[k];
            }
          }
          // True legacy: emoji char or unknown — render as text
          return '<span style="font-size: 1.25rem; line-height: 1;">' + key + '</span>';
        },

        get completedToday() {
          return this.today.filter((r) => r.completion && r.completion.tasks_completion_rate >= 50).length;
        },

        // v87: Today's overall task completion % — drives Energy Ring intensity
        get todayProgress() {
          if (!this.today.length) return 0;
          let done = 0, total = 0;
          for (const r of this.today) {
            done += this.completedCount(r);
            total += r.tasks.length;
          }
          return total > 0 ? Math.round((done / total) * 100) : 0;
        },

        isTaskDone(routine, taskId) {
          const list = routine.completion?.tasks_completed || [];
          return list.includes(taskId);
        },

        completedCount(routine) {
          return (routine.completion?.tasks_completed || []).length;
        },

        scheduleLabel(s) {
          return { daily: "Hàng ngày", weekdays: "T2-T6", weekends: "Cuối tuần", custom: "Tuỳ chỉnh" }[s] || s;
        },

        toggleTask(routine, taskId) {
          // Mutate in place
          if (!routine.completion) {
            routine.completion = {
              tasks_completed: [],
              tasks_total: routine.tasks.length,
              tasks_completion_rate: 0,
            };
          }
          const list = routine.completion.tasks_completed;
          const idx = list.indexOf(taskId);
          if (idx >= 0) list.splice(idx, 1);
          else list.push(taskId);

          // Debounced save per routine
          clearTimeout(this.saveTimers[routine.id]);
          routine._saving = true;
          this.saveTimers[routine.id] = setTimeout(() => this.saveCompletion(routine), 600);
        },

        async saveCompletion(routine) {
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/routines/${routine.id}/complete`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ completed_task_ids: routine.completion.tasks_completed }),
            });
            if (!res.ok) {
              console.warn("save fail", await res.text());
              return;
            }
            const data = await res.json();
            // Update local completion + streak
            routine.completion = data.completion;
            this.streak = data.streak;
            // Badges
            if (data.badgesUnlocked && data.badgesUnlocked.length > 0) {
              this.showBadge(data.badgesUnlocked[0]);
              if (data.badgesUnlocked.length > 1) {
                setTimeout(() => this.showBadge(data.badgesUnlocked[1]), 3000);
              }
            }
          } catch (err) {
            console.error("save error", err);
          } finally {
            routine._saving = false;
          }
        },

        showBadge(badgeId) {
          this.badgeToast = badgeId;
          this.launchConfetti();
          setTimeout(() => { this.badgeToast = null; }, 3500);
        },

        launchConfetti() {
          const colors = ["#f59e0b", "#ec4899", "#8b5cf6", "#10b981", "#3b82f6", "#f43f5e"];
          for (let i = 0; i < 40; i++) {
            const el = document.createElement("div");
            el.className = "confetti-piece";
            el.style.left = Math.random() * 100 + "vw";
            el.style.background = colors[Math.floor(Math.random() * colors.length)];
            el.style.borderRadius = Math.random() > 0.5 ? "50%" : "0";
            el.style.animationDuration = (1.8 + Math.random() * 1.2) + "s";
            el.style.animationDelay = Math.random() * 0.5 + "s";
            document.body.appendChild(el);
            el.addEventListener("animationend", () => el.remove());
          }
        },

        async useFreezeConfirm() {
          if (!this.streak || this.streak.streak_freezes_available <= 0) return;
          if (!confirm(`Dùng 1 ngày phép? Còn lại ${this.streak.streak_freezes_available - 1}/3 trong tháng. Streak sẽ +1 ngày.`)) return;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/routines/streak/use-freeze`, {
              method: "POST",
              credentials: "include",
            });
            if (res.ok) {
              const j = await res.json();
              this.streak = j.streak;
            } else {
              alert("Hết ngày phép tháng này");
            }
          } catch (_) {}
        },

        async confirmDelete(routine) {
          if (!confirm(`Xoá routine "${routine.name}"? (Soft delete — có thể khôi phục từ admin)`)) return;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/routines/${routine.id}`, {
              method: "DELETE",
              credentials: "include",
            });
            if (res.ok) {
              this.routines = this.routines.filter((r) => r.id !== routine.id);
              this.today = this.today.filter((r) => r.id !== routine.id);
            }
          } catch (_) {}
        },
      };
    }
  </script>
</Layout>
