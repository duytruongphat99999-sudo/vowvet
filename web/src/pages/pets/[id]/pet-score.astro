                </foreignObject>
              </g>
            ))}
            <circle cx="160" cy="160" r="42" fill="rgba(236,185,33,0.08)" stroke="rgba(236,185,33,0.4)" stroke-width="1"/>
            <foreignObject x="115" y="125" width="90" height="70" style="pointer-events: none;">
