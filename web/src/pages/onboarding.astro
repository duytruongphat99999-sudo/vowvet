---
/**
 * /onboarding — Màn "Thêm bé đầu tiên 🐾" (welcome-empty, thân thiện).
 *
 * v269: User chưa có pet nào → middleware đưa về đây (chặn dashboard,
 * kể cả khi gõ /dashboard trực tiếp). Màn này KHÔNG có form — chỉ chào
 * hỏi + nút "Thêm bé" dẫn sang /pets/new (chào hỏi → certificate cam
 * kết → form). Đã có ≥1 bé → /dashboard.
 */
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;

// Auth gate (belt-and-suspenders — middleware đã lo phần lớn)
if (!user) {
  return Astro.redirect("/login?return_to=%2Fonboarding");
}
if (user.is_onboarded === true) {
  return Astro.redirect("/dashboard");
}
---

<Layout title="Thêm bé đầu tiên · VowVet" description="Thêm thú cưng đầu tiên vào VowVet">
  <main class="min-h-screen flex items-center justify-center px-4 sm:px-6 py-10 bg-mmp-cream">
    <div class="max-w-md mx-auto text-center">
      <div class="mb-5 inline-block animate-bounce" style="animation-duration: 2.5s; color:#B48608">
        <svg width="64" height="64" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <ellipse cx="13" cy="19" rx="3.3" ry="4.4"/><ellipse cx="22.5" cy="13.5" rx="3.5" ry="4.8"/><ellipse cx="32.5" cy="14.5" rx="3.4" ry="4.6"/><ellipse cx="39" cy="23" rx="3" ry="4"/>
          <path d="M24 26.5c-5 0-8.8 3.6-8.8 7.5 0 3.1 2.7 4.5 5.7 4.5 2.1 0 2.5-.9 4.1-.9s2 .9 4.1.9c3 0 5.7-1.4 5.7-4.5 0-3.9-3.8-7.5-8.8-7.5Z" fill="#f7eedd" fill-opacity=".5"/>
        </svg>
      </div>
      <p class="text-sm text-mmp-ink/60 mb-1">Chào mừng bạn đến với VowVet <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:inline-block;vertical-align:-2px"><circle cx="9" cy="9" r="3.2" fill="#f0d2d2"/><circle cx="15" cy="9" r="3.2" fill="#f0d2d2"/><circle cx="9" cy="15" r="3.2" fill="#f0d2d2"/><circle cx="15" cy="15" r="3.2" fill="#f0d2d2"/><circle cx="12" cy="12" r="3.6" fill="#ecc7c7"/><circle cx="12" cy="12" r="1.8" fill="#e3b04f"/></svg></p>
      <h1 class="font-display italic text-3xl sm:text-4xl font-semibold text-mmp-ink leading-tight">
        Thêm bé đầu tiên
      </h1>
      <p class="mt-4 text-mmp-ink/75 leading-relaxed">
        Có một sinh linh nhỏ đã chọn bạn làm cả thế giới của nó.
        Mỗi bé cưng là một câu chuyện — hãy cùng VowVet mở trang đầu tiên:
        <strong class="text-mmp-ink">Hồ sơ Trọn đời</strong>, nơi tình yêu thương được ghi lại trọn vẹn.
      </p>
      <a href="/pets/new"
         class="mt-8 inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-mmp-ink text-white font-bold text-base hover:bg-mmp-ink/90 shadow-lg transition">
        <svg width="20" height="20" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="13" cy="19" rx="3.3" ry="4.4"/><ellipse cx="22.5" cy="13.5" rx="3.5" ry="4.8"/><ellipse cx="32.5" cy="14.5" rx="3.4" ry="4.6"/><ellipse cx="39" cy="23" rx="3" ry="4"/><path d="M24 26.5c-5 0-8.8 3.6-8.8 7.5 0 3.1 2.7 4.5 5.7 4.5 2.1 0 2.5-.9 4.1-.9s2 .9 4.1.9c3 0 5.7-1.4 5.7-4.5 0-3.9-3.8-7.5-8.8-7.5Z"/></svg> Thêm bé
        <span>→</span>
      </a>
      <p class="mt-6">
        <a href="/logout" class="text-xs text-mmp-ink/40 hover:text-mmp-ink">← Đăng xuất</a>
      </p>
    </div>
  </main>
</Layout>
