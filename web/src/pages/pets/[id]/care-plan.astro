            <button type="button" @click="engagement = 'eager'"
                    :class="engagement === 'eager' ? 'bg-emerald-50 border-emerald-400 text-emerald-900' : 'bg-white border-slate-200 text-mmp-ink'"
                    class="p-2.5 rounded-xl border-2 text-center hover:border-emerald-300 transition">
