        <div x-show="!isEditMode">
          <label class="text-xs font-bold text-mmp-ink uppercase tracking-widest inline-flex items-center gap-1.5">
            <FeatureIcon name="shield" class="w-3.5 h-3.5" strokeWidth={2} style="color: var(--c-gold);" />
            Tên mũi vaccine <span class="text-red-500">*</span>
          </label>
          <div class="grid grid-cols-2 gap-2 mt-2">
            <template x-for="preset in suggestionsForSpecies" :key="preset">
              <button type="button" @click="vaccineName = preset"
                      :class="vaccineName === preset
                        ? 'bg-mmp-ink text-white border-mmp-ink'
                        : 'bg-white border-slate-200 text-mmp-ink hover:border-mmp-ink'"
                      class="px-2 py-2 rounded-xl border-2 font-medium text-xs transition text-left">
                <span x-text="preset"></span>
              </button>
            </template>
          </div>
          <input type="text" x-model="vaccineName" maxlength="200"
                 placeholder="Hoặc gõ tên vaccine cụ thể (vd: Nobivac Tricat Trio)"
                 class="mt-2 w-full px-3 py-2 rounded-xl border border-slate-200 text-sm focus:border-mmp-ink focus:outline-none">
        </div>

        {/* Q1' · Edit-mode read-only name display */}
        <div x-show="isEditMode" class="rounded-xl bg-mmp-cream border border-amber-100 p-3">
          <p class="text-[10px] uppercase tracking-widest text-slate-500 font-bold mb-1">Tên vaccine (không sửa được)</p>
          <p class="text-sm font-bold text-mmp-ink" x-text="vaccineName"></p>
        </div>

        {/* Q2 · Date tiêm */}
        <div>
          <label class="text-xs font-bold text-mmp-ink uppercase tracking-widest inline-flex items-center gap-1.5">
            <FeatureIcon name="calendar" class="w-3.5 h-3.5" strokeWidth={2} style="color: var(--c-gold);" />
            Ngày tiêm <span class="text-red-500">*</span>
          </label>
          <input type="date" x-model="administeredDate" :max="todayIso"
                 class="mt-2 w-full px-3 py-2 rounded-xl border border-slate-200 text-mmp-ink text-sm focus:border-mmp-ink focus:outline-none">
        </div>

        {/* Q3 · Brand + Clinic (compact 2-col) */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-bold text-mmp-ink uppercase tracking-widest">Brand (tuỳ chọn)</label>
            <input type="text" x-model="brand" maxlength="100"
                   placeholder="VD: Nobivac"
                   class="mt-1.5 w-full px-3 py-2 rounded-xl border border-slate-200 text-sm focus:border-mmp-ink focus:outline-none">
          </div>
          <div>
            <label class="text-xs font-bold text-mmp-ink uppercase tracking-widest">Phòng khám (tuỳ chọn)</label>
            <input type="text" x-model="clinicName" maxlength="200"
                   placeholder="VD: PK Thú y A · Q3"
                   class="mt-1.5 w-full px-3 py-2 rounded-xl border border-slate-200 text-sm focus:border-mmp-ink focus:outline-none">
          </div>
        </div>

        {/* Q4 · Notes — kitchen sink (vet name + batch + side effects + price) */}
        <div>
          <label class="text-xs font-bold text-mmp-ink uppercase tracking-widest inline-flex items-center gap-1.5">
            <FeatureIcon name="info" class="w-3.5 h-3.5" strokeWidth={2} />
            Ghi chú (tuỳ chọn)
          </label>
          <textarea x-model="notes" rows="3" maxlength="2000"
                    placeholder="VD: BS Nguyễn A · Lô NB2024-A123 · Giá 350k · Sau tiêm OK"
                    class="mt-1.5 w-full px-3 py-2 rounded-xl border border-slate-200 text-sm focus:border-mmp-ink focus:outline-none resize-none"></textarea>
          <p class="text-[10px] text-slate-400 mt-1">Gợi ý: tên BS, lô vaccine, giá tiền, tác dụng phụ — tất cả ghi vào đây</p>
        </div>

        {/* Q5 · Photo attachments (collapsed) — +20đ bonus when at least one attached */}
        <details class="group">
          <summary class="cursor-pointer list-none inline-flex items-center gap-1.5 text-xs font-bold hover:underline" style="color: var(--c-gold);">
            <FeatureIcon name="camera" class="w-3.5 h-3.5" strokeWidth={2} />
            Đính kèm ảnh (tuỳ chọn — +20đ thêm Pet Score)
            <FeatureIcon name="chevron-down" class="w-3 h-3 transition-transform group-open:rotate-180" strokeWidth={2} />
          </summary>
          <div class="mt-3 space-y-3">
            {/* Photo 1 · paper booklet */}
            <div>
              <label class="text-[10px] uppercase tracking-widest text-mmp-ink font-bold mb-1.5 block">
                Ảnh sổ tiêm giấy
              </label>
              <template x-if="!proofPhotoUrl && !uploadingProof">
                <label class="block p-3 rounded-xl border-2 border-dashed border-slate-300 hover:border-mmp-ink cursor-pointer text-center transition">
                  <input type="file" accept="image/*" @change="uploadPhoto($event, 'proof')" class="hidden">
                  <FeatureIcon name="camera" class="w-5 h-5 text-slate-400 mx-auto mb-1" strokeWidth={1.8} />
                  <p class="text-xs text-slate-500">Chọn ảnh sổ giấy (≤5MB)</p>
                </label>
              </template>
              <template x-if="uploadingProof">
                <div class="p-3 rounded-xl border border-slate-200 bg-slate-50 text-center">
                  <svg class="w-4 h-4 animate-spin mx-auto text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="9" stroke-dasharray="40" stroke-dashoffset="10" stroke-linecap="round"/>
                  </svg>
                  <p class="text-[11px] text-slate-500 mt-1">Đang upload…</p>
                </div>
              </template>
              <template x-if="proofPhotoUrl && !uploadingProof">
                <div class="p-3 rounded-xl border border-emerald-200 bg-emerald-50 flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <FeatureIcon name="check" class="w-4 h-4 text-emerald-600 shrink-0" strokeWidth={2.5} />
                    <a :href="proofPhotoUrl" target="_blank" rel="noopener" class="text-xs font-semibold text-emerald-800 truncate hover:underline">Đã upload — xem</a>
                  </div>
                  <button type="button" @click="proofPhotoUrl = ''" class="text-[11px] text-red-600 hover:underline shrink-0">Xoá</button>
                </div>
              </template>
            </div>

            {/* Photo 2 · invoice */}
            <div>
              <label class="text-[10px] uppercase tracking-widest text-mmp-ink font-bold mb-1.5 block">
                Ảnh hoá đơn (proof giá)
              </label>
              <template x-if="!invoicePhotoUrl && !uploadingInvoice">
                <label class="block p-3 rounded-xl border-2 border-dashed border-slate-300 hover:border-mmp-ink cursor-pointer text-center transition">
                  <input type="file" accept="image/*" @change="uploadPhoto($event, 'invoice')" class="hidden">
                  <FeatureIcon name="clipboard" class="w-5 h-5 text-slate-400 mx-auto mb-1" strokeWidth={1.8} />
                  <p class="text-xs text-slate-500">Chọn ảnh hoá đơn (≤5MB)</p>
                </label>
              </template>
              <template x-if="uploadingInvoice">
                <div class="p-3 rounded-xl border border-slate-200 bg-slate-50 text-center">
                  <svg class="w-4 h-4 animate-spin mx-auto text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="9" stroke-dasharray="40" stroke-dashoffset="10" stroke-linecap="round"/>
                  </svg>
                  <p class="text-[11px] text-slate-500 mt-1">Đang upload…</p>
                </div>
              </template>
              <template x-if="invoicePhotoUrl && !uploadingInvoice">
                <div class="p-3 rounded-xl border border-emerald-200 bg-emerald-50 flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <FeatureIcon name="check" class="w-4 h-4 text-emerald-600 shrink-0" strokeWidth={2.5} />
                    <a :href="invoicePhotoUrl" target="_blank" rel="noopener" class="text-xs font-semibold text-emerald-800 truncate hover:underline">Đã upload — xem</a>
                  </div>
                  <button type="button" @click="invoicePhotoUrl = ''" class="text-[11px] text-red-600 hover:underline shrink-0">Xoá</button>
                </div>
              </template>
            </div>
          </div>
        </details>

        {/* Submit row */}
        <div class="flex gap-2 pt-1">
          <button type="button" @click="close()"
                  class="flex-1 bg-white border border-slate-200 text-mmp-ink px-4 py-3 rounded-xl font-medium hover:border-mmp-ink transition">
            Hủy
          </button>
          <button type="button" @click="submit()" :disabled="loading || !vaccineName || !administeredDate"
                  class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-bold text-mmp-ink transition hover:opacity-95 disabled:opacity-50 disabled:cursor-not-allowed"
                  style="background: var(--c-gold);">
            <svg x-show="!loading" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <svg x-show="loading" class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9" stroke-dasharray="40" stroke-dashoffset="10" stroke-linecap="round"/>
            </svg>
            <span x-text="loading ? 'Đang lưu…' : (isEditMode ? 'Cập nhật' : 'Lưu vào sổ')"></span>
          </button>
        </div>

      </div>
    </div>
  </div>

  <script is:inline>
    // Vaccine log modal — single global instance; per-pet buttons dispatch
    // 'open-vaccine-log' with { petId, petName, species }. Posts to the
    // existing /api/v1/pets/:id/vaccines/custom endpoint (no new API surface).
    function vaccineLogModal() {
      const SUGGESTIONS = {
        cat: ["Mũi 4-bệnh (FVRCP/FeLV)", "Mũi dại (Rabies)", "Khác"],
        dog: ["Mũi 7-bệnh (DHPPi-L)", "Mũi dại (Rabies)", "Khác"],
        other: ["Mũi vaccine", "Mũi dại", "Khác"],
      };
      const todayIso = new Date().toISOString().slice(0, 10);
      return {
        open: false,
        loading: false,
        petId: 0,
        petName: "",
        species: "",
        vaccineName: "",
        administeredDate: todayIso,
        brand: "",
        clinicName: "",
        notes: "",
        todayIso,
        // Phase 2A · photo state
        proofPhotoUrl: "",
        invoicePhotoUrl: "",
        uploadingProof: false,
        uploadingInvoice: false,
        // Phase 2C · edit mode
        isEditMode: false,
        editingId: 0,

        get suggestionsForSpecies() {
          const s = String(this.species || "").toLowerCase();
          if (s === "mèo" || s === "meo" || s === "cat") return SUGGESTIONS.cat;
          if (s === "chó" || s === "cho" || s === "dog") return SUGGESTIONS.dog;
          return SUGGESTIONS.other;
        },

        onOpen(detail) {
          this.petId = Number(detail?.petId) || 0;
          this.petName = detail?.petName || "";
          this.species = detail?.species || "";
          this.vaccineName = "";
          this.administeredDate = todayIso;
          this.brand = "";
          this.clinicName = "";
          this.notes = "";
          this.proofPhotoUrl = "";
          this.invoicePhotoUrl = "";
          this.uploadingProof = false;
          this.uploadingInvoice = false;
          this.isEditMode = false;
          this.editingId = 0;
          this.loading = false;
          this.open = true;
        },

        // Phase 2C — open the modal in EDIT mode with a record pre-filled.
        // Detail shape: { petId, petName, recordId, vaccineLabel, administeredDate, brand, clinicName, notes, proofPhotoUrl, invoicePhotoUrl }
        onOpenEdit(detail) {
          this.petId = Number(detail?.petId) || 0;
          this.petName = detail?.petName || "";
          this.species = detail?.species || "";
          this.editingId = Number(detail?.recordId) || 0;
          this.isEditMode = true;
          // Vaccine name is shown read-only — pulled from the label the API rendered.
          this.vaccineName = detail?.vaccineLabel || "Vaccine";
          this.administeredDate = (detail?.administeredDate || todayIso).slice(0, 10);
          this.brand = detail?.brand || "";
          this.clinicName = detail?.clinicName || "";
          // Strip the "[Custom] name — " prefix when prefilling notes so the user
          // sees only their freeform suffix. Server re-prefixes on PATCH if needed.
          const rawNotes = String(detail?.notes || "");
          const m = rawNotes.match(/^\[Custom\]\s+.+?(?:\s+—\s+(.*))?$/);
          this.notes = m ? (m[1] || "") : rawNotes;
          this.proofPhotoUrl = detail?.proofPhotoUrl || "";
          this.invoicePhotoUrl = detail?.invoicePhotoUrl || "";
          this.uploadingProof = false;
          this.uploadingInvoice = false;
          this.loading = false;
          this.open = true;
        },

        close() {
          this.open = false;
          this.isEditMode = false;
          this.editingId = 0;
        },

        async uploadPhoto(event, kind) {
          const input = event.target;
          const file = input?.files?.[0];
          if (!file) return;
          // Client-side size + MIME guard (server enforces too, but fail fast)
          if (file.size > 5 * 1024 * 1024) {
            showVaccineToast("Ảnh quá 5MB — chọn ảnh khác.", false);
            input.value = "";
            return;
          }
          if (!/^image\//.test(file.type)) {
            showVaccineToast("Chỉ JPEG/PNG/WebP.", false);
            input.value = "";
            return;
          }
          if (!this.petId) {
            showVaccineToast("Thiếu pet — đóng modal và thử lại.", false);
            return;
          }
          const isProof = kind === "proof";
          if (isProof) this.uploadingProof = true; else this.uploadingInvoice = true;
          try {
            const fd = new FormData();
            fd.append("photo", file);
            fd.append("kind", kind);
            const res = await fetch(`/api/v1/pets/${this.petId}/vaccines/photo-upload`, {
              method: "POST",
              credentials: "include",
              body: fd,
            });
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              console.error("[vaccine-upload] non-2xx", res.status, body);
              const apiMsg = body?.error?.message || body?.error || body?.message || "";
              const msg = res.status === 401 ? "Hết phiên đăng nhập. Tải lại."
                        : res.status === 413  ? "Ảnh quá 5MB."
                        : res.status === 415  ? "Định dạng ảnh không hỗ trợ."
                        : res.status >= 500   ? (apiMsg ? `Lỗi server: ${apiMsg}` : `Lỗi server (${res.status})`)
                        : apiMsg || `Lỗi upload (${res.status}).`;
              showVaccineToast(msg, false);
              return;
            }
            if (isProof) this.proofPhotoUrl = body.url || ""; else this.invoicePhotoUrl = body.url || "";
            showVaccineToast(isProof ? "Ảnh sổ giấy đã upload." : "Ảnh hoá đơn đã upload.", true);
          } catch (e) {
            console.error("[vaccine-upload] network err", e);
            const offline = typeof navigator !== "undefined" && navigator.onLine === false;
            showVaccineToast(offline ? "Mất kết nối — kiểm tra wifi." : `Lỗi upload: ${e?.message || e}`, false);
          } finally {
            if (isProof) this.uploadingProof = false; else this.uploadingInvoice = false;
            input.value = ""; // reset so user can re-pick the same file after a Xoá
          }
        },

        async submit() {
          if (!this.vaccineName || !this.administeredDate) {
            showVaccineToast("Cần ít nhất tên mũi + ngày tiêm.", false);
            return;
          }
          if (!this.petId) {
            showVaccineToast("Thiếu pet — đóng modal và thử lại.", false);
            return;
          }
          this.loading = true;
          // Phase 2C — branch on edit mode: POST /custom (create) vs PATCH /:id (edit).
          // PATCH body intentionally omits vaccine_name (server preserves [Custom] prefix).
          const isEdit = this.isEditMode && this.editingId > 0;
          const url = isEdit
            ? `/api/v1/pets/${this.petId}/vaccines/${this.editingId}`
            : `/api/v1/pets/${this.petId}/vaccines/custom`;
          const method = isEdit ? "PATCH" : "POST";
          const payload = isEdit
            ? {
                administered_date: this.administeredDate,
                brand: this.brand || null,
                clinic_name: this.clinicName || null,
                notes: this.notes || null,
                proof_photo_url: this.proofPhotoUrl || null,
                invoice_photo_url: this.invoicePhotoUrl || null,
              }
            : {
                vaccine_name: this.vaccineName,
                administered_date: this.administeredDate,
                brand: this.brand || null,
                clinic_name: this.clinicName || null,
                notes: this.notes || null,
                proof_photo_url: this.proofPhotoUrl || null,
                invoice_photo_url: this.invoicePhotoUrl || null,
              };
          console.log(`[vaccine-log] ${method}`, url, { isEdit, vaccineName: this.vaccineName });
          try {
            const res = await fetch(url, {
              method,
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              console.error("[vaccine-log] non-2xx", res.status, body);
              const apiMsg = body?.error?.message || body?.error || body?.message || "";
              const msg = res.status === 401 ? "Hết phiên đăng nhập. Tải lại."
                        : res.status === 404 ? "Không tìm thấy bé."
                        : res.status === 403 ? "Không có quyền với bé này."
                        : res.status >= 500   ? (apiMsg ? `Lỗi server: ${apiMsg}` : `Lỗi server (${res.status})`)
                        : apiMsg || `Lỗi ${res.status}. Thử lại.`;
              showVaccineToast(msg, false);
              return;
            }
            if (navigator.vibrate) { try { navigator.vibrate(15); } catch (_) {} }
            if (isEdit) {
              showVaccineToast("Đã cập nhật record.", true);
            } else {
              const bonus = body.pet_score_bonus || 0;
              const photoSuffix = body.has_photo ? " (có ảnh proof!)" : "";
              showVaccineToast(bonus > 0 ? `+${bonus}đ Pet Score${photoSuffix} — đã ghi vào sổ` : "Đã ghi vào sổ — bé an toàn hơn rồi!", true);
            }
            this.close();
            setTimeout(() => window.location.reload(), 900);
          } catch (e) {
            console.error("[vaccine-log] network err", e);
            const offline = typeof navigator !== "undefined" && navigator.onLine === false;
            showVaccineToast(offline ? "Mất kết nối — kiểm tra wifi." : `Lỗi kết nối: ${e?.message || e}`, false);
          } finally {
            this.loading = false;
          }
        },
      };
    }

    function showVaccineToast(message, success) {
      const t = document.createElement("div");
      t.className =
        "fixed top-20 left-1/2 -translate-x-1/2 z-[70] px-4 py-2.5 rounded-xl shadow-lg text-sm font-medium pointer-events-auto transition-all " +
        (success ? "bg-mmp-ink text-white" : "bg-red-50 border border-red-200 text-red-700");
      if (success) t.style.boxShadow = "0 8px 24px -8px rgba(236, 185, 33, 0.4)";
      t.textContent = message;
      t.style.opacity = "0";
      t.style.transform = "translate(-50%, -8px)";
      document.body.appendChild(t);
      requestAnimationFrame(() => {
        t.style.opacity = "1";
        t.style.transform = "translate(-50%, 0)";
      });
      setTimeout(() => {
        t.style.opacity = "0";
        t.style.transform = "translate(-50%, -8px)";
        setTimeout(() => t.remove(), 250);
      }, 2800);
    }

    // Phase 2C — delete a vaccine record. Confirms first, then DELETE → reload.
    async function deleteVaccineRecord(petId, recordId, vaccineLabel) {
      const labelText = vaccineLabel ? `"${vaccineLabel}"` : "record";
      if (!confirm(`Xoá ${labelText} vĩnh viễn? Không thể khôi phục.`)) return;
      const url = `/api/v1/pets/${petId}/vaccines/${recordId}`;
      console.log("[vaccine-delete] DELETE", url);
      try {
        const res = await fetch(url, {
          method: "DELETE",
          credentials: "include",
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          console.error("[vaccine-delete] non-2xx", res.status, body);
          const apiMsg = body?.error?.message || body?.error || body?.message || "";
          const msg = res.status === 401 ? "Hết phiên đăng nhập. Tải lại."
                    : res.status === 404 ? "Không tìm thấy record (đã xoá?)."
                    : res.status === 403 ? "Không có quyền xoá."
                    : res.status >= 500   ? (apiMsg ? `Lỗi server: ${apiMsg}` : `Lỗi server (${res.status})`)
                    : apiMsg || `Lỗi ${res.status}.`;
          showVaccineToast(msg, false);
          return;
        }
        if (navigator.vibrate) { try { navigator.vibrate(15); } catch (_) {} }
        showVaccineToast("Đã xoá record.", true);
        setTimeout(() => window.location.reload(), 700);
      } catch (e) {
        console.error("[vaccine-delete] network err", e);
        const offline = typeof navigator !== "undefined" && navigator.onLine === false;
        showVaccineToast(offline ? "Mất kết nối — kiểm tra wifi." : `Lỗi: ${e?.message || e}`, false);
      }
    }
    // Expose globally so onclick handlers in the matched_items list can reach it.
    window.deleteVaccineRecord = deleteVaccineRecord;

    // Phase 2C — dispatch edit modal with the record's full context.
    // Called via onclick from matched_items list rows (cannot use Alpine
    // directives outside an x-data scope).
    function openVaccineEdit(petId, petName, species, recordId, vaccineLabel, administeredDate, brand, clinicName, notes, proofPhotoUrl, invoicePhotoUrl) {
      window.dispatchEvent(new CustomEvent("open-vaccine-edit", {
        detail: { petId, petName, species, recordId, vaccineLabel, administeredDate, brand, clinicName, notes, proofPhotoUrl, invoicePhotoUrl },
      }));
    }
    window.openVaccineEdit = openVaccineEdit;
  </script>

  <style is:global>
    @media print {
      header, nav, button, .print\:hidden, [class*="print:hidden"] { display: none !important; }
      body, main { background: white !important; }
      section, article { break-inside: avoid; }
    }
  </style>
</Layout>
