---
/**
 * FosterCertificate — chứng thư công khai cho bé foster (/p/[slug], nhánh isFosterPublic).
 * Nền đen + vàng đồng + giấy ngà. Đường cong cân (weight_logs) tự vẽ, vaccine timeline,
 * nhật ký 4-metric, PassportStamp dập xuống. CHỈ render data thật từ object pet (FOSTER
 * whitelist L1) — thiếu data → ẩn block, KHÔNG bịa.
 *
 * Lưu ý kỹ thuật:
 *  - PassportStamp (L2a) hardcode class .hero-stamp (định vị pet-detail). Ở đây override
 *    vị trí bằng selector ghép :global(.cert-stamp.hero-stamp) (specificity cao hơn global)
 *    → KHÔNG sửa PassportStamp, KHÔNG đụng global.css.
 *  - Không có target_weight trong whitelist → KHÔNG vẽ "band khoẻ mạnh" (tránh bịa);
 *    dùng area-fill gradient dưới đường cong (trang trí).
 */
import PassportStamp from "./PassportStamp.astro";
import { calculatePetAge } from "@shared/public-pet-fields.ts";
import { FOSTER_PACKAGES } from "../lib/foster-packages.ts";

interface Props {
  pet: any;
  shareUrl?: string;
}
const { pet, shareUrl = "" } = Astro.props;

const name = pet.name || "Bé";
const petCode = pet.public_slug || (pet.id ? "VV-" + pet.id : ""); // mã bé cho lời nhắn Zalo (L4c)
const species = pet.species || null;
const breed = pet.breed || null;
const fosterStatus = pet.foster_status || null;
const adoptionStory = (pet.adoption_story || "").trim();
const publicBio = (pet.public_bio || "").trim();

const speciesVi = species === "dog" ? "Chó" : species === "cat" ? "Mèo" : species ? "Thú cưng" : "";

let ageStr = "";
const age = calculatePetAge(pet.dob_yearmonth);
if (age) {
  if (age.years === 0 && age.months > 0) ageStr = `${age.months} tháng tuổi`;
  else if (age.years > 0 && age.months === 0) ageStr = `${age.years} tuổi`;
  else if (age.years > 0) ageStr = `${age.years} tuổi ${age.months} tháng`;
}

// Server-side date format dd/mm/yyyy
function fmtDate(iso: any): string {
  if (!iso) return "";
  const m = String(iso).match(/^(\d{4})-(\d{2})-(\d{2})/);
  return m ? `${m[3]}/${m[2]}/${m[1]}` : String(iso).slice(0, 10);
}

// ── Weight logs → đường cong cân ──────────────────────────────
const rawW = Array.isArray(pet.foster_weight_logs) ? pet.foster_weight_logs : [];
const weights = rawW
  .filter((w: any) => w && w.weight_kg != null && w.logged_at)
  .map((w: any) => ({ kg: Number(w.weight_kg), at: String(w.logged_at) }))
  .filter((w: any) => Number.isFinite(w.kg))
  .sort((a: any, b: any) => a.at.localeCompare(b.at));

const hasChart = weights.length >= 2;
const VBW = 600, VBH = 240, PADX = 44, PADYT = 26, PADYB = 42;
let curvePath = "", areaPath = "";
let pts: Array<{ x: number; y: number; kg: number; at: string }> = [];
let firstKg = 0, lastKg = 0, weightDelta = 0;
if (hasChart) {
  firstKg = weights[0].kg;
  lastKg = weights[weights.length - 1].kg;
  weightDelta = +(lastKg - firstKg).toFixed(1);
  const kgs = weights.map((w: any) => w.kg);
  let lo = Math.min(...kgs), hi = Math.max(...kgs);
  if (lo === hi) { lo -= 0.5; hi += 0.5; }
  const pad = (hi - lo) * 0.18;
  lo -= pad; hi += pad;
  const n = weights.length;
  pts = weights.map((w: any, i: number) => {
    const x = PADX + (n === 1 ? 0 : (i / (n - 1)) * (VBW - PADX * 2));
    const y = PADYT + (1 - (w.kg - lo) / (hi - lo)) * (VBH - PADYT - PADYB);
    return { x: +x.toFixed(1), y: +y.toFixed(1), kg: w.kg, at: w.at };
  });
  curvePath = pts.map((p, i) => (i === 0 ? `M ${p.x} ${p.y}` : `L ${p.x} ${p.y}`)).join(" ");
  areaPath = `${curvePath} L ${pts[pts.length - 1].x} ${VBH - PADYB} L ${pts[0].x} ${VBH - PADYB} Z`;
}

// ── Vaccine timeline ──────────────────────────────────────────
const rawV = Array.isArray(pet.foster_vaccines) ? pet.foster_vaccines : [];
const vaccines = rawV
  .filter((v: any) => v && (v.vaccine_type || v.administered_date))
  .map((v: any) => ({ type: v.vaccine_type || "Vaccine", date: v.administered_date || null, status: v.status || null }))
  .sort((a: any, b: any) => String(a.date || "").localeCompare(String(b.date || "")));

// ── Nhật ký 4-metric (mới nhất trước, tối đa 3) ───────────────
const rawD = Array.isArray(pet.foster_daily) ? pet.foster_daily : [];
const daily = rawD
  .filter((d: any) => d && d.check_date)
  .sort((a: any, b: any) => String(b.check_date).localeCompare(String(a.check_date)))
  .slice(0, 3);

// ── Dòng tóm tắt hero ─────────────────────────────────────────
let summary = adoptionStory || publicBio || "";
if (summary.length > 150) summary = summary.slice(0, 147).trimEnd() + "…";
const weightLine = hasChart
  ? `${firstKg} kg → ${lastKg} kg${weightDelta > 0 ? ` (+${weightDelta} kg)` : ""}`
  : "";
---

<main class="foster-cert min-h-screen" style="background:#0c0a08;">
  <div class="relative max-w-2xl mx-auto px-4 py-10 sm:py-14">

    {/* ===== HERO ĐEN + VÀNG ĐỒNG ===== */}
    <section class="cert-hero relative rounded-3xl px-6 py-10 sm:px-10 sm:py-12 overflow-hidden">
      <PassportStamp animate={true} class="cert-stamp" />

      <p class="cert-eyebrow">Chứng nhận hồ sơ foster · Mon Min Pet</p>
      <h1 class="cert-name">{name}</h1>
      <p class="cert-sub">
        {[speciesVi, breed, ageStr].filter(Boolean).join(" · ")}
      </p>

      {fosterStatus && (
        <span class="cert-pill">
          <span class="cert-pill__dot"></span>
          {fosterStatus}
        </span>
      )}

      {(summary || weightLine) && (
        <p class="cert-summary">
          {summary}
          {weightLine && <span class="cert-summary__w"> {summary ? "· " : ""}{weightLine}</span>}
        </p>
      )}
    </section>

    {/* ===== RECOVERY CHART (signature) ===== */}
    <section class="cert-block">
      <h2 class="cert-h2">Hành trình cân nặng</h2>
      {hasChart ? (
        <div class="cert-chartwrap">
          <svg viewBox={`0 0 ${VBW} ${VBH}`} class="cert-chart" role="img" aria-label={`Đường cong cân nặng ${name}: ${firstKg}kg đến ${lastKg}kg`}>
            <defs>
              <linearGradient id="cert-area" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ecb921" stop-opacity="0.34" />
                <stop offset="100%" stop-color="#ecb921" stop-opacity="0" />
              </linearGradient>
              <linearGradient id="cert-stroke" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#B48608" />
                <stop offset="100%" stop-color="#ecb921" />
              </linearGradient>
            </defs>
            {/* baseline */}
            <line x1={PADX} y1={VBH - PADYB} x2={VBW - PADX} y2={VBH - PADYB} stroke="#3a3326" stroke-width="1" />
            {/* area fill */}
            <path d={areaPath} fill="url(#cert-area)" />
            {/* đường cong tự vẽ */}
            <path id="cert-curve" d={curvePath} fill="none" stroke="url(#cert-stroke)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
            {/* điểm + label đầu/cuối */}
            {pts.map((p, i) => (
              <g>
                <circle cx={p.x} cy={p.y} r={i === 0 || i === pts.length - 1 ? 5 : 3} fill={i === pts.length - 1 ? "#ecb921" : "#B48608"} stroke="#0c0a08" stroke-width="1.5" />
                {(i === 0 || i === pts.length - 1) && (
                  <text x={p.x} y={p.y - 12} text-anchor="middle" fill="#ecb921" font-size="15" font-weight="700" font-family="Azeret Mono, monospace">{p.kg}kg</text>
                )}
              </g>
            ))}
            <text x={pts[0].x} y={VBH - PADYB + 22} text-anchor="middle" fill="#8a7a52" font-size="12" font-family="Inter, sans-serif">{fmtDate(pts[0].at)}</text>
            <text x={pts[pts.length - 1].x} y={VBH - PADYB + 22} text-anchor="middle" fill="#8a7a52" font-size="12" font-family="Inter, sans-serif">{fmtDate(pts[pts.length - 1].at)}</text>
          </svg>
        </div>
      ) : (
        <p class="cert-empty">Đang cập nhật cân nặng — cần ít nhất 2 lần ghi để vẽ hành trình.</p>
      )}
    </section>

    {/* ===== GIẤY NGÀ: vaccine + nhật ký ===== */}
    {(vaccines.length > 0 || daily.length > 0) && (
      <div class="cert-paper rounded-3xl px-6 py-8 sm:px-9">

        {vaccines.length > 0 && (
          <section class="mb-7">
            <h2 class="cert-h2 cert-h2--ink">Lịch sử vaccine</h2>
            <ul class="cert-vax">
              {vaccines.map((v) => (
                <li class="cert-vax__row">
                  <span class="cert-vax__dot"></span>
                  <span class="cert-vax__type">{v.type}</span>
                  {v.date && <span class="cert-vax__date">{fmtDate(v.date)}</span>}
                  {v.status && <span class="cert-vax__status">{v.status}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}

        {daily.length > 0 && (
          <section>
            <h2 class="cert-h2 cert-h2--ink">Nhật ký gần đây</h2>
            <div class="cert-daily">
              {daily.map((d: any) => (
                <div class="cert-daily__card">
                  <p class="cert-daily__date">{fmtDate(d.check_date)}</p>
                  <div class="cert-daily__metrics">
                    {d.appetite && <span><b>Ăn:</b> {d.appetite}</span>}
                    {d.energy && <span><b>Năng lượng:</b> {d.energy}</span>}
                    {d.stool_quality && <span><b>Phân:</b> {d.stool_quality}</span>}
                    {d.water_ml != null && <span><b>Nước:</b> {d.water_ml} ml</span>}
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </div>
    )}

    {/* ===== CTA + MODAL gói (L4b) ===== */}
    <div class="text-center mt-9" x-data={`fosterSponsor(${JSON.stringify(FOSTER_PACKAGES)}, ${JSON.stringify(name)}, ${JSON.stringify(petCode)}, ${JSON.stringify(shareUrl)})`}>
      <button type="button" class="cert-cta" @click="open()">Góp gói nuôi {name}</button>
      <p class="cert-cta__note">Mỗi gói = thức ăn + chăm sóc thật, minh bạch qua hồ sơ trên.</p>

      {/* L4d-B: Share — lan bé tìm nhà */}
      <div class="mt-4">
        <button type="button" class="cert-share" @click="share()">Chia sẻ bé {name}</button>
        <p class="cert-share__toast" x-show="shareToast" style="display:none;">✓ Đã copy link! Dán lên Facebook/Zalo để giúp bé tìm nhà 💛</p>
      </div>

      {/* Modal */}
      <div x-show="show" style="display:none;" class="fp-overlay"
        @keydown.escape.window="close()" @click.self="close()">
        <div class="fp-modal" role="dialog" aria-modal="true" aria-label="Chọn gói góp nuôi">
          <button type="button" class="fp-close" @click="close()" aria-label="Đóng">✕</button>
          <h3 class="fp-title">Góp gói nuôi <span x-text="petName"></span></h3>
          <p class="fp-sub">Chọn 1 gói — MonMin lo phần còn lại.</p>

          <div class="fp-list">
            <template x-for="pkg in packages" :key="pkg.id">
              <button type="button" class="fp-card"
                :class="{ 'fp-card--sel': selectedId === pkg.id, 'fp-card--pop': pkg.popular }"
                @click="select(pkg.id)">
                <span class="fp-badge" x-show="pkg.popular">Phổ biến nhất</span>
                <span class="fp-card__title" x-text="pkg.title"></span>
                <span class="fp-card__price" x-text="pkg.priceLabel"></span>
                <span class="fp-card__contents" x-text="pkg.contents"></span>
                <span class="fp-check" x-show="selectedId === pkg.id" aria-hidden="true">✓</span>
              </button>
            </template>
          </div>

          <input type="text" x-model="donorName" maxlength="60" x-show="!notice" style="display:none;"
            placeholder="Tên bạn (không bắt buộc — bỏ trống = ẩn danh)" class="fp-donor" />
          <button type="button" class="fp-continue" @click="proceed()" x-show="!notice">Tiếp tục</button>

          <div class="fp-notice" x-show="notice" style="display:none;">
            <p class="fp-notice__t" x-show="copyOk" style="display:none;">✓ Đã copy lời nhắn! Mở Zalo, dán (Ctrl/Cmd + V) rồi gửi cho MonMin để chốt gói nhé 💛</p>
            <div x-show="!copyOk" style="display:none;">
              <p class="fp-notice__t">Copy lời nhắn này gửi MonMin qua Zalo:</p>
              <div class="fp-notice__box" x-text="lastMsg" style="user-select:all; -webkit-user-select:all;"></div>
            </div>
            <a :href="zaloUrl" target="_blank" rel="noopener" class="fp-zalo">Mở Zalo OA MonMin →</a>
          </div>

          <p class="fp-legal">MonMin giao thẳng tới nơi chăm · bạn không xử lý tiền mặt.</p>
        </div>
      </div>
    </div>

    <footer class="cert-footer">
      Powered by <a href="/" class="underline hover:text-[#ecb921]">Mon Min Pet</a>
    </footer>
  </div>
</main>

<style>
  .foster-cert { color: #f3ecdd; }

  /* ── HERO ── */
  .cert-hero {
    background: radial-gradient(120% 90% at 80% 0%, #1c160c 0%, #0c0a08 60%);
    border: 1px solid rgba(236, 185, 33, 0.28);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
  }
  .cert-eyebrow {
    font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase;
    color: #B48608; font-weight: 700; margin-bottom: 10px;
  }
  .cert-name {
    font-family: "Fraunces", Georgia, serif; font-style: italic; font-weight: 600;
    font-size: clamp(2.6rem, 8vw, 4rem); line-height: 1.02; letter-spacing: -0.01em;
    background: linear-gradient(100deg, #B48608 0%, #ecb921 40%, #fff3c4 55%, #ecb921 70%, #8a6505 100%);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    -webkit-text-fill-color: transparent;
  }
  .cert-sub { color: #cdbfa0; font-size: 15px; margin-top: 8px; }
  .cert-pill {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 16px;
    padding: 6px 15px; border-radius: 999px;
    border: 1px solid rgba(236, 185, 33, 0.45); background: rgba(236, 185, 33, 0.08);
    color: #ecb921; font-size: 13px; font-weight: 700; letter-spacing: 0.02em;
  }
  .cert-pill__dot { width: 7px; height: 7px; border-radius: 50%; background: #ecb921; box-shadow: 0 0 8px #ecb921; }
  .cert-summary { margin-top: 18px; color: #ddd2b8; font-size: 15px; line-height: 1.65; max-width: 44ch; }
  .cert-summary__w { color: #ecb921; font-weight: 600; font-family: "Azeret Mono", monospace; }

  /* ── BLOCK / CHART ── */
  .cert-block { margin-top: 28px; }
  .cert-h2 {
    font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase;
    color: #B48608; font-weight: 800; margin-bottom: 14px;
  }
  .cert-h2--ink { color: #9a7b1e; }
  .cert-chartwrap {
    background: linear-gradient(180deg, #15110a 0%, #0c0a08 100%);
    border: 1px solid rgba(236, 185, 33, 0.18); border-radius: 20px; padding: 14px;
  }
  .cert-chart { width: 100%; height: auto; display: block; }
  #cert-curve { stroke-dashoffset: 0; }
  .cert-empty { color: #8a7a52; font-size: 14px; font-style: italic; }

  /* ── GIẤY NGÀ ── */
  .cert-paper {
    margin-top: 26px; background: #FAF6EC; color: #1a1408;
    border: 1px solid #e6dcc3; box-shadow: inset 0 1px 0 #fffdf7, 0 16px 40px rgba(0,0,0,0.4);
  }
  .cert-vax { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .cert-vax__row { display: flex; align-items: center; gap: 10px; font-size: 14px; }
  .cert-vax__dot { width: 9px; height: 9px; border-radius: 50%; background: #B48608; flex: none; box-shadow: 0 0 0 3px rgba(180,134,8,0.16); }
  .cert-vax__type { font-weight: 700; color: #1a1408; }
  .cert-vax__date { color: #6b5d3c; font-family: "Azeret Mono", monospace; font-size: 12.5px; }
  .cert-vax__status {
    margin-left: auto; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    color: #7a5e0c; background: rgba(180,134,8,0.12); padding: 2px 9px; border-radius: 999px;
  }
  .cert-daily { display: grid; gap: 10px; }
  .cert-daily__card { background: #fffdf6; border: 1px solid #ece1c6; border-radius: 14px; padding: 12px 14px; }
  .cert-daily__date { font-size: 11px; font-weight: 700; color: #9a7b1e; font-family: "Azeret Mono", monospace; margin-bottom: 6px; }
  .cert-daily__metrics { display: flex; flex-wrap: wrap; gap: 6px 16px; font-size: 13.5px; color: #2a2212; }
  .cert-daily__metrics b { color: #6b5d3c; font-weight: 600; }

  /* ── CTA ── */
  .cert-cta {
    display: inline-block; padding: 15px 34px; border-radius: 999px;
    background: linear-gradient(100deg, #B48608, #ecb921); color: #1a1208;
    font-weight: 800; font-size: 16px; letter-spacing: 0.01em; border: none; cursor: pointer;
    box-shadow: 0 10px 28px rgba(236,185,33,0.32); transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .cert-cta:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(236,185,33,0.45); }
  .cert-cta__note { color: #8a7a52; font-size: 12.5px; margin-top: 12px; }
  .cert-share { display: inline-flex; align-items: center; gap: 6px; padding: 10px 22px; border-radius: 999px; background: transparent; border: 1.5px solid rgba(236,185,33,0.55); color: #ecb921; font-weight: 700; font-size: 14px; cursor: pointer; transition: background 0.15s, border-color 0.15s; }
  .cert-share:hover { background: rgba(236,185,33,0.12); border-color: #ecb921; }
  .cert-share__toast { color: #ecd9a0; font-size: 12.5px; margin-top: 10px; }
  .cert-footer { text-align: center; color: #6f6346; font-size: 12px; margin-top: 36px; }

  /* ── MODAL gói (L4b) ── */
  .fp-overlay { position: fixed; inset: 0; z-index: 80; display: flex; align-items: center; justify-content: center; padding: 16px; background: rgba(6,5,3,0.78); backdrop-filter: blur(3px); }
  .fp-modal { position: relative; width: 100%; max-width: 460px; max-height: 90vh; overflow-y: auto; background: radial-gradient(120% 80% at 80% 0%, #1c160c, #0c0a08 70%); border: 1px solid rgba(236,185,33,0.32); border-radius: 22px; padding: 24px 20px 20px; box-shadow: 0 30px 70px rgba(0,0,0,0.6); animation: fp-in 0.28s cubic-bezier(0.22,0.61,0.36,1) both; }
  @keyframes fp-in { 0% { opacity: 0; transform: translateY(16px) scale(0.97); } 100% { opacity: 1; transform: none; } }
  .fp-close { position: absolute; top: 12px; right: 14px; background: none; border: none; color: #8a7a52; font-size: 20px; cursor: pointer; line-height: 1; }
  .fp-close:hover { color: #ecb921; }
  .fp-title { font-family: "Fraunces", Georgia, serif; font-style: italic; font-weight: 600; font-size: 22px; color: #ecb921; padding-right: 24px; }
  .fp-sub { color: #cdbfa0; font-size: 13px; margin-top: 4px; margin-bottom: 16px; }
  .fp-list { display: flex; flex-direction: column; gap: 10px; }
  .fp-card { position: relative; display: block; width: 100%; text-align: left; background: #FAF6EC; color: #1a1408; border: 2px solid #e6dcc3; border-radius: 16px; padding: 14px 16px; cursor: pointer; transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s; }
  .fp-card:hover { transform: translateY(-1px); }
  .fp-card--sel { border-color: #B48608; box-shadow: 0 0 0 3px rgba(236,185,33,0.28); }
  .fp-card--pop { border-color: #ecb921; box-shadow: 0 0 18px rgba(236,185,33,0.32); }
  .fp-card--pop.fp-card--sel { box-shadow: 0 0 0 3px rgba(236,185,33,0.4), 0 0 20px rgba(236,185,33,0.4); }
  .fp-badge { display: inline-block; font-size: 10px; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; color: #1a1208; background: linear-gradient(100deg, #B48608, #ecb921); padding: 2px 9px; border-radius: 999px; margin-bottom: 6px; }
  .fp-card__title { display: block; font-weight: 800; font-size: 16px; color: #1a1408; line-height: 1.2; }
  .fp-card__price { display: block; font-family: "Azeret Mono", monospace; font-weight: 700; font-size: 18px; color: #7a5e0c; margin-top: 2px; }
  .fp-card__contents { display: block; font-size: 12.5px; color: #6b5d3c; margin-top: 5px; line-height: 1.45; }
