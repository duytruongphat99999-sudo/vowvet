---
/**
 * BottomNav — thanh điều hướng app-style (mobile only).
 *
 * Gắn 1 lần ở Layout.astro (sau <slot/>) → phủ mọi trang gated.
 * 5 ô: Trang chủ · Định vị pet (sắp có) · Tìm bạn chơi (giữa, nổi) · Vaccine · Tôi.
 * - lg:hidden (chỉ mobile) · print:hidden · z-40 (dưới modal z-60).
 * - petId fetch client-side /auth/me (pattern TopBar). Chưa có pet → 2 ô trỏ /dashboard.
 * - Active state tính SSR từ `path` (không nháy). Tông brand cream/gold/ink.
 * - Padding đáy = env(safe-area-inset-bottom) cho iOS notch.
 */
import FeatureIcon from "./FeatureIcon.astro";

interface Props {
  path?: string;
}
const { path = "" } = Astro.props;

// Active state (server-side → no flash)
const isHome = path === "/dashboard";
const isPlaydate = path.startsWith("/playdate");
const isVaccine = path.startsWith("/vaccines");
const isMe = /^\/pets\/[^/]+\/?$/.test(path); // /pets/{id} exact (không tính sub-page)
---

<nav
  class="vv-bottomnav lg:hidden print:hidden"
  x-data="bottomNav()"
  x-init="loadPet()"
  aria-label="Điều hướng chính"
>
  <a href="/dashboard" class:list={["vv-bn-item", isHome && "is-active"]} aria-label="Trang chủ">
    <FeatureIcon name="home" class="w-6 h-6" />
    <span>Trang chủ</span>
  </a>

  <!-- Định vị pet — CHƯA build → coming-soon (KHÔNG href chết, bấm hiện toast) -->
  <button type="button" class="vv-bn-item is-pending" aria-label="Định vị pet (sắp có)" @click="pingSoon()">
    <FeatureIcon name="map-pin" class="w-6 h-6" />
    <span>Định vị</span>
  </button>

  <!-- Ô GIỮA — Quét nhãn thức ăn (camera scan, FAB gold nổi). href động theo pet active (pet đầu). -->
  <a
    href="/dashboard"
    :href="petId ? `/pets/${petId}?scan=1` : '/dashboard'"
    class="vv-bn-scan"
    aria-label="Quét nhãn thức ăn"
  >
    <span class="vv-bn-scan__btn"><FeatureIcon name="scan" class="w-7 h-7" /></span>
    <span class="vv-bn-scan__label">Quét</span>
  </a>

  <a href="/vaccines" class:list={["vv-bn-item", isVaccine && "is-active"]} aria-label="Lịch vaccine">
    <FeatureIcon name="syringe" class="w-6 h-6" />
    <span>Vaccine</span>
  </a>

  <a
    href="/dashboard"
    :href="petId ? `/pets/${petId}` : '/dashboard'"
    class:list={["vv-bn-item", isMe && "is-active"]}
    aria-label="Hồ sơ của tôi"
  >
    <FeatureIcon name="user" class="w-6 h-6" />
    <span>Tôi</span>
  </a>

  <!-- Toast "sắp có" cho Định vị pet (position:fixed → không chiếm slot flex) -->
  <div x-show="soon" x-cloak class="vv-bn-toast" role="status" aria-live="polite">Định vị pet — sắp có</div>
</nav>

<script is:inline>
  function bottomNav() {
    return {
      petId: null,
      soon: false,
      _soonT: null,
      async loadPet() {
        try {
          const res = await fetch("/api/v1/auth/me", { credentials: "include" });
          if (!res.ok) return;
          const d = await res.json();
          if (d && Array.isArray(d.pets) && d.pets.length > 0) {
            this.petId = d.pets[0].id;
          }
        } catch (_) {
          /* fail-soft: ô "Tôi" vẫn trỏ /dashboard */
        }
      },
      pingSoon() {
        // Định vị pet chưa build → toast "sắp có", KHÔNG điều hướng
        this.soon = true;
        clearTimeout(this._soonT);
        this._soonT = setTimeout(() => { this.soon = false; }, 1800);
      },
    };
  }
</script>

<style>
  /* self-contained — KHÔNG ghi global token. Dùng var brand đã có ở :root/@theme. */
  .vv-bottomnav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40; /* dưới modal (z-60) + skeleton; trên content */
    display: flex;
    align-items: stretch;
    justify-content: space-around;
    background: var(--color-mmp-cream, #f5f1eb);
    border-top: 1px solid rgba(10, 10, 10, 0.1);
    box-shadow: 0 -2px 12px rgba(10, 10, 10, 0.06);
    padding-bottom: env(safe-area-inset-bottom); /* iOS notch */
  }
  /* Scoped responsive/print hide — cần ở đây vì scoped specificity ([data-astro])
     cao hơn Tailwind lg:hidden/print:hidden → phải tự ẩn trong scope. */
  @media (min-width: 1024px) {
    .vv-bottomnav { display: none; }
  }
  @media print {
    .vv-bottomnav { display: none; }
  }

  .vv-bn-item {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-height: 56px;
    padding: 8px 0 7px;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    color: rgba(10, 10, 10, 0.55);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .vv-bn-item.is-active {
    color: #b48608; /* gold-deep — contrast-safe trên cream */
  }
  /* Định vị = <button> coming-soon → reset native button + dấu pending nhẹ */
  button.vv-bn-item {
    border: 0;
    background: none;
    cursor: pointer;
    font: inherit;
  }
  .vv-bn-item.is-pending {
    opacity: 0.6;
  }

  /* Toast "sắp có" — nổi trên thanh, giữa; tự ẩn theo display (không phụ thuộc RAF) */
  .vv-bn-toast {
    position: fixed;
    left: 50%;
    bottom: calc(4.5rem + env(safe-area-inset-bottom));
    transform: translateX(-50%);
    z-index: 41;
    background: var(--color-mmp-ink, #0a0a0a);
    color: var(--color-mmp-cream, #f5f1eb);
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    padding: 6px 14px;
    border-radius: 9999px;
    box-shadow: 0 4px 14px rgba(10, 10, 10, 0.28);
    pointer-events: none;
  }

  /* QUÉT giữa — nút tròn gold nổi lên trên thanh */
  .vv-bn-scan {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
    padding-bottom: 7px;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    color: #b48608;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .vv-bn-scan__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    margin-top: -26px; /* raise above bar — app-style FAB */
    background: var(--color-mmp-gold, #ecb921);
    color: var(--color-mmp-ink, #0a0a0a);
    border: 4px solid var(--color-mmp-cream, #f5f1eb);
    box-shadow: 0 4px 14px rgba(180, 134, 8, 0.4);
  }
  /* active theo path: đang ở /playdate → ring gold quanh nút giữa */
  .vv-bn-scan.is-here .vv-bn-scan__btn {
    box-shadow: 0 0 0 3px rgba(180, 134, 8, 0.5), 0 4px 14px rgba(180, 134, 8, 0.45);
  }

  @media (prefers-reduced-motion: no-preference) {
    .vv-bn-item {
      transition: color 0.15s ease;
    }
    .vv-bn-scan__btn {
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .vv-bn-scan:active .vv-bn-scan__btn {
      transform: scale(0.94);
    }
  }
</style>
