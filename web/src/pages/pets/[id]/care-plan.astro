          </template>
        </div>

        {/* Q2 · Tần suất uống */}
        <div>
          <label class="text-xs font-bold text-mmp-ink uppercase tracking-widest inline-flex items-center gap-1.5">
            <FeatureIcon name="activity" class="w-3.5 h-3.5 text-emerald-600" strokeWidth={2} />
            Tần suất uống
          </label>
          <div class="grid grid-cols-4 gap-2 mt-2">
            <button type="button" @click="frequency = 'little'"
                    :class="frequency === 'little' ? 'bg-red-50 border-red-400 text-red-800' : 'bg-white border-slate-200 text-mmp-ink'"
                    class="p-2.5 rounded-xl border-2 text-center hover:border-red-300 transition">
              <p class="text-xs font-bold">Ít</p>
            </button>
            <button type="button" @click="frequency = 'normal'"
                    :class="frequency === 'normal' ? 'bg-emerald-50 border-emerald-400 text-emerald-900' : 'bg-white border-slate-200 text-mmp-ink'"
                    class="p-2.5 rounded-xl border-2 text-center hover:border-emerald-300 transition">
              <p class="text-xs font-bold">Bình thường</p>
            </button>
            <button type="button" @click="frequency = 'much'"
                    :class="frequency === 'much' ? 'bg-blue-50 border-blue-400 text-blue-900' : 'bg-white border-slate-200 text-mmp-ink'"
                    class="p-2.5 rounded-xl border-2 text-center hover:border-blue-300 transition">
              <p class="text-xs font-bold">Nhiều</p>
            </button>
            <button type="button" @click="frequency = 'unknown'"
                    :class="frequency === 'unknown' ? 'bg-slate-100 border-slate-400 text-slate-700' : 'bg-white border-slate-200 text-mmp-ink'"
                    class="p-2.5 rounded-xl border-2 text-center hover:border-slate-300 transition">
              <p class="text-xs font-bold">Không rõ</p>
            </button>
          </div>
        </div>

        {/* Q3 · Notes (optional → +10đ instead of +5đ) */}
        <details class="group">
          <summary class="cursor-pointer list-none inline-flex items-center gap-1.5 text-xs font-bold hover:underline" style="color: var(--c-gold);">
            <FeatureIcon name="info" class="w-3.5 h-3.5" strokeWidth={2} />
            Ghi chú thêm (tùy chọn — +10đ thay vì +5đ)
            <FeatureIcon name="chevron-down" class="w-3 h-3 transition-transform group-open:rotate-180" strokeWidth={2} />
          </summary>
          <textarea x-model="notes" rows="2" maxlength="2000"
                    placeholder="VD: Đổi bowl mới, bé thích uống hơn"
                    class="mt-2 w-full px-3 py-2 rounded-xl border border-slate-200 text-sm focus:border-mmp-ink focus:outline-none"></textarea>
        </details>

        {/* Submit row */}
        <div class="flex gap-2 pt-1">
          <button type="button" @click="open = false"
                  class="flex-1 bg-white border border-slate-200 text-mmp-ink px-4 py-3 rounded-xl font-medium hover:border-mmp-ink transition">
            Hủy
          </button>
          <button type="button" @click="submit()" :disabled="loading || !amountMl"
                  class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl font-bold text-mmp-ink transition hover:opacity-95 disabled:opacity-50 disabled:cursor-not-allowed"
                  style="background: var(--c-gold);">
            <svg x-show="!loading" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <svg x-show="loading" class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9" stroke-dasharray="40" stroke-dashoffset="10" stroke-linecap="round"/>
            </svg>
            <span x-text="loading ? 'Đang lưu…' : 'Lưu'"></span>
            <span class="text-xs bg-mmp-ink/15 px-2 py-0.5 rounded-full font-bold" x-text="`+${earnedPoints}đ`"></span>
          </button>
        </div>

      </div>
    </div>
  </div>

  <script is:inline>
    // Alpine factory for the water tracking modal — single instance, triggered
    // via 'open-water-tracker' window event with { itemKey, targetMl }.
    function waterTracker(petId) {
      return {
        open: false,
        loading: false,
        itemKey: "water_main",
        targetMl: 0,
        amountMl: 0,
        customAmount: "",
        frequency: "normal",
        notes: "",

        get earnedPoints() {
          const hasNotes = (this.notes || "").trim().length > 0;
          const nonDefault = this.frequency !== "normal";
          return (hasNotes || nonDefault) ? 10 : 5;
        },

        onOpen(detail) {
          this.itemKey = detail?.itemKey || "water_main";
          this.targetMl = Number(detail?.targetMl) || 0;
          this.amountMl = 0;
          this.customAmount = "";
          this.frequency = "normal";
          this.notes = "";
          this.loading = false;
          this.open = true;
        },

        async submit() {
          if (!this.amountMl || this.amountMl <= 0) {
            showCarePlanToast("Chọn lượng nước bé đã uống.", false);
            return;
          }
          this.loading = true;
          const url = `/api/v1/pets/${petId}/care-plan/water-log`;
          console.log("[water-log] POST", url, { amountMl: this.amountMl, frequency: this.frequency });
          try {
            const res = await fetch(url, {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                item_key: this.itemKey,
                amount_ml: this.amountMl,
                target_ml: this.targetMl,
                frequency: this.frequency,
                notes: this.notes,
              }),
            });
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              console.error("[water-log] non-2xx", res.status, body);
              const apiMsg = body?.error?.message || body?.error || body?.message || "";
              const msg = res.status === 401 ? "Hết phiên đăng nhập. Tải lại."
                        : res.status >= 500    ? (apiMsg ? `Lỗi server: ${apiMsg}` : `Lỗi server (${res.status})`)
                        : apiMsg || `Lỗi ${res.status}. Thử lại.`;
              showCarePlanToast(msg, false);
              return;
            }
            if (navigator.vibrate) { try { navigator.vibrate(15); } catch (_) {} }
            const bonus = body.pet_score_bonus || 0;
            const questMsg = body.quest_completed?.definition?.name
              ? ` + Quest "${body.quest_completed.definition.name}"`
              : "";
            showCarePlanToast(bonus > 0 ? `+${bonus}đ Pet Score${questMsg}` : `Đã ghi nhận${questMsg}`, true);
            if (body.warning) {
              setTimeout(() => showCarePlanToast(body.warning, false), 1100);
            }
            this.open = false;
            setTimeout(() => window.location.reload(), body.warning ? 2400 : 900);
          } catch (e) {
            console.error("[water-log] network err", e);
            const offline = typeof navigator !== "undefined" && navigator.onLine === false;
            showCarePlanToast(offline ? "Mất kết nối — kiểm tra wifi." : `Lỗi kết nối: ${e?.message || e}`, false);
          } finally {
            this.loading = false;
          }
        },
      };
    }

    // Alpine factory for the exercise tracking modal — single instance lives at
    // page bottom; per-item buttons dispatch 'open-exercise-tracker' window
    // event with { itemKey, time, plannedDuration, description }.
    function exerciseTracker(petId) {
      return {
        open: false,
        loading: false,
        itemKey: "",
        time: "",
        plannedDuration: 10,
        description: "",
        actualDuration: 0,
        customDuration: "",
        engagement: "normal",
        symptoms: ["none"],
        notes: "",
        SYMPTOM_OPTIONS: [
          { value: "none",           label: "Không có gì lạ", severity: "ok" },
          { value: "tired_fast",     label: "Mệt nhanh",       severity: "warn" },
          { value: "breathing_hard", label: "Thở dốc",         severity: "danger" },
          { value: "limping",        label: "Đi khập khiễng",  severity: "danger" },
          { value: "reluctant",      label: "Không muốn chơi", severity: "warn" },
          { value: "cough",          label: "Ho",              severity: "danger" },
        ],

        get earnedPoints() {
          const hasNotes = (this.notes || "").trim().length > 0;
          const hasSymptom = this.symptoms.some((s) => s !== "none");
          return (hasNotes || hasSymptom) ? 10 : 5;
        },

        onOpen(detail) {
          this.itemKey = detail.itemKey || "";
          this.time = detail.time || "";
          this.plannedDuration = Number(detail.plannedDuration) || 10;
          this.description = detail.description || "";
          // Reset form
          this.actualDuration = this.plannedDuration;
          this.customDuration = "";
          this.engagement = "normal";
          this.symptoms = ["none"];
          this.notes = "";
          this.loading = false;
          this.open = true;
        },

        toggleSymptom(s) {
          if (s === "none") {
            this.symptoms = ["none"];
            return;
          }
          // Selecting any real symptom auto-removes "none"
          const without = this.symptoms.filter((x) => x !== "none" && x !== s);
          if (this.symptoms.includes(s)) {
            this.symptoms = without.length > 0 ? without : ["none"];
          } else {
            this.symptoms = [...without, s];
          }
        },

        async submit() {
          if (!this.actualDuration || this.actualDuration <= 0) {
            showCarePlanToast("Chọn thời gian thực tế.", false);
            return;
          }
          if (!this.itemKey) {
            showCarePlanToast("Thiếu item_key — đóng modal và thử lại.", false);
            return;
          }
          this.loading = true;
          const url = `/api/v1/pets/${petId}/care-plan/exercise-log`;
          console.log("[exercise-log] POST", url, { itemKey: this.itemKey, actualDuration: this.actualDuration });
          try {
            const res = await fetch(url, {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                item_key: this.itemKey,
                planned_time: this.time,
                planned_duration_min: this.plannedDuration,
                actual_duration_min: this.actualDuration,
                engagement: this.engagement,
                symptoms: this.symptoms,
                notes: this.notes,
              }),
            });
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              console.error("[exercise-log] non-2xx", res.status, body);
              const apiMsg = body?.error?.message || body?.error || body?.message || "";
              const msg = res.status === 401 ? "Hết phiên đăng nhập. Tải lại."
                        : res.status >= 500    ? (apiMsg ? `Lỗi server: ${apiMsg}` : `Lỗi server (${res.status})`)
                        : apiMsg || `Lỗi ${res.status}. Thử lại.`;
              showCarePlanToast(msg, false);
              return;
            }
            if (navigator.vibrate) { try { navigator.vibrate(15); } catch (_) {} }
            const bonus = body.pet_score_bonus || 0;
            const questMsg = body.quest_completed?.definition?.name
              ? ` + Quest "${body.quest_completed.definition.name}"`
              : "";
            showCarePlanToast(bonus > 0 ? `+${bonus}đ Pet Score${questMsg}` : `Đã ghi nhận${questMsg}`, true);
            if (body.warning) {
              setTimeout(() => showCarePlanToast(body.warning, false), 1100);
            }
            this.open = false;
            setTimeout(() => window.location.reload(), body.warning ? 2400 : 900);
          } catch (e) {
            console.error("[exercise-log] network err", e);
            const offline = typeof navigator !== "undefined" && navigator.onLine === false;
            showCarePlanToast(offline ? "Mất kết nối — kiểm tra wifi." : `Lỗi kết nối: ${e?.message || e}`, false);
          } finally {
            this.loading = false;
          }
        },
      };
    }
  </script>
</Layout>
