---
import Layout from "../../layouts/Layout.astro";
import { DOG_BREEDS_VN, CAT_BREEDS_VN } from "../../lib/breeds.ts";

const dogBreedsJson = JSON.stringify(DOG_BREEDS_VN);
const catBreedsJson = JSON.stringify(CAT_BREEDS_VN);
---

<Layout title="Thêm pet mới · VowVet">
  <main class="min-h-screen px-4 sm:px-6 py-8 bg-mmp-cream">
    <div class="max-w-xl mx-auto" x-data={`newPetForm(${dogBreedsJson}, ${catBreedsJson})`}>
      <!-- Header -->
      <div class="mb-6 flex items-center gap-3">
        <a href="/dashboard" class="text-slate-500 hover:text-slate-700 text-sm">← Dashboard</a>
        <span class="text-slate-300">·</span>
        <h1 class="text-xl sm:text-2xl font-bold text-slate-900">Thêm pet mới</h1>
      </div>

      <!-- M3.5: Modal Quick/Full -->
      <template x-if="!mode">
        <div class="space-y-4">
          <p class="text-center text-sm text-slate-500 mb-2">Chọn cách thiết lập hồ sơ cho bé</p>
          <button type="button" @click="setMode('quick')"
            class="w-full bg-white border-2 border-sky-200 hover:border-sky-400 hover:shadow-lg rounded-2xl p-6 text-left transition">
            <div class="flex items-start gap-4">
              <span class="text-4xl">🚀</span>
              <div class="flex-1">
                <h3 class="text-lg font-bold text-slate-900">Quick Setup</h3>
                <p class="text-sm text-slate-600 mt-1">2 phút · chỉ thông tin căn bản</p>
              </div>
              <span class="text-slate-300 text-2xl">›</span>
            </div>
          </button>
          <button type="button" @click="setMode('full')"
            class="w-full bg-white border-2 border-amber-200 hover:border-orange-400 hover:shadow-lg rounded-2xl p-6 text-left transition relative">
            <span class="absolute top-3 right-3 text-xs font-semibold bg-orange-100 text-amber-700 px-2 py-0.5 rounded-full">Khuyến nghị</span>
            <div class="flex items-start gap-4">
              <span class="text-4xl">✨</span>
              <div class="flex-1">
                <h3 class="text-lg font-bold text-slate-900">Full Profile</h3>
                <p class="text-sm text-slate-600 mt-1">10 phút · hồ sơ trọn đời cho bé</p>
                <p class="text-xs text-slate-400 mt-2">Identity · Appearance · Sức khỏe · Tính cách · Lifestyle · Khẩn cấp.</p>
              </div>
              <span class="text-slate-300 text-2xl">›</span>
            </div>
          </button>
        </div>
      </template>

      <form @submit.prevent="submit()" x-show="mode" class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 sm:p-8 space-y-6">
        <!-- Tên -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Tên thú cưng *</label>
          <input
            type="text"
            x-model="pet.name"
            placeholder="VD: Mun, Mit, Bông"
            maxlength="100"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 focus:outline-none"
            required
          />
        </div>

        <!-- Loài -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-3">Loài *</label>
          <div class="grid grid-cols-2 gap-3">
            <button
              type="button"
              @click="pet.species = 'Chó'; pet.breed = ''"
              :class="pet.species === 'Chó' ? 'border-sky-500 bg-sky-50 ring-2 ring-sky-200' : 'border-slate-200 hover:border-sky-300'"
              class="border-2 rounded-xl py-5 px-4 transition flex flex-col items-center gap-2"
            >
              <span class="text-4xl">🐶</span>
              <span class="font-medium text-slate-900">Chó</span>
            </button>
            <button
              type="button"
              @click="pet.species = 'Mèo'; pet.breed = ''"
              :class="pet.species === 'Mèo' ? 'border-sky-500 bg-sky-50 ring-2 ring-sky-200' : 'border-slate-200 hover:border-sky-300'"
              class="border-2 rounded-xl py-5 px-4 transition flex flex-col items-center gap-2"
            >
              <span class="text-4xl">🐱</span>
              <span class="font-medium text-slate-900">Mèo</span>
            </button>
          </div>
        </div>

        <!-- Giống -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Giống (không bắt buộc)</label>
          <input
            type="text"
            x-model="pet.breed"
            :placeholder="pet.species === 'Chó' ? 'VD: Phú Quốc' : pet.species === 'Mèo' ? 'VD: Mèo ta' : 'Chọn loài trước'"
            :disabled="!pet.species"
            list="breed-list"
            maxlength="100"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 focus:outline-none disabled:bg-slate-50 disabled:text-slate-400"
          />
          <datalist id="breed-list">
            <template x-for="b in breedOptions" :key="b">
              <option :value="b"></option>
            </template>
          </datalist>
        </div>

        <!-- DOB -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Ngày sinh (không bắt buộc)</label>
          <input
            type="date"
            x-model="pet.dob"
            :max="todayIso"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 focus:outline-none"
          />
        </div>

        <!-- Gender -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-3">Giới tính (không bắt buộc)</label>
          <div class="grid grid-cols-2 gap-2">
            <template x-for="g in ['Đực', 'Cái']" :key="g">
              <button
                type="button"
                @click="pet.gender = (pet.gender === g ? '' : g)"
                :class="pet.gender === g ? 'border-sky-500 bg-sky-50 ring-2 ring-sky-200' : 'border-slate-200 hover:border-sky-300'"
                class="border-2 rounded-xl py-3 px-2 transition font-medium text-slate-900"
                x-text="g"
              ></button>
            </template>
          </div>
        </div>

        <!-- Weight -->
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">Cân nặng kg (không bắt buộc)</label>
          <input
            type="number"
            inputmode="decimal"
            step="0.1"
            min="0"
            max="200"
            x-model.number="pet.weight_kg"
            placeholder="VD: 4.2"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-sky-500 focus:ring-2 focus:ring-sky-200 focus:outline-none"
          />
        </div>

        <div x-show="error" class="text-sm text-red-600" x-text="error"></div>

        <!-- Actions -->
        <div class="flex gap-3 pt-2">
          <a
            href="/dashboard"
            class="flex-1 text-center bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold py-3 rounded-xl transition"
          >
            Huỷ
          </a>
          <button
            type="submit"
            :disabled="loading || !pet.name.trim() || !pet.species"
            class="flex-1 bg-sky-600 hover:bg-sky-700 disabled:bg-slate-300 text-white font-semibold py-3 rounded-xl transition"
          >
            <span x-show="!loading">Lưu</span>
            <span x-show="loading">Đang lưu…</span>
          </button>
        </div>
      </form>
    </div>
  </main>
</Layout>

<script is:inline>
  function newPetForm(dogBreeds, catBreeds) {
    return {
      loading: false,
      error: "",
      mode: "", // chưa chọn → modal hiện
      setMode(m) { this.mode = m; },
      pet: { name: "", species: "", breed: "", dob: "", gender: "", weight_kg: null },
      get breedOptions() {
        if (this.pet.species === "Chó") return dogBreeds;
        if (this.pet.species === "Mèo") return catBreeds;
        return [];
      },
      get todayIso() { return new Date().toISOString().slice(0, 10); },
      async submit() {
        this.error = "";
        if (!this.pet.name.trim() || !this.pet.species) {
          this.error = "Vui lòng nhập tên và chọn loài";
          return;
        }
        this.loading = true;
        const payload = {
          name: this.pet.name.trim(),
          species: this.pet.species,
          breed: this.pet.breed.trim() || null,
          dob: this.pet.dob || null,
          gender: this.pet.gender || null,
          weight_kg: this.pet.weight_kg || null,
        };
        try {
          const res = await fetch("/api/v1/pets", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const json = await res.json();
          if (!res.ok) {
            this.error = json.error?.message || "Có lỗi xảy ra";
            return;
          }
          // Full → vào wizard hoàn thiện. Quick → tới pet detail.
          if (this.mode === "full") {
            window.location.href = `/pets/${json.pet.id}/profile/complete`;
          } else {
            window.location.href = `/pets/${json.pet.id}`;
          }
        } catch (err) {
          this.error = "Lỗi kết nối. Thử lại nhé";
        } finally {
          this.loading = false;
        }
      },
    };
  }
</script>
