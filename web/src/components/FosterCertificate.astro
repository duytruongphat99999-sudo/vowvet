<script is:inline>
  (function () {
    function drawCurve() {
      var p = document.getElementById("cert-curve");
      if (!p || !p.getTotalLength) return;
      var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      try {
        var len = p.getTotalLength();
        p.style.strokeDasharray = len;
        if (reduce) { p.style.strokeDashoffset = 0; return; }
        p.style.strokeDashoffset = len;
        p.getBoundingClientRect(); // force reflow
        p.style.transition = "stroke-dashoffset 1.7s cubic-bezier(0.4,0,0.2,1)";
        requestAnimationFrame(function () { p.style.strokeDashoffset = 0; });
      } catch (e) {}
    }
    if (document.readyState !== "loading") drawCurve();
    else document.addEventListener("DOMContentLoaded", drawCurve);
  })();
</script>

<script is:inline>
  function fosterSponsor(packages, petName, petCode, shareUrl) {
    var list = Array.isArray(packages) ? packages : [];
    var pop = list.filter(function (p) { return p.popular; })[0];
    return {
      show: false,
      notice: false,
      copyOk: false,
      shareToast: false,
      shareUrl: shareUrl || "",
      petName: petName,
      petCode: petCode || "",
      packages: list,
      selectedId: (pop && pop.id) || (list[0] && list[0].id) || null,
      zaloUrl: "https://zalo.me/1136810892220003266",
      lastMsg: "",
      donorName: "",
      open: function () { this.show = true; this.notice = false; this.copyOk = false; document.body.style.overflow = "hidden"; },
      close: function () { this.show = false; document.body.style.overflow = ""; },
      select: function (id) { this.selectedId = id; },
      get selected() {
        var id = this.selectedId;
        return this.packages.filter(function (p) { return p.id === id; })[0] || null;
      },
      buildMessage: function (orderCode) {
        var p = this.selected;
        var pkg = p ? (p.title + " – " + p.priceLabel) : "gói góp nuôi";
        var ref = orderCode ? (" (đơn " + orderCode + ")") : (this.petCode ? (" (mã " + this.petCode + ")") : "");
        return "Mình muốn góp [" + pkg + "] cho bé " + this.petName + ref +
          " trên VowVet. Gói giao tới nơi đang chăm bé giúp mình nhé.";
      },
      proceed: async function () {
        var p = this.selected;
        // L5a: ghi đơn TRƯỚC để lấy mã. Lỗi ghi đơn KHÔNG chặn người góp (vẫn copy tin fallback).
        var orderCode = "";
        try {
          var res = await fetch("/api/v1/public/foster-order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              pet_slug: this.petCode,
              package_id: p ? p.id : 0,
              package_title: p ? p.title : "",
              package_price: p ? p.price : 0,
              donor_name: this.donorName ? this.donorName.trim() : null
            })
          });
          if (res.ok) { var j = await res.json(); orderCode = j.order_code || ""; }
        } catch (e) { /* offline/lỗi → fallback tin không mã */ }
        var msg = this.buildMessage(orderCode);
        this.lastMsg = msg;
        this.notice = true;
        var self = this;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(msg).then(
            function () { self.copyOk = true; },
            function () { self.copyOk = false; }
          );
        } else {
          this.copyOk = false;
        }
      },
      share: function () {
        var url = this.shareUrl;
        if (!url) return;
        var title = "Giúp bé " + this.petName + " — VowVet";
        if (navigator.share) {
          navigator.share({ title: title, url: url }).catch(function () {});
        } else if (navigator.clipboard && navigator.clipboard.writeText) {
          var self = this;
          navigator.clipboard.writeText(url).then(
            function () { self.shareToast = true; setTimeout(function () { self.shareToast = false; }, 3000); },
            function () {}
          );
        }
      }
    };
  }
</script>
