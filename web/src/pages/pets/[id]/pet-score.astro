    @keyframes hui-spark-twinkle { 0%, 100% { opacity: 0.2; transform: scale(1); } 50% { opacity: 1; transform: scale(1.5); } }
    .hui-coming-soon-pill {
      position: relative; display: inline-block; padding: 4px 12px;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 100%); color: #0a0a0a;
