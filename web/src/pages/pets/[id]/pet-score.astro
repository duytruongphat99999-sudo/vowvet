      <!-- Phase 6: Trend + Community merged -->
      <section class="trend-community bg-white rounded-2xl border-2 border-mmp-cream p-5 mb-4 shadow-sm" aria-labelledby="trend-heading">
        <div class="flex items-center justify-between mb-3">
