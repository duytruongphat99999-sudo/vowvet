                    <FeatureIcon name="clock" class="w-5 h-5" strokeWidth={2} style="color: var(--c-gold);" />
                  </span>
                  <div class="text-left min-w-0">
                    <p class="font-bold text-mmp-ink truncate">Sắp tới</p>
                    <p class="text-xs text-slate-500 truncate">{plan.upcoming.length} sự kiện</p>
