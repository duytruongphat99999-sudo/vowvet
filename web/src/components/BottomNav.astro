---
/**
 * BottomNav — thanh điều hướng app-style (mobile only).
 *
 * Gắn 1 lần ở Layout.astro (sau <slot/>) → phủ mọi trang gated.
 * 5 ô: Trang chủ · Định vị pet (sắp có) · Tìm bạn chơi (giữa, nổi) · Vaccine · Tôi.
 * - lg:hidden (chỉ mobile) · print:hidden · z-40 (dưới modal z-60).
 * - petId fetch client-side /auth/me (pattern TopBar). Chưa có pet → 2 ô trỏ /dashboard.
 * - Active state tính SSR từ `path` (không nháy). Tông brand cream/gold/ink.
 * - Padding đáy = env(safe-area-inset-bottom) cho iOS notch.
 */
import FeatureIcon from "./FeatureIcon.astro";

interface Props {
  path?: string;
}
const { path = "" } = Astro.props;

// Active state (server-side → no flash)
const isHome = path === "/dashboard";
const isPlaydate = path.startsWith("/playdate");
const isVaccine = path.startsWith("/vaccines");
const isTriage = path.startsWith("/triage");
const isMe = /^\/pets\/[^/]+\/?$/.test(path); // /pets/{id} exact (không tính sub-page)
---

<nav
  class="vv-bottomnav lg:hidden print:hidden"
  x-data="bottomNav()"
  x-init="loadPet()"
  aria-label="Điều hướng chính"
>
  <a href="/dashboard" class:list={["vv-bn-item", isHome && "is-active"]} aria-label="Trang chủ">
    <FeatureIcon name="home" class="w-6 h-6" />
    <span>Trang chủ</span>
  </a>

  <a href="/triage" class:list={["vv-bn-item", isTriage && "is-active"]} aria-label="Triage">
    <FeatureIcon name="stethoscope" class="w-6 h-6" />
    <span>Triage</span>
  </a>

  <!-- Ô GIỮA — Quét nhãn thức ăn (camera scan, FAB gold nổi). href động theo pet active (pet đầu). -->
  <button type="button" class="vv-bn-scan" aria-label="Quét nhãn thức ăn" @click="openScanner()">
    <span class="vv-bn-scan__btn"><FeatureIcon name="scan" class="w-7 h-7" /></span>
    <span class="vv-bn-scan__label">Quét</span>
  </button>

  <a href="/vaccines" class:list={["vv-bn-item", isVaccine && "is-active"]} aria-label="Lịch vaccine">
    <FeatureIcon name="syringe" class="w-6 h-6" />
    <span>Vaccine</span>
  </a>

  <a
    href="/dashboard"
    :href="petId ? `/pets/${petId}` : '/dashboard'"
    class:list={["vv-bn-item", isMe && "is-active"]}
    aria-label="Hồ sơ của tôi"
  >
    <FeatureIcon name="user" class="w-6 h-6" />
    <span>Tôi</span>
  </a>

    <!-- vv-fab-scan: input ẩn (camera) + sheet chọn pet -->
    <input type="file" accept="image/jpeg,image/png,image/webp" capture="environment"
           class="vv-fab-scan-input" x-ref="fabScanInput" @change="onScanPick($event)"
           style="position:absolute;width:1px;height:1px;opacity:0;pointer-events:none;" />
    <template x-if="scanSheet">
      <div class="vv-fab-sheet-backdrop" @click="closeSheet()"
           style="position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:60;display:flex;align-items:flex-end;">
        <div class="vv-fab-sheet" @click.stop
             style="background:#fff;width:100%;border-radius:18px 18px 0 0;padding:18px 16px 24px;max-height:70vh;overflow:auto;">
          <div style="font-weight:700;font-size:1.05rem;margin-bottom:4px;">Gán nhãn cho bé nào?</div>
          <div style="color:#666;font-size:.85rem;margin-bottom:14px;" x-show="!scanBusy && !scanErr && scanPets.length >= 1">Chọn thú cưng để lưu kết quả quét.</div>
          <div x-show="scanBusy" style="color:#a06a00;font-size:.9rem;margin-bottom:14px;">⏳ AI của VowVet đang đọc nhãn…</div>
          <!-- Lỗi tải danh sách → cho Thử lại -->
          <div x-show="scanErr && !scanBusy" style="margin-bottom:8px;">
            <div x-text="scanErr" style="color:#c0392b;font-size:.85rem;margin-bottom:12px;"></div>
            <button type="button" @click="retryScanList()"
              style="width:100%;padding:11px;border:1px solid #b48608;border-radius:12px;background:#fff7e6;color:#8b6f47;font-weight:700;cursor:pointer;">Thử lại</button>
          </div>
          <!-- Chưa có thú cưng → nút thêm -->
          <div x-show="!scanBusy && !scanErr && scanPets.length === 0" style="margin-bottom:8px;">
            <div style="color:#666;font-size:.9rem;margin-bottom:12px;">Bạn chưa có thú cưng nào để gán nhãn.</div>
            <button type="button" @click="location.href='/pets/new'"
              style="width:100%;padding:11px;border:1px solid #b48608;border-radius:12px;background:#fff7e6;color:#8b6f47;font-weight:700;cursor:pointer;">Thêm thú cưng</button>
          </div>
          <template x-for="p in scanPets" :key="p.id">
            <button type="button" class="vv-fab-petrow" :disabled="scanBusy" @click="chooseScanPet(p.id)"
              style="display:flex;align-items:center;gap:12px;width:100%;padding:10px 8px;border:none;background:none;border-bottom:1px solid #f0f0f0;cursor:pointer;text-align:left;">
              <img :src="p.photo_url || '/icons/pet-fallback.png'" alt="" onerror="this.style.visibility='hidden'"
                   style="width:42px;height:42px;border-radius:50%;object-fit:cover;background:#eee;flex:none;" />
              <span style="display:flex;flex-direction:column;">
                <span style="font-weight:600;" x-text="p.name"></span>
                <span style="font-size:.8rem;color:#888;" x-text="p.species"></span>
              </span>
            </button>
          </template>
          <button type="button" @click="closeSheet()" :disabled="scanBusy"
            style="margin-top:16px;width:100%;padding:11px;border:1px solid #ddd;border-radius:12px;background:#fafafa;font-weight:600;cursor:pointer;">Huỷ</button>
        </div>
      </div>
    </template>

  </nav>

<!-- IDB handoff cho nav-first scan — gắn ở BottomNav (Layout phủ mọi trang gated) → phủ launcher + FAB + /scan/result. -->
<script is:inline src="/scan-handoff.js"></script>
<script is:inline>
  function bottomNav() {
    return {
    scanSheet: false, scanPets: [], myPets: [], scanFile: null, scanBusy: false, scanErr: "",
    currentPetId() { const m = String(location.pathname).match(/^\/pets\/(\d+)/); return m ? Number(m[1]) : null; },
    openScanner() { this.scanErr=""; this.scanFile=null; if (this.$refs.fabScanInput) this.$refs.fabScanInput.click(); },
    async onScanPick(e) {
      const f = e.target.files && e.target.files[0];
      e.target.value = "";
      if (!f) return;
      if (f.size > 10*1024*1024) { alert("Ảnh tối đa 10MB."); return; }
      this.scanFile = f; this.scanErr=""; this.scanBusy=false;
      // Reuse list pet đã load ở loadPet (né fetch /auth/me lần 2 dễ fail). Chỉ fetch lại nếu list trống.
      let list = this.myPets;
      if (!list || list.length === 0) {
        list = await this.fetchScanList();
        if (list === null) return; // lỗi → fetchScanList đã set scanErr + mở sheet (empty/error state)
      }
      this.decideScan(list);
    },
    // Fetch danh sách pet có guard r.ok (KHÔNG nuốt lỗi im). Trả null + mở sheet error nếu fail.
    async fetchScanList() {
      try {
        const r = await fetch("/api/v1/auth/me", { credentials:"include" });
        if (!r.ok) { this.scanErr = "Không tải được danh sách thú cưng, thử lại."; this.scanSheet = true; return null; }
        const d = await r.json();
        const list = (d && Array.isArray(d.pets)) ? d.pets : [];
        this.myPets = list;
        return list;
      } catch {
        this.scanErr = "Lỗi mạng, không tải được danh sách, thử lại."; this.scanSheet = true; return null;
      }
    },
    // Quyết định theo số pet: 1 → quét thẳng · 0 + đang ở /pets/{id} → quét pet đó · còn lại → mở sheet.
    decideScan(list) {
      this.scanPets = list.slice();
      const here = this.currentPetId();
      if (this.scanPets.length === 1) { this.runScan(this.scanPets[0].id); return; }
      if (this.scanPets.length === 0 && here) { this.runScan(here); return; }
      if (here) this.scanPets.sort((a,b)=> (a.id===here?-1:b.id===here?1:0));
      this.scanSheet = true; // >=2 → list chọn · 0 (không ở pet page) → empty-state "chưa có pet"
    },
    async retryScanList() {
      this.scanErr = "";
      const list = await this.fetchScanList();
      if (list === null) return;
      this.decideScan(list);
    },
    chooseScanPet(id) { this.runScan(id); },
    async runScan(petId) {
      if (!this.scanFile || this.scanBusy) return;
      this.scanBusy = true; this.scanErr="";
      // Nav-first: nhét File vào IndexedDB rồi sang /scan/result NGAY (POST chạy ở trang đó, loading ở đó).
      if (typeof window.scanFilePut === "function") {
        try {
          await window.scanFilePut(petId, this.scanFile);
          window.location.href = `/scan/result?pet=${petId}&pending=1`;
          return;
        } catch (e) { /* IDB lỗi → fallback luồng cũ fetch-rồi-nav */ }
      }
      try {
        const fd = new FormData(); fd.append("photo", this.scanFile);
        const res = await fetch(`/api/v1/pets/${petId}/food/scan`, { method:"POST", credentials:"include", body: fd });
        const j = await res.json();
        if (!res.ok) { this.scanErr = (j && j.error && j.error.message) || "Quét thất bại, thử lại."; this.scanBusy=false; return; }
        try { sessionStorage.setItem("vowvet:scan:"+petId, JSON.stringify(j)); } catch {}
        window.location.href = `/scan/result?pet=${petId}`;
      } catch { this.scanErr = "Lỗi mạng, thử lại."; this.scanBusy=false; }
    },
    closeSheet() { if (this.scanBusy) return; this.scanSheet=false; this.scanFile=null; this.scanErr=""; },

      petId: null,
      async loadPet() {
        try {
          const res = await fetch("/api/v1/auth/me", { credentials: "include" });
          if (!res.ok) return;
          const d = await res.json();
          if (d && Array.isArray(d.pets) && d.pets.length > 0) {
            this.petId = d.pets[0].id;
            this.myPets = d.pets; // giữ full list cho onScanPick reuse (né fetch lần 2)
          }
        } catch (_) {
          /* fail-soft: ô "Tôi" vẫn trỏ /dashboard */
        }
      },
    };
  }
</script>

<style>
  /* self-contained — KHÔNG ghi global token. Dùng var brand đã có ở :root/@theme. */
  .vv-bottomnav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40; /* dưới modal (z-60) + skeleton; trên content */
    display: flex;
    align-items: stretch;
    justify-content: space-around;
    background: var(--color-mmp-cream, #f5f1eb);
    border-top: 1px solid rgba(10, 10, 10, 0.1);
    box-shadow: 0 -2px 12px rgba(10, 10, 10, 0.06);
    padding-bottom: env(safe-area-inset-bottom); /* iOS notch */
  }
  /* Scoped responsive/print hide — cần ở đây vì scoped specificity ([data-astro])
     cao hơn Tailwind lg:hidden/print:hidden → phải tự ẩn trong scope. */
  @media (min-width: 1024px) {
    .vv-bottomnav { display: none; }
  }
  @media print {
    .vv-bottomnav { display: none; }
  }

  .vv-bn-item {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-height: 56px;
    padding: 8px 0 7px;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    color: rgba(10, 10, 10, 0.55);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .vv-bn-item.is-active {
    color: #b48608; /* gold-deep — contrast-safe trên cream */
  }
  button.vv-bn-scan { border: 0; background: none; font: inherit; cursor: pointer; }

  /* QUÉT giữa — nút tròn gold nổi lên trên thanh */
  .vv-bn-scan {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 2px;
    padding-bottom: 7px;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    color: #b48608;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .vv-bn-scan__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    margin-top: -26px; /* raise above bar — app-style FAB */
    background: var(--color-mmp-gold, #ecb921);
    color: var(--color-mmp-ink, #0a0a0a);
    border: 4px solid var(--color-mmp-cream, #f5f1eb);
    box-shadow: 0 4px 14px rgba(180, 134, 8, 0.4);
  }
  /* active theo path: đang ở /playdate → ring gold quanh nút giữa */
  .vv-bn-scan.is-here .vv-bn-scan__btn {
    box-shadow: 0 0 0 3px rgba(180, 134, 8, 0.5), 0 4px 14px rgba(180, 134, 8, 0.45);
  }

  @media (prefers-reduced-motion: no-preference) {
    .vv-bn-item {
      transition: color 0.15s ease;
    }
    .vv-bn-scan__btn {
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .vv-bn-scan:active .vv-bn-scan__btn {
      transform: scale(0.94);
    }
  }
</style>
