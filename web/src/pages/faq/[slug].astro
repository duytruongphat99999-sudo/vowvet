---
/**
 * /faq/[slug] — FAQ article detail (M9.4).
 *
 * Server-rendered markdown via simple parser (no external lib for Phase 0).
 */
import Layout from "../../layouts/Layout.astro";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const slug = Astro.params.slug;
if (!slug) return Astro.redirect("/faq");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let article: any = null;
let loadStatus = 0;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/faq/articles/${slug}`, {
    headers: { cookie: cookieHeader },
  });
  loadStatus = res.status;
  if (res.ok) {
    article = (await res.json()).article;
  }
} catch (_) {}

if (loadStatus === 401) return Astro.redirect("/login");
if (!article) return Astro.redirect("/faq");

// Minimal markdown renderer (h3, paragraph, list, table, bold) — safe for trusted content
function escapeHtml(s: string): string {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

function renderMd(md: string): string {
  const lines = md.split("\n");
  let html = "";
  let inList = false;
  let inTable = false;
  let tableHeaderDone = false;

  const flushList = () => {
    if (inList) {
      html += "</ul>";
      inList = false;
    }
  };
  const flushTable = () => {
    if (inTable) {
      html += "</tbody></table>";
      inTable = false;
      tableHeaderDone = false;
    }
  };

  for (const raw of lines) {
    const line = raw.trimEnd();
    if (!line.trim()) {
      flushList();
      flushTable();
      continue;
    }
    // Heading
    if (line.startsWith("### ")) {
      flushList();
      flushTable();
      html += `<h3 class="text-base font-bold text-slate-900 mt-5 mb-2">${escapeHtml(line.slice(4))}</h3>`;
      continue;
    }
    // Table row
    if (line.startsWith("|")) {
      const cells = line
        .split("|")
        .slice(1, -1)
        .map((c) => c.trim());
      // Separator row "| --- |"
      if (cells.every((c) => /^:?-+:?$/.test(c))) continue;
      if (!inTable) {
        flushList();
        html += '<table class="w-full text-sm border-collapse my-3"><thead><tr>';
        for (const c of cells) {
          html += `<th class="border border-slate-200 bg-slate-50 px-2 py-1 text-left font-semibold">${escapeHtml(c)}</th>`;
        }
        html += "</tr></thead><tbody>";
        inTable = true;
        tableHeaderDone = true;
        continue;
      }
      // Data row
      html += "<tr>";
      for (const c of cells) {
        html += `<td class="border border-slate-200 px-2 py-1">${inlineMd(escapeHtml(c))}</td>`;
      }
      html += "</tr>";
      continue;
    }
    // List
    if (line.startsWith("- ")) {
      flushTable();
      if (!inList) {
        html += '<ul class="list-disc pl-5 space-y-1 my-2 text-sm text-slate-800">';
        inList = true;
      }
      html += `<li>${inlineMd(escapeHtml(line.slice(2)))}</li>`;
      continue;
    }
    // Ordered list
    const ol = line.match(/^(\d+)\.\s+(.+)$/);
    if (ol) {
      flushTable();
      if (!inList) {
        html += '<ol class="list-decimal pl-5 space-y-1 my-2 text-sm text-slate-800">';
        inList = true;
      }
      html += `<li>${inlineMd(escapeHtml(ol[2]))}</li>`;
      continue;
    }
    // Paragraph
    flushList();
    flushTable();
    html += `<p class="my-2 text-sm text-slate-800 leading-relaxed">${inlineMd(escapeHtml(line))}</p>`;
  }
  flushList();
  flushTable();
  return html;
}

function inlineMd(s: string): string {
  // Bold **text** + code `text`
  return s
    .replace(/\*\*(.+?)\*\*/g, '<strong class="font-semibold text-slate-900">$1</strong>')
    .replace(/`(.+?)`/g, '<code class="bg-slate-100 text-slate-700 px-1 py-0.5 rounded text-xs">$1</code>');
}

const renderedContent = renderMd(article.content_md);
---

<Layout title={`${article.title_vi} · FAQ · VowVet`} description={article.summary}>
  <main class="min-h-screen bg-slate-50 px-4 sm:px-6 py-4 pb-12">
    <div class="max-w-2xl mx-auto">
      <header class="flex items-center justify-between mb-4 gap-3">
        <a href="/faq" class="text-sm text-slate-500 hover:text-slate-700">← FAQ</a>
        <h1 class="text-sm font-semibold text-slate-900 truncate flex-1 text-center">{article.title_vi}</h1>
        <button onclick="window.print()" class="text-slate-500 hover:text-slate-700 text-lg" title="In / Lưu PDF">🖨️</button>
      </header>

      <!-- Article header -->
      <div class="bg-white rounded-2xl border border-slate-200 p-5 mb-3">
        <div class="flex items-center gap-2 mb-2 flex-wrap">
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-sky-100 text-sky-800">
            {article.category_label_vi}
          </span>
          {article.species.includes("dog") && <span class="text-sm">🐶 Chó</span>}
          {article.species.includes("cat") && <span class="text-sm">🐱 Mèo</span>}
          {article.species.includes("both") && <span class="text-sm">🐾 Cả 2</span>}
        </div>
        <h2 class="text-xl font-bold text-slate-900 mb-2">{article.title_vi}</h2>
        <p class="text-sm text-slate-600">{article.summary}</p>
        <div class="flex flex-wrap gap-1 mt-3">
          {article.tags.map((t: string) => (
            <span class="text-[10px] text-slate-500 bg-slate-50 border border-slate-200 px-2 py-0.5 rounded-full">#{t}</span>
          ))}
        </div>
      </div>

      <!-- Markdown content -->
      <article class="bg-white rounded-2xl border border-slate-200 p-5 mb-3 prose-style" set:html={renderedContent}></article>

      <!-- When to vet box -->
      <div class="bg-amber-50 border-2 border-amber-300 rounded-2xl p-4 mb-3">
        <h3 class="text-sm font-bold text-amber-900 mb-1">🩺 Khi nào cần khám vet?</h3>
        <p class="text-sm text-amber-900">{article.when_to_vet}</p>
      </div>

      <!-- Related -->
      {article.related_slugs && article.related_slugs.length > 0 && (
        <div class="bg-white rounded-2xl border border-slate-200 p-4">
          <h3 class="text-sm font-semibold text-slate-700 mb-2">📖 Đọc thêm</h3>
          <div class="space-y-1">
            {article.related_slugs.map((sl: string) => (
              <a href={`/faq/${sl}`} class="block text-sm text-sky-600 hover:text-sky-700">› {sl.replace(/-/g, " ")}</a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div class="mt-6 grid grid-cols-2 gap-2">
        <a href={`/chat/new?subject=${encodeURIComponent(`FAQ: ${article.title_vi}`)}`}
          class="bg-sky-600 hover:bg-sky-700 text-white font-semibold py-3 rounded-xl text-center transition">
          💬 Chat với bác sĩ
        </a>
        <a href="/faq"
          class="bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 font-semibold py-3 rounded-xl text-center transition">
          📚 Quay lại FAQ
        </a>
      </div>
    </div>
  </main>

  <style is:global>
    .prose-style table { border-radius: 0.5rem; overflow: hidden; }
    @media print {
      nav, .no-print, header > a, header > button, main > .max-w-2xl > div:last-child { display: none !important; }
      main { background: white !important; }
      a { color: black !important; text-decoration: none !important; }
    }
  </style>

  <!-- Quest hook: fire read_faq trigger as user opened a FAQ article -->
  <script is:inline>
    (() => {
      try {
        fetch("/api/v1/quests/track/read-faq", {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: "{}",
        }).catch(() => {});
      } catch (_) {}
    })();
  </script>
</Layout>
