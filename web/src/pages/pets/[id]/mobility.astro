---
/**
 * /pets/[id]/mobility — Mobility survey (M23).
 */
import Layout from "../../../layouts/Layout.astro";
import FeatureIcon from "../../../components/FeatureIcon.astro";
import { fetchPet } from "../../../lib/api-client.ts";
import { MOBILITY_QUESTIONS, MOBILITY_LABELS } from "@shared/pain-glasgow.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let history: any[] = [];
let latest: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/mobility`, { headers: { cookie: cookieHeader } });
  if (res.ok) {
    const j = await res.json();
    history = j.assessments || [];
    latest = history[0] || null;
  }
} catch (_) {}

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name },
  history, latest,
  questions: MOBILITY_QUESTIONS,
  labels: MOBILITY_LABELS,
});
---

<Layout title={`Vận động · ${pet.name}`} description="Mobility survey — phát hiện sớm vấn đề xương khớp">
  <main class="min-h-screen bg-gradient-to-b from-sky-50 to-slate-800 px-4 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`mobilityPage(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href={`/pets/${pet.id}`} class="text-sm text-slate-500 hover:text-slate-700">← {pet.name}</a>
        <h1 class="text-lg font-bold text-slate-900 inline-flex items-center gap-1.5"><FeatureIcon name="activity-run" class="w-5 h-5" />Vận động</h1>
        <span class="w-12"></span>
      </header>

      <template x-if="latest && view === 'home'">
        <div class="rounded-2xl p-5 shadow-md text-white mb-4" :class="colorClass(latest.level)">
          <div class="flex items-start gap-3">
            <span class="inline-block w-9 h-9 shrink-0" x-html="severityDot(labels[latest.level]?.color)"></span>
            <div class="flex-1 min-w-0">
              <p class="text-xs uppercase opacity-90">Lần gần nhất</p>
              <p class="text-xl font-extrabold" x-text="`${latest.pct_score}% · ${labels[latest.level]?.label}`"></p>
              <p class="text-xs opacity-90 mt-1" x-text="labels[latest.level]?.description"></p>
              <p class="text-[11px] opacity-75 mt-2" x-text="fmtDate(latest.assessed_at)"></p>
            </div>
          </div>
        </div>
      </template>

      <template x-if="view === 'home'">
        <div>
          <button @click="start()"
            class="w-full py-3.5 rounded-2xl bg-gradient-to-r from-sky-600 to-slate-800 hover:opacity-95 text-white font-bold shadow-lg mb-4">
            <span class="inline-flex items-center justify-center gap-1.5"><FeatureIcon name="activity-run" class="w-5 h-5" /><span x-text="latest ? 'Đánh giá lại' : 'Bắt đầu đánh giá vận động'"></span></span>
          </button>
        </div>
      </template>

      <template x-if="view === 'quiz'">
        <div>
          <div class="bg-white rounded-2xl border border-slate-100 p-3 mb-4">
            <div class="flex items-center gap-3 mb-2">
              <button @click="back()" :disabled="qIndex === 0" class="text-xs text-slate-500 disabled:opacity-30">← Trước</button>
              <span class="text-xs font-medium text-slate-700">Câu <span x-text="qIndex + 1"></span>/<span x-text="questions.length"></span></span>
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-sky-500 transition-all" :style="`width: ${((qIndex + 1) / questions.length) * 100}%`"></div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-3xl border border-slate-100 p-5 sm:p-7 shadow-md">
            <h2 class="text-base sm:text-lg font-bold text-slate-900 mb-5" x-text="currentQuestion?.question_vi"></h2>
            <div class="space-y-2">
              <template x-for="opt in currentQuestion?.options || []" :key="opt.score">
                <button @click="choose(opt.score)"
                  :class="answers[currentQuestion?.id] === opt.score ? 'border-sky-500 bg-sky-50 ring-2 ring-sky-200' : 'border-slate-200 hover:border-sky-300'"
                  class="w-full text-left border-2 rounded-xl p-3 transition active:scale-[0.98]">
                  <div class="flex items-center gap-3">
                    <span class="w-7 h-7 shrink-0 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-sm font-bold" x-text="opt.score"></span>
                    <span class="text-sm" x-text="opt.label_vi"></span>
                  </div>
                </button>
              </template>
            </div>
          </div>
        </div>
      </template>

      <template x-if="view === 'loading'">
        <div class="bg-white rounded-3xl p-12 text-center"><p class="mb-3 flex justify-center animate-pulse text-sky-600"><FeatureIcon name="activity-run" class="w-14 h-14" /></p><p class="font-bold">Đang tính điểm...</p></div>
      </template>

      <template x-if="view === 'result' && submittedResult">
        <div>
          <div class="rounded-3xl p-6 text-white shadow-2xl mb-4" :class="colorClass(submittedResult.level)">
            <div class="w-16 h-16 mx-auto mb-3" x-html="severityDot(labels[submittedResult.level]?.color)"></div>
            <p class="text-center text-sm opacity-90 uppercase">Mobility Score</p>
            <p class="text-center text-5xl font-extrabold mt-1" x-text="`${submittedResult.pct_score}%`"></p>
            <p class="text-center text-xl font-bold mt-2" x-text="labels[submittedResult.level]?.label"></p>
            <p class="text-center text-sm opacity-95 mt-3 px-2" x-text="labels[submittedResult.level]?.description"></p>
          </div>
          <button @click="view = 'home'; reload()" class="w-full py-3 rounded-xl bg-slate-100 text-slate-700 font-bold">Xong</button>
        </div>
      </template>

      <template x-if="error">
        <p class="bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700 mt-3" x-text="error"></p>
      </template>

    </div>
  </main>

  <script is:inline>
    function mobilityPage(initial) {
      return {
        pet: initial.pet,
        history: initial.history,
        latest: initial.latest,
        questions: initial.questions,
        labels: initial.labels,
        view: "home",
        qIndex: 0,
        answers: {},
        submittedResult: null,
        error: "",

        get currentQuestion() { return this.questions[this.qIndex]; },

        colorClass(level) {
          if (level === "excellent") return "bg-gradient-to-br from-emerald-500 to-slate-800";
          if (level === "good") return "bg-gradient-to-br from-amber-500 to-yellow-600";
          if (level === "limited") return "bg-gradient-to-br from-orange-500 to-red-500";
          if (level === "severely_limited") return "bg-gradient-to-br from-red-600 to-rose-700";
          return "bg-slate-500";
        },

        // v222: chấm severity SVG (circle-filled) theo tier color — render x-html. Đĩa trắng ngoài cho nổi trên nền card màu.
        severityDot(color) {
          const tone = ({ emerald: "text-emerald-500", yellow: "text-amber-500", orange: "text-orange-500", red: "text-red-500" })[color] || "text-slate-400";
          return '<svg class="' + tone + ' w-full h-full" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="white"/><circle cx="12" cy="12" r="6" fill="currentColor"/></svg>';
        },

        fmtDate(iso) {
          if (!iso) return "—";
          try { return new Date(iso).toLocaleDateString("vi-VN", { day: "2-digit", month: "2-digit", year: "numeric" }); }
          catch { return iso; }
        },

        start() { this.qIndex = 0; this.answers = {}; this.view = "quiz"; this.error = ""; },
        back() { if (this.qIndex > 0) this.qIndex--; },

        choose(score) {
          this.answers[this.currentQuestion.id] = Number(score);
          if (this.qIndex < this.questions.length - 1) this.qIndex++;
          else this.submit();
        },

        async submit() {
          this.view = "loading";
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/mobility`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ answers: this.answers }),
            });
            if (!res.ok) { this.error = "Lỗi lưu"; this.view = "quiz"; return; }
            this.submittedResult = await res.json();
            this.view = "result";
          } catch (_) { this.error = "Lỗi kết nối"; this.view = "quiz"; }
        },

        async reload() {
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/mobility`, { credentials: "include" });
            if (res.ok) { const j = await res.json(); this.history = j.assessments || []; this.latest = this.history[0] || null; }
          } catch (_) {}
        },
      };
    }
  </script>
</Layout>
