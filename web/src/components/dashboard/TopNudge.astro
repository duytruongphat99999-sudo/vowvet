---
/**
 * ZONE 5 — Top nudge: highest-priority opportunity with SVG icon (no emoji).
 */
import FeatureIcon from "../FeatureIcon.astro";

interface NudgeOpportunity {
  type: string;
  priority: number;
  title: string;
  body: string;
  url: string;
  nudge_key: string;
}
interface Props {
  nudge: NudgeOpportunity | null;
}
const { nudge } = Astro.props;

const TYPE_ICON: Record<string, string> = {
  tier_close:         "rocket",
  streak_at_risk:     "flame",
  achievement_close:  "trophy",
  reward_expiring:    "clock",
  profile_completion: "edit-pencil",
};
const icon = nudge ? (TYPE_ICON[nudge.type] || "sparkles") : "sparkles";
---

{nudge && (
  <a
    href={nudge.url || "/dashboard"}
    class="group block p-5 rounded-3xl bg-gradient-to-br from-mmp-cream to-amber-50 border border-amber-200/70 hover:shadow-md hover:border-amber-300 transition-all relative overflow-hidden"
  >
    {/* Decorative gold glow corner */}
    <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full opacity-30 pointer-events-none"
         style="background: radial-gradient(circle, rgba(236,185,33,0.5) 0%, transparent 70%);"></div>

    <div class="relative flex items-start gap-4">
      <div class="flex-shrink-0 inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-white shadow-sm ring-1 ring-amber-200" style="color: var(--c-gold);">
        <FeatureIcon name={icon} class="w-6 h-6" strokeWidth={1.8} />
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-[10px] uppercase tracking-widest font-bold mb-1" style="color: var(--c-gold);">Gợi ý cho bạn</p>
        <p class="font-bold text-mmp-ink leading-snug">{nudge.title}</p>
        <p class="text-sm text-slate-700 mt-1 leading-relaxed line-clamp-2">{nudge.body}</p>
        <div class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-mmp-ink">
          Bắt đầu
          <FeatureIcon name="arrow" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
        </div>
      </div>
    </div>
  </a>
)}
