---
/**
 * /lost/[slug]/sightings/[sightingId] — Owner view of single sighting + AI Match.
 *
 * Side-by-side compare: reference photos vs sighting photo. AI score gauge.
 * Confirm / Dismiss / "Need to see in person" buttons.
 */
import Layout from "../../../../layouts/Layout.astro";
import { getZaloLink } from "../../../../../../shared/contact-info.ts";

const slug = Astro.params.slug as string;
const sightingId = Number(Astro.params.sightingId);
const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let report: any = null;
let sighting: any = null;
let referencePhotos: string[] = [];
let pet: any = null;

try {
  const r = await fetch(`${API_INTERNAL}/api/v1/public/lost/${slug}`);
  if (r.ok) {
    const j = await r.json();
    report = j.report;
    pet = j.pet;
  }
} catch (_) {}
if (!report) return Astro.redirect("/dashboard");
if (report.reporter_user_id !== user.sub) return Astro.redirect(`/lost/${slug}`);

try {
  const r = await fetch(`${API_INTERNAL}/api/v1/lost-pets/${report.id}/sightings/${sightingId}`, { headers: { cookie: cookieHeader } });
  if (r.ok) {
    const j = await r.json();
    sighting = j.sighting;
    referencePhotos = j.reference_photo_urls || [];
  }
} catch (_) {}
if (!sighting) return Astro.redirect(`/lost/${slug}`);

const initialData = JSON.stringify({
  slug,
  reportId: report.id,
  sighting,
  referencePhotos,
  pet,
  zaloUrl: getZaloLink(),
});
---

<Layout title={`Sighting · ${pet?.name || 'Pet'}`} description="Báo thấy bé — AI Match detail">
  <main class="min-h-screen bg-slate-50 px-4 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`sightingPage(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a :href={`/lost/${slug}`} class="text-sm text-slate-500 hover:text-slate-700">← Báo cáo</a>
        <h1 class="text-base font-bold text-slate-900">🔍 Báo thấy bé</h1>
        <span class="text-xs text-slate-500" x-text="fmtRel(sighting.created_at)"></span>
      </header>

      <!-- AI Match gauge -->
      <div :class="tierClasses" class="rounded-3xl p-5 border-2 mb-4 text-center shadow-md">
        <div class="flex items-center justify-center gap-4 mb-3">
          <div class="text-5xl" x-text="tierMeta.emoji"></div>
          <div>
            <p class="text-3xl font-extrabold" x-text="`${sighting.ai_match_score}%`"></p>
            <p class="text-xs font-bold uppercase tracking-wide" x-text="tierMeta.label_vi"></p>
          </div>
        </div>
        <!-- Score bar -->
        <div class="h-2.5 bg-white/40 rounded-full overflow-hidden">
          <div class="h-full bg-white" :style="`width: ${sighting.ai_match_score}%`"></div>
        </div>
        <p class="text-[11px] mt-2 opacity-90"
          x-text="sighting.ai_is_mock ? '🤖 AI tạm chưa khả dụng — xem ảnh thủ công' : `Confidence: ${sighting.ai_match_confidence}`"></p>
      </div>

      <!-- Side-by-side photos -->
      <div class="bg-white rounded-2xl border border-slate-100 p-4 mb-4">
        <h2 class="text-sm font-bold text-slate-900 mb-3">📸 So sánh ảnh</h2>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-[11px] font-bold text-slate-700 uppercase mb-1.5">Ảnh tham khảo</p>
            <template x-if="referencePhotos.length > 0">
              <div class="space-y-2">
                <template x-for="(url, idx) in referencePhotos" :key="url">
                  <a :href="url" target="_blank" class="block">
                    <img :src="url" alt="" class="w-full h-32 object-cover rounded-lg border border-slate-200" />
                  </a>
                </template>
              </div>
            </template>
            <template x-if="referencePhotos.length === 0">
              <p class="text-xs text-slate-500 italic">Không có ảnh tham khảo</p>
            </template>
          </div>
          <div>
            <p class="text-[11px] font-bold text-slate-700 uppercase mb-1.5">Ảnh báo thấy</p>
            <template x-if="sighting.photo_url">
              <a :href="sighting.photo_url" target="_blank" class="block">
                <img :src="sighting.photo_url" alt="" class="w-full h-32 object-cover rounded-lg border-2 border-amber-400" />
              </a>
            </template>
            <template x-if="!sighting.photo_url">
              <div class="w-full h-32 rounded-lg bg-slate-100 flex items-center justify-center text-xs text-slate-500 italic">
                Không có ảnh
              </div>
            </template>
          </div>
        </div>
      </div>

      <!-- AI Analysis -->
      <template x-if="sighting.ai_match_analysis">
        <div class="bg-white rounded-2xl border border-slate-100 p-4 mb-4">
          <h3 class="text-xs font-bold text-slate-700 uppercase mb-2">🧠 Phân tích AI</h3>
          <p class="text-sm text-slate-700 leading-relaxed whitespace-pre-line" x-text="sighting.ai_match_analysis"></p>

          <template x-if="sighting.ai_matching_features?.length > 0">
            <div class="mt-3">
              <p class="text-[11px] font-bold text-emerald-700 uppercase mb-1">✓ Đặc điểm trùng</p>
              <ul class="text-xs text-slate-700 space-y-0.5">
                <template x-for="f in sighting.ai_matching_features" :key="f">
                  <li class="flex gap-1.5"><span class="text-emerald-600">✓</span><span x-text="f"></span></li>
                </template>
              </ul>
            </div>
          </template>

          <template x-if="sighting.ai_differences?.length > 0">
            <div class="mt-3">
              <p class="text-[11px] font-bold text-amber-700 uppercase mb-1">⚠ Khác biệt</p>
              <ul class="text-xs text-slate-700 space-y-0.5">
                <template x-for="d in sighting.ai_differences" :key="d">
                  <li class="flex gap-1.5"><span class="text-amber-600">⚠</span><span x-text="d"></span></li>
                </template>
              </ul>
            </div>
          </template>
        </div>
      </template>

      <!-- Sighting context -->
      <div class="bg-white rounded-2xl border border-slate-100 p-4 mb-4">
        <h3 class="text-xs font-bold text-slate-700 uppercase mb-2">📍 Thông tin báo thấy</h3>
        <p class="text-sm text-slate-900"><strong>Vị trí:</strong> <span x-text="sighting.sighting_address"></span></p>
        <p class="text-sm text-slate-900 mt-1"><strong>Thời gian:</strong> <span x-text="fmtDateTime(sighting.sighting_at)"></span></p>
        <template x-if="sighting.description">
          <p class="text-sm text-slate-700 mt-2 italic">"<span x-text="sighting.description"></span>"</p>
        </template>
        <p class="text-[11px] text-slate-500 mt-2">Báo bởi: <span x-text="sighting.spotter_name"></span></p>
      </div>

      <!-- Status banner if already actioned -->
      <template x-if="sighting.status === 'confirmed_by_owner'">
        <div class="bg-emerald-50 border border-emerald-300 rounded-2xl p-4 mb-4 text-sm">
          <p class="font-bold text-emerald-900">✓ Bạn đã xác nhận sighting này</p>
          <p class="text-xs text-emerald-700 mt-1">Liên hệ người báo theo SĐT bên dưới.</p>
        </div>
      </template>
      <template x-if="sighting.status === 'dismissed_by_owner'">
        <div class="bg-red-50 border border-red-300 rounded-2xl p-4 mb-4 text-sm">
          <p class="font-bold text-red-900">✗ Bạn đã đánh dấu không phải bé</p>
        </div>
      </template>

      <!-- Owner actions -->
      <template x-if="sighting.status === 'pending'">
        <div class="space-y-2 mb-4">
          <button @click="confirm()" :disabled="busy"
            class="w-full bg-emerald-600 hover:bg-emerald-700 disabled:opacity-50 text-white font-bold py-3.5 rounded-xl text-base shadow-lg">
            <span x-show="!busy">✅ Đúng bé của tôi</span>
            <span x-show="busy">Đang xử lý...</span>
          </button>
          <div class="grid grid-cols-2 gap-2">
            <button @click="dismiss()" :disabled="busy"
              class="bg-red-100 hover:bg-red-200 disabled:opacity-50 text-red-700 font-bold py-3 rounded-xl text-sm">
              ❌ Không phải
            </button>
            <a :href="`tel:${sighting.spotter_phone}`"
              class="bg-mmp-cream hover:bg-blue-200 text-mmp-ink font-bold py-3 rounded-xl text-sm text-center">
              📞 Gọi báo cáo viên
            </a>
          </div>
        </div>
      </template>

      <!-- Reporter contact (revealed after confirm) -->
      <template x-if="confirmedContact">
        <div class="bg-mmp-cream border border-mmp-cream rounded-2xl p-4 mb-4">
          <p class="font-bold text-mmp-ink mb-2">📞 Liên hệ người báo</p>
          <p class="text-sm text-slate-700"><strong>Tên:</strong> <span x-text="confirmedContact.name"></span></p>
          <p class="text-sm text-slate-700"><strong>SĐT:</strong>
            <a :href="`tel:${confirmedContact.phone}`" class="text-mmp-ink underline font-mono" x-text="confirmedContact.phone"></a>
          </p>
          <p class="text-sm text-slate-700"><strong>Địa điểm:</strong> <span x-text="confirmedContact.address"></span></p>
          <a :href="zaloUrl" target="_blank" rel="noopener"
            class="inline-block mt-3 text-xs bg-mmp-ink hover:bg-mmp-ink text-white font-bold px-3 py-1.5 rounded-lg">
            💬 Chat Zalo VowVet để được hỗ trợ
          </a>
        </div>
      </template>

      <p class="text-[11px] text-slate-400 text-center italic mt-4">
        AI Match chỉ hỗ trợ — quyết định cuối cùng là của bạn. Khi gặp trực tiếp, đem theo sổ vaccine + giấy tờ.
      </p>

    </div>
  </main>

  <script is:inline>
    function sightingPage(initial) {
      return {
        slug: initial.slug,
        reportId: initial.reportId,
        sighting: initial.sighting,
        referencePhotos: initial.referencePhotos,
        pet: initial.pet,
        zaloUrl: initial.zaloUrl,
        busy: false,
        confirmedContact: null,

        get tierMeta() {
          const s = this.sighting.ai_match_score || 0;
          if (s >= 80) return { emoji: '💚', label_vi: 'Chắc chắn' };
          if (s >= 60) return { emoji: '🟢', label_vi: 'Khả năng cao' };
          if (s >= 40) return { emoji: '🟡', label_vi: 'Nghi ngờ' };
          return { emoji: '⚪', label_vi: 'Không khả năng' };
        },

        get tierClasses() {
          const s = this.sighting.ai_match_score || 0;
          if (s >= 80) return 'bg-emerald-50 border-emerald-400 text-emerald-900';
          if (s >= 60) return 'bg-green-50 border-green-400 text-green-900';
          if (s >= 40) return 'bg-yellow-50 border-yellow-400 text-yellow-900';
          return 'bg-slate-50 border-slate-300 text-slate-700';
        },

        fmtRel(iso) {
          if (!iso) return "—";
          try {
            const ago = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
            if (ago < 1) return "vừa xong";
            if (ago < 60) return `${ago}p trước`;
            if (ago < 1440) return `${Math.floor(ago / 60)}h trước`;
            return new Date(iso).toLocaleDateString("vi-VN", { day: "2-digit", month: "2-digit" });
          } catch { return ""; }
        },

        fmtDateTime(iso) {
          if (!iso) return "—";
          try { return new Date(iso).toLocaleString("vi-VN", { day: "2-digit", month: "2-digit", year: "numeric", hour: "2-digit", minute: "2-digit" }); }
          catch { return iso.slice(0, 16); }
        },

        async confirm() {
          if (!confirm("Xác nhận đây ĐÚNG là bé của bạn? Người báo sẽ được công nhận Hero + nhận thưởng nếu có.")) return;
          this.busy = true;
          try {
            const res = await fetch(`/api/v1/lost-pets/${this.reportId}/sightings/${this.sighting.id}/confirm`, {
              method: 'POST', credentials: 'include',
            });
            const j = await res.json();
            if (!res.ok) {
              alert(j?.error?.message || "Lỗi confirm");
              return;
            }
            this.sighting.status = 'confirmed_by_owner';
            this.confirmedContact = j.reporter;
          } catch (_) {
            alert("Lỗi kết nối.");
          } finally { this.busy = false; }
        },

        async dismiss() {
          if (!confirm("Đánh dấu sighting này không phải bé của bạn?")) return;
          this.busy = true;
          try {
            const res = await fetch(`/api/v1/lost-pets/${this.reportId}/sightings/${this.sighting.id}/dismiss`, {
              method: 'POST', credentials: 'include',
            });
            if (res.ok) this.sighting.status = 'dismissed_by_owner';
          } catch (_) {}
          finally { this.busy = false; }
        },
      };
    }
  </script>
</Layout>
