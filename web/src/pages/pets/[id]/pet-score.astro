      </p>
    </div>
  </main>

  <script is:inline>
    // ── Pet Score Constellation v3.1: static config (Phase 1) ──
    const GROUP_DEFS = [
      { key: "foundational", label: "Sức khỏe nền", icon: "stethoscope", emoji: "🏥", keys: ["no_chronic_conditions", "bcs_optimal", "age_modifier", "recent_emergency", "pain_status", "allergies"] },
      { key: "preventive", label: "Y tế phòng ngừa", icon: "syringe", emoji: "💉", keys: ["vaccine_compliance", "vet_visit_recent", "water_intake"] },
      { key: "daily", label: "Hoạt động hằng ngày", icon: "paw", emoji: "🐾", keys: ["checkin_streak", "routine_consistency", "mobility", "cognitive_status"] },
      { key: "bonus", label: "Bonus", icon: "star", emoji: "🌟", keys: ["personality_modifier", "pet_hero_bonus"] },
    ];

    const COMPONENT_ICON = {
      vaccine_compliance: "syringe", vet_visit_recent: "stethoscope", water_intake: "help-circle",
      no_chronic_conditions: "heart", bcs_optimal: "scale", age_modifier: "sun",
      recent_emergency: "shield-check", pain_status: "heart", allergies: "leaf",
      checkin_streak: "calendar", routine_consistency: "refresh", mobility: "paw",
      cognitive_status: "sparkle", personality_modifier: "star", pet_hero_bonus: "heart",
    };

    const ICON_PATHS = {
      calendar: '<rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>',
      sparkle: '<path d="M12 2L15 8L21 9L17 14L18 21L12 18L6 21L7 14L3 9L9 8Z"/>',
      medal: '<circle cx="12" cy="8" r="6"/><path d="M15.5 13.5L17 22L12 19L7 22L8.5 13.5"/>',
      trophy: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
      crown: '<path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"/>',
      "trend-up": '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
      check: '<polyline points="20 6 9 17 4 12"/>',
      "chevron-down": '<polyline points="6 9 12 15 18 9"/>',
      "chevron-right": '<polyline points="9 18 15 12 9 6"/>',
      "chevron-up": '<polyline points="18 15 12 9 6 15"/>',
      refresh: '<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>',
      stethoscope: '<path d="M11 2v2"/><path d="M5 2v2"/><path d="M5 3h11s1.5 1.5 1.5 4-1.5 4-1.5 4H5"/><path d="M8 11v4a4 4 0 0 0 8 0v-4"/><circle cx="20" cy="10" r="2"/>',
      syringe: '<path d="m18 2 4 4-13 13H5v-4L18 2z"/><path d="m14 6 4 4"/><path d="m11 9 4 4"/>',
      paw: '<circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>',
      star: '<path d="M12 2L15 8L21 9L17 14L18 21L12 18L6 21L7 14L3 9L9 8Z"/>',
      heart: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
      sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>',
      "shield-check": '<path d="M12 2L3 6v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V6l-9-4z"/><polyline points="9 12 11 14 15 10"/>',
      leaf: '<path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>',
      scale: '<path d="M16 16l-4-4-4 4"/><path d="M12 12v9"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>',
      "help-circle": '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
      "star-filled": '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
      "lightbulb": '<path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 1 4 12.7c-.4.3-.7.7-.9 1.2L14 18h-4l-1.1-2.1c-.2-.5-.5-.9-.9-1.2A7 7 0 0 1 12 2z"/>',
    };

    function scorePage(initial) {
      return {
        pet: initial.pet,
        score: initial.score,
        levels: initial.levels,
        tierHex: initial.tierHex,
        refreshing: false,
        gaugeProgress: 0,
        displayScore: 0,
        showCelebration: false,
        trend: null,
        trendLoaded: false,
        percentile: null,
        age: (() => {
          const dob = initial.pet && initial.pet.dob;
          if (!dob) return null;
          const ms = Date.now() - new Date(dob).getTime();
          if (Number.isNaN(ms)) return null;
          const yrs = Math.floor(ms / (365.25 * 24 * 3600 * 1000));
          return yrs >= 0 ? yrs : null;
        })(),
        _loadingTrend: false,
        tickerIndex: 0,
        tickerPaused: false,
        hoveredComponent: null,
        _tickerTimer: null,

        get displayedComponent() {
          if (this.hoveredComponent) return this.hoveredComponent;
          const comps = this.score.breakdown.components || [];
          if (comps.length === 0) return null;
          return comps[this.tickerIndex % comps.length];
        },

        startTicker() {
          if (typeof window === "undefined") return;
          const reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (reduce) { this.tickerIndex = 0; return; }
          this._tickerTimer = setInterval(() => {
            if (!this.tickerPaused && !this.hoveredComponent && this.score.breakdown.components) {
              this.tickerIndex = (this.tickerIndex + 1) % this.score.breakdown.components.length;
            }
          }, 3000);
        },

        onMount() {
          this.loadTrend(); // populate hero stats (percentile + 30d delta) early
          this.$nextTick(() => this.startGauge());
          this.startTicker();

          try {
            const url = new URL(window.location.href);
            if (url.searchParams.get("celebrate") === "1") {
              setTimeout(() => { this.showCelebration = true; }, 1500);
              url.searchParams.delete("celebrate");
              window.history.replaceState({}, "", url.toString());
            }
          } catch (_) {}
        },

        startGauge() {
          const C = 2 * Math.PI * 125;
          const finalOff = C * (1 - this.score.score / 1000);
          const reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const arc = document.getElementById("psGaugeArc");
          const anim = document.getElementById("psGaugeAnim");
          if (reduce) {
            this.displayScore = this.score.score;
            if (arc) arc.setAttribute("stroke-dashoffset", String(finalOff));
            return;
          }
          if (anim) {
            anim.setAttribute("from", String(C));
            anim.setAttribute("to", String(finalOff));
            anim.beginElement();
          }
          this.animateScore();
        },

        animateScore() {
          const target = this.score.score;
          const duration = 1800;
          const start = performance.now();
          const tick = (now) => {
            const t = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - t, 3);
            this.displayScore = Math.round(target * eased);
            if (t < 1) requestAnimationFrame(tick);
            else this.displayScore = target;
          };
          requestAnimationFrame(tick);
        },

        get sortedComponents() {
          return [...this.score.breakdown.components].sort((a, b) => b.current_value - a.current_value);
        },

        barWidth(c) {
          const range = Math.max(Math.abs(c.max_possible), Math.abs(c.min_possible), 1);
          return Math.min(100, Math.max(3, (Math.abs(c.current_value) / range) * 100));
        },

        barFillClass(c) {
          // Palette strict: positive = gold gradient, penalty = ink, neutral = slate
          if (c.current_value < 0) return "ps-fill-neg";
          if (c.current_value === 0) return "ps-fill-neu";
          return "ps-fill-pos";
        },

        barWrapClass(c) {
          if (c.current_value > 0) return "ps-wrap-pos";
          if (c.current_value < 0) return "ps-wrap-neg";
          return "ps-wrap-neu";
        },

        fmtTime(iso) {
          if (!iso) return "—";
          try {
            return new Date(iso).toLocaleString("vi-VN", {
              hour: "2-digit", minute: "2-digit", day: "2-digit", month: "2-digit",
            });
          } catch { return ""; }
        },

        async loadTrend() {
          if (this.trendLoaded || this._loadingTrend) return;
          this._loadingTrend = true;
          try {
            const [tRes, pRes] = await Promise.all([
              fetch(`/api/v1/pets/${this.pet.id}/pet-score/trend?days=30`, { credentials: "include" }),
              fetch(`/api/v1/pets/${this.pet.id}/pet-score/percentile`, { credentials: "include" }),
            ]);
            if (tRes.ok) this.trend = await tRes.json();
            if (pRes.ok) this.percentile = await pRes.json();
            this.trendLoaded = true;

            if (this.trend?.points?.length) {
              if (typeof Chart === "undefined") {
                await new Promise((resolve, reject) => {
                  const s = document.createElement("script");
                  s.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js";
                  s.onload = resolve;
                  s.onerror = reject;
                  document.head.appendChild(s);
                });
              }
              this.$nextTick(() => this.renderChart());
            }
          } catch (_) { this.trendLoaded = true; }
        },

        renderChart() {
          const canvas = document.getElementById("trend-chart");
          if (!canvas || typeof Chart === "undefined" || !this.trend?.points) return;
          const labels = this.trend.points.map(p => p.date.slice(5));
          const data = this.trend.points.map(p => p.score);
          new Chart(canvas, {
            type: "line",
            data: {
              labels,
              datasets: [{
                label: "Pet Score",
                data,
                borderColor: "#ecb921",
                backgroundColor: "rgba(236,185,33,0.30)",
                fill: true,
                tension: 0.3,
                pointRadius: 0,
                pointHoverRadius: 4,
                borderWidth: 2.5,
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: {
                y: {
                  beginAtZero: false, suggestedMin: 0, suggestedMax: 1000,
                  ticks: { font: { size: 10 } },
                },
                x: {
                  ticks: { font: { size: 9 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 6 },
                },
              },
            }
          });
        },

        async refresh() {
          this.refreshing = true;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/pet-score/refresh`, {
              method: "POST",
              credentials: "include",
            });
            if (res.ok) {
              const fresh = await res.json();
              this.score = fresh;
              this.displayScore = 0;
              this.$nextTick(() => this.startGauge());
            }
          } catch (_) {} finally {
            this.refreshing = false;
          }
        },

        // ── Phase 1: grouping · tiers · achievements · icons (client-side only) ──
        _comp(key) {
          return (this.score.breakdown.components || []).find((c) => c.key === key) || null;
        },

        groupedComponents() {
          const comps = this.score.breakdown.components || [];
          return GROUP_DEFS.map((g) => {
            const items = g.keys.map((k) => comps.find((c) => c.key === k)).filter(Boolean);
            const sum_current = items.reduce((s, c) => s + c.current_value, 0);
            const sum_max = items.reduce((s, c) => s + Math.max(0, c.max_possible), 0);
            return { key: g.key, label_group: g.label, icon: g.icon, emoji: g.emoji, components: items, sum_current, sum_max };
          });
        },

        groupNet(group) {
          const sum = group ? group.sum_current : 0;
          if (sum > 0) return "positive";
          if (sum < 0) return "negative";
          return "neutral";
        },

        nextTier() {
          const idx = this.levels.findIndex((l) => l.id === this.score.level.id);
          if (idx === -1 || idx >= this.levels.length - 1) return null;
          return this.levels[idx + 1];
        },

        pointsToNextTier() {
          const next = this.nextTier();
          return next ? Math.max(0, next.range[0] - this.score.score) : 0;
        },

        pointsToNextTierLabel() {
          const next = this.nextTier();
          return next ? `Còn ${this.pointsToNextTier()} điểm để lên ${next.name_vi}` : "Đã đạt cấp cao nhất";
        },

        tierIconKey() {
          return { bronze: "medal-3", silver: "medal-2", gold: "medal-1", platinum: "trophy", diamond: "crown" }[this.score.level.id] || "medal-1";
        },

        topRecommendations() {
          return (this.score.recommendations || []).slice(0, 3);
        },

        achievements() {
          const out = [];
          const chronic = this._comp("no_chronic_conditions");
          if (chronic && chronic.max_possible > 0 && chronic.current_value >= chronic.max_possible)
            out.push({ key: "khoe_nen", icon: "stethoscope", label: "KHỎE NỀN", subtitle: "Không bệnh mạn" });
          const hero = this._comp("pet_hero_bonus");
          if (hero && hero.current_value > 0)
            out.push({ key: "pet_hero", icon: "heart", label: "PET HERO", subtitle: "Giúp cộng đồng" });
          if (this.age !== null && this.age >= 1 && this.age <= 8)
            out.push({ key: "tuoi_vang", icon: "sun", label: "TUỔI VÀNG", subtitle: `${this.age} tuổi sung sức` });
          const emer = this._comp("recent_emergency");
          if (emer && emer.current_value === 0)
            out.push({ key: "an_toan", icon: "shield-check", label: "AN TOÀN", subtitle: "Không cấp cứu" });
          if (this.trend && typeof this.trend.delta_30d === "number" && this.trend.delta_30d > 0)
            out.push({ key: "streak_30d", icon: "trend-up", label: "STREAK 30D", subtitle: "Tăng đều" });
          return out;
        },

        starState(c) {
          if (!c) return "faint";
          if (c.current_value < 0) return "penalty";
          if (c.current_value > 0) return "bright";
          return "faint";
        },

        componentIconKey(key) {
          return COMPONENT_ICON[key] || "star";
        },

        iconSvg(name) {
          const key = String(name || "").startsWith("medal") ? "medal" : name;
          const paths = ICON_PATHS[key] || "";
          const filled = name === "star-filled";
          return '<svg viewBox="0 0 24 24" width="100%" height="100%" fill="' + (filled ? "currentColor" : "none") +
            '" stroke="' + (filled ? "none" : "currentColor") +
            '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:block">' + paths + "</svg>";
        },
      };
    }
  </script>

  <!-- Quest hook: fire view_pet_score trigger -->
  <script is:inline define:vars={{ petId }}>
    (() => {
      try {
        fetch("/api/v1/quests/track/view-pet-score", {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pet_id: petId }),
        }).catch(() => {});
      } catch (_) {}
    })();
  </script>
</Layout>
