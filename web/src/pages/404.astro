---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Trang không tồn tại · VowVet" description="Trang bạn tìm không có. Quay về trang chủ VowVet.">
  <main class="min-h-screen bg-mmp-cream flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full text-center">
      <p class="text-7xl mb-2 select-none animate-bounce" style="animation-duration: 2s">🐾</p>
      <h1 class="font-display italic text-6xl sm:text-7xl font-semibold text-mmp-ink mb-3">404</h1>
      <p class="text-xl sm:text-2xl font-bold text-mmp-ink mb-2">Pet bị lạc rồi 😿</p>
      <p class="text-slate-600 mb-8">Trang bạn tìm không tồn tại hoặc đã bị xoá.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="bg-mmp-ink hover:bg-slate-800 text-white font-bold px-6 py-3 rounded-xl shadow-lg transition">
          Về trang chủ
        </a>
        <a href="/dashboard" class="bg-white border border-slate-200 hover:border-mmp-ink text-mmp-ink font-semibold px-6 py-3 rounded-xl transition">
          Dashboard
        </a>
      </div>
      <p class="text-xs text-slate-400 mt-8">Nếu lỗi tái diễn, báo bác sĩ Mon Min qua <a href="/health" class="text-mmp-ink hover:underline">/health</a></p>
    </div>
  </main>
</Layout>
