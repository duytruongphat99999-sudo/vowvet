---
/**
 * /admin/foster-orders — TRANG ĐƠN góp (FOSTER L5b). ADMIN-ONLY.
 * Trang VỎ: data lấy qua API admin-gated (/api/v1/admin/foster-orders, bọc requireAdmin).
 * Non-admin → API 403 → trang hiện "không có quyền", KHÔNG render data/SĐT.
 * SĐT chủ bé CHỈ về từ API admin-gated này (③ — dùng để liên hệ lấy địa chỉ giao).
 * KHÔNG gate ở web middleware — bảo vệ ở API.
 */
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Đơn góp Foster · Admin" description="Quản lý đơn góp gói foster (admin).">
  <main class="min-h-screen bg-slate-50 px-4 py-8">
    <div class="max-w-5xl mx-auto" x-data="fosterOrdersAdmin()" x-init="load()">

      <header class="mb-5">
        <h1 class="text-2xl font-bold text-slate-900">Đơn góp Foster</h1>
        <p class="text-sm text-slate-600 mt-1">Liên hệ chủ bé qua SĐT để lấy địa chỉ giao gói.</p>
        <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 mt-3 inline-block">
          🔒 SĐT chủ bé chỉ hiển thị cho admin — dùng để liên hệ lấy địa chỉ giao. Không chia sẻ.
        </p>
      </header>

      {/* FOSTER Hướng B — queue yêu cầu lấy lại (chủ cũ gửi, admin duyệt) */}
      <div x-show="!loading && !forbidden && reclaimRequests.length > 0" style="display:none;" class="mb-5">
        <div class="bg-red-50 border border-red-200 rounded-xl p-3 mb-3 flex items-center gap-2">
          <span class="bg-red-500 text-white text-xs font-bold px-2 py-0.5 rounded-full" x-text="reclaimRequests.length"></span>
          <span class="text-red-700 text-sm font-medium">yêu cầu lấy lại đang chờ duyệt</span>
        </div>
        <template x-for="req in reclaimRequests" :key="req.id">
          <div class="bg-white border border-slate-200 rounded-xl p-4 mb-2 flex items-center justify-between gap-3">
            <div class="min-w-0">
              <p class="font-medium text-slate-900">Bé <span x-text="req.pet_name"></span> (<span x-text="req.passport_code"></span>)</p>
              <p class="text-sm text-slate-500">Chủ cũ: <span x-text="req.requester_name"></span> · <span x-text="timeAgo(req.created_at)"></span></p>
            </div>
            <button @click="approveReclaim(req)" :disabled="approvingId === req.id" class="shrink-0 bg-emerald-600 hover:bg-emerald-700 disabled:opacity-50 text-white px-4 py-2 rounded-lg text-sm font-bold">
              <span x-show="approvingId !== req.id">✅ Duyệt</span>
              <span x-show="approvingId === req.id" style="display:none;">Đang duyệt…</span>
            </button>
          </div>
        </template>
      </div>

      {/* FOSTER P3b — lấy lại bé trao nhầm (admin, hoàn tác 1 bước) */}
      <section x-show="!loading && !forbidden" style="display:none;" class="bg-white border border-slate-200 rounded-xl p-4 mb-5">
        <h2 class="font-bold text-slate-900 mb-1">Lấy lại bé (trao nhầm)</h2>
        <p class="text-xs text-slate-600 mb-3">Hoàn tác 1 bước: trả bé về chủ ngay trước + trừ credit người trao. Chỉ được khi bé vẫn ở tay người vừa nhận.</p>
        <div class="flex items-center gap-2">
          <input type="text" x-model="reclaimPetId" placeholder="Mã passport (VD: 2CQFYXFY-GE)" class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm w-56 uppercase" />
          <button @click="reclaim()" :disabled="reclaiming || !reclaimPetId" class="bg-slate-900 hover:bg-slate-800 disabled:opacity-50 text-white text-sm font-bold px-4 py-1.5 rounded-lg">
            <span x-show="!reclaiming">Lấy lại</span>
            <span x-show="reclaiming">Đang xử lý…</span>
          </button>
        </div>
        <p x-show="reclaimMsg" style="display:none;" role="status" class="mt-3 bg-emerald-50 border border-emerald-200 rounded-xl p-3 text-sm text-emerald-700" x-text="reclaimMsg"></p>
        <p x-show="reclaimErr" style="display:none;" role="alert" class="mt-3 bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700" x-text="reclaimErr"></p>
      </section>

      {/* Loading */}
      <template x-if="loading">
        <p class="text-slate-500 text-sm">Đang tải…</p>
      </template>

      {/* Forbidden */}
      <template x-if="!loading && forbidden">
        <div class="bg-white border border-slate-200 rounded-xl p-8 text-center">
          <p class="text-4xl mb-2">🔒</p>
          <p class="font-bold text-slate-900">Bạn không có quyền xem trang này</p>
          <p class="text-sm text-slate-600 mt-1">Trang đơn góp chỉ dành cho admin MonMin.</p>
        </div>
      </template>

      {/* Error */}
      <template x-if="!loading && !forbidden && error">
        <p class="text-sm text-red-600" x-text="error"></p>
      </template>

      {/* Empty */}
      <template x-if="!loading && !forbidden && !error && orders.length === 0">
        <div class="bg-white border border-slate-200 rounded-xl p-8 text-center text-slate-600">Chưa có đơn góp nào.</div>
      </template>

      {/* Table */}
      <div x-show="!loading && !forbidden && orders.length > 0" style="display:none;" class="overflow-x-auto bg-white border border-slate-200 rounded-xl">
        <table class="w-full text-sm">
          <thead class="bg-slate-100 text-slate-600 text-left">
            <tr>
              <th class="px-3 py-2 font-semibold">Mã</th>
              <th class="px-3 py-2 font-semibold">Bé</th>
              <th class="px-3 py-2 font-semibold">Gói</th>
              <th class="px-3 py-2 font-semibold">Giá</th>
              <th class="px-3 py-2 font-semibold">Trạng thái</th>
              <th class="px-3 py-2 font-semibold">Ngày</th>
              <th class="px-3 py-2 font-semibold">Chủ bé · SĐT</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="o in orders" :key="o.order_code">
              <tr class="border-t border-slate-100">
                <td class="px-3 py-2 font-mono text-xs font-bold" x-text="o.order_code"></td>
                <td class="px-3 py-2" x-text="o.pet_name || '—'"></td>
                <td class="px-3 py-2" x-text="o.package_title || '—'"></td>
                <td class="px-3 py-2 font-mono" x-text="o.package_price != null ? fmtPrice(o.package_price) : '—'"></td>
                <td class="px-3 py-2">
                  <select class="border border-slate-300 rounded-lg px-2 py-1 text-xs" @change="setStatus(o, $event.target.value)">
                    <template x-for="s in statuses" :key="s">
                      <option :value="s" :selected="o.status === s" x-text="s"></option>
                    </template>
                  </select>
                </td>
                <td class="px-3 py-2 text-xs text-slate-500" x-text="fmtDate(o.created_at)"></td>
                <td class="px-3 py-2">
                  <span x-text="o.owner_name || '—'"></span>
                  <span class="block font-mono text-xs text-slate-700" x-text="o.owner_phone || '(chưa có SĐT)'"></span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script is:inline>
    function fosterOrdersAdmin() {
      return {
        orders: [],
        loading: true,
        forbidden: false,
        error: "",
        statuses: ["mới", "đã liên hệ", "đã giao", "huỷ"],
        reclaimPetId: "",
        reclaiming: false,
        reclaimMsg: "",
        reclaimErr: "",
        reclaimRequests: [],
        approvingId: null,
        async load() {
          this.loading = true; this.error = ""; this.forbidden = false;
          try {
            const r = await fetch("/api/v1/admin/foster-orders", { credentials: "include" });
            if (r.status === 403) { this.forbidden = true; return; }
            if (!r.ok) { this.error = "Lỗi tải đơn (" + r.status + ")"; return; }
            const j = await r.json();
            this.orders = Array.isArray(j.orders) ? j.orders : [];
            // FOSTER Hướng B — queue yêu cầu lấy lại (không vỡ trang nếu lỗi)
            try {
              const rr = await fetch("/api/v1/admin/reclaim-requests", { credentials: "include" });
              if (rr.ok) { const rj = await rr.json(); this.reclaimRequests = Array.isArray(rj.requests) ? rj.requests : []; }
            } catch (e2) {}
          } catch (e) {
            this.error = "Lỗi kết nối";
          } finally {
            this.loading = false;
          }
        },
        async setStatus(o, status) {
          const prev = o.status;
          o.status = status;
          try {
            const r = await fetch("/api/v1/admin/foster-orders/" + encodeURIComponent(o.order_code) + "/status", {
              method: "PATCH",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({ status: status })
            });
            if (!r.ok) { o.status = prev; this.error = "Đổi trạng thái thất bại"; }
          } catch (e) {
            o.status = prev; this.error = "Lỗi kết nối";
          }
        },
        async reclaim() {
          this.reclaimMsg = ""; this.reclaimErr = "";
          var code = (this.reclaimPetId || "").trim().toUpperCase();
          if (!code) { this.reclaimErr = "Nhập mã passport bé"; return; }
          // Xác nhận 1 bước trước khi hoàn tác (không undo được).
          if (!confirm("Chắc chắn lấy lại bé mã " + code + "? Hành động này trả bé về chủ ngay trước.")) return;
          this.reclaiming = true;
          try {
            const r = await fetch("/api/v1/admin/pets/" + encodeURIComponent(code) + "/reclaim", { method: "POST", credentials: "include" });
            const j = await r.json().catch(function () { return {}; });
            if (r.status === 403) { this.reclaimErr = "Không có quyền admin"; return; }
            if (!r.ok) { this.reclaimErr = (j.error && j.error.message) || ("Thất bại (" + r.status + ")"); return; }
            var petNm = j.pet_name || ("#" + j.pet_id);
            var pass = j.passport_code ? " (" + j.passport_code + ")" : "";
            var owner = j.previous_owner_name || ("user " + j.returned_to);
            this.reclaimMsg = "✅ Đã trả bé " + petNm + pass + " về chủ trước " + owner + ", trừ credit người trao (còn " + j.new_count + ").";
          } catch (e) {
            this.reclaimErr = "Lỗi kết nối";
          } finally {
            this.reclaiming = false;
          }
        },
        fmtPrice(v) { try { return new Intl.NumberFormat("vi-VN").format(v) + "đ"; } catch (e) { return v + "đ"; } },
        fmtDate(iso) {
          if (!iso) return "";
          var m = String(iso).match(/^(\d{4})-(\d{2})-(\d{2})/);
          return m ? (m[3] + "/" + m[2] + "/" + m[1]) : String(iso).slice(0, 10);
        },
        async approveReclaim(req) {
          if (this.approvingId) return;
          if (!confirm("Duyệt yêu cầu lấy lại bé " + (req.pet_name || ("#" + req.pet_id)) + "? Bé sẽ được trả về chủ cũ.")) return;
          this.approvingId = req.id;
          try {
            const r = await fetch("/api/v1/admin/reclaim-requests/" + req.id + "/approve", { method: "POST", credentials: "include" });
            const j = await r.json().catch(function () { return {}; });
            if (!r.ok) { alert((j.error && j.error.message) || ("Duyệt thất bại (" + r.status + ")")); return; }
            this.reclaimRequests = this.reclaimRequests.filter(function (x) { return x.id !== req.id; });
          } catch (e) {
            alert("Lỗi kết nối");
          } finally {
            this.approvingId = null;
          }
        },
        timeAgo(iso) {
          if (!iso) return "";
          var t = new Date(iso).getTime();
          if (!t) return "";
          var s = Math.floor((Date.now() - t) / 1000);
          if (s < 60) return s + " giây trước";
          var mn = Math.floor(s / 60); if (mn < 60) return mn + " phút trước";
          var h = Math.floor(mn / 60); if (h < 24) return h + " giờ trước";
          return Math.floor(h / 24) + " ngày trước";
        }
      };
    }
  </script>
</Layout>
