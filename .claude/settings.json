{
  "$comment": "Harness settings. Commit file này vào git — luật của repo phải versioned. settings.local.json (gitignored) chỉ dành cho khác biệt máy-cục-bộ, KHÔNG phải chỗ đặt biên phòng thủ.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git rev-parse:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(bun run typecheck:*)",
      "Bash(bun run build:*)",
      "Bash(bun run --cwd api typecheck)",
      "Bash(bun run --cwd web build)",
      "Bash(bun install)",
      "Bash(bun install --cwd:*)",
      "Bash(bun test:*)",
      "Bash(node --check:*)",
      "Bash(bash .claude/scripts/verify.sh)",
      "Bash(python .claude/scripts/plan.py:*)",
      "Bash(docker restart vowvet-api)",
      "Bash(docker compose -f docker/docker-compose.yml up -d --build vowvet-web)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl http://localhost:*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push -u origin main:*)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)",
      "Edit(**/nutrition-engine.ts)",
      "Write(**/nutrition-engine.ts)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .claude/scripts/guard.sh"
          },
          {
            "type": "command",
            "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .claude/scripts/require-verify.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .claude/scripts/protect-harness.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .claude/scripts/after-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .claude/scripts/require-handoff.sh"
          },
          {
            "type": "command",
            "command": "\"C:\\Program Files\\Git\\bin\\bash.exe\" .claude/scripts/notify.sh"
          }
        ]
      }
    ]
  }
}
