              <button @click="confirmDelete(r)"
                class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-[var(--c-ink-54)] hover:text-mmp-ink hover:bg-mmp-cream transition shrink-0" title="Xoá">
                <FeatureIcon name="trash" class="w-3.5 h-3.5" />
