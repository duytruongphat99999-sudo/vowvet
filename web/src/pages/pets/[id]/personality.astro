              <p class="text-xs font-extrabold">Lừ đừ</p>
            </button>
          </div>

          <!-- Toast moved outside section — now globally fixed bottom-center -->

          <!-- M15.4 — MOOD × ROUTINE Smart Suggestion (chỉ hiện khi đã tick mood hôm nay) -->
          <template x-if="moodRoutineSuggestion">
            <div class="mt-4 p-3.5 rounded-2xl border-2"
