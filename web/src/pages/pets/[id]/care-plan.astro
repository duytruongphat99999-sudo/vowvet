---
/**
 * /pets/[id]/care-plan — 3-layer hierarchy redesign (WOW Edition).
 *
 * **The problem this solves**: user feedback "bố cục rối, nhiều chữ, không biết
 * cái nào quan trọng, cái nào cần làm trước, cái nào tick được."
 *
 * **3-layer information hierarchy**:
 *   - LAYER 1: HERO "Bây giờ làm gì?" — time-aware smart suggestion + progress bar
 *   - LAYER 2: TASKS hôm nay — Ăn / Vận động / Theo dõi (visually distinct, tickable)
 *   - LAYER 3: KIẾN THỨC — accordion <details> (Breed / Lễ tết / Training / Tại sao?)
 *
 * Keeps existing wins (no regressions):
 *   - carePlanItem Alpine factory + AJAX complete + toast
 *   - Brand identity from clinic-info (NEVER hard-coded "Duy Trường Phát")
 *   - FeatureIcon SVG everywhere (zero emoji on chrome)
 *   - Brand tokens: text-mmp-ink, var(--c-gold), bg-mmp-cream, bg-mmp-ink
 *   - Top + bottom safety disclaimers
 */
import Layout from "../../../layouts/Layout.astro";
import FeatureIcon from "../../../components/FeatureIcon.astro";
import ConsentModal from "../../../components/care-plan/ConsentModal.astro";
import { fetchPet } from "../../../lib/api-client.ts";
import { getClinicInfo } from "@shared/clinic-info.ts";
import { CARE_PLAN_DISCLAIMER } from "@shared/care-plan-safety.ts";
import {
  getCurrentSuggestion,
  calculateTodayProgress,
  type CarePlanTask,
} from "@shared/care-plan-suggestion.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const clinic = getClinicInfo();

const petId = Number(Astro.params.id);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

// Referer-aware back nav
const referer = Astro.request.headers.get("referer") || "";
const backHref = referer.includes("/dashboard") ? "/dashboard"
              : referer.includes("/quests")    ? `/pets/${pet.id}/quests`
              : `/pets/${pet.id}`;
const backLabel = referer.includes("/dashboard") ? "Dashboard"
               : referer.includes("/quests")    ? "Nhiệm vụ"
               : pet.name;

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// A5: SSR-fetch care plan consent state — modal blocks view until acked
let consentedAt: string | null = null;
try {
  const cr = await fetch(`${API_INTERNAL}/api/v1/users/me/care-plan-consent`, {
    headers: { cookie: cookieHeader },
  });
  if (cr.ok) {
    const cj = await cr.json();
    consentedAt = cj.consented_at || null;
  }
} catch (_) {}

// Stable item_key from time slot — MUST match api/src/routes/pets.ts classifyCarePlanItem()
function itemKey(prefix: string, timeStr: string | undefined | null): string {
  const t = String(timeStr || "").replace(/:/g, "_").replace(/[^0-9_]/g, "") || "x";
  return `${prefix}_${t}`;
}

// SSR-fetch completions in parallel
let completedKeys: Set<string> = new Set();
let trifectaGranted = false;
try {
  const r = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/care-plan/completions/today`, {
    headers: { cookie: cookieHeader },
  });
  if (r.ok) {
    const j = await r.json();
    completedKeys = new Set<string>(j.completed_keys || []);
    trifectaGranted = !!j.trifecta_granted;
  }
} catch (_) {}

// Try preview first (cached only — fast), else trigger full gen
let plan: any = null;
let loadError: string | null = null;
try {
  const prevRes = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/care-plan/v2/preview`, {
    headers: { cookie: cookieHeader },
  });
  if (prevRes.ok) {
    const j = await prevRes.json();
    if (j.has_cache) plan = j.plan;
  }
} catch (_) {}
if (!plan) {
  try {
    const genRes = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/care-plan/v2`, {
      headers: { cookie: cookieHeader },
    });
    if (genRes.ok) {
      const j = await genRes.json();
      plan = j.plan;
    } else if (genRes.status === 401) {
      return Astro.redirect("/login");
    } else {
      const j = await genRes.json().catch(() => ({}));
      loadError = j.error?.message || `Lỗi load care plan (${genRes.status})`;
    }
  } catch (err: any) {
    loadError = err?.message || "Lỗi kết nối";
  }
}

function fmtDate(iso: string | null): string {
  if (!iso) return "";
  const d = new Date(iso + "T00:00:00");
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString("vi-VN", { weekday: "long", day: "2-digit", month: "2-digit", year: "numeric" });
}

// ── Build flat task list for suggestion engine (server-side) ────────────────
const allTasks: CarePlanTask[] = [];
if (plan?.eating?.items) {
  for (const it of plan.eating.items) {
    const k = itemKey("feeding", it.time);
    allTasks.push({
      key: k,
      time: it.time,
      description: it.what,
      note: it.reason || undefined,
      type: "feeding",
      completed: completedKeys.has(k),
    });
  }
}
if (plan?.exercise?.items) {
  for (const it of plan.exercise.items) {
    const k = itemKey("exercise", it.time);
    allTasks.push({
      key: k,
      time: it.time,
      description: it.activity,
      note: [
        it.duration_min ? `${it.duration_min} phút` : "",
        it.location_type || "",
      ].filter(Boolean).join(" · ") || undefined,
      type: "exercise",
      completed: completedKeys.has(k),
    });
  }
}
// Monitoring entries are reference values ({metric, current_value, recommendation}) —
// not time-bound actions, so they don't have a `time`. We synthesize a midday
// 12:00 placeholder so users see them, but the suggestion engine deprioritizes
// them naturally (they only "match" when both feeding+exercise are clear).
if (plan?.monitoring && Array.isArray(plan.monitoring)) {
  plan.monitoring.forEach((m: any, idx: number) => {
    const k = `monitor_${idx}`;
    allTasks.push({
      key: k,
      time: "12:00",
      description: `Kiểm tra ${m.metric || "chỉ số sức khoẻ"}`,
      note: m.recommendation || undefined,
      type: "monitoring",
      completed: completedKeys.has(k),
    });
  });
}

const suggestion = getCurrentSuggestion(allTasks);
const progress = calculateTodayProgress(allTasks);

// Color map for hero CTA based on urgency (no `text-vv-gold` — token doesn't exist)
const HERO_STATE = {
  urgent:   { label: "ƯU TIÊN BÂY GIỜ",  badge: "bg-amber-400/15 text-amber-200", ring: "ring-2 ring-amber-400/40 ring-offset-2 ring-offset-[#1a1a1a]" },
  overdue:  { label: "TRỄ — VẪN NÊN LÀM", badge: "bg-red-500/20 text-red-300",     ring: "ring-2 ring-red-500/40 ring-offset-2 ring-offset-[#1a1a1a]" },
  upcoming: { label: "SẮP TỚI",           badge: "bg-white/10 text-white/70",       ring: "" },
  all_done: { label: "HOÀN THÀNH 100%",   badge: "bg-emerald-400/20 text-emerald-200", ring: "" },
  starting: { label: "ĐANG CHUẨN BỊ",     badge: "bg-white/10 text-white/70",       ring: "" },
}[suggestion.status];

// Icon by task type — chrome-safe SVG, never emoji
const TYPE_ICON: Record<string, string> = {
  feeding:    "bowl",
  exercise:   "activity",
  monitoring: "heart",
};

// Initial data for Alpine carePlanPage factory (refresh + Zalo share)
const initialData = plan ? JSON.stringify({ plan, pet: { id: pet.id, name: pet.name } }) : null;
---

<Layout title={`Kế hoạch hôm nay · ${pet.name} · VowVet`} description="AI care plan hằng ngày — Mon Min Pet">

  {/* A5: Care Plan Consent Modal — blocks view until user acks AI disclaimer */}
  <ConsentModal initialConsented={consentedAt} apiBaseUrl="/api/v1" />

  <main class="min-h-screen bg-mmp-cream pb-12 care-plan-page">

    <!-- Sticky header (brand-synced) -->
    <header class="sticky top-0 z-30 bg-white border-b border-slate-200">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-3">
        <a href={backHref} class="text-sm text-slate-500 hover:text-mmp-ink inline-flex items-center gap-1 transition">
          <FeatureIcon name="arrow" class="w-4 h-4 rotate-180" strokeWidth={2} />
          {backLabel}
        </a>
        <h1 class="font-display italic text-lg sm:text-xl font-semibold text-mmp-ink inline-flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-mmp-cream">
            <FeatureIcon name="calendar" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          </span>
          Hôm nay
        </h1>
        <span class="text-[10px] bg-mmp-cream text-mmp-ink border border-amber-200 px-2 py-0.5 rounded-full font-bold">AI v2</span>
      </div>
    </header>

    <div class="max-w-2xl mx-auto px-4 sm:px-6 py-5 space-y-4">

      <!-- Compact safety disclaimer (top) — legal requirement, brand-safe vet name -->
      <div class="rounded-2xl bg-amber-50 border border-amber-200 px-4 py-2.5 flex items-center gap-2.5">
        <FeatureIcon name="alert-triangle" class="w-4 h-4 text-amber-700 shrink-0" strokeWidth={2} />
        <p class="text-xs text-amber-900 leading-snug">
          AI tham khảo · Hỏi
          <a href={clinic.zalo_url} target="_blank" rel="noopener" class="font-bold hover:underline" style="color: var(--c-gold);">{clinic.vet.name}</a>
          · Cấp cứu
          <a href={`tel:${clinic.phone_tel_link}`} class="font-bold hover:underline" style="color: var(--c-gold);">{clinic.phone}</a>
        </p>
      </div>

      {loadError && (
        <div class="bg-red-50 border border-red-200 rounded-2xl p-5 text-center">
          <FeatureIcon name="alert-triangle" class="w-8 h-8 mx-auto mb-2 text-red-600" strokeWidth={2} />
          <p class="font-semibold text-red-900 mb-2">Không tải được care plan</p>
          <p class="text-sm text-red-700 mb-3">{loadError}</p>
          <a href={`/pets/${pet.id}/care-plan`}
             class="inline-flex items-center justify-center gap-2 bg-mmp-ink hover:bg-slate-800 text-white font-semibold px-4 py-2 rounded-xl transition">
            <FeatureIcon name="arrow" class="w-4 h-4" strokeWidth={2} />
            Thử lại
          </a>
        </div>
      )}

      {plan && (
        <div x-data={`carePlanPage(${initialData})`} class="space-y-4">

          <!-- ═══════════════════════════════════════════════════════════ -->
          <!-- LAYER 1 · HERO — "Bây giờ làm gì?"                          -->
          <!-- Ink card with state-aware CTA + total progress bar          -->
          <!-- ═══════════════════════════════════════════════════════════ -->
          <section class={`relative rounded-3xl bg-mmp-ink text-white overflow-hidden ${HERO_STATE.ring}`}>
            <div aria-hidden="true" class="absolute -top-16 -right-16 w-48 h-48 rounded-full blur-3xl"
                 style="background: rgba(236, 185, 33, 0.18);"></div>

            <div class="relative p-5 sm:p-6">

              <!-- Pet identity strip + Refresh + Zalo -->
              <div class="flex items-center justify-between gap-3 mb-4 flex-wrap">
                <div class="min-w-0">
                  <p class="text-[10px] uppercase tracking-[0.3em] font-bold" style="color: var(--c-gold);">
                    Bé {plan.pet_name}
                  </p>
                  <p class="text-xs text-white/55 mt-0.5 truncate">
                    {plan.pet_breed && <>{plan.pet_breed} · </>}{plan.pet_age_label} · {fmtDate(plan.date)}
                  </p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <button @click="refresh()" :disabled="refreshing"
                    class="inline-flex items-center gap-1.5 text-xs bg-white/10 hover:bg-white/15 border border-white/15 disabled:opacity-50 text-white font-semibold px-2.5 py-1.5 rounded-lg transition">
                    <svg :class="refreshing ? 'animate-spin' : ''" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
                    <span x-show="!refreshing">Làm mới</span>
                    <span x-show="refreshing">…</span>
                  </button>
                  <button @click="shareZalo()"
                    class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1.5 rounded-lg text-mmp-ink transition hover:opacity-90"
                    style="background: var(--c-gold);">
                    <FeatureIcon name="share" class="w-3 h-3" strokeWidth={2} />
                    <span x-show="!copied">Zalo</span>
                    <span x-show="copied">✓</span>
                  </button>
                </div>
              </div>

              <!-- Suggestion card — content varies by status -->
              {suggestion.status === "all_done" ? (
                <div class="rounded-2xl p-5 bg-emerald-500/10 border border-emerald-400/30 text-center">
                  <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-emerald-400/20 mb-3">
                    <FeatureIcon name="trophy" class="w-7 h-7 text-emerald-300" strokeWidth={2} />
                  </span>
                  <p class={`text-[10px] uppercase tracking-[0.25em] font-bold mb-2 inline-block px-2 py-0.5 rounded ${HERO_STATE.badge}`}>
                    {HERO_STATE.label}
                  </p>
                  <h2 class="font-display italic text-2xl font-semibold text-white mb-1">
                    Hôm nay xong rồi
                  </h2>
                  <p class="text-sm text-white/70 mb-4">{suggestion.message}</p>
                  <a href={`/pets/${pet.id}/pet-score`}
                     class="inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-xl text-mmp-ink transition hover:opacity-90"
                     style="background: var(--c-gold);">
                    <FeatureIcon name="trophy" class="w-4 h-4" strokeWidth={2} />
                    Xem Pet Score
                    <FeatureIcon name="arrow" class="w-3.5 h-3.5" strokeWidth={2} />
                  </a>
                </div>
              ) : suggestion.task ? (
                <div class={`rounded-2xl p-4 sm:p-5 border ${
                  suggestion.status === "urgent"
                    ? "bg-amber-500/10 border-amber-400/30"
                    : suggestion.status === "overdue"
                      ? "bg-red-500/10 border-red-500/30"
                      : "bg-white/5 border-white/10"
                }`}>
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <div class="flex-1 min-w-0">
                      <p class={`text-[10px] uppercase tracking-[0.25em] font-bold mb-1.5 inline-block px-2 py-0.5 rounded ${HERO_STATE.badge}`}>
                        {HERO_STATE.label}
                      </p>
                      <h2 class="text-xl sm:text-2xl font-bold text-white leading-tight">
                        {suggestion.task.description}
                      </h2>
                      <p class="text-sm text-white/65 mt-1 font-mono tabular-nums">
                        {suggestion.task.time} · {suggestion.message}
                      </p>
                      {suggestion.task.note && (
                        <p class="text-xs text-white/50 mt-1.5">{suggestion.task.note}</p>
                      )}
                    </div>
                    <span class="shrink-0 inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-white/10 border border-white/10">
                      <FeatureIcon name={TYPE_ICON[suggestion.task.type] || "clock"} class="w-6 h-6" strokeWidth={2} style="color: var(--c-gold);" />
                    </span>
                  </div>

                  {/* Primary CTA — only when actionable (urgent or overdue) */}
                  {(suggestion.status === "urgent" || suggestion.status === "overdue") && (
                    suggestion.task.type === "exercise" ? (
                      // Exercise opens the rich tracking modal (captures duration/engagement/symptoms/notes)
                      <button type="button"
                              @click={`$dispatch('open-exercise-tracker', { itemKey: '${suggestion.task.key}', time: '${suggestion.task.time}', plannedDuration: ${plan.exercise?.items?.find((i: any) => itemKey("exercise", i.time) === suggestion.task.key)?.duration_min || 10}, description: ${JSON.stringify(suggestion.task.description)} })`}
                              class="w-full inline-flex items-center justify-center gap-2 font-bold px-4 py-3 rounded-xl text-mmp-ink transition hover:opacity-95"
                              style="background: var(--c-gold);">
                        <FeatureIcon name="activity" class="w-5 h-5" strokeWidth={2.2} />
                        <span>Ghi nhận buổi chơi</span>
                        <FeatureIcon name="arrow" class="w-4 h-4" strokeWidth={2.2} />
                        <span class="text-xs bg-mmp-ink/15 px-2 py-0.5 rounded-full font-bold ml-1">+5/10đ</span>
                      </button>
                    ) : (
                      <div x-data={`carePlanItem('${suggestion.task.key}', false, ${petId})`}>
                        <button type="button" @click="markComplete()" :disabled="loading || completed"
                                class="w-full inline-flex items-center justify-center gap-2 font-bold px-4 py-3 rounded-xl text-mmp-ink transition hover:opacity-95 disabled:opacity-60"
                                :class="completed ? 'bg-emerald-400' : ''"
                                style="background: var(--c-gold);">
                          <svg x-show="!completed && !loading" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                          <svg x-show="loading" class="w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="9" stroke-dasharray="40" stroke-dashoffset="10" stroke-linecap="round"/>
                          </svg>
                          <svg x-show="completed" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                          <span x-show="!completed">{suggestion.cta_label}</span>
                          <span x-show="completed">Đã ghi nhận</span>
                          <span class="text-xs bg-mmp-ink/15 px-2 py-0.5 rounded-full font-bold ml-1">+5đ</span>
                        </button>
                      </div>
                    )
                  )}
                </div>
              ) : (
                <div class="rounded-2xl p-5 bg-white/5 border border-white/10 text-center">
                  <p class="text-sm text-white/70">{suggestion.message}</p>
                </div>
              )}

              {/* Progress bar — total today */}
              <div class="mt-5 pt-4 border-t border-white/10">
                <div class="flex items-center justify-between mb-2 text-xs">
                  <span class="uppercase tracking-widest font-bold" style="color: var(--c-gold);">Tiến độ hôm nay</span>
                  <span class="font-bold text-white tabular-nums">
                    {progress.completed}/{progress.total}
                    <span class="text-white/55 font-normal"> · {progress.percent}%</span>
                  </span>
                </div>
                <div class="h-2 rounded-full bg-white/10 overflow-hidden">
                  <div class="h-full transition-all duration-700"
                       style={`width: ${progress.percent}%; background: var(--c-gold);`}></div>
                </div>
                {progress.percent < 100 && progress.completed > 0 && !trifectaGranted && (
                  <p class="text-[11px] text-white/55 mt-2 leading-snug">
                    Còn {progress.total - progress.completed} việc — hoàn thành 100% được
                    <strong class="text-white"> +30đ Trifecta</strong>.
                  </p>
                )}
                {trifectaGranted && (
                  <p class="text-[11px] mt-2 leading-snug font-semibold inline-flex items-center gap-1" style="color: var(--c-gold);">
                    <FeatureIcon name="trophy" class="w-3 h-3" strokeWidth={2.5} />
                    Trifecta hôm nay đã ghi nhận — +30đ
                  </p>
                )}
              </div>
            </div>
          </section>

          <!-- WEATHER (compact info card) -->
          {plan.weather && (
            <section class="bg-white rounded-2xl border border-slate-100 p-4 flex items-center justify-between gap-3">
              <div class="flex items-center gap-3 min-w-0">
                <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-mmp-cream shrink-0">
                  <FeatureIcon name="cloud-sun" class="w-5 h-5" strokeWidth={2} style="color: var(--c-gold);" />
                </span>
                <div class="min-w-0">
                  <p class="font-bold text-mmp-ink truncate">
                    {plan.weather.temp_celsius}°C
                    <span class="text-xs text-slate-500 font-normal"> · cảm giác {plan.weather.feels_like_celsius}°C</span>
                  </p>
                  <p class="text-[11px] text-slate-500 mt-0.5 truncate">
                    An toàn: <span class="text-mmp-ink font-semibold">{plan.weather.safe_hours_today}</span>
                  </p>
                </div>
              </div>
              <div class="text-right shrink-0">
                <p class="text-[10px] uppercase tracking-wider text-slate-500 font-bold">PetAir</p>
                <p class={`text-xl font-bold tabular-nums ${plan.weather.petair_index >= 60 ? 'text-emerald-700' : plan.weather.petair_index >= 40 ? 'text-amber-700' : 'text-red-700'}`}>
                  {plan.weather.petair_index}<span class="text-xs font-normal text-slate-400">/100</span>
                </p>
              </div>
            </section>
          )}

          <!-- ═══════════════════════════════════════════════════════════ -->
          <!-- LAYER 2 · TASKS HÔM NAY — checkboxable, 3 sections          -->
          <!-- ═══════════════════════════════════════════════════════════ -->
          <div class="pt-2 flex items-center justify-between">
            <h2 class="font-display italic text-lg font-semibold text-mmp-ink inline-flex items-center gap-2">
              <FeatureIcon name="check-square" class="w-5 h-5 text-emerald-600" strokeWidth={2} />
              Tasks hôm nay
            </h2>
            <span class="text-xs text-slate-500 font-semibold tabular-nums">
              {progress.completed}/{progress.total}
            </span>
          </div>

          <!-- 2A · ĂN UỐNG -->
          {plan.eating?.items?.length > 0 && (
            <section class="relative bg-white rounded-3xl border border-slate-100 p-5 shadow-sm overflow-hidden">
              <span aria-hidden="true" class="absolute left-0 top-0 bottom-0 w-1 rounded-l-3xl bg-amber-400"></span>

              <div class="flex items-center justify-between mb-3 pl-1">
                <h3 class="text-xs font-bold text-mmp-ink inline-flex items-center gap-2 uppercase tracking-widest">
                  <FeatureIcon name="bowl" class="w-4 h-4 text-amber-600" strokeWidth={2} />
                  Ăn uống
                </h3>
                <span class="text-xs font-bold text-amber-700 tabular-nums">
                  {progress.by_category.feeding.completed}/{progress.by_category.feeding.total}
                </span>
              </div>

              <ul class="space-y-2 pl-1">
                {plan.eating.items.map((item: any) => {
                  const key = itemKey("feeding", item.time);
                  const isDone = completedKeys.has(key);
                  const isUrgent = suggestion.task?.key === key && (suggestion.status === "urgent" || suggestion.status === "overdue");
                  return (
                    <li class={`flex items-start gap-3 rounded-xl p-3 border transition-all ${
                          isDone ? "bg-emerald-50 border-emerald-200"
                                 : isUrgent ? "bg-amber-50 border-amber-400 ring-2 ring-amber-200"
