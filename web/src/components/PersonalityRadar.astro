---
/**
 * SVG radar chart cho 7 personality axes (C-BARQ inspired).
 * Tự vẽ, không cần chart.js (Phase 0 minimal).
 *
 * Props:
 *   - ratings: { energy_level, friendliness_strangers, friendliness_other_pets,
 *                noise_sensitivity, handling_tolerance, trainability, separation_anxiety }
 *   - petName?: string (center label)
 */
interface Props {
  ratings: Record<string, number | null | undefined>;
  petName?: string;
}
const { ratings, petName } = Astro.props;

// 7 axes — order matches user spec
const AXES = [
  { key: "energy_level", label: "Năng lượng" },
  { key: "friendliness_strangers", label: "Người lạ" },
  { key: "friendliness_other_pets", label: "Pet khác" },
  { key: "noise_sensitivity", label: "Sợ ồn" },
  { key: "handling_tolerance", label: "Chịu chạm" },
  { key: "trainability", label: "Huấn luyện" },
  { key: "separation_anxiety", label: "Lo xa chủ" },
];

const SIZE = 300;
const CENTER = SIZE / 2;
const RADIUS = 100;
const MAX_VALUE = 5;

// Tính toạ độ axis (đầu mỗi axis)
function polar(angle: number, r: number) {
  return [CENTER + r * Math.cos(angle), CENTER + r * Math.sin(angle)] as const;
}

const axisPoints = AXES.map((ax, i) => {
  // Start at top (-PI/2), distribute evenly
  const angle = -Math.PI / 2 + (i * 2 * Math.PI) / AXES.length;
  return { angle, key: ax.key, label: ax.label };
});

// Grid polygons (5 levels)
const gridLevels = [1, 2, 3, 4, 5].map((level) => {
  const r = (RADIUS * level) / MAX_VALUE;
  return axisPoints
    .map((p) => {
      const [x, y] = polar(p.angle, r);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(" ");
});

// Data polygon (ratings)
const dataPoints = axisPoints
  .map((p) => {
    const v = Number(ratings?.[p.key] ?? 0);
    const r = (RADIUS * Math.min(MAX_VALUE, Math.max(0, v))) / MAX_VALUE;
    const [x, y] = polar(p.angle, r);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  })
  .join(" ");

// Label positions (slightly outside axis)
const labelOffset = RADIUS + 20;
const labelPositions = axisPoints.map((p) => {
  const [x, y] = polar(p.angle, labelOffset);
  return { x, y, label: p.label };
});

// Check nếu có ít nhất 1 rating filled
const hasData = AXES.some((ax) => {
  const v = ratings?.[ax.key];
  return v != null && Number(v) > 0;
});
---

<div class="flex flex-col items-center">
  {hasData ? (
    <svg viewBox={`0 0 ${SIZE} ${SIZE}`} class="w-full max-w-[300px]" aria-label="Personality radar chart">
      <defs>
        <linearGradient id="vow-radar-grad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" style="stop-color:rgba(56,189,248,0.5)" />
          <stop offset="100%" style="stop-color:rgba(168,85,247,0.5)" />
        </linearGradient>
      </defs>

      <!-- Grid levels -->
      {gridLevels.map((points, i) => (
        <polygon
          points={points}
          fill="none"
          stroke="#e2e8f0"
          stroke-width={i === gridLevels.length - 1 ? 1.5 : 0.5}
        />
      ))}

      <!-- Axis lines -->
      {axisPoints.map((p) => {
        const [x, y] = polar(p.angle, RADIUS);
        return (
          <line x1={CENTER} y1={CENTER} x2={x} y2={y} stroke="#e2e8f0" stroke-width="0.5" />
        );
      })}

      <!-- Data polygon -->
      <polygon
        points={dataPoints}
        fill="url(#vow-radar-grad)"
        stroke="rgb(14,165,233)"
        stroke-width="2"
      />

      <!-- Data points dots -->
      {axisPoints.map((p) => {
        const v = Number(ratings?.[p.key] ?? 0);
        const r = (RADIUS * Math.min(MAX_VALUE, Math.max(0, v))) / MAX_VALUE;
        const [x, y] = polar(p.angle, r);
        return v > 0 ? <circle cx={x} cy={y} r="3" fill="rgb(14,165,233)" /> : null;
      })}

      <!-- Center label (pet name) -->
      {petName && (
        <text x={CENTER} y={CENTER + 5} text-anchor="middle" class="fill-slate-700 text-sm font-bold">
          {petName}
        </text>
      )}

      <!-- Axis labels -->
      {labelPositions.map((p) => (
        <text
          x={p.x}
          y={p.y}
          text-anchor="middle"
          dominant-baseline="middle"
          class="fill-slate-600 text-[10px] font-medium"
        >
          {p.label}
        </text>
      ))}
    </svg>
  ) : (
    <div class="w-full max-w-[300px] aspect-square flex items-center justify-center bg-slate-50 rounded-xl border border-dashed border-slate-200">
      <p class="text-sm text-slate-400 text-center px-4">
        Chưa có đánh giá tính cách.<br /><span class="text-xs">Hoàn thiện section Tính cách để hiện biểu đồ.</span>
      </p>
    </div>
  )}
</div>
