                <defs>
                  <radialGradient id="radar6dSweepGrad" cx="50%" cy="50%" r="50%" fx="50%" fy="50%">
                    <stop offset="0%" stop-color="#ecb921" stop-opacity="0"/>
                    <stop offset="80%" stop-color="#ecb921" stop-opacity="0.18"/>
                    <stop offset="100%" stop-color="#ecb921" stop-opacity="0.55"/>
                  </radialGradient>
                </defs>
                <!-- Các phần tử sẽ được x-effect append vào đây -->
              </svg>
            </div>

            <!-- Top 3 dominant traits — light pill (v141: dùng getter để khỏi inline arrow fn) -->
            <div class="grid grid-cols-3 sm:grid-cols-1 gap-2 sm:min-w-[130px]">
              <template x-for="(lab, i) in topDim6Labels" :key="i">
                <div class="text-center sm:text-left p-2.5 rounded-lg bg-mmp-cream border border-gold-deep">
                  <p class="text-[9px] uppercase tracking-wider text-gold-deep font-extrabold" x-text="lab.label"></p>
                  <p class="text-lg font-black mt-0.5 text-mmp-ink" x-text="`${lab.score}%`"></p>
                </div>
              </template>
            </div>
          </div>

          <!-- v144 — RADAR ANIMATIONS (chạy unconditional, KHÔNG gate .is-visible nữa).
               Lý do bỏ .is-visible: IO không fire khi section ban đầu bị display:none
               bởi x-show parent → animations không bao giờ chạy → user thấy tĩnh.
               Lý do tách animation shorthand: Safari mobile parse calc() trong shorthand
               không reliable → drop animation. Tách animation-name/duration/delay riêng. -->
          <style is:inline>{`
            /* HEX RINGS — fade-in nhẹ stagger */
            .radar-living .radar-svg .radar-hex {
              animation: rl_fadeIn 0.45s ease-out backwards;
              animation-delay: calc(var(--i, 0) * 0.08s);
            }

            /* AXIS LINES — stroke draw từ center ra ngoài, stagger theo i */
            .radar-living .radar-svg .radar-axis {
              stroke-dasharray: 110;
              stroke-dashoffset: 110;
              animation: rl_strokeDraw 0.55s cubic-bezier(.2,.9,.3,1) forwards;
              animation-delay: calc(0.3s + var(--i, 0) * 0.08s);
            }

            /* SYNAPSE arcs — fade-in + dash flow (2 anim, tách shorthand cho Safari) */
            .radar-living .radar-svg .synapse {
              animation-name: rl_fadeIn, rl_synapsePulse;
              animation-duration: 0.4s, 2s;
              animation-timing-function: ease-out, ease-in-out;
              animation-fill-mode: backwards, none;
              animation-iteration-count: 1, infinite;
              animation-delay: calc(0.9s + var(--i, 0) * 0.1s), calc(1.5s + var(--i, 0) * 0.25s);
            }

            /* POLYGON — reveal scale-pop xong vào BREATHING vĩnh viễn */
            .radar-living .radar-svg .dim6-poly {
              transform-origin: 160px 140px;
              animation-name: rl_polyReveal, rl_breathe;
              animation-duration: 0.9s, 4s;
              animation-timing-function: cubic-bezier(.2,.9,.3,1.2), ease-in-out;
              animation-fill-mode: forwards, none;
              animation-iteration-count: 1, infinite;
              animation-delay: 1.2s, 2.2s;
            }

            /* VERTEX DOTS — pop-in stagger rồi PULSE forever */
            .radar-living .radar-svg .radar-dot-galaxy {
              transform-origin: center;
              transform-box: fill-box;
              filter: drop-shadow(0 0 3px rgba(180,134,8,0.7));
              animation-name: rl_dotPop, rl_dotPulse;
              animation-duration: 0.5s, 2s;
              animation-timing-function: cubic-bezier(.2,1.6,.3,1), ease-in-out;
              animation-fill-mode: forwards, none;
              animation-iteration-count: 1, infinite;
              animation-delay: calc(1.6s + var(--i, 0) * 0.2s), calc(3.5s + var(--i, 0) * 0.2s);
            }

            /* LABEL groups — reveal theo angle sweep (start opacity 0, vào 1 stagger 0.5s) */
            .radar-living .radar-svg .radar-label {
              transform-origin: center;
              opacity: 0;
              animation: rl_labelReveal 0.4s cubic-bezier(.2,.9,.3,1.2) forwards;
              animation-delay: calc(0.4s + var(--i, 0) * 0.5s);
            }

            /* SWEEP WEDGE — quay 360° vĩnh viễn (rõ nhất animation user thấy được) */
            .radar-living .radar-svg .radar-wedge {
              transform-origin: 160px 140px;
              transform-box: fill-box;
              opacity: 0.55;
              mix-blend-mode: multiply;
              animation: rl_scanRotate 3.6s linear infinite;
            }

            /* ═══ KEYFRAMES (rl_ prefix = radar-living, namespace riêng) ═══ */
            @keyframes rl_fadeIn {
              from { opacity: 0; }
              to   { opacity: 1; }
            }
            @keyframes rl_strokeDraw {
              from { stroke-dashoffset: 110; opacity: 0.4; }
              to   { stroke-dashoffset: 0;   opacity: 1; }
            }
            @keyframes rl_synapsePulse {
              0%, 100% { stroke-dashoffset: 0;   opacity: 0.65; }
              50%      { stroke-dashoffset: -28; opacity: 1; }
            }
            @keyframes rl_polyReveal {
              0%   { opacity: 0; transform: scale(0.15) rotate(-12deg); }
              60%  { opacity: 1; transform: scale(1.08) rotate(4deg); }
              100% { opacity: 1; transform: scale(1) rotate(0deg); }
            }
            @keyframes rl_breathe {
              0%, 100% {
                transform: scale(1) rotate(0deg);
                fill: rgba(180,134,8,0.30);
                stroke-width: 3;
                filter: drop-shadow(0 0 14px rgba(236,185,33,0.6));
              }
              33% {
                transform: scale(1.07) rotate(3deg);
                fill: rgba(236,185,33,0.55);
                stroke-width: 4;
                filter: drop-shadow(0 0 28px rgba(236,185,33,0.95));
              }
              66% {
                transform: scale(0.94) rotate(-3deg);
                fill: rgba(180,134,8,0.38);
                stroke-width: 3.4;
                filter: drop-shadow(0 0 20px rgba(180,134,8,0.8));
              }
            }
            @keyframes rl_dotPop {
              0%   { opacity: 0; transform: scale(0); }
              70%  { opacity: 1; transform: scale(1.6); }
              100% { opacity: 1; transform: scale(1); }
            }
            @keyframes rl_dotPulse {
              0%, 100% { r: 4; opacity: 1; }
              50%      { r: 6; opacity: 0.75; }
            }
            @keyframes rl_labelReveal {
              from { opacity: 0; transform: scale(0.5); }
              to   { opacity: 1; transform: scale(1); }
            }
            @keyframes rl_scanRotate {
              from { transform: rotate(-90deg); }
              to   { transform: rotate(270deg); }
            }

            /* prefers-reduced-motion — show ngay, không animate */
            @media (prefers-reduced-motion: reduce) {
              .radar-living .radar-svg .radar-hex,
              .radar-living .radar-svg .radar-axis,
              .radar-living .radar-svg .synapse,
              .radar-living .radar-svg .radar-label,
              .radar-living .radar-svg .radar-dot-galaxy,
              .radar-living .radar-svg .dim6-poly { opacity: 1; animation: none; stroke-dashoffset: 0; }
              .radar-living .radar-svg .radar-wedge { display: none; }
            }
          `}</style>
        </section>

