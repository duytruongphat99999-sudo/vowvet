---
/**
 * Bước 2-fix#2 — Văn bằng "Chứng nhận Hồ sơ Trọn đời" — bản LÀM MỀM.
 * Giữ brand gold/đen/cream + con dấu gold (logo-mmp.png) → THÊM pastel rose/peach,
 * hoạ tiết hoa lá mảnh ở 4 góc + vòng hoa quanh ảnh, icon điều khoản line-art mềm.
 * Tối giản, ấm áp (89% nữ) — KHÔNG đổi tông chủ đạo gold/cream.
 *
 * PRESENTATIONAL — dùng state của wizard cha (newPetForm):
 *   pet.name · pet.species · userName · photoPreview · certTicked · stamping · stampDone
 *   · confirmPledge() · todayDisplay · certNumber
 * Con dấu copy bản passport hero-stamp (đang render chữ vòng OK), id đổi vvp2-* tránh trùng.
 */

// Hoạ tiết hoa lá mảnh (watercolor-lite): cành cong + 2 lá + 1 bông hồng phấn nhụy vàng.
const FLORAL_SPRIG = `<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 56 C 22 47, 30 33, 35 15" stroke="#bd962f" stroke-width="1.2" stroke-linecap="round" opacity="0.55"/><path d="M19 47 C 11 45, 8 38, 10 31 C 18 33, 21 41, 19 47 Z" fill="#d9b98a" opacity="0.34"/><path d="M27 35 C 19 34, 15 27, 17 20 C 25 22, 29 29, 27 35 Z" fill="#d9b98a" opacity="0.34"/><g opacity="0.6"><circle cx="33" cy="9" r="3.6" fill="#f0d2d2"/><circle cx="39" cy="9" r="3.6" fill="#f0d2d2"/><circle cx="33" cy="15" r="3.6" fill="#f0d2d2"/><circle cx="39" cy="15" r="3.6" fill="#f0d2d2"/><circle cx="36" cy="12" r="4" fill="#ecc7c7"/><circle cx="36" cy="12" r="2.1" fill="#e3b04f"/></g></svg>`;

// Icon 5 điều khoản — line-art gold mảnh, bo tròn, đính chút hồng phấn.
// width/height="18" gắn THẲNG vào SVG (không phụ thuộc CSS scoped — vốn không áp được cho set:html).
const ICO_FOREVER = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B48608" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18C5.2 15.4 3 12.9 3 10.3 3 8.5 4.4 7.1 6.1 7.1c1.1 0 2.1.6 2.9 1.6.8-1 1.8-1.6 2.9-1.6 1.7 0 3.1 1.4 3.1 3.2 0 2.6-2.2 5.1-6 7.7Z" fill="#ecc7c7" fill-opacity=".4"/><path d="M15.4 7.4c.6-.5 1.4-.8 2.2-.8C19.4 6.6 20.7 8 20.7 9.8c0 2-1.3 3.9-3.7 5.8" stroke-opacity=".6"/></svg>`;
const ICO_KEY = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B48608" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="4.3"/><circle cx="8" cy="8" r="1.1" fill="#ecc7c7" stroke="none"/><path d="M11 11l8 8M16.5 16.5l2-2M14 19l1.8-1.8"/></svg>`;
const ICO_MED = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B48608" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4.2" y="4.2" width="15.6" height="15.6" rx="6"/><path d="M12 8.4v7.2M8.4 12h7.2" stroke-width="2"/></svg>`;
const ICO_CAMERA = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B48608" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.6c0-.9.7-1.6 1.6-1.6H7l1.2-1.8h7.6L17 7h2.4c.9 0 1.6.7 1.6 1.6v8.8c0 .9-.7 1.6-1.6 1.6H4.6c-.9 0-1.6-.7-1.6-1.6z"/><circle cx="12" cy="12.6" r="3.2" fill="#ecc7c7" fill-opacity=".4"/></svg>`;
const ICO_PAW = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B48608" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="7" cy="11" rx="1.7" ry="2.2"/><ellipse cx="11.2" cy="8.6" rx="1.8" ry="2.4"/><ellipse cx="15.6" cy="9.2" rx="1.7" ry="2.3"/><ellipse cx="18" cy="13" rx="1.5" ry="2"/><path d="M12 13.4c-2.4 0-4.3 1.7-4.3 3.6 0 1.5 1.3 2.1 2.8 2.1 1 0 1.2-.3 2-.3s1 .3 2 .3c1.5 0 2.8-.6 2.8-2.1 0-1.9-1.9-3.6-4.3-3.6Z" fill="#ecc7c7" fill-opacity=".4"/></svg>`;
---

<div class="vvcert-paper relative mx-auto w-full max-w-lg rounded-2xl">
  <div class="vvcert-frame relative m-1.5 rounded-xl px-5 py-6 sm:px-8 sm:py-7">

    {/* Hoạ tiết hoa lá 4 góc — thay góc hoa văn cứng */}
    <span class="vvcert-floral vvcert-floral--tl" aria-hidden="true" set:html={FLORAL_SPRIG}></span>
    <span class="vvcert-floral vvcert-floral--tr" aria-hidden="true" set:html={FLORAL_SPRIG}></span>
    <span class="vvcert-floral vvcert-floral--bl" aria-hidden="true" set:html={FLORAL_SPRIG}></span>
    <span class="vvcert-floral vvcert-floral--br" aria-hidden="true" set:html={FLORAL_SPRIG}></span>

    {/* Số hiệu — chỉ hiện khi ĐÃ có (sau khi tạo bé). Trong wizard chưa có id → ghi 'cấp sau', không hiện placeholder rỗng */}
    <p class="text-center text-[9px] sm:text-[10px] font-semibold" style="color:#c79a3a;">
      <span x-show="certNumber" class="tracking-[0.3em]">SỐ HIỆU · <span x-text="certNumber"></span></span>
      <span x-show="!certNumber" style="display:none;" class="italic tracking-wide opacity-80">Số hiệu sẽ cấp sau khi hoàn tất hồ sơ</span>
    </p>

    {/* Tiêu đề — serif mềm hơn */}
    <p class="text-center text-[10px] sm:text-[11px] tracking-[0.34em] font-semibold mt-2" style="color:#c79a3a;">CHỨNG NHẬN</p>
    <h1 class="vvcert-title text-center font-display italic text-mmp-ink leading-tight">Hồ sơ Trọn đời</h1>
    <div class="vvcert-rule mx-auto"></div>

    {/* Ảnh bé — khung tròn viền gold + vòng hoa nhẹ. Có ảnh thật → hiện ảnh; chưa có → emoji loài */}
    <div class="vvcert-photo relative mx-auto mt-3">
      <span class="vvcert-wreath vvcert-wreath--l" aria-hidden="true" set:html={FLORAL_SPRIG}></span>
      <span class="vvcert-wreath vvcert-wreath--r" aria-hidden="true" set:html={FLORAL_SPRIG}></span>
      <div class="vvcert-photo-ring">
        <template x-if="photoPreview"><img :src="photoPreview" alt="" class="w-full h-full object-cover" /></template>
        <template x-if="!photoPreview"><span class="vvcert-photo-emoji" x-text="pet.species==='Mèo' ? '🐱' : pet.species==='Chó' ? '🐶' : '🐾'"></span></template>
      </div>
    </div>

    {/* Dòng định danh */}
    <p class="text-center text-[13px] text-mmp-ink/85 leading-relaxed mt-3 px-1">
      Chứng nhận rằng <strong class="font-display italic text-mmp-ink" x-text="pet.name || 'bé cưng của bạn'"></strong>
      được người giám hộ cam kết chăm sóc và khai báo trung thực thông tin <strong class="text-mmp-ink">trọn đời</strong>.
    </p>

    {/* 5 điều khoản — icon mềm + tiêu đề + mô tả */}
    <ul class="mt-4 space-y-2 text-left">
      <li class="flex gap-3 items-start"><span class="vvcert-ico-badge" aria-hidden="true" set:html={ICO_FOREVER}></span><span class="min-w-0"><span class="block font-semibold text-mmp-ink text-[12.5px]">Bên nhau trọn kiếp</span><span class="block text-[11px] text-mmp-ink/70 leading-snug">Gắn kết từ hôm nay, an yên đến những ngày sau cuối.</span></span></li>
      <li class="flex gap-3 items-start"><span class="vvcert-ico-badge" aria-hidden="true" set:html={ICO_KEY}></span><span class="min-w-0"><span class="block font-semibold text-mmp-ink text-[12.5px]">Gửi gắm lòng tin</span><span class="block text-[11px] text-mmp-ink/70 leading-snug">Thành thật chia sẻ chính là chiếc chìa khóa bảo vệ bé yêu.</span></span></li>
      <li class="flex gap-3 items-start"><span class="vvcert-ico-badge" aria-hidden="true" set:html={ICO_MED}></span><span class="min-w-0"><span class="block font-semibold text-mmp-ink text-[12.5px]">Song hành cùng VowVet</span><span class="block text-[11px] text-mmp-ink/70 leading-snug">Khi tình yêu thương được tiếp sức bởi chuyên môn và công nghệ.</span></span></li>
      <li class="flex gap-3 items-start"><span class="vvcert-ico-badge" aria-hidden="true" set:html={ICO_CAMERA}></span><span class="min-w-0"><span class="block font-semibold text-mmp-ink text-[12.5px]">Lưu dấu yêu thương</span><span class="block text-[11px] text-mmp-ink/70 leading-snug">Từng nét chữ, thước phim được bảo mật vẹn nguyên theo năm tháng.</span></span></li>
      <li class="flex gap-3 items-start"><span class="vvcert-ico-badge" aria-hidden="true" set:html={ICO_PAW}></span><span class="min-w-0"><span class="block font-semibold text-mmp-ink text-[12.5px]">Tất cả vì con</span><span class="block text-[11px] text-mmp-ink/70 leading-snug">Một cái gật đầu hôm nay, đổi lại vạn ngày an lành phía trước.</span></span></li>
    </ul>

    {/* Khu chữ ký + ngày — con mộc đóng đè lên đây */}
    <div class="relative mt-7 flex items-end justify-between gap-5">
      {/* TRÁI — người nuôi cam kết + ngày */}
      <div class="text-left flex-1 min-w-0">
        <p class="text-[10px] uppercase tracking-wider text-mmp-ink/55">Người cam kết</p>
        <p class="font-display italic text-sm font-semibold text-mmp-ink truncate" x-text="userName || 'Người giám hộ'"></p>
        <div class="vvcert-sigline"></div>
        <p class="mt-1 text-[10.5px] text-mmp-ink/60">Ngày <span x-text="todayDisplay"></span></p>
      </div>
      {/* PHẢI — đại diện VowVet, chữ ký viết tay (font hỗ trợ tiếng Việt) */}
      <div class="text-right flex-1 min-w-0">
        <p class="text-[10px] uppercase tracking-wider text-mmp-ink/55">Đại diện</p>
        <p class="vvcert-sign-hand">VowVet</p>
        <div class="vvcert-sigline ml-auto"></div>
        <p class="mt-1 text-[10.5px] text-mmp-ink/60">Mon Min Pet</p>
      </div>

      {/* CON MỘC GOLD — copy bản passport (hsp→vvp2). Đóng xuống giữa khu chữ ký */}
      <span class="vvcert-stamp" :class="{ 'is-stamping': stamping }" aria-hidden="true">
        <span class="vvcert-ripple" :class="{ 'go': stamping }"></span>
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mon Min Pet Cam Kết Trọn Đời">
          <defs>
            <filter id="vvp2-ink" x="-5%" y="-5%" width="110%" height="110%">
              <feTurbulence type="fractalNoise" baseFrequency="1.1" numOctaves="2" seed="11" result="t"/>
              <feDisplacementMap in="SourceGraphic" in2="t" scale="0.9"/>
            </filter>
            <filter id="vvp2-logo-gold" x="-40%" y="-40%" width="180%" height="180%">
              <feColorMatrix type="matrix" values="0 0 0 0 0.706  0 0 0 0 0.525  0 0 0 0 0.031  0 0 0 1.4 0" result="goldLogo"/>
              <feGaussianBlur in="goldLogo" stdDeviation="2" result="glowInner"/>
              <feGaussianBlur in="goldLogo" stdDeviation="5" result="glowOuter"/>
              <feFlood flood-color="#ecb921" flood-opacity="0.7" result="glowColor1"/>
              <feComposite in="glowColor1" in2="glowInner" operator="in" result="glow1"/>
              <feFlood flood-color="#ecb921" flood-opacity="0.4" result="glowColor2"/>
              <feComposite in="glowColor2" in2="glowOuter" operator="in" result="glow2"/>
              <feMerge><feMergeNode in="glow2"/><feMergeNode in="glow1"/><feMergeNode in="goldLogo"/></feMerge>
            </filter>
            <path id="vvp2-arc-top" d="M 24 100 A 76 76 0 0 1 176 100" fill="none"/>
            <path id="vvp2-arc-bot" d="M 24 100 A 76 76 0 0 0 176 100" fill="none"/>
          </defs>

          <g filter="url(#vvp2-ink)" fill="#B48608" stroke="#B48608">
            <circle cx="100" cy="100" r="92" fill="none" stroke-width="3.8" stroke-opacity="0.95"/>
            <circle cx="100" cy="100" r="84" fill="none" stroke-width="1.6" stroke-opacity="0.85"/>
            <circle cx="100" cy="100" r="64" fill="none" stroke-width="0.8" stroke-opacity="0.55"/>

            <text font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="11.5" letter-spacing="2.6" fill-opacity="0.96" stroke="none">
              <textPath href="#vvp2-arc-top" startOffset="50%" text-anchor="middle">CERTIFIED · PASSPORT · OFFICIAL</textPath>
            </text>
            <text font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="11" letter-spacing="3" fill-opacity="0.96" stroke="none">
              <textPath href="#vvp2-arc-bot" startOffset="50%" text-anchor="middle">★ BY MON MIN PET ★</textPath>
            </text>

            <text x="20" y="107" text-anchor="middle" font-size="16" font-weight="900" fill-opacity="0.92" stroke="none">✦</text>
            <text x="180" y="107" text-anchor="middle" font-size="16" font-weight="900" fill-opacity="0.92" stroke="none">✦</text>

            <text x="100" y="115" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-style="italic" font-weight="700" font-size="18" letter-spacing="0.4" fill-opacity="1" stroke="none">VowVet</text>

            <line x1="60" y1="126" x2="140" y2="126" stroke-width="0.8" stroke-opacity="0.7"/>

            <text x="100" y="139" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-weight="800" font-size="8.5" letter-spacing="1.5" fill-opacity="0.96" stroke="none">CAM KẾT TRỌN ĐỜI</text>
          </g>

          <image href="/logo-mmp.png" x="76" y="46" width="48" height="48" preserveAspectRatio="xMidYMid meet" opacity="0.98" filter="url(#vvp2-logo-gold)"/>
        </svg>
      </span>
    </div>

    {/* Checkbox + nút (ẩn sau khi đóng mộc) */}
    <div x-show="!stampDone" class="mt-5">
      <label class="flex items-start gap-2 text-left text-[12.5px] text-mmp-ink/85 cursor-pointer bg-white/70 rounded-2xl px-3 py-2.5 border" style="border-color: rgba(180,134,8,.3);">
        <input type="checkbox" x-model="certTicked" class="mt-0.5 shrink-0" style="accent-color:#B48608;" />
        <span>Tôi cam kết khai báo trung thực thông tin của <strong x-text="pet.name || 'bé'"></strong>, vì sức khỏe và cuộc sống của bé.</span>
      </label>
      <button type="button" @click="confirmPledge()" :disabled="!certTicked || stamping"
              class="mt-3 w-full px-5 py-3 rounded-2xl font-bold text-sm transition"
              :class="certTicked ? 'bg-mmp-ink text-white hover:bg-mmp-ink/90 shadow-lg' : 'bg-mmp-ink/15 text-mmp-ink/40 cursor-not-allowed'">
        <span x-text="stamping ? 'Đang đóng mộc…' : 'Xác nhận cam kết'"></span>
      </button>
    </div>
    <p x-show="stampDone" style="display:none;" class="mt-5 text-center text-sm font-semibold" style="color:#B48608;">✓ Đã đóng mộc · Hồ sơ trọn đời đã lập</p>
  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&display=swap");
  /* Giấy vân kem ấm + chút pastel rose/peach (KHÔNG đổi tông chủ đạo) */
  .vvcert-paper {
    background:
      radial-gradient(circle at 16% 12%, rgba(236,199,199,.18), transparent 42%),
      radial-gradient(circle at 86% 88%, rgba(244,214,176,.18), transparent 44%),
      radial-gradient(circle at 82% 14%, rgba(180,134,8,.05), transparent 40%),
      repeating-linear-gradient(135deg, rgba(180,134,8,.02) 0 2px, transparent 2px 7px),
      linear-gradient(135deg, #fbf7f0, #f6eede);
    border: 1.5px solid rgba(180,134,8,.7);
    box-shadow: 0 16px 44px rgba(10,10,10,.4), inset 0 0 0 1px rgba(180,134,8,.22);
    animation: vvcert-in .4s cubic-bezier(.22,.61,.36,1) both;
  }
  .vvcert-frame { border: 1.2px solid rgba(180,134,8,.42); box-shadow: inset 0 0 0 4px rgba(255,255,255,.42), inset 0 0 0 5px rgba(236,199,199,.28); }
  @keyframes vvcert-in { from { opacity: 0; transform: translateY(16px) scale(.97); } to { opacity: 1; transform: none; } }

  /* Tiêu đề mềm — Fraunces italic, nhẹ tracking */
  .vvcert-title { font-size: 1.7rem; font-weight: 500; letter-spacing: .01em; margin-top: .15rem; }
  @media (min-width: 640px) { .vvcert-title { font-size: 2.05rem; } }
  .vvcert-rule { margin-top: .5rem; width: 92px; height: 2px; background: linear-gradient(90deg, transparent, rgba(180,134,8,.85), rgba(236,199,199,.9), transparent); }

  /* Hoa lá 4 góc */
  .vvcert-floral { position: absolute; width: 54px; height: 54px; pointer-events: none; z-index: 1; }
  .vvcert-floral--tl { top: -3px; left: -3px; }
  .vvcert-floral--tr { top: -3px; right: -3px; transform: scaleX(-1); }
  .vvcert-floral--bl { bottom: -3px; left: -3px; transform: scaleY(-1); }
  .vvcert-floral--br { bottom: -3px; right: -3px; transform: scale(-1,-1); }

  /* Ảnh tròn + vòng hoa */
  .vvcert-photo { width: 84px; }
  .vvcert-photo-ring {
    width: 84px; height: 84px; border-radius: 9999px; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    background: #fbf3e6;
    box-shadow: 0 0 0 3px #d8b25a, 0 0 0 4.5px rgba(236,199,199,.6), 0 6px 18px rgba(180,134,8,.22);
  }
  .vvcert-photo-emoji { font-size: 2rem; line-height: 1; color: #B48608; }
  .vvcert-wreath { position: absolute; bottom: -4px; width: 32px; height: 32px; opacity: .75; z-index: 0; }
  .vvcert-wreath--l { left: -19px; transform: rotate(18deg); }
  .vvcert-wreath--r { right: -19px; transform: scaleX(-1) rotate(18deg); }

  /* Icon 5 điều khoản — badge tròn trắng-kem + viền gold mảnh để icon gold NỔI RÕ (không trùng nền) */
  .vvcert-ico-badge { width: 30px; height: 30px; flex-shrink: 0; border-radius: 9999px; background: rgba(255,255,255,.8); box-shadow: inset 0 0 0 1px rgba(180,134,8,.22); display: flex; align-items: center; justify-content: center; margin-top: 1px; }
  .vvcert-ico-badge svg { display: block; }
  /* Chữ ký viết tay đại diện (Dancing Script — có subset tiếng Việt) */
  .vvcert-sign-hand { font-family: "Dancing Script", "Segoe Script", cursive; font-weight: 700; font-size: 1.6rem; line-height: 1.05; color: #B48608; margin-top: 1px; }

  .vvcert-sigline { margin-top: 4px; height: 1px; width: 100%; min-width: 96px; background: rgba(10,10,10,.35); }

  /* Con mộc — đóng đè lên khu chữ ký (giữa) */
  .vvcert-stamp {
    position: absolute; left: 50%; bottom: -6px; transform: translateX(-50%);
    width: 150px; height: 150px; pointer-events: none; z-index: 5;
    opacity: 0;  /* LUÔN trong layout (KHÔNG display:none) để <textPath> chữ vòng render đúng */
  }
  .vvcert-stamp.is-stamping { opacity: 1; }
  .vvcert-stamp svg { width: 100%; height: 100%; filter: drop-shadow(0 6px 14px rgba(0,0,0,.32)); transform: rotate(-8deg); }
  .vvcert-stamp.is-stamping svg { animation: vvcert-stamp-down .85s cubic-bezier(.3,.7,.4,1) both; }
  @keyframes vvcert-stamp-down {
    0%   { opacity: 0; transform: scale(1.6) rotate(-12deg); }
    50%  { opacity: 1; transform: scale(.97) rotate(-6deg); }
    64%  { transform: scale(.92) rotate(-9deg); }
    78%  { transform: scale(1.03) rotate(-7deg); }
    100% { transform: scale(1) rotate(-8deg); }
  }
  .vvcert-ripple { position: absolute; left: 50%; top: 50%; width: 120px; height: 120px; margin: -60px 0 0 -60px; border-radius: 9999px; border: 2px solid rgba(180,134,8,.5); opacity: 0; }
  .vvcert-ripple.go { animation: vvcert-ripple .8s ease-out .25s 1; }
  @keyframes vvcert-ripple { 0% { opacity: .65; transform: scale(.5); } 100% { opacity: 0; transform: scale(1.7); } }
  @media (prefers-reduced-motion: reduce) {
    .vvcert-paper, .vvcert-stamp.is-stamping svg, .vvcert-ripple.go { animation: none !important; }
    .vvcert-stamp svg { transform: rotate(-8deg); }
  }
</style>
