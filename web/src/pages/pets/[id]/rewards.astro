    function renderRewardIcon(emoji, size) {
      const s = size || '24px';
      const svg = REWARD_LUCIDE_ICONS[emoji];
      if (svg) return '<span style="display:inline-flex;width:' + s + ';height:' + s + ';">' + svg + '</span>';
      // Fallback: emoji char
      return '<span style="font-size:' + s + ';line-height:1;">' + (emoji || '🎁') + '</span>';
    }

    function rewardsPage(initial) {
      return {
        pet: initial.pet,
        unlockable: initial.unlockable.map(r => ({ ...r, claiming: false, claim_error: null })),
        locked: initial.locked,
        claimed: initial.claimed,
        tab: 'unlockable',
        renderIcon: renderRewardIcon,

        statusBadge(s) {
          return ({
            active: 'bg-gold-tint-strong text-gold-ink',
            redeemed: 'bg-ink-tint text-ink-strong',
            expired: 'bg-ink-soft text-ink-mute',
            cancelled: 'bg-ink-tint text-ink-strong',
            pending: 'bg-gold-tint text-gold',
          }[s]) || 'bg-ink-tint text-ink-strong';
        },

        statusLabel(s) {
          return ({ active: 'Hiệu lực', redeemed: 'Đã dùng', expired: 'Hết hạn', cancelled: 'Đã huỷ', pending: 'Chờ' }[s]) || s;
        },

        launchConfetti() {
          const colors = ['#ecb921', '#B48608', '#fff7d6', '#d4a615'];
          for (let i = 0; i < 50; i++) {
            const el = document.createElement('div');
            el.className = 'confetti-piece';
            el.style.left = Math.random() * 100 + 'vw';
            el.style.background = colors[Math.floor(Math.random() * colors.length)];
            el.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
            el.style.animationDuration = (1.8 + Math.random() * 1.4) + 's';
            el.style.animationDelay = Math.random() * 0.4 + 's';
            document.body.appendChild(el);
            el.addEventListener('animationend', () => el.remove());
          }
        },

        async claim(r) {
          if (r.claiming) return;
          r.claiming = true;
          r.claim_error = null;
          try {
            const res = await fetch(`/api/v1/rewards/pets/${this.pet.id}/${r.code}/claim`, {
              method: 'POST', credentials: 'include',
            });
            const j = await res.json();
            if (!res.ok) {
              r.claim_error = j?.error?.message || 'Lỗi claim';
              return;
            }
            this.launchConfetti();
            // Delay redirect to let confetti show
            setTimeout(() => {
              window.location.href = `/rewards/${j.claim.id}`;
            }, 1200);
          } catch (_) {
            r.claim_error = 'Lỗi kết nối';
          } finally {
            r.claiming = false;
          }
        },
      };
    }
  </script>

  <style>
    [x-cloak] { display: none !important; }

    /* v103: Brand status badges (replacing emerald/yellow/red) */
    .bg-gold-tint-strong { background: rgba(236, 185, 33, 0.22); }
    .bg-gold-tint { background: rgba(236, 185, 33, 0.12); }
    .bg-ink-tint { background: rgba(10, 10, 10, 0.08); }
    .bg-ink-soft { background: rgba(10, 10, 10, 0.04); }
    .text-gold-ink { color: #5a4a2a; }
    .text-gold { color: #B48608; }
    .text-ink-strong { color: #0a0a0a; }
    .text-ink-mute { color: rgba(10, 10, 10, 0.54); }

    /* v103: Tab active state (in vault hero + tab switcher) */
    .reward-tab {
      background: transparent;
      color: var(--c-ink-72);
    }
    .reward-tab.is-active {
      background: linear-gradient(90deg, #ecb921 0%, #B48608 100%);
      color: #0a0a0a;
      box-shadow: 0 3px 10px rgba(236, 185, 33, 0.3);
    }
    button[class*="rounded-xl"][class*="text-center"].is-active {
      box-shadow: inset 0 0 0 2px #ecb921, 0 0 12px rgba(236, 185, 33, 0.35);
    }

    /* v103: Unlockable card glow pulse */
    .reward-unlock-card {
      animation: vault-pulse 2.8s ease-in-out infinite;
    }
    @keyframes vault-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(236, 185, 33, 0.55), 0 4px 14px rgba(10, 10, 10, 0.18); }
      50%      { box-shadow: 0 0 0 10px rgba(236, 185, 33, 0), 0 6px 22px rgba(236, 185, 33, 0.25); }
    }

    /* v103: Claim button gold shimmer sweep */
    .claim-btn {
      position: relative;
      overflow: hidden;
    }
    .claim-btn:not([disabled])::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 35%, rgba(255, 255, 255, 0.4) 50%, transparent 65%);
      background-size: 220% 100%;
      background-position: 220% 0;
      animation: claim-shimmer 3.2s ease-in-out 1.2s infinite;
      pointer-events: none;
      border-radius: inherit;
    }
    @keyframes claim-shimmer {
      0%, 40%  { background-position: 220% 0; }
      70%      { background-position: -120% 0; }
      100%     { background-position: -120% 0; }
    }

    /* v103: Confetti falling */
    @keyframes confetti-fall {
      0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
      100% { transform: translateY(80vh) rotate(540deg); opacity: 0; }
    }
    .confetti-piece {
      position: fixed; top: 10vh;
      width: 9px; height: 9px;
      animation: confetti-fall 2.2s ease-out forwards;
      z-index: 9999; pointer-events: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .reward-unlock-card { animation: none; }
      .claim-btn::after { animation: none; }
    }
  </style>
</Layout>
