          <FeatureIcon name="arrow" class="w-3.5 h-3.5 rotate-180" />
          <span>Routines</span>
        </a>
        <h1 class="font-display italic text-lg font-semibold text-mmp-ink inline-flex items-center gap-2">
          <span x-show="step === 1" class="inline-flex items-center gap-2">
            <FeatureIcon name="clipboard" class="w-4 h-4" style="color: #B48608;" />
            <span>Chọn mẫu</span>
          </span>
          <span x-show="step === 2" class="inline-flex items-center gap-2">
            <FeatureIcon name="settings" class="w-4 h-4" style="color: #B48608;" />
            <span>Tuỳ chỉnh</span>
          </span>
          <span x-show="step === 3" class="inline-flex items-center gap-2">
            <FeatureIcon name="check-square" class="w-4 h-4" style="color: #B48608;" />
            <span>Tasks</span>
          </span>
        </h1>
        <span class="text-[10px] italic uppercase tracking-[0.2em] font-bold" style="color: #B48608;">Bước <span x-text="step"></span>/3</span>
      </header>

      <!-- Progress bar gold gradient -->
      <div class="h-1.5 rounded-full overflow-hidden mb-6" style="background: rgba(180, 134, 8, 0.1);">
        <div class="h-full rounded-full transition-all duration-700"
          :style="`width: ${(step / 3) * 100}%; background: linear-gradient(90deg, #ecb921 0%, #B48608 100%);`"></div>
      </div>

      <!-- ───── v101: Step 1 — Smart Blueprint Engine (same as /routines page) ───── -->
      <div x-show="step === 1" x-data="{ showMore: false }">

        {/* Pet context header */}
        <div class="mb-4 flex items-end justify-between gap-2">
          <div class="min-w-0">
            <p class="text-[10px] uppercase italic tracking-[0.22em] font-bold" style="color: #B48608;">Gợi ý cho bé {pet.name}</p>
            <h2 class="font-display italic text-lg sm:text-xl font-semibold text-mmp-ink leading-tight">Mẫu Routine thông minh</h2>
            {petContextLine && (
              <p class="text-[11px] italic text-[var(--c-ink-54)] mt-0.5 truncate">{petContextLine}</p>
            )}
          </div>
          <span class="shrink-0 inline-flex items-center gap-1 text-[10px] italic uppercase tracking-wider font-bold px-2.5 py-1 rounded-full" style="background: rgba(236, 185, 33, 0.14); color: #B48608; border: 1px solid rgba(180, 134, 8, 0.35);">
            <FeatureIcon name="sparkles" class="w-3 h-3" />
            AI matched
          </span>
        </div>

        {/* Top 4 smart-matched cards */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {TOP_BLUEPRINTS.map((bp, idx) => {
            const palette = idx === 0 ? "ink" : "gold";
            const perDay = forecastPerDay(bp);
            const totalMin = bp.tasks.reduce((s, t) => s + t.duration_minutes, 0);
            return (
              <button type="button" @click={`pickBlueprint('${bp.id}')`}
                class={`blueprint-card relative rounded-2xl p-4 text-left overflow-hidden transition active:scale-[0.98] ${palette === "ink" ? "bg-mmp-ink text-white" : "bg-white border-2"}`}
                style={palette === "gold" ? "border-color: rgba(180,134,8,0.4);" : ""}>
                {palette === "ink" && (
                  <div aria-hidden="true" class="absolute -top-10 -right-10 w-32 h-32 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(236,185,33,0.3) 0%, transparent 70%);"></div>
                )}
                {idx === 0 && (
                  <span class="absolute top-2 right-2 inline-flex items-center gap-0.5 text-[9px] uppercase italic tracking-wider font-bold px-1.5 py-0.5 rounded-full z-10" style="background: #ecb921; color: #0a0a0a;">
                    <FeatureIcon name="sparkles" class="w-2.5 h-2.5" />
                    Top
                  </span>
                )}

                <div class="relative">
                  <div class="flex items-start gap-3 mb-2">
                    <span class="shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-xl" style={palette === "ink" ? "background: rgba(236,185,33,0.18); border: 1px solid rgba(236,185,33,0.4); color: #ecb921;" : "background: rgba(180,134,8,0.1); border: 1px solid rgba(180,134,8,0.3); color: #B48608;"}>
                      <FeatureIcon name={bp.icon} class="w-5 h-5" strokeWidth={1.7} />
                    </span>
                    <div class="flex-1 min-w-0">
                      <p class="text-[9px] uppercase italic tracking-[0.18em] font-bold" style={palette === "ink" ? "color: #ecb921;" : "color: #B48608;"}>
                        {bp.species === "cat" ? "Mèo" : bp.species === "dog" ? "Chó" : "Mọi loài"}
                      </p>
                      <h3 class={`font-display italic font-semibold text-base leading-tight ${palette === "ink" ? "text-white" : "text-mmp-ink"}`}>{bp.label}</h3>
                    </div>
                  </div>
                  <p class={`text-xs italic ${palette === "ink" ? "text-white/70" : "text-[var(--c-ink-54)]"}`}>{bp.description}</p>

                  {/* Pet Score forecast */}
                  <div class="mt-3 rounded-lg px-2.5 py-2 inline-flex items-center gap-2 w-full" style={palette === "ink" ? "background: rgba(236,185,33,0.12); border: 1px solid rgba(236,185,33,0.32);" : "background: rgba(180,134,8,0.08); border: 1px solid rgba(180,134,8,0.25);"}>
                    <FeatureIcon name="trophy" class="w-3.5 h-3.5 shrink-0" style={palette === "ink" ? "color: #ecb921;" : "color: #B48608;"} />
                    <div class="text-[10px] italic leading-tight min-w-0">
                      <span class="font-bold" style={palette === "ink" ? "color: #ecb921;" : "color: #B48608;"}>+{perDay} điểm/ngày</span>
                      <span class={palette === "ink" ? "text-white/65" : "text-[var(--c-ink-54)]"}> · Pet Score</span>
                    </div>
                  </div>

                  <p class={`text-[10px] italic mt-2 inline-flex items-center gap-1.5 ${palette === "ink" ? "text-white/65" : "text-[var(--c-ink-54)]"}`}>
                    <FeatureIcon name="clock" class="w-3 h-3" />
                    <span>{bp.tasks.length} task · {totalMin}ph/ngày</span>
                    <span class="opacity-50">·</span>
