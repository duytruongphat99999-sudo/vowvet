    @keyframes position-pulse { 0%, 100% { box-shadow: 0 0 12px rgba(236,185,33,0.7); } 50% { box-shadow: 0 0 18px rgba(236,185,33,1), 0 0 30px rgba(236,185,33,0.4); } }
