          "trophy": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z"/><path d="M7 4H5a2 2 0 0 0-2 2v1a3 3 0 0 0 3 3M17 4h2a2 2 0 0 1 2 2v1a3 3 0 0 1-3 3"/></svg>',
          "target": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
          "sparkles": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/></svg>',
          "leaf": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.3 16.2-8.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>',
          "clipboard": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>',
          "home": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
          "star": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
          "cat": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3.1-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/></svg>',
          "dog": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:24px;height:24px;"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.945-1.45-2.328-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/><path d="M4.5 13.5C4.5 12 5 11 6 11h12c1 0 1.5 1 1.5 2.5l-1 4c-.75 1.5-1.5 2.5-3 2.5h-1.25l-.75-1.5L12 21l-1.5-2.5-.75 1.5H8.5c-1.5 0-2.25-1-3-2.5z"/></svg>',
        },
        // v93: gold-leaning palette + neutrals (still allow personalization but lean brand)
        colorOptions: ["#B48608","#ecb921","#0a0a0a","#5a4a2a","#8b6914","#d4a615","#a16207","#713f12","#3f3f46","#78716c","#404040","#1f2937"],
        scheduleOptions: [
          { value: "daily", label: "Hàng ngày" },
          { value: "weekdays", label: "T2-T6" },
          { value: "weekends", label: "T7-CN" },
          { value: "custom", label: "Tuỳ chỉnh" },
        ],
        weekdayKeys: [
          { key: "mon", label: "T2" }, { key: "tue", label: "T3" }, { key: "wed", label: "T4" },
          { key: "thu", label: "T5" }, { key: "fri", label: "T6" }, { key: "sat", label: "T7" },
          { key: "sun", label: "CN" },
        ],
        taskEmojiOptions: ["🍴","💧","🚶","🏃","🎾","🦷","🛁","🪮","💊","🧠","🎓","🎁","🎮","🎯","📚","🧘","🏋️","💤","🌅","🌙","💩","✂️","👂","📌"],

        get canNext() {
          if (this.step === 2) return this.form.name.trim().length >= 2;
          return true;
        },

        get canSave() {
          if (!this.form.name.trim()) return false;
          if (this.form.tasks.length === 0) return false;
          if (this.form.tasks.some((t) => !t.title.trim())) return false;
          return true;
        },

        scheduleLabel(v) {
          return ({ daily: "Hàng ngày", weekdays: "T2-T6", weekends: "Cuối tuần", custom: "Tuỳ chỉnh" })[v] || v;
        },

        totalDuration(tasks) {
          return tasks.reduce((s, t) => s + (t.duration_minutes || 0), 0);
        },

        pickTemplate(t) {
          if (t) {
            this.form.name = t.name;
            this.form.icon = t.icon;
            this.form.color = t.color;
            this.form.schedule_type = t.schedule_type;
            this.form.start_time = t.start_time;
            // Re-id tasks so they don't collide if user adds more
            this.form.tasks = t.tasks.map((task) => ({ ...task, id: genId() }));
          } else {
            this.form.tasks = [];
          }
          this.blueprintApplied = null;
          this.step = 2;
        },

        // v101: Pick blueprint by ID from window registry (smart match selector)
        pickBlueprint(bpId) {
          const all = window.__VOWVET_BLUEPRINTS || [];
          const bp = all.find((b) => b.id === bpId);
          if (!bp) return;
          this.form.name = bp.label;
          this.form.icon = bp.icon;
          this.form.color = "#B48608";
          this.form.schedule_type = bp.schedule_type;
          this.form.start_time = bp.start_time;
          this.form.tasks = bp.tasks.map((task) => ({ ...task, id: genId() }));
          this.blueprintApplied = { id: bp.id, name: bp.label, icon: bp.icon };
          this.step = 2;
        },

        // v95: Reset blueprint and let user start fresh
        resetBlueprint() {
          this.blueprintApplied = null;
          this.form = {
            name: "",
            icon: "clipboard",
            color: "#B48608",
            schedule_type: "daily",
            custom_days: [],
            start_time: "08:00",
            push_reminder: true,
            tasks: [],
          };
          this.step = 1;
          // Clean URL
          if (typeof window !== "undefined" && window.history) {
            window.history.replaceState({}, "", window.location.pathname);
          }
        },

        toggleCustomDay(key) {
          const idx = this.form.custom_days.indexOf(key);
          if (idx >= 0) this.form.custom_days.splice(idx, 1);
          else this.form.custom_days.push(key);
        },

        addTask() {
          this.form.tasks.push({
            id: genId(),
            title: "",
            emoji: "📌",
            duration_minutes: 10,
            points: 1,
            category: "other",
          });
        },

        removeTask(idx) {
          this.form.tasks.splice(idx, 1);
        },

        nextStep() { if (this.canNext && this.step < 3) this.step++; },
        prevStep() { if (this.step > 1) this.step--; },

        async save() {
          this.error = null;
          if (!this.canSave) {
            this.error = "Tên + ít nhất 1 task có tiêu đề.";
            return;
          }
          this.saving = true;
          try {
            const url = this.editingRoutine
              ? `/api/v1/pets/${this.pet.id}/routines/${this.editingRoutine.id}`
              : `/api/v1/pets/${this.pet.id}/routines`;
            const method = this.editingRoutine ? "PUT" : "POST";
            const res = await fetch(url, {
              method,
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify(this.form),
            });
            if (!res.ok) {
              const j = await res.json().catch(() => ({}));
              this.error = j?.error?.message || "Lỗi lưu routine.";
              return;
            }
            window.location.href = `/pets/${this.pet.id}/routines`;
          } catch (err) {
            this.error = "Không kết nối server.";
          } finally {
            this.saving = false;
          }
        },
      };
    }
  </script>
