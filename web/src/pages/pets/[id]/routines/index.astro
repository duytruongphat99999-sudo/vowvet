/**
 * /pets/[id]/routines — Routine Builder dashboard (M19).
 *
 * 3 sections: Streak hero · Today's routines (tick UI) · All routines (list).
 */
import Layout from "../../../../layouts/Layout.astro";
import FeatureIcon from "../../../../components/FeatureIcon.astro";
import { fetchPet } from "../../../../lib/api-client.ts";
import { formatAge } from "../../../../lib/age.ts";
import { ROUTINE_BADGES } from "../../../../../../shared/routine-badges.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let routines: any[] = [];
let todayData: any = { today: [], streak: null, scheduled_count: 0, completed_count: 0, pending_count: 0 };
let profile: any = {};

try {
  const [rRes, tRes, pRes] = await Promise.all([
    fetch(`${API_INTERNAL}/api/v1/pets/${petId}/routines`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/pets/${petId}/routines/today`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/pets/${petId}/profile`, { headers: { cookie: cookieHeader } }),
  ]);
  if (rRes.ok) routines = (await rRes.json()).routines || [];
  if (tRes.ok) todayData = await tRes.json();
  if (pRes.ok) profile = (await pRes.json()).pet || {};
} catch (_) {}

const initialData = JSON.stringify({
  pet: {
    id: pet.id,
    name: pet.name,
    photo_url: (pet as any).photo_url || null,
    species: typeof pet.species === "object" ? (pet.species as any)?.value : pet.species,
  },
  routines,
  today: todayData.today,
  streak: todayData.streak,
  badgesMeta: ROUTINE_BADGES,
});

