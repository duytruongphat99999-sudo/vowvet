---
import Layout from "../../layouts/Layout.astro";
import PersonalityRadar from "../../components/PersonalityRadar.astro";
import FeatureIcon from "../../components/FeatureIcon.astro";
import { fetchPet, fetchCompletion } from "../../lib/api-client.ts";
import { formatAge } from "../../lib/age.ts";
import { DOG_BREEDS_VN, CAT_BREEDS_VN } from "../../lib/breeds.ts";
import {
  HEALTH_CONDITIONS, CONDITION_NUTRITION, TIER_META, CONDITION_STATUSES,
  COAT_CONDITIONS, DENTAL_STATUSES, ACTIVITY_LEVELS, LIFE_STAGES,
} from "@shared/health-conditions.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const petId = Number(Astro.params.id);

if (!Number.isFinite(petId) || petId <= 0) {
  return Astro.redirect("/dashboard");
}

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// v276: 3 fetch SSR độc lập (đều theo petId từ URL) → chạy SONG SONG thay vì tuần tự
// (trước: fetchPet→completion→profile ~6s; sau: ~2s).
const [petResult, completion, profileJson] = await Promise.all([
  fetchPet(petId, cookieHeader),
  fetchCompletion(petId, cookieHeader),
  fetch(`${API_INTERNAL}/api/v1/pets/${petId}/profile`, { headers: { cookie: cookieHeader } })
    .then((r) => (r.ok ? r.json() : null))
    .catch(() => null),
]);

const { pet, status } = petResult;
if (status === 401) return Astro.redirect("/login");
if (status === 404) return Astro.redirect("/dashboard");
if (status === 403) {
  return new Response("Bạn không có quyền truy cập pet này", { status: 403 });
}
if (!pet) return Astro.redirect("/dashboard");

// M3.5: completion + full profile để hiển thị bar + badge + accordion sections
const completionPct = completion?.pct ?? 0;
const completionBadge = completion?.badge ?? null;
const isLegacy = completionPct < 30;
const profile: any = profileJson?.pet || {};

// Phase 3: SSR fetch MonMin supplements (live-fetch+cache backend). Defensive: lỗi → [] (KHÔNG vỡ trang).
let supplements: any[] = [];
try {
  const sres = await fetch(`${API_INTERNAL}/api/v1/public/monmin-supplements`, { headers: { cookie: cookieHeader } });
  if (sres.ok) { const sj = await sres.json(); supplements = sj.supplements || []; }
} catch (err) { console.error("[pet page] supplements fetch failed:", err); }
const supplementsJson = JSON.stringify(supplements);

// BƯỚC 2: cam kết hồ sơ trọn đời — chặn đầu khi chưa cam kết HOẶC pledge > 6 tháng (re-confirm)
const _pledgeRaw = (pet as any)?.pledge_at || null;
const _pledgeDate = _pledgeRaw ? new Date(_pledgeRaw) : null;
const _pledgeValid = !!_pledgeDate && !isNaN(_pledgeDate.getTime());
const pledgeNeeds = !_pledgeValid || (Date.now() - (_pledgeDate as Date).getTime() > 1000 * 60 * 60 * 24 * 182);
const pledgeIsReconfirm = _pledgeValid && pledgeNeeds;
const pledgeDateDisplay = _pledgeValid ? String(_pledgeRaw).split("-").reverse().join("/") : null;

// VN labels cho dropdown values
const VN_LABELS: Record<string, Record<string, string>> = {
  age_estimation_method: { exact: "Biết chính xác", vet_estimated: "Bác sĩ ước lượng", owner_guess: "Tự đoán" },
  coat_pattern: { solid: "Đơn sắc", spotted: "Đốm", striped: "Vằn", multicolor: "Đa sắc", other: "Khác" },
  origin_type: { rescue: "Cứu hộ", pet_shop: "Pet shop", breeder: "Trại giống", friend: "Bạn cho", found: "Nhặt được", own_litter: "Tự đẻ", other: "Khác" },
  sleep_location: { owner_bed: "Giường chủ", sofa: "Sofa", own_bed: "Ổ riêng", kennel: "Chuồng", outdoor: "Sân vườn" },
  bathroom_location: { indoor_pad: "Puppy pad", outdoor: "Ngoài trời", litter_box: "Khay cát", mixed: "Mix" },
  walk_frequency: { daily: "Hàng ngày", weekly_few: "Vài lần/tuần", rarely: "Hiếm khi", never: "Không đi" },
  bath_frequency: { weekly: "Hàng tuần", biweekly: "2 tuần/lần", monthly: "Hàng tháng", rarely: "Hiếm" },
  diet_type: { dry: "Hạt khô", wet: "Pate", raw: "Tươi sống", homemade: "Tự nấu", mixed: "Mix" },
  archetype: { explorer: "Năng động", friendly: "Thân thiện", shy: "Nhút nhát", lazy: "Lười", smart: "Lanh lợi", stubborn: "Bướng", cuddler: "Cuddler", athlete: "Athletic" },
  fears: { fireworks: "Pháo", thunder: "Sấm", vacuum: "Hút bụi", bath: "Tắm", vet: "Bác sĩ", car_rides: "Đi xe", alone: "Một mình", strangers: "Người lạ", children: "Trẻ con", other: "Khác" },
};
const lbl = (group: string, key: any) => {
  if (!key) return "—";
  if (Array.isArray(key)) return key.map(k => VN_LABELS[group]?.[k] || k).join(", ");
  return VN_LABELS[group]?.[key] || key;
};
const fmt = (v: any) => (v === null || v === undefined || v === "" ? "—" : String(v));
const fmtBool = (v: any) => (v === true ? "Có" : v === false ? "Không" : "—");

// Build personality ratings object cho radar
const personalityRatings = {
  energy_level: profile.energy_level,
  friendliness_strangers: profile.friendliness_strangers,
  friendliness_other_pets: profile.friendliness_other_pets,
  noise_sensitivity: profile.noise_sensitivity,
  handling_tolerance: profile.handling_tolerance,
  trainability: profile.trainability,
  separation_anxiety: profile.separation_anxiety,
};

const initialJson = JSON.stringify(pet);
// Đợt 2a: cấu hình bệnh sử y khoa truyền vào Alpine petDetail
const healthConfigJson = JSON.stringify({
  conditions: HEALTH_CONDITIONS,
  tiers: TIER_META,
  statuses: CONDITION_STATUSES,
  coats: COAT_CONDITIONS,
  dentals: DENTAL_STATUSES,
  activities: ACTIVITY_LEVELS,
  lifeStages: LIFE_STAGES,
  nutrition: CONDITION_NUTRITION,
});
const dogBreedsJson = JSON.stringify(DOG_BREEDS_VN);
const catBreedsJson = JSON.stringify(CAT_BREEDS_VN);
const appUrl = import.meta.env.APP_URL || "https://vowvet.monminpet.com";

// v71: Spotlight Sidebar — compute days-with-us + next-step suggestion (SSR, no extra fetch)
const arrivalIso = (profile as any).arrival_date || pet.created_at;
let daysWithUs: number | null = null;
if (arrivalIso) {
  const arrival = new Date(arrivalIso).getTime();
  if (!Number.isNaN(arrival)) {
    daysWithUs = Math.max(0, Math.floor((Date.now() - arrival) / (1000 * 60 * 60 * 24)));
  }
}
const daysLabel = daysWithUs === null ? "—" : daysWithUs >= 365
  ? `${Math.floor(daysWithUs / 365)} năm ${Math.floor((daysWithUs % 365) / 30)} tháng`
  : daysWithUs >= 30
  ? `${Math.floor(daysWithUs / 30)} tháng`
  : `${daysWithUs} ngày`;

// v211 Grand Entrance — birthday detection (VN TZ, so MM-DD hôm nay)
const _vnNow = new Date(Date.now() + 7 * 3600 * 1000);
const todayVN = _vnNow.toISOString().slice(0, 10);
let isBirthday = false;
{
  const _dob = String((pet as any).dob || (profile as any).dob || "");
  const _m = _dob.match(/^\d{4}-(\d{2})-(\d{2})/);
  if (_m) isBirthday = `${_m[1]}-${_m[2]}` === todayVN.slice(5);
}

// Next-step suggestion text
const NEXT_STEP_HINTS: Record<string, { title: string; tip: string }> = {
  identity: { title: "Hoàn thiện danh tính", tip: "Thêm microchip + nickname để hộ chiếu chuẩn quốc tế." },
  appearance: { title: "Thêm ngoại hình", tip: "Màu lông + dấu nhận diện giúp tìm bé nhanh hơn nếu lạc." },
  origin: { title: "Kể câu chuyện về bé", tip: "Đoạn hồi ức nhỏ — AI sẽ nhắc lại vào sinh nhật bé." },
  health: { title: "Cập nhật sức khỏe", tip: "Vaccine + dị ứng để AI tránh đề xuất sai." },
  diet: { title: "Khai dinh dưỡng", tip: "Brand + bữa/ngày để AI gợi ý combo phối trộn." },
  personality: { title: "Quiz tính cách", tip: "20 câu · 3 phút · AI dự đoán hành vi & tương thích." },
  lifestyle: { title: "Lối sống thường ngày", tip: "Nơi ngủ + tần suất đi dạo để tính DER chính xác." },
  emergency: { title: "Liên hệ khẩn cấp", tip: "Bác sĩ + người thân — 1 cú gọi cứu mạng bé." },
};
const nextSuggestion = completion?.next_section_suggested
  ? NEXT_STEP_HINTS[completion.next_section_suggested]
  : null;

const topArchetypes: string[] = Array.isArray((profile as any).personality_archetype)
  ? (profile as any).personality_archetype.slice(0, 3)
  : [];
const hasStory = Boolean((profile as any).adoption_story);
const storyExcerpt = hasStory
  ? String((profile as any).adoption_story).slice(0, 140) + ((profile as any).adoption_story.length > 140 ? "…" : "")
  : "";
---

<Layout title={`${pet.name} · VowVet`}>
  <main class="min-h-screen px-4 sm:px-6 py-6 bg-mmp-cream">
    {/* v211 Grand Entrance — gate script SLOT-LESS, con ĐẦU TIÊN của <main>: chạy SYNC trước mọi GE element + content → set html.pge-run/seen kịp, chống flash. (Pattern define:vars slot-less proven 5× trong app.) */}
    <script is:inline define:vars={{ isBirthday, todayVN }}>
      (function () {
        try {
          var petId = (location.pathname.match(/\/pets\/(\d+)/) || [])[1] || "";
          var html = document.documentElement;
          var key = "vowvet:pet:" + petId + ":welcomed:" + todayVN;
          if (isBirthday) {
            html.classList.add("pge-run", "pge-birthday");
          } else if (!localStorage.getItem(key)) {
            html.classList.add("pge-run");
            localStorage.setItem(key, "1");
          } else {
            html.classList.add("pge-seen");
          }
        } catch (e) {}
      })();
    </script>
    {/* v211 Grand Entrance layers — fixed, pointer-events:none (CLICK XUYÊN QUA), ẩn mặc định, gate html.pge-run */}
    <div class="pge-overlay no-print" aria-hidden="true"></div>
    <div class="pge-spotlight no-print" aria-hidden="true"></div>
    <div class="pge-sparkles no-print" aria-hidden="true">
      {[[8,14],[22,5],[5,38],[30,24],[12,68],[4,84],[34,86],[46,18],[40,50],[18,60]].map((p, i) => (
        <span class="pge-sparkle" style={`top:${p[0]}%;left:${p[1]}%;animation-delay:${(1.4 + i * 0.035).toFixed(3)}s`}></span>
      ))}
    </div>
    {isBirthday && (
      <Fragment>
        <div class="pge-confetti no-print" aria-hidden="true">
          {Array.from({ length: 14 }).map((_, i) => (
            <span class="pge-confetti-piece" style={`left:${(4 + i * 6.5).toFixed(1)}%;background:${["#ecb921","#fde68a","#d4960a"][i % 3]};animation-delay:${(0.1 + i * 0.06).toFixed(2)}s`}></span>
          ))}
        </div>
        <div class="pge-birthday-banner no-print" aria-hidden="true">
          <p class="pge-birthday-text">🎂 Chúc mừng sinh nhật {pet.name}!</p>
        </div>
      </Fragment>
    )}
    <!-- v74 WOW: gold scroll progress bar (Pet Detail scope) -->
    <div
      class="pet-scroll-progress no-print"
      aria-hidden="true"
      x-data="{ pct: 0 }"
      x-init="
        const u = () => {
          const s = document.documentElement;
          const max = Math.max(1, s.scrollHeight - s.clientHeight);
          pct = Math.min(100, Math.max(0, (s.scrollTop / max) * 100));
        };
        window.addEventListener('scroll', u, { passive: true });
        window.addEventListener('resize', u);
        u();
      "
    >
      <div class="pet-scroll-progress__fill" :style="`width: ${pct}%`"></div>
    </div>
    <div
      class="max-w-5xl mx-auto pet-detail-tabs"
      x-data={`petDetail(${initialJson}, ${dogBreedsJson}, ${catBreedsJson}, "${appUrl}", ${healthConfigJson}, ${supplementsJson})`}
      :data-active="pageTab"
      @scan-add-to-plan.window="applyScanBrand($event.detail && $event.detail.brandId)"
      x-init="if (new URLSearchParams(window.location.search).get('scan') === '1') { pageTab = 'health'; $nextTick(() => { activeTab = 'nutrition'; $nextTick(() => document.getElementById('food-scan')?.scrollIntoView({ behavior: 'smooth', block: 'center' })); }); }"
    >
      <!-- Top bar -->
      <div class="mb-4 flex items-center justify-between gap-3 flex-wrap">
        <a href="/dashboard" class="text-mmp-ink/60 hover:text-mmp-ink text-sm">← Dashboard</a>
        <button type="button" @click="window.print()"
                class="no-print text-xs sm:text-sm font-semibold italic border-2 border-[var(--c-ink)] text-[var(--c-ink)] hover:bg-[var(--c-ink)] hover:text-white px-4 py-2 rounded-2xl transition btn-eu inline-flex items-center gap-2">
          <FeatureIcon name="file-text" class="w-4 h-4" /><span>Xuất PDF Hộ chiếu</span>
        </button>
      </div>

      {/* BƯỚC 2-fix: re-confirm cam kết 6 tháng — banner MỀM, không chặn cứng */}
      {pledgeIsReconfirm && (
        <div x-data="{ show: true, busy: false }" x-show="show" style="display:none;"
             class="no-print mb-4 rounded-2xl border border-amber-300 bg-amber-50 px-4 py-3 flex items-start gap-3">
          <svg class="w-5 h-5 shrink-0 text-amber-600 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-amber-900 leading-relaxed">Hồ sơ cam kết của bé đã hơn 6 tháng — rà soát lại thông tin còn đúng nhé.</p>
            <button type="button" :disabled="busy"
              @click={`busy = true; fetch('/api/v1/pets/${petId}/pledge', { method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin', body: '{}' }).then(() => { show = false; }).catch(() => { busy = false; })`}
              class="mt-2 text-xs font-semibold px-3 py-1.5 rounded-lg bg-mmp-ink text-white hover:bg-mmp-ink/90 transition disabled:opacity-60">
              <span x-text="busy ? 'Đang lưu…' : 'Xác nhận còn đúng'"></span>
            </button>
          </div>
          <button type="button" @click="show = false" aria-label="Đóng" class="shrink-0 text-amber-600 hover:text-amber-800 text-lg leading-none">✕</button>
        </div>
      )}

      <!-- v68: HERO PASSPORT — gold top accent + warm cream gradient + larger luxury padding -->
      <div class="hero-passport mb-10 rounded-2xl shadow-sm">
        <!-- v74 WOW additive layer: badge · particles · paw watermark · MonMin stamp -->
        <!-- v75 upgrade: badge moved bottom-left · VV monogram crest top-left · stamp rebuilt as SVG · sparkles around stamp -->
        <div class="hero-paw-bg no-print" aria-hidden="true"></div>
        <span class="hero-particle hero-particle--1 no-print" aria-hidden="true"></span>
        <span class="hero-particle hero-particle--2 no-print" aria-hidden="true"></span>
        <span class="hero-particle hero-particle--3 no-print" aria-hidden="true"></span>
        <span class="hero-particle hero-particle--4 no-print" aria-hidden="true"></span>
        <span class="hero-particle hero-particle--5 no-print" aria-hidden="true"></span>

        <span class="hero-vv-monogram no-print" aria-hidden="true">
          <svg viewBox="0 0 46 46" xmlns="http://www.w3.org/2000/svg">
            <circle cx="23" cy="23" r="21" fill="none" stroke="rgba(236,185,33,0.55)" stroke-width="0.8" stroke-dasharray="2 1.5"/>
            <circle cx="23" cy="23" r="17" fill="none" stroke="rgba(236,185,33,0.4)" stroke-width="0.5"/>
            <path d="M 9 12 L 15 30 L 21 12 M 25 12 L 31 30 L 37 12" stroke="rgba(236,185,33,0.95)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="23" cy="6" r="1.2" fill="rgba(236,185,33,0.85)"/>
            <circle cx="23" cy="40" r="1.2" fill="rgba(236,185,33,0.85)"/>
          </svg>
        </span>

        <span class="hero-spark hero-spark--1 no-print" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" fill="rgba(236,185,33,0.95)"/></svg>
        </span>
        <span class="hero-spark hero-spark--2 no-print" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" fill="rgba(236,185,33,0.95)"/></svg>
        </span>
        <span class="hero-spark hero-spark--3 no-print" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" fill="rgba(236,185,33,0.95)"/></svg>
        </span>
        <span class="hero-spark hero-spark--4 no-print" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" fill="rgba(236,185,33,0.95)"/></svg>
        </span>
        <span class="hero-spark hero-spark--5 no-print" aria-hidden="true">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0 L13.5 10.5 L24 12 L13.5 13.5 L12 24 L10.5 13.5 L0 12 L10.5 10.5 Z" fill="rgba(236,185,33,0.95)"/></svg>
        </span>

        <span class="hero-stamp no-print" aria-hidden="true">
          <svg class="hero-stamp-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mon Min Pet Certified Passport Official">
            <defs>
              <filter id="hsp-ink-rough" x="-5%" y="-5%" width="110%" height="110%">
                <feTurbulence type="fractalNoise" baseFrequency="1.1" numOctaves="2" seed="11" result="t"/>
                <feDisplacementMap in="SourceGraphic" in2="t" scale="0.9"/>
              </filter>
              <filter id="hsp-logo-gold" x="-40%" y="-40%" width="180%" height="180%">
                <feColorMatrix type="matrix" values="0 0 0 0 0.706  0 0 0 0 0.525  0 0 0 0 0.031  0 0 0 1.4 0" result="goldLogo"/>
                <feGaussianBlur in="goldLogo" stdDeviation="2" result="glowInner"/>
                <feGaussianBlur in="goldLogo" stdDeviation="5" result="glowOuter"/>
                <feFlood flood-color="#ecb921" flood-opacity="0.7" result="glowColor1"/>
                <feComposite in="glowColor1" in2="glowInner" operator="in" result="glow1"/>
                <feFlood flood-color="#ecb921" flood-opacity="0.4" result="glowColor2"/>
                <feComposite in="glowColor2" in2="glowOuter" operator="in" result="glow2"/>
                <feMerge>
                  <feMergeNode in="glow2"/>
                  <feMergeNode in="glow1"/>
                  <feMergeNode in="goldLogo"/>
                </feMerge>
              </filter>
              <path id="hsp-arc-top" d="M 24 100 A 76 76 0 0 1 176 100" fill="none"/>
              <path id="hsp-arc-bot" d="M 24 100 A 76 76 0 0 0 176 100" fill="none"/>
            </defs>

            <g filter="url(#hsp-ink-rough)" fill="#B48608" stroke="#B48608">
              <circle cx="100" cy="100" r="92" fill="none" stroke-width="3.8" stroke-opacity="0.95"/>
              <circle cx="100" cy="100" r="84" fill="none" stroke-width="1.6" stroke-opacity="0.85"/>
              <circle cx="100" cy="100" r="64" fill="none" stroke-width="0.8" stroke-opacity="0.55"/>

              <text font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="11.5" letter-spacing="2.6" fill-opacity="0.96" stroke="none">
                <textPath href="#hsp-arc-top" startOffset="50%" text-anchor="middle">CERTIFIED · PASSPORT · OFFICIAL</textPath>
              </text>
              <text font-family="Inter, system-ui, sans-serif" font-weight="900" font-size="11" letter-spacing="3" fill-opacity="0.96" stroke="none">
                <textPath href="#hsp-arc-bot" startOffset="50%" text-anchor="middle">★ BY MON MIN PET ★</textPath>
              </text>

              <text x="20" y="107" text-anchor="middle" font-size="16" font-weight="900" fill-opacity="0.92" stroke="none">✦</text>
              <text x="180" y="107" text-anchor="middle" font-size="16" font-weight="900" fill-opacity="0.92" stroke="none">✦</text>

              <text x="100" y="115" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-style="italic" font-weight="700" font-size="18" letter-spacing="0.4" fill-opacity="1" stroke="none">VowVet</text>

              <line x1="60" y1="126" x2="140" y2="126" stroke-width="0.8" stroke-opacity="0.7"/>

              <text x="100" y="138" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-weight="700" font-size="7.5" letter-spacing="1.4" fill-opacity="0.95" stroke="none">VERIFIED · MAY 2026</text>
              <text x="100" y="150" text-anchor="middle" font-family="Inter, system-ui, sans-serif" font-weight="600" font-size="7" letter-spacing="1" fill-opacity="0.88" stroke="none">HCM CITY · VIETNAM</text>
            </g>

            <image href="/logo-mmp.png" x="76" y="46" width="48" height="48" preserveAspectRatio="xMidYMid meet" opacity="0.98" filter="url(#hsp-logo-gold)"/>
          </svg>
        </span>
        {pledgeDateDisplay && (
          <p class="no-print -mt-1 mb-4 inline-flex items-center gap-1.5 text-[11px] font-semibold" style="color:#B48608;">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
            Đã cam kết hồ sơ trọn đời · {pledgeDateDisplay}
          </p>
        )}
        <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6 lg:gap-10">
          <!-- v66: QR Passport — display + management consolidated (Alpine reactive) -->
          <div class="space-y-3">
