                    <span x-text="moodRoutineSuggestion.label"></span>
                    <span class="ml-1 text-[11px] inline-flex items-center px-2 py-0.5 rounded-full text-white font-bold align-middle" style="background:#B48608">
                      +<span x-text="moodRoutineSuggestion.bonusPts"></span>đ
                    </span>
                  </p>
                  <p class="text-[12px] text-mmp-ink/75 leading-relaxed mt-1.5" x-text="moodRoutineSuggestion.detail"></p>
                  <a :href="`/pets/${pet.id}/routines`"
                    class="mt-2.5 inline-flex items-center gap-1.5 text-[11px] font-extrabold text-gold-deep hover:text-mmp-ink transition">
                    <FeatureIcon name="arrow" class="w-3.5 h-3.5" />
                    <span>Áp dụng vào routine →</span>
                  </a>
                </div>
              </div>
            </div>
          </template>

          <p class="text-[11px] text-mmp-ink/70 mt-3 flex items-start gap-1.5">
            <FeatureIcon name="info" class="w-3.5 h-3.5 shrink-0 mt-0.5 text-gold-deep" />
            <span><b class="text-mmp-ink">3 ngày liền</b> chọn "Lo âu" hoặc "Lừ đừ" → micro-quiz xuất hiện để rà <b>behavior shift</b>.</span>
          </p>
        </section>

        <!-- 4. QUARTERLY REFRESH — chỉ hiện khi >= 90 ngày -->
        <template x-if="quarterlyDue">
          <section class="mt-4 rounded-3xl p-5 sm:p-6 shadow-md pulse-ring relative overflow-hidden bg-mmp-cream border-2 border-gold-deep">
            <div class="flex items-start gap-3">
              <span class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-gold-deep text-white shrink-0 shadow">
                <FeatureIcon name="sparkles" class="w-6 h-6" />
              </span>
              <div class="flex-1">
                <h3 class="text-base font-extrabold text-mmp-ink">Đến lúc tinh chỉnh tính cách</h3>
                <p class="text-xs text-mmp-ink/80 mt-1" x-text="`Bé ${pet.name} đã ${daysSinceQuiz} ngày từ lần khảo sát trước — 3 câu nhanh trong 30 giây để mình rà behavior shift.`"></p>
                <button class="mt-3 inline-flex items-center gap-2 bg-mmp-ink hover:opacity-90 text-white text-xs font-bold px-4 py-2 rounded-xl shadow"
                  @click="alert('Tính năng Quarterly Micro-Quiz sẽ ra mắt cùng M28. Hiện tại bạn có thể làm lại đầy đủ 20 câu nếu thấy bé thay đổi rõ rệt.')">
                  Làm micro-quiz 30s
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                </button>
              </div>
            </div>
          </section>
        </template>

        <!-- 5. v139 — Growth Journey Vellum Timeline (luxury editorial, pure Tailwind).
             Gold thread vertical + 4 vellum cards. Watermark numerals Fraunces 7xl.
             Chỉ active card full color + scale 1.02 hover; done/locked đều opacity-40 grayscale. -->
        <section class="relative max-w-2xl mx-auto py-10 px-6 mt-4" aria-label="Lộ trình phát triển 4 bước cho bé">

          <!-- Gold thread — vertical axis connecting the 4 dots -->
          <div
            class="absolute left-8 top-12 bottom-12 w-0.5 bg-gradient-to-b from-[#B48608] to-transparent pointer-events-none"
            aria-hidden="true"
          ></div>

          <!-- 4 steps -->
          <template x-for="(step, i) in journeySteps" :key="step.id">
            <div
              class="relative pl-12 pb-12 transition-all duration-500"
              :class="(!step.done && step.id === journeyActiveStep.id) ? '' : 'opacity-40 grayscale'"
            >
              <!-- Gold dot on the thread -->
              <span
                class="absolute left-[26px] top-8 w-4 h-4 rounded-full bg-[#B48608] border-4 border-white shadow-sm z-10"
                aria-hidden="true"
              ></span>

              <!-- Vellum card -->
              <div
                class="relative bg-white/50 backdrop-blur-sm border border-slate-200 rounded-2xl p-6 shadow-sm transition-all duration-500 hover:shadow-lg hover:-translate-y-1 overflow-hidden"
                :class="(!step.done && step.id === journeyActiveStep.id) ? 'hover:scale-[1.02]' : ''"
              >
                <!-- Watermark numeral — huge faded Fraunces italic -->
                <span
                  class="absolute -left-3 top-2 text-7xl font-display italic font-semibold leading-none select-none pointer-events-none"
                  style="color: rgba(180, 134, 8, 0.10);"
                  x-text="`0${step.num}`"
                  aria-hidden="true"
                >01</span>

                <!-- Content layer (above watermark) -->
                <div class="relative">
                  <h4
                    class="text-2xl font-display font-semibold text-[#0a0a0a] leading-tight"
                    x-text="step.title"
                  >Lên lịch trình</h4>
                  <p
                    class="text-sm italic text-slate-500 mt-2 leading-relaxed max-w-md"
                    x-text="step.lead"
                  >Mô tả 1 câu Fraunces italic.</p>

                  <!-- State row: done tick / locked label / ready CTA -->
                  <div class="mt-5 flex items-center justify-between gap-4 min-h-[40px]">
                    <!-- Done state -->
                    <template x-if="step.done">
                      <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#B48608]">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M5 12l5 5 9-11"/>
                        </svg>
                        Đã hoàn tất
                      </span>
                    </template>

                    <!-- Locked state (gated bởi prerequisite hoặc petScore=0 cho step 4) -->
                    <template x-if="!step.done && step.id !== journeyActiveStep.id">
                      <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="4" y="11" width="16" height="10" rx="2"/>
                          <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
                        </svg>
                        <span x-text="step.id === 'share' && isStepGated('share') ? 'Cần Pet Score > 0' : 'Chờ tới lượt'">Chờ tới lượt</span>
                      </span>
                    </template>

                    <!-- Ready: ghost CTA, right-aligned.
                         v140 — Step 1/2/3 navigate; step 4 (share) mở Wow Card modal.
                         Marking đã do journeyAutoSync() lo, không mark thủ công khi click. -->
                    <template x-if="!step.done && step.id === journeyActiveStep.id">
                      <button
                        class="ml-auto inline-flex items-center gap-2 text-[12px] font-bold uppercase tracking-[0.06em] text-[#0a0a0a] border border-[#0a0a0a] rounded-full px-5 py-2.5 transition-all duration-200 hover:bg-[#0a0a0a] hover:text-[#ecb921] hover:gap-3 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#B48608]"
                        :aria-label="`${step.id === 'share' ? 'Khoe thẻ ngay' : 'Khởi hành'}: ${step.title}`"
                        @click="step.id === 'share' ? openWowCard() : (step.href ? (window.location.href = step.href) : shareZalo())"
                      >
                        <span x-text="step.id === 'share' ? 'Khoe ngay' : 'Khởi hành'">Khởi hành</span>
                        <span aria-hidden="true">→</span>
                      </button>
                    </template>
                  </div>
                </div>
              </div>
            </div>
          </template>

          <!-- Trọn lộ trình — completion seal (only when all 4 done) -->
          <template x-if="journeyAllDone">
            <div class="relative pl-12 pt-2">
              <span
                class="absolute left-[24px] top-3 w-5 h-5 rounded-full bg-gradient-to-br from-[#ecb921] to-[#B48608] border-[3px] border-white shadow-md z-10"
                aria-hidden="true"
              ></span>
              <div class="bg-gradient-to-br from-[#FAF6EC] to-white border border-[#B48608]/30 rounded-2xl p-8 text-center shadow-sm">
                <p class="text-[11px] uppercase tracking-[0.28em] font-bold text-[#B48608]">· Trọn lộ trình ·</p>
                <h4 class="font-display italic text-2xl font-semibold text-[#0a0a0a] mt-3">Bốn nhánh đã hoàn tất</h4>
                <p class="text-sm italic text-slate-500 mt-3 max-w-md mx-auto leading-relaxed">
                  Tính cách của bé {pet.name} đang vận hành đầy đủ — từ lịch trình mỗi ngày đến điểm sức khoẻ và quà tặng.
                </p>
              </div>
            </div>
          </template>
        </section>

      </div>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!--  STEP: intro                                                -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <div x-show="step === 'intro'">
        <!-- Hero — Profile banner pattern (same as result) -->
        <div class="pp-shell">
          <div class="pp-banner" style="padding-bottom:22px">
            <div class="pp-banner-strip">
              <span class="pp-tag">· Personality Atelier ·</span>
              <span class="pp-tag">12 TYPES</span>
            </div>
            <h1 class="pp-watermark">Định danh<br/>tính cách</h1>
            <p class="text-xs italic mt-2 mb-5" style="color:rgba(255,255,255,0.72)">Bé {pet.name} thuộc 1 trong 12 personality types khoa học</p>

            <div class="flex items-center gap-4 pt-4" style="border-top:1px solid rgba(236,185,33,0.25)">
              <div class="pp-avatar-wrap">
                {pet.photo_url ? (
                  <img src={pet.photo_url} alt={pet.name} class="pp-avatar" />
                ) : (
                  <div class="pp-avatar flex items-center justify-center" style="background:#0a0a0a">
                    <FeatureIcon name={pet.species === "cat" ? "cat" : "dog"} class="w-10 h-10" style="color:#ecb921" />
                  </div>
                )}
                <span class="pp-avatar-crest">
                  <FeatureIcon name="brain" class="w-4 h-4" />
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="pp-meta-name">BÉ · {pet.name}</p>
                <p class="pp-meta-group">≈ 3 PHÚT · 20 CÂU HỎI</p>
                <p class="pp-meta-sub">Khoa học hành vi · 6 chiều radar</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Value preview card -->
        <div class="pv-card">
          <div class="p-2">
            <div class="grid grid-cols-3 gap-2 mb-5">
              <div class="text-center p-3 rounded-2xl bg-mmp-cream">
                <p class="text-[10px] uppercase tracking-wider text-gold-deep font-bold mb-1">Thời gian</p>
                <p class="text-base font-extrabold text-mmp-ink">≈ 3 phút</p>
              </div>
              <div class="text-center p-3 rounded-2xl bg-mmp-cream">
                <p class="text-[10px] uppercase tracking-wider text-gold-deep font-bold mb-1">Câu hỏi</p>
                <p class="text-base font-extrabold text-mmp-ink">{questions.length || 20}</p>
              </div>
              <div class="text-center p-3 rounded-2xl bg-mmp-cream">
                <p class="text-[10px] uppercase tracking-wider text-gold-deep font-bold mb-1">Personality</p>
                <p class="text-base font-extrabold text-mmp-ink">12 types</p>
              </div>
            </div>

            <!-- What you get -->
            <div class="rounded-2xl border-2 border-gold-deep bg-mmp-cream p-4 mb-5">
              <p class="text-[11px] uppercase tracking-wider text-gold-deep font-bold mb-2 flex items-center gap-1.5">
                <FeatureIcon name="gift" class="w-3.5 h-3.5" /> Sau khi xong bạn nhận
              </p>
              <ul class="space-y-1.5 text-sm text-mmp-ink">
                <li class="flex items-start gap-2">
                  <span class="text-gold-deep mt-0.5 font-bold">◆</span>
                  <span><b>Bộ nhân Pet Score</b> (×0.75 → ×1.60) áp lên tổng điểm hằng ngày</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold-deep mt-0.5 font-bold">◆</span>
                  <span><b>30-day Action Plan</b> điều phối theo type của bé</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold-deep mt-0.5 font-bold">◆</span>
                  <span><b>Psychological Badge</b> mở khóa danh mục voucher phù hợp</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-gold-deep mt-0.5 font-bold">◆</span>
                  <span><b>Lịch nhắn thông minh</b> theo nhịp sinh học từng nhóm</span>
                </li>
              </ul>
            </div>

            <button @click="startQuiz()"
              class="w-full inline-flex items-center justify-center gap-2 bg-mmp-ink hover:bg-mmp-ink/90 text-white font-extrabold px-6 py-4 rounded-2xl text-base shadow-xl">
              Bắt đầu định danh
              <FeatureIcon name="arrow" class="w-5 h-5" />
            </button>

            <template x-if="resumeAvailable">
              <p class="mt-4 text-xs text-mmp-ink text-center">
                <FeatureIcon name="info" class="w-3.5 h-3.5 inline -mt-0.5" />
                Có khảo sát đang dở.
                <button @click="resume()" class="underline font-bold text-gold-deep">Tiếp tục</button>
              </p>
            </template>

            <p class="text-[11px] text-mmp-ink/60 text-center mt-4 italic">
              Tiến độ tự lưu mỗi khi bạn chọn — nghỉ giữa chừng vẫn quay lại được
            </p>
          </div>
        </div>{/* close pv-card */}

        <!-- Hybrid model preview — 3 nhịp -->
        <section class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="rounded-2xl bg-white border border-mmp-cream p-4">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-mmp-cream text-gold-deep mb-2">
              <FeatureIcon name="brain" class="w-5 h-5" />
            </span>
            <p class="text-xs uppercase tracking-wider text-gold-deep font-bold">Core · 1 lần</p>
            <p class="text-sm font-bold text-mmp-ink mt-0.5">20 câu — Type cố định</p>
            <p class="text-[11px] text-mmp-ink/70 mt-1">Tạo nền tảng nhân vật cho bé</p>
          </div>
          <div class="rounded-2xl bg-white border border-mmp-cream p-4">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-mmp-cream text-gold-deep mb-2">
              <FeatureIcon name="heart" class="w-5 h-5" />
            </span>
            <p class="text-xs uppercase tracking-wider text-gold-deep font-bold">State · Hằng ngày</p>
            <p class="text-sm font-bold text-mmp-ink mt-0.5">Daily Mood 3 nút</p>
            <p class="text-[11px] text-mmp-ink/70 mt-1">Theo dõi cảm xúc thoáng qua</p>
          </div>
          <div class="rounded-2xl bg-white border border-mmp-cream p-4">
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-mmp-cream text-gold-deep mb-2">
              <FeatureIcon name="sparkles" class="w-5 h-5" />
            </span>
            <p class="text-xs uppercase tracking-wider text-gold-deep font-bold">Refresh · 90 ngày</p>
            <p class="text-sm font-bold text-mmp-ink mt-0.5">Micro-quiz 3 câu</p>
            <p class="text-[11px] text-mmp-ink/70 mt-1">Rà nhanh behavior shift</p>
          </div>
        </section>
      </div>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!--  STEP: quiz                                                 -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <div x-show="step === 'quiz'">
        <!-- Progress -->
        <div class="mb-5 sticky top-2 z-10 bg-white/95 backdrop-blur-md rounded-2xl p-3.5 shadow-md border border-mmp-cream">
          <div class="flex items-center gap-3 mb-1.5">
            <button @click="back()" :disabled="qIndex === 0"
              class="shrink-0 text-xs font-medium text-mmp-ink/70 disabled:opacity-30 hover:text-gold-deep inline-flex items-center gap-1">
              ← Trước
            </button>
            <span class="text-xs font-bold text-mmp-ink shrink-0">
              <span x-text="qIndex + 1"></span><span class="text-mmp-ink/50">/<span x-text="questions.length"></span></span>
            </span>
            <div class="flex-1 h-2 bg-mmp-cream rounded-full overflow-hidden">
              <div class="h-full transition-all duration-500 rounded-full"
                style="background:linear-gradient(90deg, #B48608 0%, #ecb921 100%)"
                :style="`width: ${((qIndex + 1) / questions.length) * 100}%; background:linear-gradient(90deg, #B48608 0%, #ecb921 100%)`"></div>
            </div>
            <span class="text-[10px] uppercase tracking-wider text-gold-deep font-bold shrink-0" x-text="currentQuestion?.dimension || ''"></span>
          </div>
        </div>

        <!-- Current question -->
        <div :key="qIndex" class="bg-white rounded-3xl border border-mmp-cream p-6 sm:p-8 shadow-md question-enter">
          <!-- Subtle dimension icon thay 3xl emoji sticker -->
          <div class="flex items-center justify-center mb-3">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-mmp-cream text-gold-deep text-[10px] font-bold uppercase tracking-wider">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
              <span x-text="currentQuestion?.dimension || ''"></span>
            </span>
          </div>
          <h2 class="text-lg sm:text-xl font-extrabold text-mmp-ink text-center mb-6 leading-snug" x-text="currentQuestion?.question_vi"></h2>

          <div class="space-y-2.5">
            <template x-for="opt in currentQuestion?.options || []" :key="opt.id">
              <button @click="choose(opt.id)"
                :class="answers[currentQuestion.id] === opt.id ? 'quiz-opt selected' : 'quiz-opt'"
                class="w-full text-left border-2 border-mmp-ink/12 rounded-2xl p-4 bg-white active:scale-[0.98] hover:border-gold-deep">
                <div class="flex items-center gap-3">
                  <span class="w-8 h-8 shrink-0 rounded-full bg-mmp-cream text-mmp-ink flex items-center justify-center text-sm font-extrabold uppercase"
                    :class="answers[currentQuestion.id] === opt.id ? 'bg-gold-deep text-white' : ''"
                    x-text="opt.id"></span>
                  <span class="text-sm font-medium text-mmp-ink" x-text="opt.text_vi"></span>
                </div>
              </button>
            </template>
          </div>
        </div>

        <p class="text-center text-[11px] text-mmp-ink/55 mt-4 italic">
          <FeatureIcon name="check" class="w-3 h-3 inline -mt-0.5" />
          Tiến độ tự lưu mỗi khi bạn chọn — có thể tạm dừng và quay lại bất cứ lúc nào
        </p>
      </div>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!--  STEP: loading                                              -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <div x-show="step === 'loading'" class="bg-white rounded-3xl border border-mmp-cream p-12 text-center shadow-md">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-mmp-cream text-gold-deep mb-4 animate-pulse">
          <FeatureIcon name="paw" class="w-10 h-10" />
        </div>
        <p class="text-lg font-extrabold text-mmp-ink" x-text="`Đang định danh tính cách bé ${pet.name}...`"></p>
        <p class="text-xs text-mmp-ink/60 mt-2">Đối chiếu 12 types · Tính radar 6 chiều · Mapping k_factor</p>
        <div class="mt-5 flex justify-center gap-1.5">
          <span class="inline-block w-2 h-2 rounded-full bg-gold-deep animate-bounce" style="animation-delay: 0ms"></span>
          <span class="inline-block w-2 h-2 rounded-full bg-gold-deep animate-bounce" style="animation-delay: 120ms"></span>
          <span class="inline-block w-2 h-2 rounded-full bg-gold-deep animate-bounce" style="animation-delay: 240ms"></span>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════════ -->
      <!--  STEP: result                                               -->
      <!-- ═══════════════════════════════════════════════════════════ -->
      <div x-show="step === 'result'">
        <template x-if="result">
          <div>
            <!-- PROFILE BANNER — same pattern as existing -->
            <div id="result-card" class="pp-shell result-card-enter">
              <div class="pp-banner" style="padding-bottom:22px">
                <div class="pp-banner-strip">
                  <span class="pp-tag">· Vừa định danh ·</span>
                  <span class="pp-tag" x-text="`№ ${String(pet.id).padStart(4,'0')}`"></span>
                </div>
                <h1 class="pp-watermark" x-text="result.primary_meta?.name_vi"></h1>
