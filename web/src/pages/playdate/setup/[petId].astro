---
/**
 * /playdate/setup/[petId] — Profile config form (M27).
 *
 * Owner sets: bio, max_distance_km, looking_for, play_styles, active toggle.
 * Auto-fetches lat/lng from browser geolocation (optional).
 */
import Layout from "../../../layouts/Layout.astro";
import FeatureIcon from "../../../components/FeatureIcon.astro";
import { fetchPet } from "../../../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.petId);
const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let eligibility: any = null;
let profile: any = null;
let safety: any = null;
try {
  const [eRes, pRes, sRes] = await Promise.all([
    fetch(`${API_INTERNAL}/api/v1/playdate/can-create/${petId}`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/playdate/profile/${petId}`, { headers: { cookie: cookieHeader } }),
    fetch(`${API_INTERNAL}/api/v1/playdate/safety-tips`),
  ]);
  if (eRes.ok) eligibility = await eRes.json();
  if (pRes.ok) profile = (await pRes.json()).profile;
  if (sRes.ok) safety = await sRes.json();
} catch (_) {}

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name },
  eligibility,
  profile,
  playStyles: safety?.play_styles || [],
});
---

<Layout title={`Playdate · ${pet.name}`} description="Cài đặt hồ sơ playdate">
  <main class="min-h-screen bg-mmp-cream px-4 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`setupPage(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href="/playdate" class="text-sm text-mmp-ink/60 hover:text-mmp-ink">← Playdate</a>
        <h1 class="text-lg font-bold text-mmp-ink inline-flex items-center gap-1.5"><FeatureIcon name="settings" class="w-5 h-5 shrink-0" />Profile {pet.name}</h1>
        <span class="w-12"></span>
      </header>

      <!-- Eligibility -->
      <template x-if="!eligibility?.eligible">
        <div class="bg-mmp-cream border border-mmp-gold/30 rounded-2xl p-5 mb-5">
          <p class="font-bold text-mmp-ink inline-flex items-center gap-1.5"><FeatureIcon name="syringe" class="w-4 h-4 shrink-0" />Cần thêm vaccine</p>
          <p class="text-sm text-mmp-ink/70 mt-1" x-text="eligibility?.reason"></p>
          <a href="/vaccines" class="inline-block mt-3 text-sm bg-mmp-ink text-white font-bold px-4 py-2 rounded-lg">Cập nhật vaccine →</a>
        </div>
      </template>

      <template x-if="eligibility?.eligible">
        <div>
          <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-3 mb-5 text-xs">
            <p class="font-bold text-emerald-900 inline-flex items-center gap-1.5"><FeatureIcon name="check" class="w-4 h-4 shrink-0" />Đủ điều kiện</p>
            <p class="text-emerald-700">Đã có <span x-text="eligibility.vaccine_count"></span> vaccine hoàn tất.</p>
          </div>

          <!-- Bio -->
          <div class="bg-white rounded-2xl border border-slate-100 p-5 mb-4">
            <label class="text-xs font-bold text-slate-700 uppercase">Giới thiệu bé (bio)</label>
            <textarea x-model="form.bio" rows="3" maxlength="500" placeholder="VD: Bé hiền, thích chạy nhảy, hơi nhút nhát với người lạ..."
              class="w-full mt-1 border border-slate-200 rounded-xl px-3 py-2 text-sm"></textarea>
            <p class="text-[11px] text-slate-400 mt-1"><span x-text="form.bio.length"></span>/500</p>
          </div>

          <!-- Looking for -->
          <div class="bg-white rounded-2xl border border-slate-100 p-5 mb-4">
            <label class="text-xs font-bold text-slate-700 uppercase">Tìm kiếm</label>
            <div class="grid grid-cols-2 gap-2 mt-2">
              <template x-for="opt in lookingForOptions" :key="opt.key">
                <button type="button" @click="form.looking_for = opt.key"
                  :class="form.looking_for === opt.key ? 'bg-mmp-ink text-white shadow' : 'bg-slate-100 text-slate-700'"
                  class="px-3 py-2 rounded-lg text-xs font-bold text-left">
                  <span x-text="`${opt.emoji} ${opt.label}`"></span>
                </button>
              </template>
            </div>
          </div>

          <!-- Play styles -->
          <div class="bg-white rounded-2xl border border-slate-100 p-5 mb-4">
            <label class="text-xs font-bold text-slate-700 uppercase">Kiểu chơi (chọn nhiều)</label>
            <div class="flex flex-wrap gap-2 mt-2">
              <template x-for="ps in playStyles" :key="ps.key">
                <button type="button" @click="togglePlayStyle(ps.key)"
                  :class="form.play_styles.includes(ps.key) ? 'bg-mmp-ink text-white shadow' : 'bg-slate-100 text-slate-700'"
                  class="px-3 py-1.5 rounded-full text-xs font-bold">
                  <span x-text="`${ps.emoji} ${ps.label_vi}`"></span>
                </button>
              </template>
            </div>
          </div>

          <!-- Distance -->
          <div class="bg-white rounded-2xl border border-slate-100 p-5 mb-4">
            <label class="text-xs font-bold text-slate-700 uppercase flex items-center justify-between">
              <span>Khoảng cách tối đa</span>
              <span class="text-mmp-ink font-bold"><span x-text="form.max_distance_km"></span> km</span>
            </label>
            <input type="range" min="1" max="50" x-model.number="form.max_distance_km"
              class="w-full mt-2 accent-violet-600" />
            <p class="text-[11px] text-slate-400 mt-1">Chỉ thấy bé khác trong bán kính này.</p>
          </div>

          <!-- Location -->
          <div class="bg-white rounded-2xl border border-slate-100 p-5 mb-4">
            <label class="text-xs font-bold text-slate-700 uppercase">Vị trí của bạn</label>
            <div class="flex items-center gap-2 mt-2">
              <input type="number" step="0.000001" x-model.number="form.lat" placeholder="Lat" class="flex-1 border border-slate-200 rounded-lg px-2 py-1.5 text-xs font-mono" />
              <input type="number" step="0.000001" x-model.number="form.lng" placeholder="Lng" class="flex-1 border border-slate-200 rounded-lg px-2 py-1.5 text-xs font-mono" />
              <button type="button" @click="locate()" :disabled="locating"
                class="text-xs bg-mmp-cream hover:bg-yellow-100 text-mmp-ink font-bold px-3 py-1.5 rounded-lg">
                <span x-show="!locating" class="inline-flex items-center gap-1.5"><FeatureIcon name="map-pin" class="w-4 h-4 shrink-0" />Tự định vị</span>
                <span x-show="locating">...</span>
              </button>
            </div>
            <p class="text-[11px] text-slate-400 mt-1">Vị trí chỉ dùng để tính khoảng cách — không hiển thị chính xác cho bé khác.</p>
          </div>

          <!-- Active toggle -->
          <div class="bg-white rounded-2xl border border-slate-100 p-5 mb-4 flex items-center justify-between">
            <div>
              <p class="text-sm font-bold text-slate-900">Hiển thị trong khám phá</p>
              <p class="text-[11px] text-slate-500">Tắt để pause profile mà không xoá.</p>
            </div>
            <button @click="form.active = !form.active" type="button"
              :class="form.active ? 'bg-emerald-500' : 'bg-slate-300'"
              class="relative inline-flex h-6 w-11 items-center rounded-full transition">
              <span :class="form.active ? 'translate-x-6' : 'translate-x-1'"
                class="inline-block h-4 w-4 transform rounded-full bg-white transition"></span>
            </button>
          </div>

          <template x-if="error">
            <p class="text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg p-3 mb-3" x-text="error"></p>
          </template>
          <template x-if="success">
            <p class="text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-lg p-3 mb-3" x-html="svgIcon('check', 14) + ' ' + success"></p>
          </template>

          <div class="flex gap-2">
            <button @click="submit()" :disabled="saving"
              class="flex-1 bg-mmp-ink hover:opacity-90 disabled:opacity-50 text-white font-bold py-3 rounded-xl shadow-lg text-sm">
              <span x-show="!saving" x-html="profile ? svgIcon('save', 16) + ' Lưu' : svgIcon('rocket', 16) + ' Bật profile'"></span>
              <span x-show="saving">Đang lưu...</span>
            </button>
            <template x-if="profile">
              <a :href="`/playdate/discover/${pet.id}`" class="bg-white border border-mmp-cream text-mmp-ink font-bold py-3 px-4 rounded-xl text-sm inline-flex items-center gap-1.5">
                <FeatureIcon name="flame" class="w-4 h-4 shrink-0" />Khám phá →
              </a>
            </template>
          </div>
        </div>
      </template>

    </div>
  </main>

  <script is:inline>
    function setupPage(initial) {
      const p = initial.profile;
      return {
        pet: initial.pet,
        eligibility: initial.eligibility,
        profile: p,
        playStyles: initial.playStyles,
        lookingForOptions: [
          { key: "play_buddy", label: "Bạn chơi", emoji: "🎾" },
          { key: "walking_partner", label: "Bạn dắt đi dạo", emoji: "🚶" },
          { key: "breeding", label: "Tìm phối giống", emoji: "🧬" },
          { key: "all", label: "Tất cả", emoji: "✨" },
        ],
        form: {
          bio: p?.bio || "",
          looking_for: p?.looking_for || "play_buddy",
          play_styles: p?.play_styles || [],
          max_distance_km: p?.max_distance_km || 10,
          lat: p?.lat || 0,
          lng: p?.lng || 0,
          active: p ? p.active : true,
        },
        saving: false,
        locating: false,
        error: "",
        success: "",

        // Iconify emoji trong x-text → SVG-string (render qua x-html). Path đồng bộ FeatureIcon.
        svgIcon(name, size) {
          var P = {
            save: '<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>',
            rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
            check: '<path d="M5 12l5 5 9-11"/>',
          };
          var s = size || 18;
          return '<svg width="' + s + '" height="' + s + '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-0.15em">' + (P[name] || "") + "</svg>";
        },

        togglePlayStyle(key) {
          const i = this.form.play_styles.indexOf(key);
          if (i >= 0) this.form.play_styles.splice(i, 1);
          else if (this.form.play_styles.length < 5) this.form.play_styles.push(key);
        },

        locate() {
          if (!navigator.geolocation) { this.error = "Trình duyệt không hỗ trợ định vị."; return; }
          this.locating = true;
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              this.form.lat = Number(pos.coords.latitude.toFixed(6));
              this.form.lng = Number(pos.coords.longitude.toFixed(6));
              this.locating = false;
            },
            () => { this.error = "Không lấy được vị trí. Vui lòng cho phép location."; this.locating = false; }
          );
        },

        async submit() {
          this.error = ""; this.success = "";
          this.saving = true;
          try {
            const res = await fetch(`/api/v1/playdate/profile/${this.pet.id}`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify(this.form),
            });
            const j = await res.json();
            if (!res.ok) {
              this.error = j?.error?.message || "Lỗi lưu";
              return;
            }
            this.profile = j.profile;
            this.success = "Đã lưu profile. Sang tab Khám phá để tìm bạn!";
          } catch (_) {
            this.error = "Lỗi kết nối.";
          } finally {
            this.saving = false;
          }
        },
      };
    }
  </script>
</Layout>
