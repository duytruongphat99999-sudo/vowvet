                  <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl shrink-0" style="background: rgba(236, 185, 33, 0.15);">
                    <FeatureIcon name="sparkles" class="w-5 h-5" strokeWidth={2} style="color: var(--c-gold);" />
                  </span>
                  <div class="text-left min-w-0">
