---
/**
 * Cross-site navigation for the Mon Min Pet ecosystem.
 *
 * Matches the homepage "3 platform · 1 sứ mệnh" section EXACTLY:
 *   - 3 premium cards · p-5 padding · rounded-3xl
 *   - 14×14 icon container · ink/5 bg · hover bg-mmp-gold/15
 *   - SVG icons (shop · stethoscope · app) — NO emojis
 *   - Bold h3 title + small sub-description
 *   - Active card: ink dark + gold spotlight + "Bạn đang ở đây" shimmer pill + attention-card pulse
 */
import FeatureIcon from "./FeatureIcon.astro";

interface Props {
  active?: "vowvet" | "monmin" | "bio";
  /** Compact = footer mode (smaller padding). Default = standard. */
  compact?: boolean;
}
const { active = "vowvet", compact = false } = Astro.props;

const cardPad = compact ? "p-4 sm:p-5" : "p-5 sm:p-6";
const iconBox = compact ? "w-12 h-12" : "w-14 h-14";
const titleSize = compact ? "text-base sm:text-lg" : "text-lg sm:text-xl";

const platforms = [
  {
    key: "monmin" as const,
    href: "https://monminpet.com",
    icon: "shop" as const,
    eyebrow: "Platform 1",
    title: "Mon Min Pet",
    desc: "Cửa hàng sản phẩm thú y curated bởi BSTY. Grooming · Spa · Dịch vụ tại nhà.",
    url: "monminpet.com",
  },
  {
    key: "bio" as const,
    href: "https://bio.monminpet.com",
    icon: "stethoscope" as const,
    eyebrow: "Platform 2",
    title: "Tư vấn BSTY",
    desc: "Chat trực tiếp với BSTY Mon Min Pet qua Zalo OA. Tư vấn dinh dưỡng 1:1 miễn phí.",
    url: "bio.monminpet.com",
  },
  {
    key: "vowvet" as const,
    href: "/",
    icon: "app" as const,
    eyebrow: "Platform 3",
    title: "VowVet · ALL-IN-ONE",
    desc: "AI tracking pet trọn đời. QR Passport · WSAVA · AAFCO · Tiếng Việt · Miễn phí.",
    url: "vowvet.monminpet.com",
  },
];
---

<section aria-label="Hệ sinh thái Mon Min Pet" class="space-y-5">
  <div class="text-center">
    <p class="eyebrow" style="color: var(--c-gold);">
      <span class="gold-dot"></span>Hệ sinh thái Mon Min Pet
    </p>
    <h3 class="font-display italic text-xl sm:text-2xl font-semibold text-mmp-ink tracking-tight mt-2">
      3 platform · 1 sứ mệnh
    </h3>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    {platforms.map((p) => {
      const isActive = p.key === active;
      const isExternal = p.href.startsWith("http");

      if (isActive) {
        // ─── Active card: ink dark with attention-pill ────────
        return (
          <div class="relative">
            {/* Animated "Bạn đang ở đây" pill — outside overflow-hidden so it peeks above */}
            <div class="attention-pill absolute -top-3 left-5 text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full inline-flex items-center gap-1.5 z-20 shadow-lg">
              <span class="live-dot inline-block w-1.5 h-1.5 rounded-full bg-red-600"></span>
              <span>Bạn đang ở đây</span>
            </div>

            <a
              href={p.href}
              class={`attention-card relative block bg-mmp-ink text-white rounded-3xl ${cardPad} overflow-hidden`}
              {...(isExternal ? { target: "_blank", rel: "noopener" } : {})}
            >
              {/* Gold spotlight inside active card */}
              <div class="absolute inset-0 opacity-25 pointer-events-none" aria-hidden="true">
                <div class="absolute top-1/4 right-0 w-48 h-48 rounded-full"
                     style="background: radial-gradient(circle, rgba(236,185,33,0.5) 0%, transparent 70%);"></div>
              </div>

              <div class="relative">
                <div class={`${iconBox} rounded-2xl bg-mmp-gold/20 ring-1 ring-mmp-gold/40 flex items-center justify-center mb-4`}>
                  <FeatureIcon name={p.icon} class="w-7 h-7" strokeWidth={1.8} />
                </div>
                <p class="eyebrow mb-1" style="color: var(--c-gold);">{p.eyebrow}</p>
                <h4 class={`font-bold ${titleSize} mb-2`}>{p.title}</h4>
                <p class="text-xs sm:text-sm text-white/70 leading-relaxed mb-4">{p.desc}</p>
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold" style="color: var(--c-gold);">
                  {p.url}
                  <FeatureIcon name="arrow" class="w-3.5 h-3.5" strokeWidth={2} />
                </span>
              </div>
            </a>
          </div>
        );
      }

      // ─── Inactive card: white + gold-hover ────────
      return (
        <a
          href={p.href}
          class={`group block bg-white border border-slate-200 rounded-3xl ${cardPad} hover:border-mmp-ink hover:shadow-lg transition-all`}
          {...(isExternal ? { target: "_blank", rel: "noopener" } : {})}
        >
          <div class={`${iconBox} rounded-2xl bg-mmp-ink/5 flex items-center justify-center mb-4 group-hover:bg-mmp-gold/15 transition`}>
            <FeatureIcon name={p.icon} class="w-7 h-7 text-mmp-ink" strokeWidth={1.8} />
          </div>
          <p class="eyebrow mb-1" style="color: var(--c-gold);">{p.eyebrow}</p>
          <h4 class={`font-bold ${titleSize} text-mmp-ink mb-2`}>{p.title}</h4>
          <p class="text-xs sm:text-sm text-slate-600 leading-relaxed mb-4">{p.desc}</p>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-mmp-ink">
            {p.url}
            <FeatureIcon name={isExternal ? "external" : "arrow"} class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" strokeWidth={2} />
          </span>
        </a>
      );
    })}
  </div>
</section>
