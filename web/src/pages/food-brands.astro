---
/**
 * /food-brands — Public catalogue (M8).
 *
 * SEO-optimized landing page giới thiệu 14+ brand thức ăn cho chó/mèo.
 * KHÔNG auth required. Cache 1h ở backend (loadFoodBrands).
 * Client-side filter qua Alpine.js (14 brands → moot pagination).
 */
import Layout from "../layouts/Layout.astro";

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";
let brands: any[] = [];
let totalCount = 0;
try {
  // Fetch tối đa 50 brands (Phase 0 chỉ có 14, tương lai mở rộng vẫn fit)
  const res = await fetch(`${API_INTERNAL}/api/v1/public/food-brands?size=50`);
  if (res.ok) {
    const j = await res.json();
    brands = j.brands || [];
    totalCount = j.pagination?.total || brands.length;
  }
} catch (err) {
  console.error("[food-brands page] fetch failed:", err);
}

// === v34: SSR fetch user pets + latest BCS (graceful fallback for guests) ===
const cookieHeader = Astro.request.headers.get("cookie") || "";
let userPets: any[] = [];
let initialBcsScore: number | null = null;

try {
  // v43-fix: endpoint thật là /api/v1/auth/me (mount tại app.route("/api/v1/auth", authRoute)).
  // URL cũ /api/v1/users/me trả về 404 từ v34 → mọi logged-in user bị fallback guest.
  const meRes = await fetch(`${API_INTERNAL}/api/v1/auth/me`, {
    headers: { cookie: cookieHeader },
  });
  // v43: log non-401 errors (401 = guest expected; còn lại = lỗi thật cần debug)
  if (!meRes.ok && meRes.status !== 401) {
    console.error("[food-brands SSR] /auth/me unexpected status:", meRes.status);
  }
  if (meRes.ok) {
    const meData = await meRes.json();
    userPets = meData.pets || [];
    if (userPets.length > 0) {
      try {
        // v43-fix: endpoint thật là /bcs/latest (BCS routes có 4 sub: /assess, /history, /latest, /:assessId — không có trần /bcs)
        const bcsRes = await fetch(`${API_INTERNAL}/api/v1/pets/${userPets[0].id}/bcs/latest`, {
          headers: { cookie: cookieHeader },
        });
        if (bcsRes.ok) {
          const bcsData = await bcsRes.json();
          // Response shape: { assessment: BcsApi | null } với BcsApi.bcs_score: number
          const score = bcsData?.assessment?.bcs_score;
          if (score != null) {
            initialBcsScore = Number(score);
          }
        } else if (bcsRes.status !== 404) {
          // 404 expected khi pet chưa có BCS assessment nào (new pet) → không phải lỗi
          console.error("[food-brands SSR] /pets/:id/bcs/latest status:", bcsRes.status);
        }
      } catch (err) {
        console.error("[food-brands SSR] /pets/:id/bcs/latest fetch failed:", err);
      }
    }
  }
} catch (err) {
  console.error("[food-brands SSR] /users/me fetch failed:", err);
}

const brandsJson = JSON.stringify(brands);
const userPetsJson = JSON.stringify(userPets);
const initialBcsScoreJson = JSON.stringify(initialBcsScore);
const pageUrl = "https://vowvet.monminpet.com/food-brands";
const ogImage = "https://vowvet.monminpet.com/og-image.png"; // placeholder — production sẽ có ảnh real
---

<Layout
  title="Catalog dinh dưỡng pet | VowVet"
  description="So sánh 14+ thương hiệu thức ăn cho chó mèo tại Việt Nam. Lọc theo loài, life stage, thành phần dị ứng. Khuyến nghị bởi bác sĩ Mon Min."
>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content="Catalog dinh dưỡng pet | VowVet" />
    <meta property="og:description" content="So sánh 14+ thương hiệu thức ăn cho chó mèo tại Việt Nam. Khuyến nghị bởi bác sĩ Mon Min." />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="keywords" content="thức ăn chó, thức ăn mèo, dinh dưỡng pet, Royal Canin, Whiskas, Mon Min, dog food Vietnam, cat food Vietnam" />
  </Fragment>

  <main class="min-h-screen bg-mmp-cream">
    <!-- v44: x-data hoisted to wrap nav so Alpine directives work in nav avatar -->
    <div x-data={`brandsCatalog(${brandsJson}, ${userPetsJson}, ${initialBcsScoreJson})`}>
    <!-- v44: Public top nav — auth-aware avatar (logged-in) vs login button (guest) -->
    <nav class="bg-white border-b border-slate-100 sticky top-0 z-30 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-3">
        <!-- v44: Logo image — dùng /logo-mmp.png thay emoji 🐾 -->
        <a href="/" class="flex items-center gap-2.5 group shrink-0">
          <img src="/logo-mmp.png" alt="VowVet logo" class="h-12 w-12 object-contain" />
          <div>
            <p class="font-bold text-slate-900 leading-none">VowVet</p>
            <p class="text-[10px] text-slate-500 leading-none">by Mon Min Pet</p>
          </div>
        </a>
        <div class="flex items-center gap-3 text-sm">
          <a href="/food-brands" class="text-mmp-ink font-semibold hover:underline">Dinh dưỡng</a>
          <span class="text-slate-300 hidden sm:inline">·</span>

          <!-- v44: Logged-in branch — avatar pill linking to dashboard -->
          <a x-show="userPets.length > 0" style="display:none;"
             href="/dashboard"
             class="flex items-center gap-2 pl-1 pr-3 py-1 rounded-full hover:bg-slate-50 transition group">
            <span class="shrink-0 w-9 h-9 rounded-full overflow-hidden ring-1 ring-amber-200/60 bg-mmp-cream/60 flex items-center justify-center">
              <template x-if="profile.petImage">
                <img :src="profile.petImage" :alt="profile.petName"
                     class="w-full h-full object-cover"
                     @error="profile.petImage = ''" />
              </template>
              <template x-if="!profile.petImage">
                <span class="text-lg" x-text="breedSticker || (profile.species === 'cat' ? '🐱' : '🐶')"></span>
              </template>
            </span>
            <div class="hidden sm:block min-w-0 text-left">
              <p class="font-bold text-slate-900 leading-tight truncate max-w-[100px]" x-text="profile.petName || 'bé'"></p>
              <p class="text-[10px] text-slate-500 leading-tight truncate" x-text="getBreedName(profile.breed) || 'Pet của bạn'"></p>
            </div>
          </a>

          <!-- v44: Guest branch — login button -->
          <a x-show="userPets.length === 0" style="display:none;"
             href="/login"
             class="bg-mmp-ink hover:bg-slate-800 text-white font-semibold px-3 py-1.5 rounded-lg transition">
            Đăng nhập
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="px-4 sm:px-6 pt-10 pb-6 max-w-6xl mx-auto">
      <span class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-widest text-amber-700 mb-3">
        <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--c-gold);"></span>
        Catalog dinh dưỡng pet
      </span>
      <h1 class="font-display italic text-3xl sm:text-5xl font-semibold text-mmp-ink mb-3 leading-tight">
        Chọn thức ăn đúng cho bé
      </h1>
      <p class="text-base sm:text-lg text-slate-600 max-w-2xl">
        So sánh <span class="font-semibold text-mmp-ink">{totalCount}+ thương hiệu</span> thức ăn cho chó mèo tại Việt Nam.
        Khuyến nghị bởi bác sĩ Mon Min Pet.
      </p>
    </section>

    <!-- Filter + grid layout (v44: x-data đã hoist lên parent wrapper bao luôn nav) -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 pb-12">
      <div class="lg:grid lg:grid-cols-[260px_1fr] lg:gap-6">

        <!-- SIDEBAR — Profile Matcher + Filters (v34 architecture) -->
        <aside class="lg:sticky lg:top-20 lg:self-start mb-4 lg:mb-0 space-y-3">

          <!-- WIDGET 1: HỒ SƠ BÉ (Premium Quick-Profile Matcher) -->
          <div class="bg-white border border-slate-100 rounded-2xl p-5">
            <!-- v38: Breed sticker swaps into heading when breed selected -->
            <div class="mb-4">
              <!-- v40: Personalized header — pet portrait + dynamic title + quick stats -->
              <div class="flex items-center gap-3">
                <!-- Avatar: real photo nếu có, fallback breed sticker / ✨ -->
                <div class="shrink-0 w-12 h-12 rounded-full overflow-hidden ring-1 ring-amber-200/60 bg-mmp-cream/60 flex items-center justify-center">
                  <template x-if="profile.petImage">
                    <img :src="profile.petImage" :alt="profile.petName || 'pet avatar'"
                         class="w-full h-full object-cover"
                         @error="profile.petImage = ''" />
                  </template>
                  <template x-if="!profile.petImage">
                    <span class="text-2xl transition-all duration-300"
                          :style="breedSticker ? '' : 'color: var(--c-gold);'"
                          x-text="breedSticker || (profile.species === 'cat' ? '🐱' : '🐶')"></span>
                  </template>
                </div>
                <!-- Title block -->
                <div class="min-w-0 flex-1">
                  <!-- v47: bỏ truncate → tên dài wrap thay vì cắt; thêm Verified badge inline -->
                  <h2 class="font-display italic text-lg font-semibold text-mmp-ink leading-tight break-words">
                    <span x-text="'Dinh dưỡng cho ' + (profile.petName || 'bé cưng của bạn')"></span>
                    <template x-if="profile.is_verified">
                      <span class="ml-1 align-middle inline-flex items-center gap-0.5 text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-emerald-100 text-emerald-800 border border-emerald-200 not-italic" title="Đã thẩm định bởi BS Mon Min">
                        ✓
                      </span>
                    </template>
                  </h2>
                  <p class="text-[11px] text-slate-500 leading-tight mt-0.5 truncate"
                     x-text="profile.weight.toFixed(1) + ' kg' + (getBreedName(profile.breed) ? ' · ' + getBreedName(profile.breed) : '')"></p>
                  <div x-show="filters.breed && filters.breed !== 'khac'" style="display:none;" class="mt-1">
                    <span class="inline-flex items-center gap-1 text-[10px] font-bold px-2.5 py-0.5 rounded-full"
                          style="background: var(--c-gold); color: #1A1814;">
                      <span x-text="breedSticker"></span>
                      <span x-text="currentBreedOptions.find(b => b.code === filters.breed)?.name || ''"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Pet dropdown (only if logged in + has pets) -->
            <template x-if="userPets.length > 0">
              <div class="mb-3">
                <select :value="profile.selectedPetId || ''"
                        @change="selectPet($event.target.value)"
                        class="w-full text-sm bg-mmp-cream/40 border border-slate-200 rounded-xl px-3 py-2 font-semibold text-mmp-ink focus:outline-none focus:ring-1 focus:ring-amber-300">
                  <option value="">— Nhập thủ công —</option>
                  <template x-for="p in userPets" :key="p.id">
                    <option :value="p.id" x-text="p.name"></option>
                  </template>
                </select>
              </div>
            </template>

            <!-- v48: Manual name input + Scan giấy tờ ĐÃ MOVE sang trang Profile (single source of truth) -->
            <!-- Sidebar nay chỉ chứa filters + read-only display synced từ /auth/me -->

            <!-- v35: Locked indicator (read-only mode khi pet selected — Data Enforcement) -->
            <template x-if="isProfileLocked">
              <div class="mb-3 px-3 py-2 rounded-xl bg-amber-50 border border-amber-200/70 text-[10px] leading-relaxed text-amber-800 inline-flex items-start gap-1.5 w-full">
                <span class="shrink-0 mt-0.5">🔒</span>
                <span><strong class="font-bold">Đồng bộ từ hồ sơ bé.</strong> Chọn <em>"Nhập thủ công"</em> để giả lập dinh dưỡng tự do.</span>
              </div>
            </template>

            <!-- v48: Sửa hồ sơ CTA — link sang Profile page để edit Poop Score / Allergens / Tên / Scan giấy tờ -->
            <template x-if="isProfileLocked && profile.selectedPetId">
              <a :href="'/pets/' + profile.selectedPetId + '/profile/complete'"
                 class="group mb-3 px-3 py-2 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-[11px] leading-relaxed text-slate-700 inline-flex items-center justify-between w-full transition">
                <span class="inline-flex items-center gap-1.5">
                  <span>✏️</span>
                  <span>Sửa hồ sơ bé</span>
                </span>
                <span class="text-mmp-ink font-semibold transition-transform group-hover:translate-x-0.5">→</span>
              </a>
            </template>

            <!-- v42: Guest onboarding CTA — chỉ fire cho TRUE guest (chưa có pet nào trong account) -->
            <template x-if="userPets.length === 0">
              <div class="mb-3 px-3 py-2.5 rounded-xl bg-emerald-50/80 border border-emerald-200/70 text-[11px] leading-relaxed text-emerald-800 flex items-start gap-2 w-full">
                <span class="shrink-0 text-base leading-none mt-0.5">👋</span>
                <span><strong class="font-semibold">Chào bạn!</strong> Hãy nhập nhanh thông tin bé để AI của VowVet tính khẩu phần chính xác nhất.</span>
              </div>
            </template>

            <!-- Species toggle (v35: locked when pet selected) -->
            <div class="mb-3">
              <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest mb-1.5">Loài</p>
              <div class="grid grid-cols-2 gap-1.5">
                <!-- v39: Lock affordance — title tooltip + 🔒 hint khi locked -->
                <button type="button" :disabled="isProfileLocked"
                        @click="if(!isProfileLocked) profile.species = 'dog'"
                        :class="btnClass(profile.species === 'dog', isProfileLocked)"
                        :title="isProfileLocked ? `Read-only · chọn 'Nhập thủ công' để đổi loài` : ''"
                        class="text-xs font-semibold py-2 rounded-xl transition inline-flex items-center justify-center gap-1">
                  <span x-show="isProfileLocked && profile.species !== 'dog'" class="text-[10px] opacity-60" style="display:none;">🔒</span>
                  <span>🐶 Chó</span>
                </button>
                <button type="button" :disabled="isProfileLocked"
                        @click="if(!isProfileLocked) profile.species = 'cat'"
                        :class="btnClass(profile.species === 'cat', isProfileLocked)"
                        :title="isProfileLocked ? `Read-only · chọn 'Nhập thủ công' để đổi loài` : ''"
                        class="text-xs font-semibold py-2 rounded-xl transition inline-flex items-center justify-center gap-1">
                  <span x-show="isProfileLocked && profile.species !== 'cat'" class="text-[10px] opacity-60" style="display:none;">🔒</span>
                  <span>🐱 Mèo</span>
                </button>
              </div>
            </div>

            <!-- v36: BCS 9-level slider + Tap-to-Answer (replaces 3-pill toggle) -->
            <div class="mb-3">
              <div class="flex items-baseline justify-between mb-1.5">
                <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest">Thể trạng (BCS 1-9)</p>
                <p class="text-[10px] font-bold tabular-nums"
                   :class="{
                     'text-slate-500': currentBcs.tier === 'under-critical' || currentBcs.tier === 'under',
                     'text-emerald-700': currentBcs.tier === 'ideal',
                     'text-orange-600': currentBcs.tier === 'over',
                     'text-red-600': currentBcs.tier === 'obese' || currentBcs.tier === 'obese-critical'
                   }"
                   x-text="currentBcs.label"></p>
              </div>
              <input type="range" min="1" max="9" step="1" x-model.number="profile.bcs"
                     :disabled="isProfileLocked"
                     class="w-full disabled:cursor-not-allowed disabled:opacity-50"
                     :class="{
                       'accent-slate-400': currentBcs.tier === 'under-critical' || currentBcs.tier === 'under',
                       'accent-emerald-500': currentBcs.tier === 'ideal',
                       'accent-orange-500': currentBcs.tier === 'over',
                       'accent-red-500': currentBcs.tier === 'obese' || currentBcs.tier === 'obese-critical'
                     }" />
              <div class="flex justify-between text-[9px] text-slate-400 mt-1">
                <span>1 · Gầy</span><span>5 · Chuẩn</span><span>9 · Béo phì</span>
              </div>
              <!-- v38: BCS Visual Avatar — fixed w-14 h-14 → zero layout shift -->
              <div class="flex items-start gap-3 mt-2" style="min-height: 3.5rem;">
                <div class="relative shrink-0 flex items-center justify-center w-14 h-14 rounded-full ring-2 transition-all duration-500"
                     :class="bcsAvatar.bg + ' ' + bcsAvatar.ring">
                  <div class="absolute" :style="bcsAvatarShapeStyle"></div>
                  <span class="relative text-2xl select-none leading-none"
                        :class="bcsAvatar.anim"
                        x-text="bcsAvatar.emoji"></span>
                </div>
                <div class="flex-1 min-w-0 pt-0.5">
                  <p class="text-[10px] text-slate-600 italic leading-relaxed" x-text="currentBcs.description"></p>
                  <p class="text-[10px] font-bold mt-1 leading-tight"
                     x-show="bcsAvatar.warn"
                     :class="bcsAvatar.warnColor"
                     style="display:none;"
                     x-text="bcsAvatar.warn"></p>
                </div>
              </div>
              <template x-if="!isProfileLocked">
                <div class="mt-3">
                  <p class="text-[9px] font-semibold text-slate-400 uppercase tracking-widest mb-1.5">⚡ Chạm nhanh để chọn</p>
                  <div class="grid grid-cols-1 gap-1.5">
                    <button type="button" @click="profile.bcs = 2"
                            class="text-[11px] font-semibold text-left px-3 py-2 rounded-xl bg-slate-50 hover:bg-slate-100 text-slate-700 transition">
                      🦴 Chỉ thấy xương cứng
                    </button>
                    <button type="button" @click="profile.bcs = 5"
                            class="text-[11px] font-semibold text-left px-3 py-2 rounded-xl bg-emerald-50 hover:bg-emerald-100 text-emerald-800 transition">
                      ✨ Sườn ẩn dưới lớp mỡ mỏng
                    </button>
                    <button type="button" @click="profile.bcs = 8"
                            class="text-[11px] font-semibold text-left px-3 py-2 rounded-xl bg-red-50 hover:bg-red-100 text-red-700 transition">
                      🎈 Không thấy gì ngoài mỡ
                    </button>
                  </div>
                </div>
              </template>
            </div>

            <!-- v48: Poop Score input ĐÃ MOVE sang trang Profile -->
            <!-- State `poopScore` vẫn giữ trong Alpine để filter fat cap + hint hoạt động khi API trả poop_score field -->
            <template x-if="poopScore > 0">
              <div class="mb-4">
                <div class="flex items-baseline justify-between mb-1">
                  <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest">Poop Score</p>
                  <p class="text-[10px] font-bold tabular-nums" :class="poopScoreLabel.tone" x-text="poopScore + '/5 · ' + poopScoreLabel.text"></p>
                </div>
                <p x-show="poopScore >= 4" style="display:none;" class="text-[10px] leading-relaxed text-rose-700 font-medium">
                  🚨 AI giảm trần %Fat về <span class="font-bold tabular-nums" x-text="poopFatCap"></span>%.
                </p>
              </div>
            </template>

            <!-- Weight slider (v35: locked + breed weight hint in manual mode) -->
            <div class="mb-4">
              <div class="flex items-baseline justify-between mb-1.5">
                <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest">Cân nặng</p>
                <p class="font-bold text-mmp-ink tabular-nums" style="min-width: 5ch; text-align: right;">
                  <span class="text-sm" x-text="profile.weight.toFixed(1)"></span><span class="text-xs font-normal text-slate-400 ml-0.5">kg</span>
                </p>
              </div>
              <input type="range" min="0.5" max="50" step="0.1" x-model.number="profile.weight"
                     :disabled="isProfileLocked"
                     class="w-full accent-mmp-ink disabled:cursor-not-allowed disabled:opacity-60" />
              <div class="flex justify-between text-[9px] text-slate-400 mt-1">
                <span>0.5</span><span>50kg</span>
              </div>
              <!-- v35: Breed standard weight hint (manual mode only, when breed selected) -->
              <template x-if="!isProfileLocked && breedWeightHint">
                <p class="text-[10px] text-amber-700 italic mt-1.5" x-text="breedWeightHint"></p>
              </template>
            </div>

            <!-- v36: Free-text NLP input (manual mode only) -->
            <template x-if="!isProfileLocked">
              <div class="mb-3">
                <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest mb-1.5">Mô tả thêm (tùy chọn)</p>
                <textarea x-model="freeText" @input.debounce.300ms="parseFreeText(freeText)"
                          placeholder="VD: bé ăn hạt gà hay gãi, ở chung cư phòng kín..."
                          rows="2"
                          class="w-full text-xs px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 focus:outline-none focus:ring-1 focus:ring-amber-300 resize-none leading-snug"></textarea>
                <template x-if="nlpSuggestions.length > 0">
                  <div class="mt-2 space-y-1">
                    <p class="text-[9px] text-slate-400 uppercase tracking-widest">Đề xuất từ AI (chạm để thêm)</p>
                    <div class="flex flex-wrap gap-1.5">
                      <template x-for="sug in nlpSuggestions" :key="sug.code">
                        <button type="button" @click="applySuggestion(sug)"
                                class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 rounded-full bg-amber-50 text-amber-800 border border-amber-200 hover:bg-amber-100 transition animate-pulse">
                          <span>+</span>
                          <span x-text="sug.label"></span>
                        </button>
                      </template>
                    </div>
                  </div>
                </template>
              </div>
            </template>

            <!-- v36: Allergen Matrix display (3 tiers) -->
            <template x-if="hasAnyAllergen">
              <div class="mb-3 pt-3 border-t border-slate-100">
                <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest mb-1.5">Hồ sơ rủi ro</p>
                <div class="flex flex-wrap gap-1.5">
                  <template x-for="tag in activeAllergenTags" :key="tag.code">
                    <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-1 rounded-full border"
                          :class="{
                            'bg-red-50 text-red-700 border-red-200': tag.tier === 'red',
                            'bg-orange-50 text-orange-700 border-orange-200': tag.tier === 'orange',
                            'bg-amber-50 text-amber-700 border-amber-200': tag.tier === 'yellow',
                            'bg-yellow-100 text-yellow-900 border-yellow-300': tag.tier === 'darkYellow'
                          }">
                      <span x-text="tag.emoji"></span>
