  <style is:inline>{`
    /* v93+v95: Routine builder polish — brand sync + WOW effects */

    /* Step fade-in animation */
    @keyframes step-fade-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    [x-show]:not([style*="display: none"]) {
      animation: step-fade-in 0.45s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    /* Form card hover lift */
    .form-card {
      transition: transform 0.25s cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 0.25s ease-out;
    }
    .form-card:focus-within {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(180, 134, 8, 0.14);
    }
    .form-card input:focus,
    .form-card select:focus {
      box-shadow: 0 0 0 3px rgba(236, 185, 33, 0.25);
    }

    /* Template picker — hover lift + stagger glow */
    button[class*="template"]:not([disabled]),
    button[class*="border-dashed"]:not([disabled]):not(.weekday-pill):not(.schedule-pill) {
      transition: transform 0.25s cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 0.25s ease-out, border-color 0.25s;
    }
    button[class*="template"]:not([disabled]):hover,
    button[class*="border-dashed"]:not([disabled]):not(.weekday-pill):not(.schedule-pill):hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(180, 134, 8, 0.18);
      border-color: #B48608 !important;
    }

    /* v96: Icon picker — Lucide SVG icons in gold tint, scale + glow on selected */
    .routine-icon-btn {
      background: rgba(180, 134, 8, 0.06);
      border: 1px solid transparent;
      color: #B48608;
      transition: transform 0.2s, background 0.2s, box-shadow 0.25s ease-out, color 0.2s;
    }
    .routine-icon-btn:hover {
      background: rgba(180, 134, 8, 0.14);
      transform: scale(1.06);
      color: #8b6914;
    }
    .routine-icon-btn.is-selected {
      background: rgba(236, 185, 33, 0.22);
      border-color: #B48608;
      box-shadow: 0 0 0 2px rgba(236, 185, 33, 0.35), 0 4px 10px rgba(236, 185, 33, 0.25);
      transform: scale(1.08);
      color: #0a0a0a;
    }
    .routine-icon-btn svg {
      display: block;
    }

    /* Schedule pill */
    .schedule-pill {
      background: #ffffff;
      border-color: rgba(10, 10, 10, 0.12);
      color: var(--c-ink-72);
      transition: all 0.2s ease;
    }
    .schedule-pill:hover {
      border-color: rgba(180, 134, 8, 0.4);
      background: rgba(180, 134, 8, 0.04);
    }
    .schedule-pill.is-active {
      background: rgba(236, 185, 33, 0.14);
      border-color: #B48608;
      color: var(--c-ink);
      box-shadow: 0 4px 12px rgba(236, 185, 33, 0.2);
    }

    /* Weekday pill */
    .weekday-pill {
      background: rgba(10, 10, 10, 0.04);
      color: var(--c-ink-54);
      border: 1px solid transparent;
      transition: all 0.2s ease;
    }
    .weekday-pill:hover {
      background: rgba(180, 134, 8, 0.08);
      transform: scale(1.04);
    }
    .weekday-pill.is-active {
      background: #0a0a0a;
      color: #ecb921;
      border-color: #B48608;
      box-shadow: 0 4px 10px rgba(10, 10, 10, 0.2);
    }

    /* Color picker swatch hover */
    button[style*="background-color:"]:not([class*="bg-"]) {
      transition: transform 0.2s, box-shadow 0.2s;
    }
    button[style*="background-color:"]:not([class*="bg-"]):hover {
      transform: scale(1.12);
    }

    /* Save button gold shimmer sweep */
    button[style*="linear-gradient(90deg, #ecb921"] {
      position: relative;
      overflow: hidden;
    }
    button[style*="linear-gradient(90deg, #ecb921"]:not([disabled])::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent 35%, rgba(255, 255, 255, 0.42) 50%, transparent 65%);
      background-size: 220% 100%;
      background-position: 220% 0;
      animation: save-shimmer 3.4s ease-in-out 1.5s infinite;
      pointer-events: none;
      border-radius: inherit;
    }
    @keyframes save-shimmer {
      0%, 40%   { background-position: 220% 0; }
      70%       { background-position: -120% 0; }
      100%      { background-position: -120% 0; }
    }

    /* Progress bar shimmer */
    .h-1\\.5 > div[style*="linear-gradient"] {
      position: relative;
      overflow: hidden;
    }
    .h-1\\.5 > div[style*="linear-gradient"]::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.6) 50%, transparent 100%);
      animation: progress-shimmer 2.4s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes progress-shimmer {
      0%   { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    /* Reduce motion */
    @media (prefers-reduced-motion: reduce) {
      [x-show],
      .routine-icon-btn,
      .weekday-pill,
      .schedule-pill,
      button[style*="linear-gradient(90deg, #ecb921"]::after,
      .h-1\\.5 > div[style*="linear-gradient"]::after { animation: none !important; transition: none !important; transform: none !important; }
    }
  `}</style>

  <script is:inline>
