      weatherEmoji(id) {
        // v213: trả chuỗi SVG (render qua x-html) thay vì emoji — path copy từ FeatureIcon.
        const wrap = (inner) =>
          '<svg class="w-8 h-8 mx-auto text-mmp-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + inner + '</svg>';
        const INFO = '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="8.01"/><path d="M11 12h1v4h1"/>';
        if (!id) return wrap(INFO);
        if (id >= 200 && id < 300) return wrap('<path d="M19 16.9A5 5 0 0 0 18 7h-1.26a8 8 0 1 0-11.62 9"/><polyline points="13 11 9 17 15 17 11 23"/>'); // dông → cloud-lightning
        if (id >= 300 && id < 400) return wrap('<path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M20 12h2"/><path d="m19.07 4.93-1.41 1.41"/><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"/><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"/>'); // mưa phùn → cloud-sun
        if (id >= 500 && id < 600) return wrap('<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>'); // mưa → droplet
        if (id >= 600 && id < 700) return wrap('<line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/><line x1="19.07" y1="4.93" x2="4.93" y2="19.07"/><polyline points="9 5 12 2 15 5"/><polyline points="9 19 12 22 15 19"/><polyline points="5 9 2 12 5 15"/><polyline points="19 9 22 12 19 15"/>'); // tuyết → snowflake
        if (id >= 700 && id < 800) return wrap('<path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M16 17H7"/><path d="M17 21H9"/>'); // sương mù → fog
        if (id === 800) return wrap('<circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/>'); // nắng → sun
        if (id > 800 && id < 900) return wrap('<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>'); // mây → cloud
        return wrap(INFO);
      },
      formatShortDate(iso) {
