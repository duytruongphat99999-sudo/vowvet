---
/**
 * /lost/nearby — Thú cưng thất lạc gần bạn (M20).
 *
 * Browser geolocation → GET /api/v1/lost-pets/nearby. Shows list.
 * Redesign v305: cream/ink/gold theo design system MMP — đỏ CHỈ làm semantic lost,
 * icon line-art FeatureIcon thay emoji, spinner reduced-motion safe.
 */
import Layout from "../../layouts/Layout.astro";
import FeatureIcon from "../../components/FeatureIcon.astro";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");
---

<Layout title="Thú cưng thất lạc gần bạn · VowVet" description="Tìm thú cưng thất lạc trong khu vực của bạn">
  <main class="min-h-screen bg-mmp-cream px-4 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data="nearbyPage()" x-init="onMount()">

      <header class="mb-6">
        <a href="/dashboard" class="text-sm text-slate-500 hover:text-mmp-ink inline-flex items-center gap-1 mb-3">← Dashboard</a>
        <h1 class="font-display italic text-2xl sm:text-3xl font-semibold text-mmp-ink leading-tight">Thú cưng thất lạc gần bạn</h1>
        <p class="text-sm mt-1" style="color:#8b6f47">Cùng để mắt giúp các bé về nhà.</p>
      </header>

      <!-- Radius picker -->
      <div class="bg-white rounded-2xl border border-slate-100 p-4 mb-4 shadow-sm">
        <div class="flex items-center justify-between gap-3 mb-3">
          <p class="text-sm font-semibold text-mmp-ink">Bán kính tìm kiếm</p>
          <select x-model.number="radius" @change="load()"
            class="border border-slate-200 rounded-lg px-3 py-1.5 text-sm text-mmp-ink bg-white">
            <option :value="1">1 km</option>
            <option :value="5">5 km</option>
            <option :value="10">10 km</option>
            <option :value="20">20 km</option>
            <option :value="50">50 km</option>
          </select>
        </div>
        <template x-if="myLocation">
          <p class="text-xs text-slate-500 inline-flex items-center gap-1.5">
            <FeatureIcon name="map-pin" class="w-3.5 h-3.5 shrink-0" />
            Từ vị trí <span class="font-mono" x-text="`${myLocation.lat.toFixed(4)}, ${myLocation.lng.toFixed(4)}`"></span>
          </p>
        </template>
        <template x-if="!myLocation && !loading">
          <button @click="getLocation()" class="text-xs text-mmp-ink hover:underline font-semibold inline-flex items-center gap-1.5">
            <FeatureIcon name="map-pin" class="w-3.5 h-3.5 shrink-0" />
            Bật vị trí
          </button>
        </template>
      </div>

      <!-- Loading -->
      <template x-if="loading">
        <div class="text-center py-10">
          <span class="inline-block w-8 h-8 rounded-full border-2 border-slate-200 animate-spin motion-reduce:animate-none mb-3" style="border-top-color:#B48608" aria-hidden="true"></span>
          <p class="text-sm text-slate-500">Đang tìm quanh bạn…</p>
        </div>
      </template>

      <!-- Error -->
      <template x-if="error">
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700" x-text="error"></div>
      </template>

      <!-- No results -->
      <template x-if="!loading && !error && reports.length === 0 && myLocation">
        <div class="bg-white rounded-2xl border border-slate-100 p-10 text-center shadow-sm">
          <FeatureIcon name="paw" class="w-10 h-10 mx-auto mb-3 text-slate-300" />
          <p class="font-bold text-mmp-ink mb-1">Không có bé nào thất lạc gần bạn</p>
          <p class="text-sm text-slate-500">Trong bán kính <span x-text="radius"></span> km</p>
        </div>
      </template>

      <!-- Results -->
      <div class="space-y-3" x-show="!loading && reports.length > 0">
        <template x-for="r in reports" :key="r.id">
          <a :href="`/lost/${r.public_url_slug}`"
            class="block bg-white rounded-2xl border border-slate-100 border-l-4 border-l-red-500 p-4 shadow-sm hover:shadow-md transition">
            <div class="flex items-center gap-3">
              <span class="w-9 h-9 rounded-full bg-red-50 text-red-600 flex items-center justify-center shrink-0">
                <FeatureIcon name="siren" class="w-5 h-5" />
              </span>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-mmp-ink text-sm truncate" x-text="r.last_seen_location"></p>
                <p class="text-xs text-slate-500 mt-0.5">
                  Mất <span x-text="formatRelative(r.last_seen_at)"></span>
                </p>
                <p class="text-[11px] text-slate-600 mt-1 line-clamp-2" x-text="r.circumstances"></p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xs font-bold font-mono text-red-700" x-text="`${r.distance_km.toFixed(1)} km`"></p>
                <template x-if="r.reward_amount > 0">
                  <p class="text-[10px] font-semibold mt-1" style="color:#B48608" x-text="fmtVnd(r.reward_amount)"></p>
                </template>
              </div>
            </div>
          </a>
        </template>
      </div>

      <p class="text-center text-xs text-slate-400 mt-6 italic">
        Vị trí của bạn KHÔNG được lưu — chỉ dùng tìm kiếm.
      </p>
    </div>
  </main>

  <script is:inline>
    function nearbyPage() {
      return {
        radius: 5,
        myLocation: null,
        reports: [],
        loading: false,
        error: "",

        onMount() {
          this.getLocation();
        },

        getLocation() {
          if (!navigator.geolocation) {
            this.error = "Trình duyệt không hỗ trợ vị trí";
            return;
          }
          this.loading = true;
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              this.myLocation = { lat: pos.coords.latitude, lng: pos.coords.longitude };
              this.load();
            },
            (err) => {
              this.error = "Không lấy được vị trí: " + err.message;
              this.loading = false;
            },
            { enableHighAccuracy: false, timeout: 10000 }
          );
        },

        async load() {
          if (!this.myLocation) return;
          this.loading = true;
          this.error = "";
          try {
            const url = `/api/v1/lost-pets/nearby?lat=${this.myLocation.lat}&lng=${this.myLocation.lng}&radius=${this.radius}`;
            const res = await fetch(url, { credentials: "include" });
            if (!res.ok) {
              this.error = "Lỗi load (HTTP " + res.status + ")";
              return;
            }
            const j = await res.json();
            this.reports = j.reports || [];
          } catch (err) {
            this.error = "Không kết nối server.";
          } finally {
            this.loading = false;
          }
        },

        formatRelative(iso) {
          if (!iso) return "—";
          const diffMs = Date.now() - new Date(iso).getTime();
          const hr = diffMs / 3600000;
          if (hr < 1) return `${Math.max(1, Math.floor(diffMs / 60000))} phút trước`;
          if (hr < 24) return `${Math.floor(hr)} giờ trước`;
          return `${Math.floor(hr / 24)} ngày trước`;
        },

        fmtVnd(n) {
          try {
            return new Intl.NumberFormat("vi-VN", { style: "currency", currency: "VND", maximumFractionDigits: 0 }).format(n);
          } catch { return n + "đ"; }
        },
      };
    }
  </script>
</Layout>
