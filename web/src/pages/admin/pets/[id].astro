---
/**
 * /admin/pets/[id] — chi tiết bé (admin): info + chủ + lịch sử trao + xoá mềm.
 */
import AdminLayout from "../../../layouts/AdminLayout.astro";

import { isAdminIdentity } from "../../../../../shared/admin.ts";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");
if (!isAdminIdentity(user.phone, user.email)) return Astro.redirect("/dashboard");

const id = Number(Astro.params.id);
if (!Number.isFinite(id) || id <= 0) return Astro.redirect("/admin/pets");

const cookieHeader = Astro.request.headers.get("cookie") || "";
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let data: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/admin/pets/${id}`, { headers: { cookie: cookieHeader } });
  if (res.ok) data = await res.json();
} catch (_) {}
if (!data?.pet) return Astro.redirect("/admin/pets");

const p = data.pet;
const handovers: any[] = data.handovers || [];

function fmtDate(iso: string) {
  if (!iso) return "—";
  const parts = String(iso).slice(0, 10).split("-");
  return parts.length === 3 ? `${parts[2]}/${parts[1]}/${parts[0]}` : String(iso).slice(0, 10);
}
const speciesLabel = p.species === "cat" ? "Mèo" : p.species === "dog" ? "Chó" : "Khác";
---

<AdminLayout title={p.name} currentPage="pets">
  <a href="/admin/pets" class="text-xs text-gray-400 hover:text-gray-600 mb-4 inline-block">← Danh sách thú cưng</a>

  <div class="bg-white rounded-2xl border border-gray-100 p-6 mb-6">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class="text-lg font-bold text-gray-900">{p.name}</p>
        <span class="font-mono text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded inline-block mt-1">{p.qr_code || "—"}</span>
        <p class="text-xs text-gray-400 mt-2">{speciesLabel} · Chủ hiện tại: <span class="text-gray-600">{p.ownerName}</span> · Đăng ký {fmtDate(p.created_at)}</p>
        {p.deleted && <p class="text-xs text-red-500 mt-1">⚠ Bé này đã bị xoá mềm (deleted_at).</p>}
      </div>
      {!p.deleted && (
        <button id="del-btn" data-pet-id={p.id} data-pet-name={p.name} class="flex-shrink-0 text-xs text-red-400 hover:text-red-600 font-medium border border-red-200 hover:border-red-300 rounded-lg px-3 py-1.5 transition-colors">Xoá mềm</button>
      )}
    </div>
  </div>

  <!-- W-F: admin toàn quyền bật/tắt foster + đổi trạng thái (bất kỳ pet nào) -->
  <div class="bg-white rounded-2xl border border-gray-100 p-6 mb-6" x-data="fosterAdmin()">
    <h3 class="text-sm font-bold text-gray-900 mb-4">Quản foster</h3>

    <div class="flex items-center justify-between mb-4">
      <div class="min-w-0">
        <p class="text-sm text-gray-900">Chế độ foster công khai</p>
        <p class="text-xs text-gray-400 mt-0.5" x-text="foster_public ? 'Đang bật — bé hiện trên danh sách cần foster' : 'Đang tắt'"></p>
      </div>
      <button type="button" @click="toggle()" :disabled="busy" :aria-pressed="foster_public ? 'true' : 'false'"
        :class="foster_public ? 'bg-emerald-500' : 'bg-gray-300'"
        class="relative flex-shrink-0 w-12 h-6 rounded-full transition-colors disabled:opacity-40">
        <span class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full transition-transform" :class="foster_public ? 'translate-x-6' : ''"></span>
      </button>
    </div>

    <div class="mb-3" x-show="foster_public">
      <label class="text-xs text-gray-500 block mb-1">Trạng thái foster</label>
      <div class="flex gap-2">
        <select x-model="foster_status" class="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-[#d4a520]">
          <option value="cần tài trợ">cần tài trợ</option>
          <option value="đang foster">đang foster</option>
          <option value="sắp có nhà">sắp có nhà</option>
          <option value="đã về nhà">đã về nhà</option>
        </select>
        <button type="button" @click="saveStatus()" :disabled="busy" class="flex-shrink-0 text-sm font-medium border border-gray-200 rounded-xl px-4 py-2 hover:bg-gray-50 transition-colors disabled:opacity-40">Lưu trạng thái</button>
      </div>
    </div>

    <a x-show="public_slug" :href="'/p/' + public_slug" target="_blank" rel="noopener" class="text-xs text-amber-600 hover:text-amber-700">Xem thẻ công khai →</a>
    <p x-show="msg" x-text="msg" class="text-xs mt-3" :class="err ? 'text-red-500' : 'text-emerald-600'" style="display:none;"></p>
  </div>

  <h3 class="text-sm font-bold text-gray-900 mb-3">Lịch sử trao bé ({handovers.length})</h3>
  {handovers.length === 0 ? (
    <p class="text-sm text-gray-400">Chưa có lịch sử trao.</p>
  ) : (
    <ol class="space-y-3 border-l border-gray-100 pl-4">
      {handovers.map((h: any) => (
        <li class="relative">
          <span class="absolute -left-[21px] top-1.5 w-2 h-2 rounded-full bg-amber-500"></span>
          <p class="text-sm text-gray-900"><span class="font-medium">{h.from}</span> → <span class="font-medium">{h.to}</span></p>
          <p class="text-xs text-gray-400">{fmtDate(h.created_at)}</p>
        </li>
      ))}
    </ol>
  )}

  <script is:inline set:html={`window.__adminPetFoster = ${JSON.stringify({
    id: p.id,
    foster_public: p.foster_public === true,
    foster_status: p.foster_status ?? null,
    public_slug: p.public_slug || null,
  }).replace(/</g, "\\u003c")};`}></script>
  <script is:inline>
    function fosterAdmin() {
      var s = window.__adminPetFoster || {};
      return {
        id: s.id,
        foster_public: !!s.foster_public,
        foster_status: s.foster_status || "cần tài trợ",
        public_slug: s.public_slug || null,
        busy: false,
        msg: "",
        err: false,
        async patch(body) {
          this.busy = true;
          this.msg = "";
          try {
            var r = await fetch("/api/v1/admin/pets/" + this.id + "/foster", {
              method: "PATCH",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(body),
            });
            var j = await r.json().catch(function () { return {}; });
            if (!r.ok) {
              this.err = true;
              this.msg = (j.error && j.error.message) || ("Lỗi (" + r.status + ")");
              return null;
            }
            this.err = false;
            return j.pet;
          } catch (e) {
            this.err = true;
            this.msg = "Lỗi kết nối";
            return null;
          } finally {
            this.busy = false;
          }
        },
        async toggle() {
          var pet = await this.patch({ foster_public: !this.foster_public });
          if (!pet) return;
          this.foster_public = pet.foster_public;
          this.public_slug = pet.public_slug;
          if (pet.foster_status) this.foster_status = pet.foster_status;
          this.msg = this.foster_public ? "Đã bật foster công khai" : "Đã tắt foster";
        },
        async saveStatus() {
          var pet = await this.patch({ foster_status: this.foster_status });
          if (!pet) return;
          if (pet.foster_status) this.foster_status = pet.foster_status;
          this.msg = "Đã lưu trạng thái";
        },
      };
    }
  </script>
  <script is:inline>
    (() => {
      var b = document.getElementById("del-btn");
      if (!b) return;
      b.addEventListener("click", async () => {
        if (!confirm("Xoá bé " + (b.dataset.petName || "") + "? Hành động này ảnh hưởng dữ liệu thật.")) return;
        b.disabled = true;
        try {
          var r = await fetch("/api/v1/admin/pets/" + b.dataset.petId + "/delete", { method: "POST", credentials: "include" });
          if (r.ok) { window.location.href = "/admin/pets"; }
          else { alert("Xoá thất bại (" + r.status + ")"); b.disabled = false; }
        } catch (e) { alert("Lỗi kết nối"); b.disabled = false; }
      });
    })();
  </script>
</AdminLayout>
