      "🚀": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
      "🦋": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>',
      "🦸": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
      "🌙": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>',
      "📷": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>',
      "🛡️": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
      "🎂": '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M4 21h16"/><path d="M4 21V10a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v11"/><path d="M4 14h16M9 8V3M12 8V3M15 8V3"/></svg>',
    };

    function renderAchIcon(emoji, size) {
      const s = size || '24px';
      const svg = ACH_LUCIDE_ICONS[emoji];
      if (svg) return svg;
      return '<span style="font-size:' + s + ';line-height:1;">' + (emoji || '🏆') + '</span>';
    }

    // Category Lucide SVGs (for tab pills)
    const CAT_LUCIDE = {
      all: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
      health: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
      milestone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>',
      completion: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>',
      social: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>',
      hero: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
      secret: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;display:inline-block;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>',
    };

    function achievementsPage(initial) {
      return {
        pet: initial.pet,
        achievements: initial.achievements,
        summary: initial.summary,
        filter: 'all',
        socialProof: {},
        renderIcon: renderAchIcon,

        categories: [
          { key: 'all',         label: 'Tất cả' },
          { key: 'health',      label: 'Sức khoẻ' },
          { key: 'milestone',   label: 'Streak' },
          { key: 'completion',  label: 'Hoàn thiện' },
          { key: 'social',      label: 'Cộng đồng' },
          { key: 'hero',        label: 'Anh hùng' },
          { key: 'secret',      label: 'Bí mật' },
        ],

        renderCatIcon(key) {
          return CAT_LUCIDE[key] || '';
        },

        async loadSocialProof() {
          const codesToFetch = this.achievements
            .filter(a => !a.unlocked && !a.is_secret)
            .slice(0, 8)
            .map(a => a.code);
          await Promise.all(codesToFetch.map(async (code) => {
            try {
              const r = await fetch(`/api/v1/achievements/${code}/social-proof`);
              if (r.ok) {
                this.socialProof[code] = await r.json();
              }
            } catch (_) {}
          }));
          this.socialProof = { ...this.socialProof };
        },

        get categoryCounts() {
          const counts = { all: this.achievements.length };
          for (const a of this.achievements) {
            counts[a.category] = (counts[a.category] || 0) + 1;
          }
          return counts;
        },

        get filteredAchievements() {
          if (this.filter === 'all') return this.achievements;
          return this.achievements.filter(a => a.category === this.filter);
        },

        // v104: Brand tier colors — gold spectrum (deeper for higher tier)
        cardClasses(ach) {
          if (!ach.unlocked) return 'ach-card--locked';
          return 'ach-card--' + (ach.tier || 'bronze');
        },

        fmtDate(iso) {
          if (!iso) return '';
          try { return new Date(iso).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' }); }
          catch { return ''; }
        },
      };
    }
  </script>

  <style is:inline>{`
    /* v104: Brand-aligned tier card styles */
    .ach-card { background: #fff; }
    .ach-card--locked {
      background: rgba(10, 10, 10, 0.04);
      border-color: rgba(10, 10, 10, 0.08);
      color: var(--c-ink-54);
    }
    .ach-card--bronze {
      background: linear-gradient(135deg, rgba(180,134,8,0.08) 0%, rgba(180,134,8,0.18) 100%);
      border-color: rgba(180, 134, 8, 0.45);
      color: #5a4a2a;
    }
    .ach-card--silver {
      background: linear-gradient(135deg, rgba(180,134,8,0.04) 0%, rgba(10,10,10,0.06) 100%);
      border-color: rgba(10, 10, 10, 0.2);
      color: #0a0a0a;
    }
    .ach-card--gold {
      background: linear-gradient(135deg, rgba(236,185,33,0.15) 0%, rgba(180,134,8,0.32) 100%);
      border-color: #B48608;
      color: #0a0a0a;
      box-shadow: 0 4px 12px rgba(236, 185, 33, 0.18);
    }
    .ach-card--platinum {
      background: linear-gradient(135deg, #0a0a0a 0%, #5a4a2a 100%);
      border-color: #B48608;
      color: #ecb921;
      box-shadow: 0 4px 14px rgba(10, 10, 10, 0.32), 0 0 18px rgba(236, 185, 33, 0.2);
    }
    .ach-card--secret {
      background: rgba(10, 10, 10, 0.85);
      border-color: rgba(236, 185, 33, 0.4);
      color: #ecb921;
    }

    /* Tab pills */
    .ach-tab {
      background: #ffffff;
      color: var(--c-ink-72);
      border: 1px solid rgba(180, 134, 8, 0.22);
    }
    .ach-tab:hover {
      border-color: rgba(180, 134, 8, 0.45);
    }
    .ach-tab--active {
      background: #0a0a0a;
      color: #ecb921;
      border-color: #B48608;
      box-shadow: 0 3px 10px rgba(10, 10, 10, 0.25);
    }

    /* Pulse animation for new unlocked achievements */
    @keyframes pulse-gold {
      0%, 100% { transform: scale(1); opacity: 1; }
      50%      { transform: scale(1.3); opacity: 0.65; }
    }
    .animate-pulse-gold { animation: pulse-gold 1.8s ease-in-out infinite; }

    /* Card hover lift */
    .ach-card {
      transition: transform 0.22s cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 0.22s ease-out;
    }
    .ach-card:hover {
      transform: translateY(-2px);
    }

    @media (prefers-reduced-motion: reduce) {
      .animate-pulse-gold { animation: none; }
      .ach-card { transition: none; }
    }
  `}</style>
</Layout>
