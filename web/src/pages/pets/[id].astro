                <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </a>
            </div>
            <p class="text-[10px] text-mmp-ink/55 italic mt-2 inline-flex items-start gap-1">
              <FeatureIcon name="info" class="w-3 h-3 shrink-0 translate-y-0.5" />
              <span>Thông tin tham khảo cho gợi ý dinh dưỡng. Với tình trạng nghiêm trọng, hãy hỏi bác sĩ thú y trước khi thay đổi chế độ ăn của bé.</span>
            </p>
          </div>
        </div>

        <div class="space-y-2">

          {/* SECTION 1: IDENTITY */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('identity') ? openSections.delete('identity') : openSections.add('identity'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="edit-pencil" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Danh tính</span>
              <span class="text-xs text-slate-400">{completion?.sections?.identity?.pct ?? 0}%</span>
              {completion?.sections?.identity?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('identity') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('identity')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div><dt class="text-slate-500 text-xs">Tên gọi ở nhà</dt><dd class="font-medium">{fmt(profile.nickname)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Tên chính thức</dt><dd class="font-medium">{fmt(profile.formal_name)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Microchip</dt><dd class="font-medium font-mono text-xs">{fmt(profile.microchip_id)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Đăng ký phường</dt><dd class="font-medium">{fmt(profile.registration_id)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Cách biết tuổi</dt><dd class="font-medium">{lbl("age_estimation_method", profile.age_estimation_method)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Đã triệt sản</dt><dd class="font-medium">{fmtBool(profile.neutered)}{profile.neutered_date ? ` (${profile.neutered_date})` : ""}</dd></div>
              </dl>
              <span class="inline-block mt-3 text-[10px] italic text-slate-400">Click section header để collapse · Sửa qua API</span>
            </div>
          </div>

          {/* SECTION 2: APPEARANCE */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('appearance') ? openSections.delete('appearance') : openSections.add('appearance'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="palette" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Ngoại hình</span>
              <span class="text-xs text-slate-400">{completion?.sections?.appearance?.pct ?? 0}%</span>
              {completion?.sections?.appearance?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('appearance') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('appearance')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div><dt class="text-slate-500 text-xs">Màu lông</dt><dd class="font-medium">{fmt(profile.coat_color)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Họa tiết</dt><dd class="font-medium">{lbl("coat_pattern", profile.coat_pattern)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Màu mắt</dt><dd class="font-medium">{fmt(profile.eye_color)}</dd></div>
              </dl>
              {profile.distinguishing_marks && (
                <p class="mt-2 text-sm text-slate-700 italic">"{profile.distinguishing_marks}"</p>
              )}
              <span class="inline-block mt-3 text-[10px] italic text-slate-400">Click section header để collapse · Sửa qua API</span>
            </div>
          </div>

          {/* SECTION 3: ORIGIN */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('origin') ? openSections.delete('origin') : openSections.add('origin'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="book-open" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Câu chuyện về bé</span>
              <span class="text-xs text-slate-400">{completion?.sections?.origin?.pct ?? 0}%</span>
              {completion?.sections?.origin?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('origin') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('origin')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div><dt class="text-slate-500 text-xs">Từ đâu về</dt><dd class="font-medium">{lbl("origin_type", profile.origin_type)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Ngày về</dt><dd class="font-medium">{fmt(profile.arrival_date)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Người/nơi</dt><dd class="font-medium">{fmt(profile.breeder_info)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Phả hệ</dt><dd class="font-medium">{fmtBool(profile.has_pedigree)}</dd></div>
              </dl>
              {profile.adoption_story && (
                <p class="mt-2 text-sm text-slate-700 italic whitespace-pre-wrap">"{profile.adoption_story}"</p>
              )}
              <span class="inline-block mt-3 text-[10px] italic text-slate-400">Click section header để collapse · Sửa qua API</span>
            </div>
          </div>

          {/* SECTION 4: HEALTH summary */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('health') ? openSections.delete('health') : openSections.add('health'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="stethoscope" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Sức khỏe</span>
              <span class="text-xs text-slate-400">{completion?.sections?.health?.pct ?? 0}%</span>
              {completion?.sections?.health?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('health') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('health')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3">
              <p class="text-sm text-slate-600 mb-3">Quản lý vaccine, tẩy giun, dị ứng, sự kiện y tế ở wizard.</p>
              <span class="inline-block text-[10px] italic text-slate-400">Sửa qua API · Vaccine/Allergy CRUD</span>
            </div>
          </div>

          {/* SECTION 5: DIET */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('diet') ? openSections.delete('diet') : openSections.add('diet'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="bowl" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Dinh dưỡng</span>
              <span class="text-xs text-slate-400">{completion?.sections?.diet?.pct ?? 0}%</span>
              {completion?.sections?.diet?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('diet') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('diet')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div><dt class="text-slate-500 text-xs">Loại thức ăn</dt><dd class="font-medium">{lbl("diet_type", profile.diet_type)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Brand chính</dt><dd class="font-medium">{fmt(profile.diet_brand_primary)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Bữa/ngày</dt><dd class="font-medium">{fmt(profile.meals_per_day)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Gram/bữa</dt><dd class="font-medium">{fmt(profile.portion_grams)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Nước/ngày</dt><dd class="font-medium">{profile.daily_water_ml ? `${profile.daily_water_ml} ml` : "—"}</dd></div>
              </dl>
              <span class="inline-block mt-3 text-[10px] italic text-slate-400">Click section header để collapse · Sửa qua API</span>
            </div>
          </div>

          {/* SECTION 6: PERSONALITY với RADAR */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('personality') ? openSections.delete('personality') : openSections.add('personality'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="brain" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Tính cách</span>
              <span class="text-xs text-slate-400">{completion?.sections?.personality?.pct ?? 0}%</span>
              {completion?.sections?.personality?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('personality') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('personality')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3 space-y-3">
              <!-- Archetype tags -->
              {Array.isArray(profile.personality_archetype) && profile.personality_archetype.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {profile.personality_archetype.map((a: string) => (
                    <span class="text-xs font-medium bg-sky-100 text-sky-700 px-2 py-1 rounded-full">{lbl("archetype", a)}</span>
                  ))}
                </div>
              )}

              <!-- Radar chart -->
              <PersonalityRadar ratings={personalityRatings} petName={pet.name} />

              <!-- Fears chips -->
              {Array.isArray(profile.fears) && profile.fears.length > 0 && (
                <div>
                  <p class="text-xs text-slate-500 mb-1">Sợ:</p>
                  <div class="flex flex-wrap gap-1.5">
                    {profile.fears.map((f: string) => (
                      <span class="text-xs font-medium bg-red-50 text-red-700 px-2 py-1 rounded-full">⚠️ {lbl("fears", f)}</span>
                    ))}
                  </div>
                </div>
              )}

              {profile.favorite_toys && (
                <p class="text-sm"><span class="text-xs text-slate-500">Đồ chơi yêu thích:</span> {profile.favorite_toys}</p>
              )}

              <span class="inline-block text-[10px] italic text-slate-400">Sửa qua API</span>
            </div>
          </div>

          {/* SECTION 7: LIFESTYLE */}
          <div class="bg-white border border-slate-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('lifestyle') ? openSections.delete('lifestyle') : openSections.add('lifestyle'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-slate-50 transition">
              <span class="accordion-icon"><FeatureIcon name="home" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Lối sống</span>
              <span class="text-xs text-slate-400">{completion?.sections?.lifestyle?.pct ?? 0}%</span>
              {completion?.sections?.lifestyle?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('lifestyle') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('lifestyle')" x-collapse class="px-4 pb-4 border-t border-slate-50 pt-3">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div><dt class="text-slate-500 text-xs">Nơi ngủ</dt><dd class="font-medium">{lbl("sleep_location", profile.sleep_location)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Vệ sinh</dt><dd class="font-medium">{lbl("bathroom_location", profile.bathroom_location)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Đi dạo</dt><dd class="font-medium">{lbl("walk_frequency", profile.walk_frequency)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Tắm</dt><dd class="font-medium">{lbl("bath_frequency", profile.bath_frequency)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Giờ ăn cố định</dt><dd class="font-medium">{fmtBool(profile.has_fixed_meal_schedule)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Đi du lịch cùng chủ</dt><dd class="font-medium">{fmtBool(profile.travels_with_owner)}</dd></div>
              </dl>
              {profile.caregiver_when_away && (
                <p class="mt-2 text-sm"><span class="text-xs text-slate-500">Người chăm khi vắng:</span> {profile.caregiver_when_away}</p>
              )}
              <span class="inline-block mt-3 text-[10px] italic text-slate-400">Click section header để collapse · Sửa qua API</span>
            </div>
          </div>

          {/* SECTION 8: EMERGENCY */}
          <div class="bg-white border border-amber-100 rounded-xl overflow-hidden">
            <button type="button" @click="openSections.has('emergency') ? openSections.delete('emergency') : openSections.add('emergency'); openSections = new Set(openSections)"
              class="w-full flex items-center gap-3 px-4 py-3 hover:bg-amber-50 transition">
              <span class="accordion-icon"><FeatureIcon name="siren" class="w-4 h-4" /></span>
              <span class="flex-1 text-left font-medium text-slate-900">Liên hệ khẩn cấp</span>
              <span class="text-xs text-slate-400">{completion?.sections?.emergency?.pct ?? 0}%</span>
              {completion?.sections?.emergency?.complete && <span class="text-green-500 text-xs">✓</span>}
              <span class="text-slate-400" :class="openSections.has('emergency') ? 'rotate-180' : ''">▾</span>
            </button>
            <div x-show="openSections.has('emergency')" x-collapse class="px-4 pb-4 border-t border-amber-50 pt-3 bg-amber-50/30">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div><dt class="text-slate-500 text-xs">Bác sĩ thú y</dt><dd class="font-medium">{fmt(profile.primary_vet_name)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Clinic</dt><dd class="font-medium">{fmt(profile.primary_clinic_name)}</dd></div>
                <div><dt class="text-slate-500 text-xs">SĐT vet</dt><dd class="font-medium font-mono">{fmt(profile.primary_vet_phone)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Liên hệ khẩn cấp</dt><dd class="font-medium">{fmt(profile.emergency_contact_name)} {profile.emergency_contact_relation ? `(${profile.emergency_contact_relation})` : ""}</dd></div>
                <div><dt class="text-slate-500 text-xs">SĐT khẩn cấp</dt><dd class="font-medium font-mono">{fmt(profile.emergency_contact_phone)}</dd></div>
                <div><dt class="text-slate-500 text-xs">Bảo hiểm</dt><dd class="font-medium">{fmt(profile.insurance_provider)}</dd></div>
              </dl>
              {profile.special_notes_for_vet && (
                <div class="mt-3 bg-amber-100 border border-amber-200 rounded-lg p-3">
                  <p class="text-xs font-semibold text-amber-900 mb-1">⚠️ Lưu ý đặc biệt cho bác sĩ:</p>
                  <p class="text-sm text-amber-900">{profile.special_notes_for_vet}</p>
                </div>
              )}
              <span class="inline-block mt-3 text-[10px] italic text-slate-400">Click section header để collapse · Sửa qua API</span>
            </div>
          </div>

        </div>
      </div>

      <!-- Tabs section -->
      <div data-page-tab="health" class="mt-8 bg-white rounded-2xl shadow-md border border-slate-100"
        x-effect="activeTab === 'care' && !care.loaded && initCareTab()"
        x-effect.once="false"
        x-init="$watch('activeTab', v => { if (v === 'climate' && !climate.loaded) initClimateTab(); if (v === 'vaccine' && !vaccine.loaded) initVaccineTab(); if (v === 'nutrition' && !nutrition.loaded) initNutritionTab(); })">
        <div class="flex border-b border-slate-100">
          <template x-for="t in tabs" :key="t.key">
            <button
              @click="activeTab = t.key"
              :class="activeTab === t.key ? 'border-sky-500 text-sky-700' : 'border-transparent text-slate-500 hover:text-slate-700'"
              class="px-4 sm:px-6 py-3 text-sm font-medium border-b-2 transition"
              x-text="t.label"
            ></button>
          </template>
        </div>

        <!-- NUTRITION TAB (M7) -->
        <template x-if="activeTab === 'nutrition'">
          <div class="p-4 sm:p-6 space-y-5">

            <!-- Loading state -->
            <template x-if="nutrition.loading.calorie || nutrition.loading.plan">
              <div class="bg-white rounded-2xl border border-slate-100 p-6 text-center">
                <div class="inline-block w-6 h-6 border-2 border-sky-300 border-t-sky-600 rounded-full animate-spin mb-2"></div>
                <p class="text-sm text-slate-500">Đang tính dinh dưỡng…</p>
              </div>
            </template>

            <!-- No weight warning -->
            <template x-if="!nutrition.loading.calorie && nutrition.noWeight">
              <div class="bg-amber-50 border-2 border-amber-200 rounded-2xl p-6">
                <div class="flex items-start gap-3">
                  <FeatureIcon name="scale" class="w-8 h-8 text-amber-600 shrink-0" />
                  <div class="flex-1">
                    <p class="font-semibold text-slate-900 mb-1">Cần cân nặng để tính dinh dưỡng</p>
                    <p class="text-sm text-slate-700 mb-3">Hãy log cân nặng cho bé để tính calorie target và meal plan.</p>
                    <button @click="nutrition.showLogForm = true" class="bg-sky-600 hover:bg-sky-700 text-white text-sm font-semibold px-4 py-2 rounded-lg">
                      <span class="inline-flex items-center gap-1.5"><FeatureIcon name="scale" class="w-4 h-4" />Log cân nặng ngay</span>
                    </button>
                  </div>
                </div>
              </div>
            </template>

            <!-- SECTION 1: CALORIE SUMMARY -->
            <template x-if="!nutrition.loading.calorie && nutrition.calorie">
              <section class="bg-mmp-cream rounded-2xl border border-mmp-ink/12 p-5">
                <div class="flex items-start justify-between gap-3 mb-3">
                  <div>
                    <h3 class="text-sm font-semibold text-slate-700 mb-1 flex items-center gap-1.5"><FeatureIcon name="target" class="w-4 h-4" />Bé cần mỗi ngày</h3>
                    <!-- Mức nền: số ổn định để cân đong (der_raw × bcs_adjust — GIỮ BCS/phản hồi cân, chưa thời tiết) -->
                    <div class="flex items-baseline gap-2">
                      <span class="text-4xl font-bold text-sky-700" x-text="Math.round(nutrition.calorie.breakdown.der_raw * nutrition.calorie.breakdown.bcs_adjust)"></span>
                      <span class="text-lg text-slate-600 font-medium">kcal/ngày · mức nền</span>
                    </div>
                    <!-- Hôm nay: sinh lý ngày (der_final) — chỉ hiện khi khác nền -->
                    <p class="text-xs text-slate-600 mt-1" x-show="nutrition.calorie.breakdown.der_final !== nutrition.calorie.breakdown.der_raw">
                      Hôm nay cơ thể bé cần ~<span class="font-semibold" x-text="nutrition.calorie.breakdown.der_final"></span> kcal
                    </p>
                    <!-- Chênh lệch thời tiết (chỉ chữ, không phải số bắt cân theo) -->
                    <p class="text-xs text-amber-700 mt-1" x-show="nutrition.calorie.breakdown.weather_adjust !== 1">
                      Hôm nay trời <span x-text="nutrition.calorie.breakdown.weather_adjust < 1 ? 'nóng' : 'lạnh'"></span>, cơ thể bé cần ~<span class="font-semibold" x-text="Math.round(Math.abs(1 - nutrition.calorie.breakdown.weather_adjust) * 100)"></span>% <span x-text="nutrition.calorie.breakdown.weather_adjust < 1 ? 'ít' : 'nhiều'"></span> hơn.
                    </p>
                    <!-- Gợi ý nước khi nóng — KHÔNG đổi số nước -->
                    <p class="text-xs text-sky-700 mt-1 flex items-center gap-1" x-show="nutrition.calorie.breakdown.weather_adjust < 1">
                      <FeatureIcon name="droplet" class="w-3.5 h-3.5" /> Trời nóng, để ý bé uống đủ nước.
                    </p>
                    <!-- ageingNote (cluster-1) senior/geriatric -->
                    <p class="text-xs text-amber-700 mt-1" x-show="nutrition.calorie.breakdown.ageingNote" x-text="nutrition.calorie.breakdown.ageingNote"></p>
                    <!-- Nhãn trung thực -->
                    <p class="text-[11px] text-slate-400 mt-1">Điểm khởi đầu — theo dõi cân, app sẽ nhắc điều chỉnh.</p>
                  </div>
                  <button @click="invalidateAndReload()" class="text-xs text-slate-500 hover:text-sky-600" title="Tính lại" aria-label="Tính lại"><FeatureIcon name="refresh" class="w-4 h-4" /></button>
                </div>
                <!-- Breakdown chips -->
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <span class="text-xs bg-white border border-slate-200 px-2 py-1 rounded-full">
                    RER: <span class="font-semibold" x-text="nutrition.calorie.breakdown.rer"></span> kcal
                  </span>
                  <span class="text-xs bg-white border border-slate-200 px-2 py-1 rounded-full">
                    Vận động ×<span class="font-semibold" x-text="nutrition.calorie.breakdown.base_multiplier.toFixed(2)"></span>
                  </span>
                  <template x-if="nutrition.calorie.breakdown.life_stage_modifier !== 1">
                    <span class="text-xs bg-white border border-slate-200 px-2 py-1 rounded-full">
                      Độ tuổi ×<span class="font-semibold" x-text="nutrition.calorie.breakdown.life_stage_modifier.toFixed(2)"></span>
                    </span>
                  </template>
                  <template x-if="nutrition.calorie.breakdown.weather_adjust !== 1">
                    <span class="text-xs bg-amber-50 border border-amber-200 text-amber-700 px-2 py-1 rounded-full">
                      Thời tiết ×<span class="font-semibold" x-text="nutrition.calorie.breakdown.weather_adjust.toFixed(2)"></span>
                    </span>
                  </template>
                  <template x-if="nutrition.calorie.breakdown.bcs_adjust !== 1">
                    <span class="text-xs bg-amber-50 border border-amber-200 text-amber-700 px-2 py-1 rounded-full">
                      BCS ×<span class="font-semibold" x-text="nutrition.calorie.breakdown.bcs_adjust.toFixed(2)"></span>
                    </span>
                  </template>
                </div>
                <p class="text-xs text-slate-500 mt-3" x-show="nutrition.calorie.weather">
                  Cảm giác <span x-text="nutrition.calorie.weather?.feels_like"></span>°C · AQI <span x-text="nutrition.calorie.weather?.aqi"></span> · <span x-text="nutrition.calorie.weather?.city"></span>
                </p>
                <p class="text-xs text-slate-400 mt-1">
                  Giai đoạn: <span class="font-medium" x-text="lifeStageLabel(nutrition.calorie.breakdown.life_stage)"></span>
                  · Vận động: <span class="font-medium" x-text="activityLevelLabel(nutrition.calorie.breakdown.activity_level)"></span>
                </p>
              </section>
            </template>

            <!-- SECTION: SCAN NHÃN THỨC ĂN (C pha 2) — widget Alpine tự chứa, monochrome gold/ink -->
            <section id="food-scan" x-data={`foodScanWidget(${petId})`} class="bg-white rounded-2xl border border-mmp-ink/12 p-5">
              <div class="mb-2">
                <h3 class="text-sm font-semibold text-mmp-ink flex items-center gap-1.5"><FeatureIcon name="camera" class="w-4 h-4" />Scan nhãn thức ăn</h3>
                <p class="text-xs text-mmp-ink/60 mt-0.5">Chụp bảng Guaranteed Analysis trên bao bì — AI của VowVet đọc số dinh dưỡng & dò trong thư viện.</p>
              </div>

              <input type="file" accept="image/jpeg,image/png,image/webp" capture="environment" @change="onPick($event)" class="hidden" :id="inputId" aria-label="Chụp hoặc chọn ảnh nhãn thức ăn" />
              <label :for="inputId"
                class="block border-2 border-dashed border-mmp-ink/20 rounded-xl p-4 text-center cursor-pointer transition hover:border-mmp-gold"
                :class="preview ? 'bg-mmp-cream border-mmp-gold' : ''">
                <template x-if="!preview">
                  <div>
                    <p class="flex justify-center text-mmp-ink/40"><FeatureIcon name="camera" class="w-7 h-7" /></p>
                    <p class="text-xs text-mmp-ink/70 mt-1">Tap để chụp / chọn ảnh nhãn</p>
                  </div>
                </template>
                <template x-if="preview">
                  <img :src="preview" alt="Xem trước nhãn" class="max-h-40 mx-auto rounded-lg" />
                </template>
              </label>

              <template x-if="error">
                <p class="text-xs text-mmp-ink bg-mmp-cream border border-mmp-ink/12 rounded-lg p-2 mt-3" x-text="error" aria-live="polite"></p>
              </template>

              <button @click="submit()" :disabled="!file || scanning"
                class="w-full bg-mmp-ink hover:opacity-90 disabled:opacity-40 text-white font-bold py-3 rounded-xl text-sm shadow-sm mt-3"
                aria-label="Phân tích nhãn bằng AI của VowVet">
                <span x-show="!scanning" class="inline-flex items-center justify-center gap-1.5"><FeatureIcon name="wand" class="w-4 h-4" />Phân tích nhãn</span>
                <span x-show="scanning">AI của VowVet đang phân tích nhãn…</span>
              </button>

              <!-- KẾT QUẢ — 1 card verdict duy nhất (server trả category/verdict/cta). KHÔNG tính FE. -->
              <template x-if="result">
                <div class="mt-4 space-y-3">
                  <template x-if="result.scan_url">
                    <img :src="result.scan_url" alt="Ảnh nhãn đã quét" class="w-full max-h-48 object-contain rounded-xl border border-mmp-ink/12 bg-slate-50" />
                  </template>

                  <!-- FAIL: không đọc được nhãn (gộp 1 state, không vừa-báo-fail-vừa-báo-có-số) -->
                  <template x-if="failState">
                    <p class="text-xs text-mmp-ink/70 bg-slate-50 border border-mmp-ink/12 rounded-lg p-3">AI của VowVet chưa đọc được nhãn — chụp lại bảng Guaranteed Analysis, đủ sáng, không loá.</p>
                  </template>

                  <!-- VERDICT: 1 card -->
                  <template x-if="!failState && verdict">
                    <div class="bg-white rounded-xl border border-mmp-ink/12 p-4 space-y-3">
                      <div>
                        <div class="flex items-center gap-1.5 flex-wrap mb-1">
                          <span class="text-[11px] uppercase tracking-wide text-mmp-ink/50 inline-flex items-center gap-1"><FeatureIcon name="ai" class="w-3.5 h-3.5" />AI của VowVet</span>
                          <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full border border-mmp-ink/15 bg-slate-50 text-mmp-ink" x-text="verdict.category.label"></span>
                        </div>
                        <p class="text-sm font-semibold text-mmp-ink leading-snug" x-text="verdict.headline"></p>
                      </div>

                      <!-- Hỏi bác sĩ (dạng chữ, nổi lên đầu khi có cờ) -->
                      <template x-for="(note, i) in vetNotes" :key="i">
                        <p class="text-xs text-mmp-ink bg-amber-50 border border-amber-200 rounded-lg p-2.5 flex items-start gap-1.5">
                          <FeatureIcon name="alert-triangle" class="w-4 h-4 shrink-0 mt-0.5" /><span x-text="note.label"></span>
                        </p>
                      </template>

                      <ul class="space-y-1.5">
                        <template x-for="(ln, i) in verdict.lines" :key="i">
                          <li class="text-sm text-mmp-ink/80 leading-snug flex items-start gap-1.5">
                            <span class="w-1 h-1 rounded-full bg-mmp-ink/30 shrink-0 mt-2"></span><span x-text="ln"></span>
                          </li>
                        </template>
                      </ul>

                      <!-- Chi tiết số từ nhãn (gập) — số nhãn nằm mục phụ, không phải bảng chính -->
                      <template x-if="gaRows.length || (result.match && result.match.matched)">
                        <details>
                          <summary class="text-[11px] uppercase tracking-wide text-mmp-ink/50 cursor-pointer select-none">Chi tiết số từ nhãn</summary>
                          <div class="mt-2 space-y-2">
                            <template x-if="gaRows.length">
                              <div class="flex flex-wrap gap-1.5">
                                <template x-for="row in gaRows" :key="row.k">
                                  <span class="text-xs bg-slate-50 border border-mmp-ink/12 px-2 py-1 rounded-full text-mmp-ink"><span x-text="row.k"></span>: <span class="font-semibold" x-text="row.v"></span></span>
                                </template>
                              </div>
                            </template>
                            <template x-if="result?.carb_pct != null">
                              <p class="text-xs text-mmp-ink">Tinh bột ~<span class="font-semibold" x-text="result.carb_pct"></span>% <span class="text-mmp-ink/50">(ước tính từ nhãn<span x-show="result?.ash_estimated">, khoáng ước tính</span>)</span></p>
                            </template>
                            <template x-if="result.match && result.match.matched">
                              <div class="bg-slate-50 rounded-lg border border-mmp-ink/12 p-2.5">
                                <div class="flex items-center justify-between gap-2 mb-1.5">
                                  <p class="text-xs font-semibold text-mmp-ink" x-text="result.match.brand.brand_name"></p>
                                  <span class="text-[11px] text-mmp-ink/60">Khớp thư viện <span class="font-semibold" x-text="confPct"></span>%</span>
                                </div>
                                <div class="flex flex-wrap gap-1.5">
                                  <template x-for="row in brandRows" :key="row.k">
                                    <span class="text-xs bg-white border border-mmp-ink/12 px-2 py-1 rounded-full text-mmp-ink"><span x-text="row.k"></span>: <span class="font-semibold" x-text="row.v"></span></span>
                                  </template>
                                </div>
                              </div>
                            </template>
                          </div>
                        </details>
                      </template>

                      <!-- CTA theo loại + verdict -->
                      <div class="flex flex-wrap gap-2 pt-1">
                        <template x-for="(c, i) in actionCtas" :key="i">
                          <button type="button" @click="runCta(c)"
                            class="text-sm font-semibold px-3 py-2 rounded-xl transition"
                            :class="c.primary ? 'bg-mmp-ink text-white hover:opacity-90' : 'bg-slate-50 text-mmp-ink border border-mmp-ink/15 hover:border-mmp-ink/30'"
                            x-text="c.label"></button>
                        </template>
                      </div>
                    </div>
                  </template>
                </div>
              </template>

              <p class="text-[11px] text-mmp-ink/40 text-center italic mt-3"><FeatureIcon name="ai" class="w-3 h-3 inline-block align-text-bottom mr-1" />AI của VowVet phân tích — tham khảo, không thay thế bác sĩ thú y.</p>
            </section>

            <!-- SECTION 2: MEAL PLAN -->
            <template x-if="!nutrition.loading.plan && nutrition.plan">
              <section class="bg-white rounded-2xl border border-slate-100 p-5">
                <div class="flex items-start justify-between gap-2 mb-3 flex-wrap">
                  <h3 class="text-sm font-semibold text-slate-700 flex items-center gap-1.5"><FeatureIcon name="utensils" class="w-4 h-4" />Kế hoạch bữa ăn</h3>
                  <div class="flex items-center gap-2">
                    <label class="text-xs text-slate-500">Bữa/ngày:</label>
                    <select x-model.number="nutrition.mealsPerDay" @change="reloadPlan()"
                      class="text-xs border border-slate-200 rounded px-2 py-1 bg-white">
                      <option :value="1">1</option>
                      <option :value="2">2</option>
                      <option :value="3">3</option>
                      <option :value="4">4</option>
                    </select>
                  </div>
                </div>
                <!-- Suggested brand -->
                <template x-if="nutrition.plan.suggested_brand">
                  <div class="mb-3 bg-emerald-50 border border-emerald-200 rounded-lg p-3 flex items-center gap-2">
                    <span class="completion-badge completion-badge--gold"><FeatureIcon name="trophy" class="w-3.5 h-3.5" /></span>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs text-slate-500">Loại hạt đang tính</p>
                      <p class="text-sm font-semibold text-slate-900 truncate" x-text="nutrition.plan.suggested_brand.brand_name"></p>
                      <p class="text-xs text-slate-500">
                        <span x-text="nutrition.plan.suggested_brand.calories_per_100g"></span> kcal/100g
                        <template x-if="nutrition.plan.suggested_brand.mon_min_recommended">
                          <span class="ml-2 bg-emerald-200 text-emerald-800 px-1.5 py-0.5 rounded font-semibold text-[10px]">MON MIN</span>
                        </template>
                      </p>
                    </div>
                    <button @click="nutrition.showBrandPicker = true" class="text-xs text-sky-600 hover:text-sky-700 font-medium shrink-0">Đổi →</button>
                  </div>
                </template>
                <template x-if="!nutrition.plan.suggested_brand">
                  <div class="mb-3 bg-slate-50 border border-slate-200 rounded-lg p-3 text-xs text-slate-500">
                    Chưa chọn loại hạt → hiện theo kcal. <button @click="nutrition.showBrandPicker = true" class="text-sky-600 hover:underline">Chọn loại hạt</button> để ra gram.
                  </div>
                </template>
                <!-- Meals list -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2">
                  <template x-for="meal in nutrition.plan.plan.meals" :key="meal.time">
                    <div class="bg-slate-50 border border-slate-100 rounded-xl p-3">
                      <div class="flex items-center justify-between mb-1">
                        <span class="inline-flex" x-html="mealIcon(meal.type)"></span>
                        <span class="text-xs text-slate-500 font-mono" x-text="meal.time"></span>
                      </div>
                      <p class="text-xs text-slate-500 capitalize" x-text="mealTypeLabel(meal.type)"></p>
                      <p class="text-lg font-bold text-slate-900"><span x-text="meal.calories"></span> <span class="text-xs font-normal text-slate-500">kcal</span></p>
                      <p class="text-xs text-emerald-700 font-medium" x-show="meal.grams > 0">
                        ≈ <span x-text="(nutrition.plan.plan.breakdown && nutrition.plan.plan.breakdown.der_final) ? Math.round(meal.grams * nutrition.plan.plan.breakdown.der_raw * nutrition.plan.plan.breakdown.bcs_adjust / nutrition.plan.plan.breakdown.der_final) : meal.grams"></span> g
                        <span class="text-slate-400 font-normal">(cân đong nền)</span>
                      </p>
                    </div>
                  </template>
                </div>
                <!-- Treats + water -->
                <div class="mt-3 grid grid-cols-2 gap-2 text-xs">
                  <div class="bg-amber-50 border border-orange-100 rounded-lg p-2 text-center">
                    <p class="text-slate-500 flex items-center justify-center gap-1"><FeatureIcon name="cookie" class="w-3.5 h-3.5" />Đồ thưởng</p>
                    <p class="font-semibold text-amber-700"><span x-text="(nutrition.plan.plan.breakdown && nutrition.plan.plan.breakdown.der_final) ? Math.round(nutrition.plan.plan.treat_budget_kcal * nutrition.plan.plan.breakdown.der_raw * nutrition.plan.plan.breakdown.bcs_adjust / nutrition.plan.plan.breakdown.der_final) : nutrition.plan.plan.treat_budget_kcal"></span> kcal/ngày</p>
                  </div>
                  <div class="bg-sky-50 border border-sky-100 rounded-lg p-2 text-center">
                    <p class="text-slate-500 flex items-center justify-center gap-1"><FeatureIcon name="droplet" class="w-3.5 h-3.5" />Nước uống</p>
                    <p class="font-semibold text-sky-700"><span x-text="nutrition.plan.plan.water_target_ml"></span> ml/ngày</p>
                  </div>
                </div>
                <!-- Warnings từ engine -->
                <template x-if="nutrition.plan.plan.warnings && nutrition.plan.plan.warnings.length > 0">
                  <div class="mt-3 space-y-1">
                    <template x-for="(w, i) in nutrition.plan.plan.warnings" :key="i">
                      <p class="text-xs px-3 py-2 rounded-lg"
                         :class="w.severity === 'warning' ? 'bg-amber-50 border border-amber-200 text-amber-800' : 'bg-sky-50 border border-sky-200 text-sky-700'">
                        <span x-text="w.message"></span>
                      </p>
                    </template>
                  </div>
                </template>
              </section>
            </template>

            <!-- SECTION 3: BRAND RECOMMENDATIONS -->
            <template x-if="!nutrition.loading.brands && nutrition.brands.length > 0">
              <section class="bg-white rounded-2xl border border-slate-100 p-5">
                <h3 class="text-sm font-semibold text-slate-700 mb-3 inline-flex items-center gap-2">
                  <span class="completion-badge completion-badge--gold"><FeatureIcon name="trophy" class="w-3.5 h-3.5" /></span>
                  <span>Top brand phù hợp với bé</span>
                </h3>
                <p class="text-xs text-slate-500 mb-3">Đã lọc theo loài, life stage, và không chứa allergen bé bị dị ứng.</p>
                <div class="space-y-2">
                  <template x-for="b in nutrition.brands.slice(0, 5)" :key="b.brand_id">
                    <div class="border border-slate-100 rounded-xl p-3 hover:border-sky-200 hover:bg-sky-50/30 transition">
                      <div class="flex items-start justify-between gap-2 mb-1">
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-1.5 flex-wrap">
                            <span class="font-semibold text-slate-900 text-sm" x-text="b.brand_name"></span>
                            <template x-if="b.mon_min_recommended">
                              <span class="bg-emerald-200 text-emerald-800 px-1.5 py-0.5 rounded font-semibold text-[10px]">MON MIN</span>
                            </template>
                          </div>
                          <p class="text-xs text-slate-500" x-text="b.product_line"></p>
                        </div>
                        <button @click="setBrandForPlan(b.brand_id)" class="text-xs bg-sky-100 hover:bg-sky-200 text-sky-700 px-2 py-1 rounded font-medium shrink-0">
                          Chọn
                        </button>
                      </div>
                      <div class="flex flex-wrap gap-1 text-[10px] text-slate-500 mt-1">
                        <span class="bg-slate-100 px-1.5 py-0.5 rounded">Protein <span x-text="b.protein_pct"></span>%</span>
                        <span class="bg-slate-100 px-1.5 py-0.5 rounded">Fat <span x-text="b.fat_pct"></span>%</span>
                        <span class="bg-slate-100 px-1.5 py-0.5 rounded"><span x-text="b.calories_per_100g"></span> kcal/100g</span>
                        <span class="bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded" x-show="b.price_vnd_per_kg">
                          <span x-text="formatVnd(b.price_vnd_per_kg)"></span>/kg
                        </span>
                      </div>
                    </div>
                  </template>
                </div>
                <p class="text-xs text-slate-400 mt-3" x-show="nutrition.brands.length > 5">
                  +<span x-text="nutrition.brands.length - 5"></span> brand khác đã được lọc
                </p>
              </section>
            </template>

            <!-- ===== Phase 3: Bổ sung từ MonMin (PREMIUM spotlight — match bệnh CỦA PET NÀY) ===== -->
            <template x-if="hasAnySupp">
              <section class="rounded-2xl p-5 shadow-md border border-[#B48608]/25" style="background: linear-gradient(180deg, #FDFAF2 0%, #FAF6EC 100%);" aria-label="Bổ sung từ MonMin">
                <!-- Header -->
                <div class="flex items-start gap-2.5 mb-4">
                  <span class="shrink-0 mt-0.5 text-[#B48608]"><FeatureIcon name="sparkles" class="w-6 h-6" /></span>
                  <div>
                    <h3 class="font-display italic text-lg sm:text-xl font-bold text-mmp-ink leading-tight">Dinh dưỡng bổ sung từ MonMin</h3>
                    <p class="text-xs text-mmp-ink/60 mt-0.5">
                      <span x-show="isSuppMatched" x-cloak>Chọn riêng cho <span class="font-semibold text-mmp-ink/80" x-text="pet.name"></span> theo tình trạng sức khoẻ</span>
                      <span x-show="!isSuppMatched">Gợi ý từ MonMin</span>
                    </p>
                  </div>
                </div>

                <!-- HERO CARD (món match #1) -->
                <template x-if="heroSupp">
                  <div x-data="{ imgError: false }">
                    <article class="relative bg-white rounded-2xl overflow-hidden border border-mmp-gold/40 ring-1 ring-mmp-gold/40 shadow-sm">
                      <div class="grid sm:grid-cols-2">
                        <div class="aspect-[4/3] sm:aspect-auto sm:min-h-[176px] bg-slate-50 relative flex items-center justify-center">
                          <img x-show="heroSupp.image && !imgError" x-cloak :src="heroSupp.image" :alt="heroSupp.name" @error="imgError = true" class="absolute inset-0 w-full h-full object-cover" />
                          <span class="text-mmp-ink/25" x-show="!heroSupp.image || imgError"><FeatureIcon name="shop" class="w-12 h-12" /></span>
                          <span class="absolute top-2.5 left-2.5 bg-mmp-gold text-mmp-ink text-[10px] font-bold px-2 py-0.5 rounded-full ring-1 ring-mmp-gold/60 shadow-sm inline-flex items-center gap-1 max-w-[92%]">
                            <FeatureIcon name="check" class="w-3 h-3 shrink-0" /><span class="truncate" x-text="'Hợp với ' + suppMatchLabels(heroSupp)[0]"></span>
                          </span>
                        </div>
                        <div class="p-4 sm:p-5 flex flex-col gap-2">
                          <h4 class="font-display italic text-lg font-bold text-mmp-ink leading-tight" x-text="heroSupp.name"></h4>
                          <p class="text-xs text-mmp-ink/60 inline-flex items-start gap-1 leading-snug">
                            <span class="text-[#B48608] shrink-0 mt-0.5"><FeatureIcon name="sparkles" class="w-3 h-3" /></span><span x-text="'Hỗ trợ ' + suppFocus(heroSupp)"></span>
                          </p>
                          <p class="text-base font-bold text-mmp-ink tabular-nums mt-1" x-text="heroSupp.price ? formatVnd(heroSupp.price) : 'Liên hệ'"></p>
                          <a :href="heroSupp.url" target="_blank" rel="noopener noreferrer" class="mt-auto w-full inline-flex items-center justify-center gap-1.5 px-3 py-2.5 rounded-xl bg-mmp-ink text-white hover:bg-mmp-ink/90 text-sm font-semibold transition">
                            <FeatureIcon name="shop" class="w-4 h-4" /> Xem sản phẩm
                          </a>
                        </div>
                      </div>
                    </article>
                  </div>
                </template>

                <!-- GRID (rest khi matched · toàn bộ featured khi không match) -->
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3" :class="heroSupp ? 'mt-3' : 'mt-1'">
                  <template x-for="s in shownGrid" :key="s.slug">
                    <div class="relative" x-data="{ imgError: false }">
                      <article class="relative bg-white rounded-xl border overflow-hidden flex flex-col h-full transition"
                               :class="(s._hits && s._hits.length) ? 'border-mmp-gold/50 ring-1 ring-mmp-gold/30' : 'border-mmp-ink/12 hover:shadow-sm'">
                        <div class="aspect-square bg-slate-50 relative flex items-center justify-center">
                          <img x-show="s.image && !imgError" x-cloak :src="s.image" :alt="s.name" @error="imgError = true" class="absolute inset-0 w-full h-full object-cover" />
                          <span class="text-mmp-ink/25" x-show="!s.image || imgError"><FeatureIcon name="shop" class="w-8 h-8" /></span>
                          <template x-if="s._hits && s._hits.length">
                            <span class="absolute top-1.5 left-1.5 bg-mmp-gold text-mmp-ink text-[9px] font-bold px-1.5 py-0.5 rounded-full ring-1 ring-mmp-gold/60 inline-flex items-center gap-0.5 max-w-[92%]">
                              <FeatureIcon name="check" class="w-2.5 h-2.5 shrink-0" /><span class="truncate" x-text="suppMatchLabels(s)[0]"></span>
                            </span>
                          </template>
                        </div>
                        <div class="p-2.5 flex-1 flex flex-col gap-1">
                          <h4 class="text-xs font-semibold text-mmp-ink leading-snug line-clamp-2" x-text="s.name"></h4>
                          <p class="text-xs font-bold text-mmp-ink tabular-nums mt-auto" x-text="s.price ? formatVnd(s.price) : 'Liên hệ'"></p>
                          <a :href="s.url" target="_blank" rel="noopener noreferrer" class="mt-1 w-full inline-flex items-center justify-center gap-1 px-2 py-1.5 rounded-lg bg-mmp-ink text-white hover:bg-mmp-ink/90 text-[11px] font-semibold transition">
                            <FeatureIcon name="shop" class="w-3 h-3" /> Xem
                          </a>
                        </div>
                      </article>
                    </div>
                  </template>
                </div>

                <!-- Xem thêm (gập mặc định; KHÔNG x-transition trên grid để tránh kẹt rAF preview) -->
                <template x-if="hasMoreSupp">
                  <button type="button" @click="showAllSupp = !showAllSupp" :aria-expanded="showAllSupp"
                          class="mt-3 w-full inline-flex items-center justify-center gap-1.5 text-sm text-mmp-ink/70 hover:text-mmp-ink font-medium py-2 rounded-xl border border-[#B48608]/25 bg-white/50 hover:bg-white motion-safe:transition">
                    <span x-text="showAllSupp ? 'Thu gọn' : ('Xem thêm sản phẩm MonMin (' + (gridSupp.length - gridLimit) + ')')"></span>
                    <svg class="w-4 h-4 motion-safe:transition-transform" :class="showAllSupp ? 'rotate-180' : ''" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                  </button>
                </template>

                <p class="text-[10px] text-mmp-ink/50 italic mt-3 inline-flex items-start gap-1">
                  <FeatureIcon name="info" class="w-3 h-3 shrink-0 translate-y-0.5" />
                  <span>Sản phẩm bổ sung — mang tính tham khảo, hỏi bác sĩ thú y trước khi dùng.</span>
                </p>
              </section>
            </template>

            <!-- SECTION 4: ALLERGY ALERTS (chỉ hiển thị nếu có) -->
            <template x-if="nutrition.insights && (nutrition.insights.recommendations.length > 0)">
              <section class="bg-amber-50 border-2 border-amber-200 rounded-2xl p-4">
                <h3 class="text-sm font-semibold text-amber-900 mb-2 flex items-center gap-1.5"><FeatureIcon name="alert-triangle" class="w-4 h-4" />Cảnh báo dinh dưỡng</h3>
                <div class="space-y-1.5">
                  <template x-for="(r, i) in nutrition.insights.recommendations" :key="i">
                    <p class="text-sm px-3 py-2 rounded-lg"
                       :class="r.severity === 'critical' ? 'bg-red-100 text-red-900' : r.severity === 'warning' ? 'bg-amber-100 text-amber-900' : 'bg-sky-100 text-sky-800'"
                       x-text="r.message"></p>
                  </template>
                </div>
              </section>
            </template>

            <!-- SECTION 5: WEIGHT TRACKING -->
            <section class="bg-white rounded-2xl border border-slate-100 p-5">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-slate-700 flex items-center gap-1.5"><FeatureIcon name="scale" class="w-4 h-4" />Theo dõi cân nặng</h3>
                <button @click="nutrition.showLogForm = !nutrition.showLogForm" class="text-xs bg-sky-600 hover:bg-sky-700 text-white font-semibold px-3 py-1.5 rounded-lg">
                  <span x-show="!nutrition.showLogForm">+ Log cân nặng</span>
                  <span x-show="nutrition.showLogForm">Hủy</span>
                </button>
              </div>

              <!-- Lớp 2: banner nhắc cân (mềm, đóng được, KHÔNG chặn) -->
              <template x-if="weighReminder().show">
                <div class="mb-3 flex items-start gap-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2">
                  <FeatureIcon name="scale" class="w-4 h-4 text-amber-600 shrink-0 mt-0.5" />
                  <p class="text-xs text-amber-800 flex-1 leading-snug" x-text="weighReminder().message"></p>
                  <button @click="nutrition.showLogForm = true" class="text-xs font-semibold text-sky-700 hover:underline shrink-0">Cân ngay</button>
                  <button @click="nutrition.weighReminderDismissed = true" class="text-xs text-amber-500 hover:text-amber-700 shrink-0" aria-label="Bỏ qua">Bỏ qua</button>
                </div>
              </template>

              <!-- Insights summary -->
              <template x-if="nutrition.insights">
                <div class="grid grid-cols-3 gap-2 mb-3">
                  <div class="bg-slate-50 rounded-lg p-2 text-center">
                    <p class="text-[10px] text-slate-500 uppercase">Hiện tại</p>
                    <p class="font-bold text-slate-900">
                      <span x-text="nutrition.insights.current_weight_kg ?? '—'"></span>
                      <span class="text-xs font-normal" x-show="nutrition.insights.current_weight_kg">kg</span>
                    </p>
                  </div>
                  <div class="bg-emerald-50 rounded-lg p-2 text-center">
                    <p class="text-[10px] text-slate-500 uppercase">Mục tiêu</p>
                    <p class="font-bold text-emerald-700">
                      <span x-text="nutrition.insights.target_weight_kg ?? '—'"></span>
                      <span class="text-xs font-normal" x-show="nutrition.insights.target_weight_kg">kg</span>
                    </p>
                  </div>
                  <div class="bg-sky-50 rounded-lg p-2 text-center">
                    <p class="text-[10px] text-slate-500 uppercase">Xu hướng 30d</p>
                    <p class="font-bold" :class="trendColor(nutrition.insights.trend_30d.direction)">
                      <span x-text="trendIcon(nutrition.insights.trend_30d.direction)"></span>
                      <span x-show="nutrition.insights.trend_30d.delta_kg != null" x-text="(nutrition.insights.trend_30d.delta_kg > 0 ? '+' : '') + nutrition.insights.trend_30d.delta_kg + ' kg'"></span>
                      <span x-show="nutrition.insights.trend_30d.delta_kg == null" class="text-xs">Chưa đủ data</span>
                    </p>
                  </div>
                </div>
              </template>

              <!-- Lớp 2: nhãn trung thực khi chưa đủ mốc -->
              <template x-if="nutrition.insights && nutrition.insights.trend_30d.direction === 'insufficient_data'">
                <p class="text-[11px] text-slate-400 mb-3">Chưa đủ mốc cân để tính xu hướng.</p>
              </template>

              <!-- Lớp 2.1+2.2: nhắc theo xu hướng + đề xuất (app CHỈ đề xuất; người bấm mới đổi) -->
              <template x-if="nutrition.insights">
                <div class="mb-3 space-y-2" x-show="!nutrition.suggestDismissed">
                  <!-- Nhắc theo trend (tái dùng recommendations / trấn an) -->
                  <template x-if="weightNudge().show">
                    <div class="rounded-xl border px-3 py-2 text-xs leading-snug flex items-start gap-2"
                         :class="weightNudge().severity === 'critical' ? 'bg-red-50 border-red-200 text-red-800' : weightNudge().severity === 'warning' ? 'bg-amber-50 border-amber-200 text-amber-800' : 'bg-sky-50 border-sky-200 text-sky-800'">
                      <FeatureIcon name="info" class="w-3.5 h-3.5 shrink-0 mt-0.5" />
                      <div class="flex-1">
                        <p x-text="weightNudge().message"></p>
                        <p x-show="weightNudge().needVet" class="mt-0.5 font-medium">→ Nên hỏi bác sĩ thú y.</p>
                      </div>
                    </div>
                  </template>

                  <!-- Đề xuất -->
                  <template x-if="rationSuggestion().show">
                    <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2.5 text-xs">
                      <!-- concern → điều chỉnh khẩu phần -->
                      <template x-if="rationSuggestion().concern">
                        <div class="mb-2">
                          <p class="font-semibold text-slate-700 mb-1">Gợi ý điều chỉnh khẩu phần</p>
                          <template x-if="rationSuggestion().canLowerActivity">
                            <div class="flex items-start justify-between gap-2">
                              <p class="text-slate-600 flex-1">Hạ vận động: <b x-text="activityLevelLabel(rationSuggestion().activity)"></b> → <b x-text="activityLevelLabel(rationSuggestion().nextLower)"></b> — bé sẽ ăn ít hơn. <span class="text-slate-400">(số khẩu phần mới hiện sau khi áp dụng)</span></p>
                              <button @click="askApply('activity')" :disabled="nutrition.applying" class="shrink-0 text-xs font-semibold bg-sky-600 hover:bg-sky-700 text-white px-2.5 py-1 rounded-lg">Áp dụng</button>
                            </div>
                          </template>
                          <template x-if="!rationSuggestion().canLowerActivity">
                            <p class="text-slate-600">Vận động đã ở mức thấp nhất. Cân nhắc <b>giảm khẩu phần ~10%</b> và theo dõi 4 tuần — hỏi bác sĩ trước khi đổi chế độ.</p>
                          </template>
                        </div>
                      </template>

                      <!-- chưa có target → đặt mục tiêu (số CÂN cũ→mới, user nhập, default = cân hiện tại) -->
                      <template x-if="!rationSuggestion().hasTarget">
                        <div>
                          <p class="text-slate-600 mb-1.5">Chưa đặt <b>cân mục tiêu</b>. Đặt để app theo dõi đúng hướng + nhắc chính xác hơn.</p>
                          <template x-if="!nutrition.showTargetInput">
                            <button @click="startSetTarget()" class="text-xs font-semibold bg-emerald-600 hover:bg-emerald-700 text-white px-2.5 py-1 rounded-lg">Đặt cân mục tiêu</button>
                          </template>
                          <template x-if="nutrition.showTargetInput">
                            <div class="flex items-center gap-2 flex-wrap">
                              <span class="text-slate-500" x-text="(nutrition.insights.current_weight_kg ?? '—') + 'kg →'"></span>
                              <input type="number" step="0.1" min="0.5" max="100" x-model.number="nutrition.targetInput" class="w-20 px-2 py-1 border border-slate-200 rounded text-sm" />
                              <span class="text-slate-500">kg</span>
                              <button @click="askApply('target')" :disabled="nutrition.applying || !nutrition.targetInput" class="text-xs font-semibold bg-sky-600 hover:bg-sky-700 text-white px-2.5 py-1 rounded-lg">Áp dụng</button>
                              <button @click="nutrition.showTargetInput = false" class="text-xs text-slate-500">Hủy</button>
                            </div>
                          </template>
                        </div>
                      </template>

                      <!-- HỘP XÁC NHẬN — GUARD: PATCH chỉ chạy sau khi bấm Xác nhận -->
                      <template x-if="nutrition.pendingApply">
                        <div class="mt-2 rounded-lg border border-amber-300 bg-amber-50 px-2.5 py-2">
                          <p class="text-amber-900 mb-1.5" x-show="nutrition.pendingApply === 'target'">Đổi cân mục tiêu: <b x-text="(nutrition.insights.target_weight_kg ?? '—')"></b> → <b x-text="nutrition.targetInput + 'kg'"></b>?</p>
                          <p class="text-amber-900 mb-1.5" x-show="nutrition.pendingApply === 'activity'">Đổi vận động: <b x-text="activityLevelLabel(rationSuggestion().activity)"></b> → <b x-text="activityLevelLabel(rationSuggestion().nextLower)"></b>? Khẩu phần sẽ giảm.</p>
                          <div class="flex gap-2">
                            <button @click="confirmApply()" :disabled="nutrition.applying" class="text-xs font-bold bg-amber-600 hover:bg-amber-700 text-white px-3 py-1 rounded-lg">Xác nhận đổi</button>
                            <button @click="cancelApply()" class="text-xs text-amber-700">Hủy</button>
                          </div>
                        </div>
                      </template>

                      <!-- nhãn trung thực + bỏ qua -->
                      <div class="mt-2 flex items-start justify-between gap-2">
                        <p class="text-[10px] text-slate-400 leading-snug flex-1">Đề xuất theo xu hướng cân — bạn quyết định, app không tự đổi. Điểm khởi đầu, không thay tư vấn bác sĩ.</p>
                        <button @click="nutrition.suggestDismissed = true" class="text-[10px] text-slate-400 hover:text-slate-600 shrink-0">Bỏ qua</button>
                      </div>
                    </div>
                  </template>

                  <!-- feedback sau áp dụng (ngoài card để không biến mất khi card ẩn) -->
                  <p x-show="nutrition.applyMsg" x-text="nutrition.applyMsg" class="text-xs text-emerald-700 font-medium"></p>
                </div>
              </template>

              <!-- Log form -->
              <template x-if="nutrition.showLogForm">
                <div class="bg-slate-50 border border-slate-200 rounded-xl p-3 mb-3">
                  <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                    <div>
                      <label class="text-xs text-slate-600">Cân nặng (kg) *</label>
                      <input type="number" step="0.01" x-model.number="nutrition.logForm.weight_kg"
                        class="w-full px-2 py-1.5 border border-slate-200 rounded text-sm" placeholder="5.5" />
                    </div>
                    <div>
                      <label class="text-xs text-slate-600">BCS (1–9)</label>
                      <input type="number" min="1" max="9" step="1" x-model.number="nutrition.logForm.body_condition_score"
                        class="w-full px-2 py-1.5 border border-slate-200 rounded text-sm" placeholder="5" />
                    </div>
                    <div>
                      <label class="text-xs text-slate-600">Ghi chú</label>
                      <input type="text" x-model="nutrition.logForm.notes" maxlength="500"
                        class="w-full px-2 py-1.5 border border-slate-200 rounded text-sm" placeholder="(tùy chọn)" />
                    </div>
                  </div>
                  <div class="flex items-center justify-end gap-2 mt-2">
                    <p class="text-xs text-red-600 flex-1" x-show="nutrition.logError" x-text="nutrition.logError"></p>
                    <button @click="submitWeightLog()" :disabled="nutrition.logSubmitting"
                      class="text-xs bg-emerald-600 hover:bg-emerald-700 disabled:bg-slate-300 text-white font-semibold px-3 py-1.5 rounded">
                      <span x-show="!nutrition.logSubmitting">Lưu</span>
                      <span x-show="nutrition.logSubmitting">Đang lưu…</span>
                    </button>
                  </div>
                </div>
              </template>

              <!-- Recent logs table -->
              <template x-if="nutrition.insights && nutrition.insights.recent_logs.length > 0">
                <div class="overflow-x-auto">
                  <table class="w-full text-xs">
                    <thead class="bg-slate-50 text-slate-500">
                      <tr>
                        <th class="text-left px-2 py-1">Ngày</th>
                        <th class="text-right px-2 py-1">Cân (kg)</th>
                        <th class="text-right px-2 py-1">BCS</th>
                        <th class="text-left px-2 py-1">Ghi chú</th>
                      </tr>
                    </thead>
                    <tbody>
                      <template x-for="log in nutrition.insights.recent_logs" :key="log.id">
                        <tr class="border-b border-slate-100">
                          <td class="px-2 py-1.5 text-slate-600" x-text="formatLogDate(log.logged_at)"></td>
                          <td class="px-2 py-1.5 text-right font-medium" x-text="log.weight_kg.toFixed(2)"></td>
                          <td class="px-2 py-1.5 text-right" x-text="log.body_condition_score ?? '—'"></td>
                          <td class="px-2 py-1.5 text-slate-500 truncate max-w-[200px]" x-text="log.notes || '—'"></td>
                        </tr>
                      </template>
                    </tbody>
                  </table>
                </div>
              </template>
              <template x-if="nutrition.insights && nutrition.insights.recent_logs.length === 0">
                <p class="text-xs text-slate-400 text-center py-3">Chưa có log cân nặng. Log để theo dõi xu hướng theo thời gian.</p>
              </template>
            </section>

            <!-- SECTION 6: FORBIDDEN FOODS -->
            <template x-if="nutrition.forbidden && nutrition.forbidden.length > 0">
              <section class="bg-white rounded-2xl border border-slate-100 p-5">
                <h3 class="text-sm font-semibold text-slate-700 mb-1 flex items-center gap-1.5"><FeatureIcon name="ban" class="w-4 h-4 text-red-600" />Thực phẩm cấm</h3>
                <p class="text-xs text-slate-500 mb-3">Tham khảo nguồn ASPCA + WSAVA. <span class="text-red-600 font-semibold">ĐỎ = tuyệt đối không</span>, <span class="text-amber-700 font-semibold">vàng = hạn chế</span>.</p>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                  <template x-for="f in nutrition.forbidden" :key="f.id">
                    <div :class="f.level === 'critical' ? 'bg-red-50 border-red-200' : 'bg-amber-50 border-amber-200'"
                         class="border-2 rounded-lg p-2">
                      <p class="font-semibold text-sm" :class="f.level === 'critical' ? 'text-red-900' : 'text-amber-900'" x-text="f.name_vn"></p>
                      <p class="text-[10px] text-slate-600 mt-1" x-text="f.reason_vn"></p>
                    </div>
                  </template>
                </div>
              </section>
            </template>

            <!-- Brand picker modal -->
            <template x-if="nutrition.showBrandPicker">
              <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50 p-4" @click.self="nutrition.showBrandPicker = false">
                <div class="bg-white rounded-2xl max-w-md w-full max-h-[80vh] overflow-y-auto p-5">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-slate-900">Chọn brand cho meal plan</h3>
                    <button @click="nutrition.showBrandPicker = false" class="text-slate-400 hover:text-slate-700" aria-label="Đóng"><FeatureIcon name="close" class="w-5 h-5" /></button>
                  </div>
                  <div class="space-y-2">
                    <button @click="setBrandForPlan(null)" class="w-full text-left bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-lg p-3">
                      <p class="text-sm font-medium text-slate-700">Không chọn brand cụ thể</p>
                      <p class="text-xs text-slate-500">Hiển thị kcal/bữa, không có gram</p>
                    </button>
                    <template x-for="b in nutrition.brands" :key="b.brand_id">
                      <button @click="setBrandForPlan(b.brand_id)" class="w-full text-left bg-white hover:bg-sky-50 border border-slate-200 hover:border-sky-300 rounded-lg p-3">
                        <div class="flex items-center gap-1.5 flex-wrap">
                          <span class="font-medium text-sm text-slate-900" x-text="b.brand_name"></span>
                          <template x-if="b.mon_min_recommended">
                            <span class="bg-emerald-200 text-emerald-800 px-1.5 py-0.5 rounded font-semibold text-[10px]">MON MIN</span>
                          </template>
                        </div>
                        <p class="text-xs text-slate-500"><span x-text="b.calories_per_100g"></span> kcal/100g</p>
                      </button>
                    </template>
                  </div>
                </div>
              </div>
            </template>

          </div>
        </template>

        <!-- VACCINE TAB (M6) -->
        <template x-if="activeTab === 'vaccine'">
          <div class="p-4 sm:p-6 space-y-5 print:p-0">
            <!-- Summary -->
            <section class="bg-white rounded-2xl border border-slate-100 p-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
              <template x-if="vaccine.loading">
                <p class="col-span-4 text-sm text-slate-500">Đang tải lịch tiêm…</p>
              </template>
              <template x-if="!vaccine.loading && vaccine.summary">
                <div class="contents">
                  <div class="text-center"><p class="text-2xl font-bold text-green-700" x-text="vaccine.summary.completed"></p><p class="text-xs text-slate-500">Đã tiêm</p></div>
                  <div class="text-center"><p class="text-2xl font-bold text-yellow-600" x-text="vaccine.summary.due_soon"></p><p class="text-xs text-slate-500">Sắp tới (≤14d)</p></div>
                  <div class="text-center"><p class="text-2xl font-bold text-red-600" x-text="vaccine.summary.overdue"></p><p class="text-xs text-slate-500">Trễ hạn</p></div>
                  <div class="text-center"><p class="text-2xl font-bold text-slate-600" x-text="vaccine.summary.scheduled"></p><p class="text-xs text-slate-500">Đã lên lịch</p></div>
                </div>
              </template>
            </section>

            <!-- Timeline + List toggle -->
            <section x-show="!vaccine.loading && vaccine.calendar.length > 0">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-sm font-semibold text-slate-700">📅 Lịch tiêm 12 tháng</h3>
                <div class="flex gap-2 text-xs print:hidden">
                  <button @click="vaccine.viewMode = 'timeline'" :class="vaccine.viewMode === 'timeline' ? 'bg-sky-100 text-sky-700' : 'bg-slate-100 text-slate-600'" class="px-2 py-1 rounded">Timeline</button>
                  <button @click="vaccine.viewMode = 'list'" :class="vaccine.viewMode === 'list' ? 'bg-sky-100 text-sky-700' : 'bg-slate-100 text-slate-600'" class="px-2 py-1 rounded">Danh sách</button>
                </div>
              </div>

              <!-- Timeline SVG -->
              <template x-if="vaccine.viewMode === 'timeline'">
                <div class="bg-white rounded-xl border border-slate-100 p-3 overflow-x-auto">
                  <svg viewBox="0 0 720 160" style="min-width:700px;width:100%;height:160px" aria-label="Vaccine timeline 12 tháng">
                    <!-- 12 month grid -->
                    <template x-for="m in 12" :key="m">
                      <g>
                        <line :x1="50 + (m-1) * 55" y1="30" :x2="50 + (m-1) * 55" y2="120" stroke="#e2e8f0" stroke-width="0.5" />
                        <text :x="50 + (m-1) * 55 + 27" y="135" text-anchor="middle" style="font-size:10px;fill:#64748b" x-text="timelineMonthLabel(m-1)"></text>
                      </g>
                    </template>
                    <!-- Today marker -->
                    <line :x1="todayMarkerX" y1="25" :x2="todayMarkerX" y2="115" stroke="#0ea5e9" stroke-width="1.5" stroke-dasharray="3,3" />
                    <text :x="todayMarkerX" y="20" text-anchor="middle" style="font-size:9px;fill:#0284c7;font-weight:600">Hôm nay</text>
                    <!-- Vaccine dots -->
                    <template x-for="(v, i) in vaccine.calendar" :key="v.vaccine_row_id || i">
                      <g x-show="v.due_date || v.administered_date">
                        <circle
                          :cx="vaccineDotX(v.due_date || v.administered_date)"
                          :cy="55 + vaccineRowOffset(v.vaccine_code)"
                          r="7"
                          :fill="vaccineDotColor(v.status)"
                          :stroke="vaccineDotStrokeColor(v.status)"
                          stroke-width="1.5"
                          class="cursor-pointer"
                          @click="openVaccineModal(v)"
                        >
                          <title x-text="`${v.vaccine_name_vn} — ${v.status} — ${v.due_date || v.administered_date}`"></title>
                        </circle>
                      </g>
                    </template>
                  </svg>
                  <div class="mt-2 flex flex-wrap gap-3 text-xs text-slate-600">
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-500"></span> Đã tiêm</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-mmp-ink"></span> Sắp tới</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-yellow-500"></span> ≤14 ngày</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-600"></span> Trễ hạn</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-slate-300"></span> Đã bỏ qua</span>
                  </div>
                </div>
              </template>

              <!-- List view -->
              <template x-if="vaccine.viewMode === 'list'">
                <div class="space-y-3 print:space-y-1">
                  <template x-for="group in vaccineGroups" :key="group.key">
                    <div x-show="group.items.length > 0">
                      <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5 mt-2" x-text="group.label"></h4>
                      <div class="space-y-1.5">
                        <template x-for="v in group.items" :key="v.vaccine_row_id">
                          <article :class="vaccineCardClass(v.status)" class="rounded-xl border-2 p-3 flex items-start gap-3">
                            <span class="text-2xl shrink-0" x-text="vaccineStatusIcon(v.status)"></span>
                            <div class="flex-1 min-w-0">
                              <div class="flex items-start justify-between gap-2">
                                <h5 class="font-semibold text-slate-900 text-sm" x-text="v.vaccine_name_vn"></h5>
                                <span x-show="v.is_core" class="text-[10px] bg-red-100 text-red-700 px-1.5 py-0.5 rounded">Core</span>
                              </div>
                              <p class="text-xs text-slate-600 mt-0.5">
                                <span x-show="v.status === 'completed'" x-text="`Đã tiêm ${v.administered_date}`"></span>
                                <span x-show="v.status === 'scheduled'" x-text="`Đến hạn ${v.due_date} (còn ${v.days_to_due} ngày)`"></span>
                                <span x-show="v.status === 'overdue'" x-text="`⚠️ Trễ ${Math.abs(v.days_to_due)} ngày`"></span>
                                <span x-show="v.status === 'skipped'">Đã bỏ qua</span>
                                <template x-if="v.series_type"><span class="ml-1 text-slate-400" x-text="`(${seriesTypeLabel(v.series_type)})`"></span></template>
                              </p>
                              <div class="mt-2 flex gap-1.5 text-xs print:hidden">
                                <template x-if="v.status === 'scheduled' || v.status === 'overdue'">
                                  <button @click="openMarkCompletedModal(v)" class="bg-green-600 hover:bg-green-700 text-white px-2.5 py-1 rounded font-medium">✓ Đã tiêm</button>
                                </template>
                                <template x-if="v.status === 'scheduled' || v.status === 'overdue'">
                                  <button @click="openSkipModal(v)" class="bg-slate-100 hover:bg-slate-200 text-slate-600 px-2.5 py-1 rounded">Bỏ qua</button>
                                </template>
                                <button @click="openVaccineModal(v)" class="bg-white border border-slate-200 hover:bg-slate-50 text-slate-600 px-2.5 py-1 rounded">Chi tiết</button>
                              </div>
                            </div>
                          </article>
                        </template>
                      </div>
                    </div>
                  </template>
                </div>
              </template>
            </section>

            <template x-if="!vaccine.loading && vaccine.calendar.length === 0">
              <div class="bg-white rounded-2xl border border-slate-100 p-8 text-center">
                <p class="text-3xl mb-2">💉</p>
                <p class="text-sm text-slate-500">Chưa có vaccine nào được lên lịch.</p>
              </div>
            </template>

            <!-- Add custom vaccine -->
            <section class="bg-slate-50 rounded-2xl p-4 print:hidden">
              <button @click="openCustomVaccineModal()" class="text-sm bg-white border border-sky-200 hover:bg-sky-50 text-sky-700 font-medium px-4 py-2 rounded-lg">
                + Thêm vaccine không có trong danh sách
              </button>
            </section>

            <!-- Print button -->
            <div class="text-center text-xs text-slate-400 print:hidden">
              <button @click="window.print()" class="text-sky-600 hover:text-sky-700 underline">🖨️ In lịch tiêm</button>
            </div>

            <!-- Modal -->
            <div x-show="vaccine.modal.kind" x-transition.opacity class="fixed inset-0 z-50 flex items-center justify-center px-4 bg-slate-900/50" style="display:none">
              <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6 space-y-4" @click.outside="closeVaccineModal()">

                <!-- Mark Completed -->
                <template x-if="vaccine.modal.kind === 'mark-completed'">
                  <div>
                    <h3 class="text-lg font-semibold text-slate-900">Đánh dấu đã tiêm</h3>
                    <p class="text-sm text-slate-500 mt-1" x-text="vaccine.modal.vaccine?.vaccine_name_vn"></p>
                    <div class="mt-3 space-y-2">
                      <div><label class="text-xs text-slate-600">Ngày tiêm *</label><input type="date" x-model="vaccine.modal.form.administered_date" :max="todayIso" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Brand</label><input type="text" x-model="vaccine.modal.form.brand" placeholder="VD: Nobivac" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Phòng khám</label><input type="text" x-model="vaccine.modal.form.clinic_name" placeholder="Mon Min Clinic" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Số lô</label><input type="text" x-model="vaccine.modal.form.batch_number" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Ghi chú</label><textarea x-model="vaccine.modal.form.notes" rows="2" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200"></textarea></div>
                    </div>
                    <p x-show="vaccine.modal.error" class="text-sm text-red-600" x-text="vaccine.modal.error"></p>
                    <div class="flex gap-2 pt-2">
                      <button @click="closeVaccineModal()" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Huỷ</button>
                      <button @click="submitMarkCompleted()" :disabled="vaccine.modal.loading || !vaccine.modal.form.administered_date" class="flex-1 bg-green-600 hover:bg-green-700 disabled:bg-slate-300 text-white font-semibold py-2 rounded-lg">
                        <span x-show="!vaccine.modal.loading">✓ Lưu</span><span x-show="vaccine.modal.loading">Đang lưu…</span>
                      </button>
                    </div>
                  </div>
                </template>

                <!-- Skip -->
                <template x-if="vaccine.modal.kind === 'skip'">
                  <div>
                    <h3 class="text-lg font-semibold text-slate-900">Bỏ qua</h3>
                    <p class="text-sm text-slate-500 mt-1" x-text="vaccine.modal.vaccine?.vaccine_name_vn"></p>
                    <div class="mt-3"><label class="text-xs text-slate-600">Lý do</label><textarea x-model="vaccine.modal.form.reason" rows="2" placeholder="VD: Vet recommends defer, indoor cat..." class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200"></textarea></div>
                    <div class="flex gap-2 pt-3">
                      <button @click="closeVaccineModal()" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Huỷ</button>
                      <button @click="submitSkip()" :disabled="vaccine.modal.loading || !vaccine.modal.form.reason?.trim()" class="flex-1 bg-orange-500 hover:bg-orange-600 disabled:bg-slate-300 text-white font-semibold py-2 rounded-lg">Bỏ qua</button>
                    </div>
                  </div>
                </template>

                <!-- Detail -->
                <template x-if="vaccine.modal.kind === 'detail'">
                  <div>
                    <h3 class="text-lg font-semibold text-slate-900" x-text="vaccine.modal.vaccine?.vaccine_name_vn"></h3>
                    <p class="text-xs text-slate-500 mt-1"><span x-text="vaccine.modal.vaccine?.status"></span> · <span x-text="vaccine.modal.vaccine?.importance_level"></span></p>
                    <p class="text-sm text-slate-700 mt-3" x-text="vaccine.modal.vaccine?.description_vn"></p>
                    <dl class="mt-4 grid grid-cols-2 gap-2 text-xs">
                      <div><dt class="text-slate-500">Đến hạn</dt><dd class="font-medium" x-text="vaccine.modal.vaccine?.due_date || '—'"></dd></div>
                      <div><dt class="text-slate-500">Đã tiêm</dt><dd class="font-medium" x-text="vaccine.modal.vaccine?.administered_date || '—'"></dd></div>
                      <div><dt class="text-slate-500">Dose</dt><dd class="font-medium" x-text="`${vaccine.modal.vaccine?.dose_number}/${vaccine.modal.vaccine?.doses_total}`"></dd></div>
                      <div><dt class="text-slate-500">Series</dt><dd class="font-medium" x-text="seriesTypeLabel(vaccine.modal.vaccine?.series_type)"></dd></div>
                    </dl>
                    <button @click="closeVaccineModal()" class="mt-4 w-full bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Đóng</button>
                  </div>
                </template>

                <!-- Custom -->
                <template x-if="vaccine.modal.kind === 'custom'">
                  <div>
                    <h3 class="text-lg font-semibold text-slate-900">Thêm vaccine tuỳ chỉnh</h3>
                    <p class="text-xs text-slate-500 mt-1">Cho vaccines không trong danh sách chuẩn.</p>
                    <div class="mt-3 space-y-2">
                      <div><label class="text-xs text-slate-600">Tên vaccine *</label><input type="text" x-model="vaccine.modal.form.vaccine_name" maxlength="200" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Ngày tiêm *</label><input type="date" x-model="vaccine.modal.form.administered_date" :max="todayIso" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Phòng khám</label><input type="text" x-model="vaccine.modal.form.clinic_name" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200" /></div>
                      <div><label class="text-xs text-slate-600">Ghi chú</label><textarea x-model="vaccine.modal.form.notes" rows="2" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200"></textarea></div>
                    </div>
                    <p x-show="vaccine.modal.error" class="text-sm text-red-600" x-text="vaccine.modal.error"></p>
                    <div class="flex gap-2 pt-3">
                      <button @click="closeVaccineModal()" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Huỷ</button>
                      <button @click="submitCustomVaccine()" :disabled="vaccine.modal.loading || !vaccine.modal.form.vaccine_name?.trim() || !vaccine.modal.form.administered_date" class="flex-1 bg-sky-600 hover:bg-sky-700 disabled:bg-slate-300 text-white font-semibold py-2 rounded-lg">Lưu</button>
                    </div>
                  </div>
                </template>

              </div>
            </div>
          </div>
        </template>

        <!-- CLIMATE TAB (M5) -->
        <template x-if="activeTab === 'climate'">
          <div class="p-4 sm:p-6 space-y-6">

            <!-- Section 1: Sensitivity Score -->
            <section>
              <h3 class="text-lg font-semibold text-slate-900 mb-3">Climate Sensitivity</h3>
              <template x-if="climate.loading.sensitivity">
                <p class="text-sm text-slate-500">Đang tính…</p>
              </template>
              <template x-if="!climate.loading.sensitivity && climate.sensitivity">
                <div class="bg-white rounded-2xl border-2 p-5 flex items-center gap-5"
                  :class="sensitivityCardClass(climate.sensitivity.level)">
                  <div class="text-center">
                    <p class="text-5xl font-bold" x-text="climate.sensitivity.score"></p>
                    <p class="text-xs text-slate-500">/ 100</p>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-semibold uppercase tracking-wider opacity-75" x-text="sensitivityLevelLabel(climate.sensitivity.level)"></p>
                    <p class="text-xs text-slate-600 mt-1">
                      <template x-if="!climate.sensitivity.factors.length">
                        <span>Bé không có yếu tố nhạy cảm đặc biệt</span>
                      </template>
                      <template x-if="climate.sensitivity.factors.length">
                        <span x-text="`${climate.sensitivity.factors.length} yếu tố`"></span>
                      </template>
                    </p>
                    <ul class="mt-2 space-y-0.5">
                      <template x-for="f in climate.sensitivity.factors" :key="f.key">
                        <li class="text-xs">+<span x-text="f.impact"></span> <span x-text="f.label_vn"></span></li>
                      </template>
                    </ul>
                  </div>
                </div>
              </template>
            </section>

            <!-- Section 2: 7-day Forecast -->
            <section>
              <h3 class="text-lg font-semibold text-slate-900 mb-3">Thời tiết 5-7 ngày tới</h3>
              <template x-if="climate.loading.forecast">
                <p class="text-sm text-slate-500">Đang tải…</p>
              </template>
              <template x-if="!climate.loading.forecast && climate.forecast">
                <div class="overflow-x-auto -mx-4 px-4">
                  <div class="flex gap-3" style="min-width: max-content">
                    <template x-for="d in climate.forecast.days" :key="d.date">
                      <div class="bg-white border-2 rounded-xl px-4 py-3 min-w-[120px] text-center"
                        :class="forecastCardClass(d)">
                        <p class="text-xs text-slate-500" x-text="formatShortDate(d.date)"></p>
                        <p class="my-1 flex justify-center" x-html="weatherEmoji(d.weather_id)"></p>
                        <p class="text-sm font-semibold text-slate-900" x-text="`${Math.round(d.temp_min)}°-${Math.round(d.temp_max)}°`"></p>
                        <p class="text-xs text-slate-500" x-text="`cảm ${Math.round(d.feels_like_max)}°`"></p>
                        <p class="text-[10px] mt-1 inline-block px-1.5 py-0.5 rounded" :class="aqiBadgeClass(d.aqi)" x-text="`AQI ${d.aqi}`"></p>
                      </div>
                    </template>
                  </div>
                </div>
              </template>
            </section>

            <!-- Section 3: Active alerts cho pet này -->
            <section>
              <h3 class="text-lg font-semibold text-slate-900 mb-3">Cảnh báo hiện tại</h3>
              <template x-if="climate.loading.alerts">
                <p class="text-sm text-slate-500">Đang tải…</p>
              </template>
              <template x-if="!climate.loading.alerts && climate.petAlerts.length === 0">
                <p class="text-sm text-slate-500 italic">Không có cảnh báo. Bé đang an toàn 💚</p>
              </template>
              <div class="space-y-2">
                <template x-for="a in climate.petAlerts" :key="a.id">
                  <div class="border-2 rounded-xl p-3 flex items-start gap-3" :class="severityCardClass(a.severity)">
                    <span class="text-2xl shrink-0" x-text="alertIcon(a.alert_type)"></span>
                    <div class="flex-1 min-w-0">
                      <p class="font-semibold text-sm" x-text="a.title"></p>
                      <p class="text-xs text-slate-700 mt-0.5" x-text="a.message"></p>
                    </div>
                  </div>
                </template>
              </div>
              <a x-show="climate.petAlerts.length > 0" href="/alerts" class="inline-block mt-3 text-xs text-sky-600 hover:text-sky-700">Xem tất cả cảnh báo →</a>
            </section>

          </div>
        </template>

        <!-- CARE TAB (M4) -->
        <template x-if="activeTab === 'care'">
          <div class="p-4 sm:p-6 space-y-6">

            <!-- SECTION 1: Weather widget -->
            <div class="bg-mmp-cream rounded-xl px-4 py-3 border border-slate-100">
              <template x-if="!care.weather && care.loading.weather">
                <p class="text-sm text-slate-500">Đang tải thời tiết…</p>
              </template>
              <template x-if="care.weather">
                <div class="flex flex-wrap gap-4 items-center text-sm">
                  <div class="flex items-center gap-1">
                    <span class="text-lg">🌡️</span>
                    <span class="font-semibold text-slate-900" x-text="`${care.weather.temp}°C`"></span>
                    <span class="text-slate-500" x-text="`(cảm giác ${care.weather.feels_like}°C)`"></span>
                  </div>
                  <div class="flex items-center gap-1">
                    <span class="text-lg">💧</span>
                    <span class="text-slate-900" x-text="`${care.weather.humidity}%`"></span>
                  </div>
                  <div class="flex items-center gap-1">
                    <span class="text-lg">🌫️</span>
                    <span class="text-slate-900" x-text="`AQI ${care.weather.aqi}/5 — ${care.weather.aqi_label_vn}`"></span>
                  </div>
                  <span class="text-xs text-slate-400 ml-auto" x-text="care.weather.city"></span>
                </div>
              </template>
              <!-- v58: Weather error surfacing — silent fail tránh, hiển thị retry inline -->
              <template x-if="!care.weather && !care.loading.weather && care.weatherError">
                <div class="text-xs italic text-slate-400 inline-flex items-center gap-2">
                  <span>⚠️ Không tải được thời tiết</span>
                  <span class="text-slate-300" x-text="'(' + care.weatherError + ')'"></span>
                  <button type="button" @click="fetchWeather()" class="text-slate-500 hover:text-slate-700 underline italic">Thử lại</button>
                </div>
              </template>
            </div>

            <!-- SECTION 2: Check-in hôm nay -->
            <section>
              <h3 class="text-lg font-semibold text-slate-900 mb-3">Check-in hôm nay</h3>

              <!-- Đã check-in, không show form -->
              <template x-if="care.checkIn && !care.showCheckInForm">
                <div class="bg-green-50 border border-green-200 rounded-xl p-4">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-sm font-medium text-green-800">
                        ✅ Đã check-in lúc <span x-text="formatTime(care.checkIn.created_at)"></span>
                      </p>
                      <div class="mt-2 grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs text-slate-600">
                        <div>Thèm ăn: <span class="font-medium" x-text="`${care.checkIn.appetite || '—'}/5`"></span></div>
                        <div>Năng lượng: <span class="font-medium" x-text="`${care.checkIn.energy || '—'}/5`"></span></div>
                        <div>Tiêu hoá: <span class="font-medium" x-text="stoolLabelVi(care.checkIn.stool_quality)"></span></div>
                        <div x-show="care.checkIn.symptoms.length">Triệu chứng: <span class="font-medium" x-text="care.checkIn.symptoms.map(symptomLabelVi).join(', ')"></span></div>
                      </div>
                    </div>
                    <button @click="openCheckInForm()" class="text-sm text-sky-600 hover:text-sky-700 font-medium shrink-0">✏️ Cập nhật</button>
                  </div>
                </div>
              </template>

              <!-- Form check-in -->
              <template x-if="care.showCheckInForm || (!care.checkIn && !care.loading.checkIn)">
                <div class="bg-white border border-slate-200 rounded-xl p-4 sm:p-5 space-y-5">
                  <p class="text-sm text-slate-600">Theo dõi sức khoẻ bé hôm nay để VowVet đưa ra lời khuyên phù hợp.</p>

                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <!-- Cột 1 -->
                    <div class="space-y-5">
                      <!-- Appetite -->
                      <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Thèm ăn</label>
                        <div class="flex gap-1.5">
                          <button type="button" @click="care.form.appetite = 1" aria-label="Bỏ ăn" title="Bỏ ăn"
                            :class="care.form.appetite === 1 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-nausea" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.appetite = 2" aria-label="Ăn ít" title="Ăn ít"
                            :class="care.form.appetite === 2 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-needy" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.appetite = 3" aria-label="Tạm ổn" title="Tạm ổn"
                            :class="care.form.appetite === 3 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-chill" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.appetite = 4" aria-label="Ăn ngon" title="Ăn ngon"
                            :class="care.form.appetite === 4 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-happy" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.appetite = 5" aria-label="Ăn ngon miệng" title="Ăn ngon miệng"
                            :class="care.form.appetite === 5 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-excited" class="w-8 h-8" />
                          </button>
                        </div>
                        <p class="text-xs text-slate-400 mt-1" x-text="['Bỏ ăn','Ăn ít','Tạm ổn','Ăn ngon','Ăn ngon miệng'][care.form.appetite-1] || ' '"></p>
                      </div>

                      <!-- Energy -->
                      <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Năng lượng</label>
                        <div class="flex gap-1.5">
                          <button type="button" @click="care.form.energy = 1" aria-label="Mệt lả" title="Mệt lả"
                            :class="care.form.energy === 1 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-sleeping" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.energy = 2" aria-label="Uể oải" title="Uể oải"
                            :class="care.form.energy === 2 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-tired" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.energy = 3" aria-label="Bình thường" title="Bình thường"
                            :class="care.form.energy === 3 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-chill" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.energy = 4" aria-label="Hứng khởi" title="Hứng khởi"
                            :class="care.form.energy === 4 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-happy" class="w-8 h-8" />
                          </button>
                          <button type="button" @click="care.form.energy = 5" aria-label="Sôi nổi" title="Sôi nổi"
                            :class="care.form.energy === 5 ? 'border-mmp-gold bg-mmp-gold/10 ring-2 ring-mmp-gold/30 text-mmp-gold pcq-on' : 'border-slate-200 hover:border-mmp-gold/40 text-mmp-ink/50'"
                            class="pcq-btn flex-1 border-2 rounded-lg py-2 transition flex items-center justify-center">
                            <FeatureIcon name="mood-energetic" class="w-8 h-8" />
                          </button>
                        </div>
                        <p class="text-xs text-slate-400 mt-1" x-text="['Mệt lả','Uể oải','Bình thường','Hứng khởi','Sôi nổi'][care.form.energy-1] || ' '"></p>
                      </div>

                      <!-- Stool -->
                      <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Tiêu hoá</label>
                        <select x-model="care.form.stool_quality" class="w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none">
                          <option value="">— chưa nhập —</option>
                          <option value="normal">💩 Bình thường</option>
                          <option value="soft">💧 Mềm</option>
                          <option value="liquid">💦 Lỏng</option>
                          <option value="hard">🥚 Cứng</option>
                          <option value="none">🚫 Không có</option>
                        </select>
                      </div>
                    </div>

                    <!-- Cột 2 -->
                    <div class="space-y-5">
                      <!-- Water ml -->
                      <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Nước uống (ml, optional)</label>
                        <input type="number" x-model.number="care.form.water_ml" min="0" max="5000" placeholder="VD: 300"
                          class="w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none" />
                      </div>

                      <!-- Symptoms -->
                      <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Triệu chứng (chọn nhiều)</label>
                        <div class="grid grid-cols-2 gap-2 text-sm">
                          <label class="pcq-sym flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition"
                            :class="care.form.symptoms.includes('vomit') ? 'border-mmp-gold bg-mmp-gold/10 text-mmp-gold' : 'border-slate-200 text-mmp-ink/70'">
                            <input type="checkbox" value="vomit" x-model="care.form.symptoms" class="rounded" />
                            <FeatureIcon name="mood-nausea" class="w-5 h-5 shrink-0" /><span>Nôn</span>
                          </label>
                          <label class="pcq-sym flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition"
                            :class="care.form.symptoms.includes('cough') ? 'border-mmp-gold bg-mmp-gold/10 text-mmp-gold' : 'border-slate-200 text-mmp-ink/70'">
                            <input type="checkbox" value="cough" x-model="care.form.symptoms" class="rounded" />
                            <FeatureIcon name="mask" class="w-5 h-5 shrink-0" /><span>Ho</span>
                          </label>
                          <label class="pcq-sym flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition"
                            :class="care.form.symptoms.includes('sneeze') ? 'border-mmp-gold bg-mmp-gold/10 text-mmp-gold' : 'border-slate-200 text-mmp-ink/70'">
                            <input type="checkbox" value="sneeze" x-model="care.form.symptoms" class="rounded" />
                            <FeatureIcon name="sneeze" class="w-5 h-5 shrink-0" /><span>Hắt hơi</span>
                          </label>
                          <label class="pcq-sym flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition"
                            :class="care.form.symptoms.includes('itch') ? 'border-mmp-gold bg-mmp-gold/10 text-mmp-gold' : 'border-slate-200 text-mmp-ink/70'">
                            <input type="checkbox" value="itch" x-model="care.form.symptoms" class="rounded" />
                            <FeatureIcon name="paw" class="w-5 h-5 shrink-0" /><span>Ngứa</span>
                          </label>
                          <label class="pcq-sym flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition"
                            :class="care.form.symptoms.includes('limp') ? 'border-mmp-gold bg-mmp-gold/10 text-mmp-gold' : 'border-slate-200 text-mmp-ink/70'">
                            <input type="checkbox" value="limp" x-model="care.form.symptoms" class="rounded" />
                            <FeatureIcon name="limp" class="w-5 h-5 shrink-0" /><span>Khập khiễng</span>
                          </label>
                          <label class="pcq-sym flex items-center gap-2 px-3 py-2 rounded-lg border cursor-pointer transition"
                            :class="care.form.symptoms.includes('other') ? 'border-mmp-gold bg-mmp-gold/10 text-mmp-gold' : 'border-slate-200 text-mmp-ink/70'">
                            <input type="checkbox" value="other" x-model="care.form.symptoms" class="rounded" />
                            <FeatureIcon name="info" class="w-5 h-5 shrink-0" /><span>Khác</span>
                          </label>
                        </div>
                      </div>

                      <!-- Notes -->
                      <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Ghi chú (optional)</label>
                        <textarea x-model="care.form.notes" rows="2" maxlength="2000" placeholder="VD: Bé vui chơi bình thường"
                          class="w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none resize-none"></textarea>
                      </div>
                    </div>
                  </div>

                  <p x-show="care.checkInError" class="text-sm text-red-600" x-text="care.checkInError"></p>

                  <div class="flex gap-2">
                    <template x-if="care.checkIn">
                      <button @click="care.showCheckInForm = false" class="px-4 py-2.5 text-sm bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium rounded-lg">Huỷ</button>
                    </template>
                    <button @click="submitCheckIn()" :disabled="care.submittingCheckIn || !care.form.appetite || !care.form.energy"
                      class="flex-1 bg-sky-600 hover:bg-sky-700 disabled:bg-slate-300 text-white font-semibold py-2.5 rounded-lg transition">
                      <span x-show="!care.submittingCheckIn" class="inline-flex items-center justify-center gap-1.5"><FeatureIcon name="clipboard-check" class="w-5 h-5" />Lưu check-in</span>
                      <span x-show="care.submittingCheckIn">Đang lưu…</span>
                    </button>
                  </div>
                </div>
              </template>
            </section>

            <!-- SECTION 3: Care plan -->
            <section>
              <h3 class="text-lg font-semibold text-slate-900 mb-3">Lời khuyên hôm nay</h3>

              <!-- No check-in -->
              <template x-if="care.planStatus === 'no_checkin'">
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-center">
                  <p class="flex justify-center mb-2"><FeatureIcon name="info" class="w-8 h-8 text-amber-700" /></p>
                  <p class="text-sm text-amber-800">Vui lòng check-in cho bé trước để VowVet phân tích.</p>
                </div>
              </template>

              <!-- Loading / processing -->
              <template x-if="care.planStatus === 'processing' || care.planStatus === 'loading'">
                <div class="bg-sky-50 border border-sky-200 rounded-xl p-8 text-center">
                  <div class="inline-block w-8 h-8 border-4 border-sky-300 border-t-sky-600 rounded-full animate-spin mb-3"></div>
                  <p class="text-sm text-sky-800">AI đang phân tích cho bé… (5-15 giây)</p>
                </div>
              </template>

              <!-- Error / timeout -->
              <template x-if="care.planStatus === 'error'">
                <div class="bg-red-50 border border-red-200 rounded-xl p-5">
                  <p class="text-sm text-red-700 font-medium mb-2">Có vấn đề khi phân tích.</p>
                  <p class="text-xs text-slate-600 mb-3" x-text="care.planError || 'Thử lại sau nhé.'"></p>
                  <button @click="fetchCarePlan()" class="text-sm bg-red-600 hover:bg-red-700 text-white font-medium px-4 py-2 rounded-lg">Thử lại</button>
                </div>
              </template>

              <!-- Ready -->
              <template x-if="care.planStatus === 'fresh' && care.plan">
                <div class="space-y-4">
                  <!-- Urgency badge -->
                  <div class="rounded-xl border-2 px-5 py-4 flex items-center gap-3" :class="urgencyClass(care.plan.urgency_level)">
                    <span class="text-2xl" x-text="urgencyIcon(care.plan.urgency_level)"></span>
                    <div>
                      <p class="text-xs font-medium uppercase tracking-wider opacity-75">Tình trạng</p>
                      <p class="text-lg font-bold" x-text="urgencyLabel(care.plan.urgency_level)"></p>
                    </div>
                  </div>

                  <!-- Summary -->
                  <p class="text-base text-slate-800 leading-relaxed" x-text="care.plan.summary"></p>

                  <!-- Concerns -->
                  <div x-show="care.plan.concerns && care.plan.concerns.length" class="bg-amber-50 border border-amber-200 rounded-xl p-4">
                    <p class="text-sm font-semibold text-orange-900 mb-2">⚠️ Cần lưu ý:</p>
                    <ul class="space-y-1 text-sm text-amber-700">
                      <template x-for="(c, i) in care.plan.concerns" :key="i">
                        <li class="flex gap-2"><span class="shrink-0">•</span><span x-text="c"></span></li>
                      </template>
                    </ul>
                  </div>

                  <!-- Recommendations 2x2 -->
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <template x-for="(r, i) in care.plan.recommendations" :key="i">
                      <div class="bg-white border border-slate-100 rounded-xl p-4">
                        <div class="flex items-start gap-3">
                          <span class="text-2xl shrink-0" x-text="r.icon"></span>
                          <div class="min-w-0">
                            <p class="font-semibold text-slate-900 text-sm" x-text="r.title"></p>
                            <p class="text-xs text-slate-600 mt-1 leading-relaxed" x-text="r.advice"></p>
                          </div>
                        </div>
                      </div>
                    </template>
                  </div>

                  <!-- Alerts -->
                  <template x-for="(a, i) in care.plan.alerts" :key="i">
                    <div class="bg-orange-100 border-l-4 border-orange-500 rounded-r-lg px-4 py-3 flex gap-2">
                      <span class="text-xl shrink-0">⚠️</span>
                      <p class="text-sm text-orange-900" x-text="a"></p>
                    </div>
                  </template>

                  <!-- Actions -->
                  <div class="flex flex-wrap gap-2 pt-2">
                    <button @click="sendFeedback('helpful')" :disabled="care.feedbackPending"
                      :class="care.feedback === 'helpful' ? 'bg-green-100 text-green-700 border-green-300' : 'bg-white text-slate-600 border-slate-200 hover:border-green-300'"
                      class="text-sm font-medium px-3 py-2 rounded-lg border transition">👍 Hữu ích</button>
                    <button @click="sendFeedback('not_helpful')" :disabled="care.feedbackPending"
                      :class="care.feedback === 'not_helpful' ? 'bg-red-100 text-red-700 border-red-300' : 'bg-white text-slate-600 border-slate-200 hover:border-red-300'"
                      class="text-sm font-medium px-3 py-2 rounded-lg border transition">👎 Không hữu ích</button>
                    <button @click="refreshPlan()" :disabled="care.refreshing || !care.refresh?.ok"
                      :title="care.refresh?.ok ? `Còn ${care.refresh.remaining} lần refresh hôm nay` : 'Đã refresh tối đa hôm nay'"
                      class="text-sm font-medium px-3 py-2 rounded-lg border bg-white text-slate-600 border-slate-200 hover:border-sky-300 disabled:opacity-50 disabled:cursor-not-allowed transition">
                      <span x-show="!care.refreshing">🔄 Làm mới</span>
                      <span x-show="care.refreshing">Đang tạo lại…</span>
                    </button>
                    <span x-show="care.metadata?.model" class="ml-auto self-center text-xs text-slate-400" x-text="care.metadata?.model"></span>
                  </div>

                  <!-- Disclaimer -->
                  <p class="text-xs text-slate-400 italic mt-3 pt-3 border-t border-slate-100">
                    VowVet không thay thế bác sĩ thú y. Mọi quyết định điều trị, hãy gặp bác sĩ Mon Min hoặc bác sĩ thú y gần nhất.
                  </p>
                </div>
              </template>
            </section>

            <!-- SECTION 4: Lịch sử 30 ngày -->
            <section>
              <button @click="toggleHistory()" class="w-full flex items-center justify-between bg-slate-50 hover:bg-slate-100 rounded-xl px-4 py-3 transition">
                <h3 class="text-base font-semibold text-slate-900">Lịch sử 30 ngày</h3>
                <span class="text-slate-500 transition-transform" :class="care.historyExpanded ? 'rotate-180' : ''">▾</span>
              </button>

              <div x-show="care.historyExpanded" x-transition class="mt-3 space-y-3">
                <div class="flex gap-2 text-xs">
                  <template x-for="f in [['all','Tất cả'],['concern','Có concern'],['normal','Bình thường']]" :key="f[0]">
                    <button @click="care.historyFilter = f[0]"
                      :class="care.historyFilter === f[0] ? 'bg-sky-100 text-sky-700' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'"
                      class="px-3 py-1.5 rounded-full font-medium transition" x-text="f[1]"></button>
                  </template>
                </div>

                <template x-if="care.loading.history">
                  <p class="text-sm text-slate-500 text-center py-4">Đang tải…</p>
                </template>
                <template x-if="!care.loading.history && filteredHistory().length === 0">
                  <p class="text-sm text-slate-500 text-center py-4">Chưa có dữ liệu lịch sử.</p>
                </template>
                <ul class="space-y-2">
                  <template x-for="h in filteredHistory()" :key="h.id">
                    <li class="bg-white border border-slate-100 rounded-xl p-3 flex items-center gap-3">
                      <span class="w-2 h-2 rounded-full shrink-0" :class="urgencyDot(h.plan?.urgency_level)"></span>
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium text-slate-900" x-text="h.check_date"></p>
                        <p class="text-xs text-slate-500 truncate" x-text="h.plan?.summary || 'Chưa có phân tích'"></p>
                      </div>
                      <span class="text-xs text-slate-400 shrink-0" x-text="h.plan ? urgencyLabel(h.plan.urgency_level) : '—'"></span>
                    </li>
                  </template>
                </ul>
              </div>
            </section>

          </div>
        </template>
      </div>

      <!-- Edit Modal -->
      <div
        x-show="showEdit"
        x-transition.opacity
        class="fixed inset-0 z-50 flex items-center justify-center px-4 bg-slate-900/50"
        @keydown.escape.window="showEdit = false"
        style="display:none"
      >
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6 space-y-4" @click.outside="showEdit = false">
          <h3 class="text-lg font-semibold text-slate-900">Sửa thông tin</h3>
          <div>
            <label class="text-sm font-medium text-slate-700">Tên</label>
            <input type="text" x-model="editForm.name" maxlength="100" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700">Giống</label>
            <input type="text" x-model="editForm.breed" list="breed-list" maxlength="100" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none" />
            <datalist id="breed-list">
              <template x-for="b in breedOptions" :key="b"><option :value="b"></option></template>
            </datalist>
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700">Ngày sinh</label>
            <input type="date" x-model="editForm.dob" :max="todayIso" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700">Giới tính</label>
            <div class="mt-1 grid grid-cols-3 gap-2">
              <template x-for="g in ['Đực', 'Cái', '']" :key="g">
                <button type="button" @click="editForm.gender = g" :class="editForm.gender === g ? 'border-sky-500 bg-sky-50' : 'border-slate-200'" class="border rounded-lg py-2 text-sm" x-text="g || '(bỏ trống)'"></button>
              </template>
            </div>
          </div>
          <div>
            <label class="text-sm font-medium text-slate-700">Cân nặng (kg)</label>
            <input type="number" step="0.1" min="0" max="200" x-model.number="editForm.weight_kg" class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-200 focus:border-sky-500 focus:outline-none" />
          </div>
          <p x-show="editError" class="text-sm text-red-600" x-text="editError"></p>
          <div class="flex gap-2 pt-2">
            <button @click="showEdit = false" :disabled="editLoading" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Huỷ</button>
            <button @click="saveEdit()" :disabled="editLoading" class="flex-1 bg-sky-600 hover:bg-sky-700 disabled:bg-slate-300 text-white font-semibold py-2 rounded-lg">
              <span x-show="!editLoading">Lưu</span>
              <span x-show="editLoading">Đang lưu…</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Delete confirm dialog (2 steps) -->
      <div
        x-show="deleteStep > 0"
        x-transition.opacity
        class="fixed inset-0 z-50 flex items-center justify-center px-4 bg-slate-900/50"
        style="display:none"
      >
        <div class="bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6 space-y-4">
          <template x-if="deleteStep === 1">
            <div>
              <h3 class="text-lg font-semibold text-slate-900">Xoá pet "<span x-text="pet.name"></span>"?</h3>
              <p class="text-sm text-slate-600 mt-2">Bạn sắp xoá thông tin của bé. Tiếp tục?</p>
              <div class="mt-4 flex gap-2">
                <button @click="deleteStep = 0" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Không</button>
                <button @click="deleteStep = 2" class="flex-1 bg-red-100 hover:bg-red-200 text-red-700 font-semibold py-2 rounded-lg">Tiếp tục</button>
              </div>
            </div>
          </template>
          <template x-if="deleteStep === 2">
            <div>
              <h3 class="text-lg font-semibold text-red-700">⚠️ Hành động không thể hoàn tác</h3>
              <p class="text-sm text-slate-600 mt-2">Toàn bộ ảnh, vaccine, lịch sử của <span class="font-medium" x-text="pet.name"></span> sẽ mất.</p>
              <p x-show="deleteError" class="text-sm text-red-600 mt-2" x-text="deleteError"></p>
              <div class="mt-4 flex gap-2">
                <button @click="deleteStep = 0" :disabled="deleteLoading" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-lg">Huỷ</button>
                <button @click="doDelete()" :disabled="deleteLoading" class="flex-1 bg-red-600 hover:bg-red-700 disabled:bg-red-300 text-white font-semibold py-2 rounded-lg">
                  <span x-show="!deleteLoading">Xoá vĩnh viễn</span>
                  <span x-show="deleteLoading">Đang xoá…</span>
                </button>
              </div>
            </div>
          </template>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script is:inline src="/image-compress.js"></script>
