---
/**
 * /memorial/[slug]/upgrade — Premium tier interest form (M30).
 *
 * LEGAL SAFE: Collects interest only — NO payment, NO commitment, NO cremation services.
 * Mon Min team contacts manually after submission.
 */
import Layout from "../../../layouts/Layout.astro";

const slug = Astro.params.slug as string;
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";
const cookieHeader = Astro.request.headers.get("cookie") || "";

let memorial: any = null;
try {
  const r = await fetch(`${API_INTERNAL}/api/v1/public/memorial/${slug}`);
  if (r.ok) memorial = (await r.json()).memorial;
} catch (_) {}

if (!memorial) {
  return new Response("Memorial không khả dụng", { status: 404, headers: { "content-type": "text/plain; charset=utf-8" } });
}

const initialData = JSON.stringify({ memorial });
---

<Layout title="Nâng cấp Tưởng Nhớ" description="Đăng ký quan tâm các gói nâng cao">
  <main class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-700 to-slate-900 text-white px-4 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`upgradePage(${initialData})`}>

      <header class="flex items-center justify-between mb-6 gap-3">
        <a :href={`/memorial/${slug}`} class="text-sm text-slate-300 hover:text-white">← Memorial</a>
        <h1 class="text-lg font-bold">✨ Nâng cấp</h1>
        <span class="w-12"></span>
      </header>

      <!-- Legal disclaimer banner -->
      <div class="bg-amber-900/30 border border-amber-700/50 rounded-2xl p-4 mb-5 text-xs leading-relaxed">
        <p class="font-bold text-amber-100 mb-1">⚠️ Đăng ký quan tâm — không phải thanh toán</p>
        <p class="text-amber-200/90">
          Mon Min đang phát triển các gói cao cấp. Form này CHỈ ghi nhận quan tâm — KHÔNG thu phí trả trước.
          Đội ngũ sẽ liên hệ lại trong 1-2 ngày làm việc để tư vấn chi tiết. Bạn có quyền từ chối bất cứ lúc nào.
        </p>
      </div>

      <!-- Tier picker -->
      <div class="space-y-3 mb-5">
        <template x-for="t in tiers" :key="t.key">
          <button @click="form.tier = t.key" type="button"
            :class="form.tier === t.key ? 'border-mmp-cream bg-purple-900/40 ring-2 ring-mmp-ink/50' : 'border-white/10 bg-white/5'"
            class="w-full border rounded-2xl p-5 text-left hover:bg-white/10 transition">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-bold text-lg" x-text="`${t.emoji} ${t.name}`"></h3>
              <span class="text-xs px-2 py-0.5 rounded-full bg-mmp-ink/50 font-bold" x-text="t.price"></span>
            </div>
            <ul class="text-xs space-y-1 text-yellow-700">
              <template x-for="f in t.features" :key="f">
                <li>✓ <span x-text="f"></span></li>
              </template>
            </ul>
          </button>
        </template>
      </div>

      <!-- Contact form -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-5 mb-4">
        <h2 class="text-sm font-bold uppercase tracking-wider text-yellow-700 mb-3">📞 Thông tin liên hệ</h2>

        <label class="text-xs font-bold text-yellow-700 uppercase">Số điện thoại *</label>
        <input type="tel" x-model="form.contact_phone" placeholder="0901234567" inputmode="tel" maxlength="20"
          class="w-full mt-1 mb-3 bg-white/10 border border-white/20 rounded-xl px-3 py-2.5 text-sm" />

        <label class="text-xs font-bold text-yellow-700 uppercase">Thời gian gọi thuận tiện (optional)</label>
        <input type="text" x-model="form.contact_preferred_time" placeholder="VD: sau 6PM, cuối tuần..." maxlength="100"
          class="w-full mt-1 mb-3 bg-white/10 border border-white/20 rounded-xl px-3 py-2.5 text-sm" />

        <label class="text-xs font-bold text-yellow-700 uppercase">Ghi chú thêm (optional)</label>
        <textarea x-model="form.notes" rows="3" maxlength="1000" placeholder="Bạn muốn hỏi gì? Bé cần điều gì đặc biệt?"
          class="w-full mt-1 bg-white/10 border border-white/20 rounded-xl px-3 py-2.5 text-sm"></textarea>
      </div>

      <template x-if="error">
        <p class="text-xs bg-red-900/50 border border-red-500 rounded-lg p-3 mb-3" x-text="error"></p>
      </template>

      <template x-if="success">
        <div class="bg-emerald-900/30 border border-emerald-500/50 rounded-2xl p-4 mb-4 text-sm">
          <p class="font-bold text-emerald-100">✓ Đã ghi nhận quan tâm</p>
          <p class="text-emerald-200/90 text-xs mt-1" x-text="success"></p>
        </div>
      </template>

      <button @click="submit()" :disabled="!canSubmit || saving"
        class="w-full bg-gradient-to-r from-mmp-cream to-white hover:opacity-90 disabled:opacity-50 font-bold py-3 rounded-xl text-sm">
        <span x-show="!saving">📩 Gửi đăng ký quan tâm</span>
        <span x-show="saving">Đang gửi...</span>
      </button>

      <p class="text-[10px] text-slate-500 text-center italic mt-4 leading-relaxed">
        Bằng cách gửi form, bạn đồng ý để VowVet liên hệ qua số điện thoại đã cung cấp.<br />
        VowVet KHÔNG bán hay chia sẻ thông tin với bên thứ 3.<br />
        Dịch vụ hỏa táng và keepsake do đối tác bên thứ ba có giấy phép cung cấp — VowVet không trực tiếp cung cấp.
      </p>

      <!-- Direct contact (Zalo + hotline) -->
      <div class="mt-6 pt-5 border-t border-white/10 text-center">
        <p class="text-xs text-yellow-700 mb-3">Muốn hỏi trực tiếp trước khi gửi form?</p>
        <a href="https://zalo.me/1136810892220003266" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-mmp-ink hover:bg-mmp-ink text-white font-bold text-sm">
          💬 Chat Zalo VowVet
        </a>
        <p class="text-[11px] text-slate-400 mt-2">
          hoặc gọi <a href="tel:+84779029133" class="font-bold text-yellow-700 underline">0779 029 133</a>
        </p>
      </div>

    </div>
  </main>

  <script is:inline>
    function upgradePage(initial) {
      return {
        memorial: initial.memorial,
        tiers: [
          {
            key: "tribute",
            name: "Tribute",
            emoji: "💜",
            price: "Liên hệ",
            features: [
              "100 ảnh (free 20)",
              "Nhạc nền tự chọn",
              "Album slideshow tự động",
              "Custom domain (mộn.com/ten-be)",
            ],
          },
          {
            key: "lifetime",
            name: "Lifetime",
            emoji: "💎",
            price: "Liên hệ",
            features: [
              "Tất cả tính năng Tribute",
              "Lưu trữ vĩnh viễn (cam kết 25 năm)",
              "QR plaque vật lý (ship về tận nhà)",
              "Personal memorial book PDF",
            ],
          },
          {
            key: "pro",
            name: "Pro (concierge)",
            emoji: "🌟",
            price: "Liên hệ",
            features: [
              "Tất cả tính năng Lifetime",
              "Tư vấn cá nhân hoá memorial",
              "Hỗ trợ tổ chức lễ tưởng niệm online",
              "Ưu tiên hỗ trợ 24/7",
            ],
          },
        ],
        form: {
          tier: "tribute",
          contact_phone: "",
          contact_preferred_time: "",
          notes: "",
        },
        saving: false,
        error: "",
        success: "",

        get canSubmit() {
          return this.form.tier && this.form.contact_phone.trim().length >= 9;
        },

        async submit() {
          this.error = "";
          this.success = "";
          if (!this.canSubmit) {
            this.error = "Cần tier + số điện thoại hợp lệ.";
            return;
          }
          this.saving = true;
          try {
            const res = await fetch(`/api/v1/memorials/${this.memorial.id}/interest`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify(this.form),
            });
            const j = await res.json();
            if (!res.ok) {
              if (res.status === 401) {
                this.error = "Cần đăng nhập để gửi đăng ký. Đang chuyển sang trang đăng nhập...";
                setTimeout(() => (window.location.href = "/login"), 1500);
                return;
              }
              this.error = j?.error?.message || "Lỗi gửi";
              return;
            }
            this.success = j.message || "Mon Min sẽ liên hệ lại trong 1-2 ngày làm việc.";
            this.form.contact_phone = "";
            this.form.contact_preferred_time = "";
            this.form.notes = "";
          } catch (_) {
            this.error = "Lỗi kết nối.";
          } finally {
            this.saving = false;
          }
        },
      };
    }
  </script>
</Layout>
