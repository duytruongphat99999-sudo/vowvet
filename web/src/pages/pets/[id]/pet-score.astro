    /* === Phase 6: Trend + Community merged === */
    .trend-community { position: relative; overflow: hidden; }
    .trend-community::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent 0%, #ecb921 30%, #B48608 50%, #ecb921 70%, transparent 100%);
      background-size: 200% 100%; animation: gold-thread 4s linear infinite; opacity: 0.6;
    }
    .trend-counter-pill {
      position: relative; display: inline-block; padding: 4px 12px;
      background: linear-gradient(135deg, #ecb921 0%, #B48608 100%); color: #0a0a0a;
