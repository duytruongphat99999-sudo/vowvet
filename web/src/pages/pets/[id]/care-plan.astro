  <script is:inline>
    function carePlanPage(initial) {
      return {
        plan: initial.plan,
        pet: initial.pet,
        refreshing: false,
        copied: false,

        async refresh() {
          if (!confirm("Tải mới care plan? AI sẽ chấm điểm + sinh lại (mất 5-10 giây).")) return;
          this.refreshing = true;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/care-plan/v2/refresh`, { method: "POST" });
            const j = await res.json();
            if (res.ok && j.plan) {
              this.plan = j.plan;
              window.location.reload(); // SSR re-fetch refreshes suggestion + progress too
            } else {
              alert(j.error?.message || "Lỗi refresh");
            }
          } catch (_) {
            alert("Lỗi kết nối");
          } finally {
            this.refreshing = false;
          }
        },

        async shareZalo() {
          const p = this.plan;
          const lines = [
            `Kế hoạch hôm nay — Bé ${p.pet_name} (${p.pet_age_label})`,
            ``,
            `${p.weather.city} ${p.weather.temp_celsius}°C (PetAir ${p.weather.petair_index}/100)`,
            `   Khung an toàn: ${p.weather.safe_hours_today}`,
            ``,
          ];
          if (p.festival_warning) {
            lines.push(`Lễ ${p.festival_warning.festival_name}: ${p.festival_warning.key_warnings[0]}`);
            lines.push(``);
          }
          lines.push(`Ăn uống:`);
          for (const m of p.eating.items) lines.push(`   • ${m.time}: ${m.what}`);
          lines.push(``);
          lines.push(`Vận động:`);
          for (const m of p.exercise.items) lines.push(`   • ${m.time}: ${m.activity} (${m.duration_min}p)`);
          if (p.training) {
            lines.push(``);
            lines.push(`Training: ${p.training.focus_this_week} — ${p.training.sessions}`);
          }
          lines.push(``);
          lines.push(`Đầy đủ: ${window.location.href}`);
          lines.push(``);
          lines.push(`— Mon Min Pet`);
          const text = lines.join("\n");
          try {
            if (navigator.share) {
              await navigator.share({ text, title: `Care plan ${p.pet_name}` });
            } else {
              await navigator.clipboard.writeText(text);
            }
            this.copied = true;
            setTimeout(() => (this.copied = false), 3000);
          } catch (_) {}
        },
      };
    }

    // Per-item Alpine factory — unchanged (AJAX complete + toast + haptic).
    function carePlanItem(itemKey, initialCompleted, petId) {
      return {
        completed: !!initialCompleted,
        loading: false,
        async markComplete() {
          if (this.completed || this.loading) return;
          this.loading = true;
          const url = `/api/v1/pets/${petId}/care-plan/items/${itemKey}/complete`;
          console.log("[care-plan/complete]", itemKey, "→", url);
          try {
            const res = await fetch(url, {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
            });
            // Try to read the body either way — server returns JSON for both success and error.
            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              console.error("[care-plan/complete] non-2xx", res.status, body);
              const apiMsg = body?.error?.message || body?.error || body?.message || "";
              let msg;
              if (res.status === 401) {
                msg = "Hết phiên đăng nhập. Tải lại trang.";
              } else if (res.status === 404) {
                msg = "API chưa sẵn sàng — hard refresh trang.";
              } else if (res.status === 403) {
                msg = "Không có quyền với bé này.";
              } else if (res.status >= 500) {
                msg = apiMsg ? `Lỗi server: ${apiMsg}` : `Lỗi server (${res.status}). Báo dev.`;
              } else {
                msg = apiMsg || `Lỗi ${res.status}. Thử lại.`;
              }
              showCarePlanToast(msg, false);
              return;
            }
            if (body.already_completed) { this.completed = true; return; }
            this.completed = true;
            if (navigator.vibrate) { try { navigator.vibrate(15); } catch (_) {} }
            const bonus = body.pet_score_bonus || 0;
            const questMsg = body.quest_completed?.definition?.name
              ? ` + Quest "${body.quest_completed.definition.name}" +${body.quest_completed.definition.pet_score_bonus || 0}đ`
              : "";
            showCarePlanToast(`+${bonus}đ Pet Score${questMsg}`, true);
            if (body.all_complete_bonus) {
              setTimeout(() => {
                showCarePlanToast(`Care Plan Trifecta — +${body.all_complete_bonus_amount}đ bonus`, true);
                setTimeout(() => window.location.reload(), 1500);
              }, 1200);
            } else {
              // Soft reload after 800ms so the hero suggestion advances to the next task
              setTimeout(() => window.location.reload(), 800);
            }
          } catch (e) {
            console.error("[care-plan/complete] network/JS err", e);
            const offline = typeof navigator !== "undefined" && navigator.onLine === false;
            const msg = offline
              ? "Mất kết nối — kiểm tra wifi/4G."
              : `Không kết nối được server: ${e?.message || e}`;
            showCarePlanToast(msg, false);
          } finally {
            this.loading = false;
          }
        },
      };
    }

    function showCarePlanToast(message, success) {
      const host = document.getElementById("care-plan-toast-host");
      if (!host) return;
      const t = document.createElement("div");
      t.className =
        "px-4 py-2.5 rounded-xl shadow-lg text-sm font-medium pointer-events-auto transition-all " +
        (success ? "bg-mmp-ink text-white" : "bg-red-50 border border-red-200 text-red-700");
      if (success) t.style.boxShadow = "0 8px 24px -8px rgba(236, 185, 33, 0.4)";
      t.textContent = message;
      t.style.opacity = "0";
      t.style.transform = "translateY(-8px)";
      host.appendChild(t);
      requestAnimationFrame(() => {
        t.style.opacity = "1";
        t.style.transform = "translateY(0)";
      });
      setTimeout(() => {
        t.style.opacity = "0";
        t.style.transform = "translateY(-8px)";
        setTimeout(() => t.remove(), 250);
      }, 2800);
    }
  </script>

