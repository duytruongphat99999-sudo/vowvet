---
/**
 * /dashboard — behavior-driven, brand-aligned WOW redesign.
 *
 * 6 zones (top-to-bottom — v29 merged former TopNudge into Pet Score subtitle):
 *   1. PetHeroCard  — pet + mood + top action
 *   2. UrgencyBar   — conditional: vaccine overdue / lost / climate / voucher expiring
 *   3. QuestStrip   — daily 3 quests with cta_link
 *   4. PetScoreCompact — count-up + progress + tier_close nudge absorbed as subtitle
 *   5.5 CarePlanProgress — daily care plan completion (conditional)
 *   6. QuickAccess  — 3×2 grid quick links
 *   7. CommunityMini — top 3 community events
 *
 * Plus: sticky TopBar (logo + actions, client-side counts), EcosystemNav footer.
 *
 * SSR-first with parallel fetches. Fail-soft: any failed endpoint just hides
 * its zone — dashboard stays usable.
 */
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import FeatureIcon from "../components/FeatureIcon.astro";
import EcosystemNav from "../components/EcosystemNav.astro";
import PetHeroCard from "../components/dashboard/PetHeroCard.astro";
import UrgencyBar from "../components/dashboard/UrgencyBar.astro";
import QuestStrip from "../components/dashboard/QuestStrip.astro";
import PetScoreCompact from "../components/dashboard/PetScoreCompact.astro";
import QuickAccess from "../components/dashboard/QuickAccess.astro";
import CommunityMini from "../components/dashboard/CommunityMini.astro";
import CarePlanProgress from "../components/dashboard/CarePlanProgress.astro";
import { fetchMe } from "../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const { data, setCookie } = await fetchMe(cookieHeader);
if (setCookie) Astro.response.headers.append("set-cookie", setCookie);
if (!data) return Astro.redirect("/login");

const { user, pets } = data;
const displayName = user.name?.trim() || user.phone || "bạn";
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";
const primaryPet = pets[0];
// Link định danh để user (nhất là Zalo-thuần) tự đưa người trao bé.
// Dùng Astro.site (canonical "https://vowvet.monminpet.com" khai ở astro.config) — KHÔNG hardcode,
// KHÔNG dùng Astro.url.origin vì SSR sau proxy trả origin nội bộ (localhost) → link chia sẻ hỏng.
// Fallback Astro.url.origin nếu site chưa set. Trùng dạng route /transfer (v345) rút ra để tra recipient.
const shareProfileLink = `${Astro.site?.origin ?? Astro.url.origin}/heroes/profile/${user.id}`;

// ────────────────────────────────────────────────────────────
// Parallel fetch all dashboard data (fail-soft)
// ────────────────────────────────────────────────────────────
async function safeJson(url: string): Promise<any | null> {
  try {
    const r = await fetch(url, { headers: { cookie: cookieHeader } });
    if (!r.ok) return null;
    return await r.json();
  } catch { return null; }
}

let moodInfo: any = null;
let questsInfo: any = null;
let nudges: any = null;
let scoreInfo: any = null;
let community: any = null;
let urgentAlerts: any = null;
let carePlanSummary: any = null;
let carePlanTotalItems = 0;

if (primaryPet) {
  const [m, q, n, s, c, u, cps, cpp] = await Promise.all([
    safeJson(`${API_INTERNAL}/api/v1/mood/pets/${primaryPet.id}`),
    safeJson(`${API_INTERNAL}/api/v1/quests/pets/${primaryPet.id}/today`),
    safeJson(`${API_INTERNAL}/api/v1/nudges/pets/${primaryPet.id}`),
    safeJson(`${API_INTERNAL}/api/v1/pets/${primaryPet.id}/pet-score`),
    safeJson(`${API_INTERNAL}/api/v1/community/feed?limit=3`),
    safeJson(`${API_INTERNAL}/api/v1/alerts/urgent/${primaryPet.id}`),
    safeJson(`${API_INTERNAL}/api/v1/pets/${primaryPet.id}/care-plan/completions/summary`),
    safeJson(`${API_INTERNAL}/api/v1/pets/${primaryPet.id}/care-plan/v2/preview`),
  ]);
  moodInfo = m?.mood || null;
  questsInfo = q;
  nudges = n;
  scoreInfo = s;
  community = c;
  urgentAlerts = u;
  carePlanSummary = cps || null;
  if (cpp?.has_cache && cpp.plan) {
    // total items = eating + exercise + monitoring sections
    carePlanTotalItems =
      (cpp.plan.eating?.items?.length || 0) +
      (cpp.plan.exercise?.items?.length || 0) +
      (cpp.plan.monitoring?.length || 0);
  }
}

// Banner flags
const setupSuccess = new URL(Astro.request.url).searchParams.get("setup") === "success";
const welcomeNew = new URL(Astro.request.url).searchParams.get("welcome") === "1";

// Tier-close nudge (absorbed into Pet Score card as subtitle — TopNudge zone removed for unified UX)
const tierNudge = (nudges?.opportunities || []).find((o: any) => o.type === "tier_close") || null;
// Community events
const communityEvents = community?.events || [];
// Urgent alerts list
const urgentList = urgentAlerts?.alerts || [];

// FOSTER Hướng B — reclaim data cho chủ cũ (user-level, độc lập primaryPet)
const _reclaimSummary = await safeJson(`${API_INTERNAL}/api/v1/users/me/reclaim-summary`);
const reclaimEligible: any[] = _reclaimSummary?.eligible || [];
const reclaimResolved: any[] = _reclaimSummary?.resolved || [];

// FOSTER #3 — bé user vừa NHẬN (receiver) trong 7 ngày → card "bé mới nhận"
const _fosterReceived = await safeJson(`${API_INTERNAL}/api/v1/users/me/foster-received`);
const fosterReceived: any[] = _fosterReceived?.received || [];
---

<Layout title={`${primaryPet ? primaryPet.name + " · " : ""}VowVet`}>
  <main class="min-h-screen pb-24 relative" style="background: linear-gradient(180deg, #f5f1eb 0%, #fafaf7 30%, #fafafa 60%, #f5f1eb 100%);">

    <!-- ─── Sticky TopBar (shared component — GĐ1) ─── -->
    <TopBar pet={primaryPet} isAdmin={user.is_admin} />

    <div class="max-w-screen-md mx-auto px-4 py-5 space-y-4 sm:space-y-5">

      <!-- Welcome banner sau onboarding lần đầu -->
      {welcomeNew && (
        <div class="p-4 rounded-2xl bg-mmp-cream border-2 border-amber-200 flex items-center gap-3">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-white shadow-sm" style="color: var(--c-gold);">
            <FeatureIcon name="sparkles" class="w-6 h-6" strokeWidth={1.8} />
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-mmp-ink">Chào mừng đến VowVet, {displayName}!</p>
            <p class="text-xs text-mmp-ink/70 mt-0.5">Bé yêu đã được tạo. Bắt đầu chăm sóc bé nào.</p>
          </div>
        </div>
      )}

      {setupSuccess && (
        <div class="p-3 rounded-2xl bg-emerald-50 border border-emerald-200 text-sm text-emerald-800 inline-flex items-center gap-2">
          <FeatureIcon name="check" class="w-4 h-4 text-emerald-600" strokeWidth={3} />
          Đã setup email + mật khẩu. Lần sau bạn có thể đăng nhập 1-click.
        </div>
      )}

      <!-- FOSTER Hướng B — banner "yêu cầu đã được duyệt" (chủ cũ) -->
      {reclaimResolved.map((n: any) => (
        <div class="p-4 rounded-2xl bg-emerald-50 border border-emerald-200 flex items-center justify-between gap-3" data-reclaim-notif={n.id}>
          <p class="text-emerald-800 text-sm flex-1 min-w-0">
            ✅ Yêu cầu lấy lại bé <strong>{n.pet_name}</strong> ({n.passport_code}) đã được duyệt. Bé đã về với bạn!
          </p>
          <button type="button" data-reclaim-dismiss={n.id} aria-label="Đóng" class="shrink-0 text-emerald-500 hover:text-emerald-700 text-lg leading-none">✕</button>
        </div>
      ))}

      <!-- FOSTER Hướng B — card "yêu cầu lấy lại bé" (chủ cũ, trong 72h) -->
      {reclaimEligible.map((e: any) => (
        <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-2xl p-4 shadow-sm flex items-center gap-4" data-reclaim-card={e.pet_id}>
          <div class="w-11 h-11 rounded-full bg-amber-100 flex items-center justify-center text-xl flex-shrink-0">🔄</div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-900 text-sm">Bé <span class="text-amber-700">{e.pet_name}</span> đang chờ bạn lấy lại</p>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="text-xs bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full font-mono font-medium">{e.passport_code}</span>
              <span class="text-xs text-gray-400">·</span>
              <span class="text-xs text-gray-500">Còn {e.hours_left}h để yêu cầu</span>
            </div>
            <p data-reclaim-msg={e.pet_id} style="display:none;" class="text-xs mt-1"></p>
          </div>
          <button type="button" data-reclaim-pet={e.pet_id} data-reclaim-name={e.pet_name} class="flex-shrink-0 bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold px-4 py-2 rounded-xl transition-colors whitespace-nowrap">
            Lấy lại bé →
          </button>
          <button type="button" data-dismiss-pet={e.pet_id} aria-label="Ẩn thẻ" class="flex-shrink-0 text-gray-400 hover:text-gray-600 text-lg leading-none">✕</button>
        </div>
      ))}

      <!-- FOSTER #3 — card "bé mới nhận" (receiver): vừa nhận bé → nhắn người trao -->
      {fosterReceived.map((h: any) => (
        <div class="bg-gradient-to-br from-blue-50 to-emerald-50 border border-blue-200 rounded-2xl p-4 shadow-sm flex items-start gap-3" data-foster-card={h.handover_id}>
          <span class="w-11 h-11 rounded-full bg-white border-2 border-blue-100 flex items-center justify-center text-blue-500 flex-shrink-0">
            <FeatureIcon name="paw" class="w-6 h-6" />
          </span>
          <div class="flex-1 min-w-0">
            <span class="inline-block text-[10px] font-bold text-blue-600 bg-blue-100 px-2 py-0.5 rounded mb-1">Bé mới nhận</span>
            <p class="text-sm font-semibold text-gray-900 leading-snug">Bạn vừa nhận bé <span class="text-blue-700">{h.pet_name}</span> từ <span class="text-blue-700">{h.giver_name}</span></p>
            <p class="text-xs text-gray-500 mt-0.5 mb-2.5">Nhắn tin để hỏi thăm về bé nhé</p>
            <button type="button" data-foster-msg={h.handover_id} class="inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-xl transition-colors">
              <FeatureIcon name="message-circle" class="w-4 h-4" strokeWidth={2} />
              Nhắn tin
            </button>
          </div>
          <button type="button" data-dismiss-foster={h.handover_id} aria-label="Ẩn thẻ" class="flex-shrink-0 text-gray-400 hover:text-gray-600 text-lg leading-none">✕</button>
        </div>
      ))}

      {!primaryPet ? (
        user.is_foster_carer ? (
          <!-- Empty state — foster-carer chưa nhận bé nào -->
          <section class="bg-white rounded-3xl border border-mmp-cream p-10 text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-mmp-cream mb-4 text-mmp-ink/40">
              <FeatureIcon name="paw" class="w-10 h-10" />
            </div>
            <h2 class="text-xl font-bold text-mmp-ink mb-2">Bạn chưa nhận bé nào</h2>
            <p class="text-sm text-mmp-ink/70 mb-6">Xem các bé đang cần người nhận nuôi tạm và kết nối với chủ hiện tại của bé.</p>
            <a href="/foster" class="inline-flex items-center gap-2 bg-mmp-ink hover:bg-mmp-ink/90 text-white font-bold px-6 py-3 rounded-xl transition">
              <FeatureIcon name="paw" class="w-4 h-4" strokeWidth={2.5} />
              Xem các bé đang cần nhận nuôi
            </a>

            {/* Chia sẻ link nhận bé (v346) — user Zalo-thuần tự lấy link định danh đưa người trao */}
            <div class="mt-6 pt-6 border-t border-mmp-cream text-center">
              <p class="text-sm font-semibold text-mmp-ink">Có người muốn trao bé cho bạn?</p>
              <p class="text-xs text-mmp-ink/60 mt-0.5 mb-3">Gửi link này để họ trao bé cho bạn — dùng được cả khi bạn đăng nhập bằng Zalo.</p>
              <button type="button" id="share-link-btn" data-share-link={shareProfileLink}
                class="inline-flex items-center gap-2 bg-white border-2 border-mmp-ink/15 hover:border-mmp-ink/30 text-mmp-ink font-bold px-6 py-3 rounded-xl transition">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span id="share-link-label">Chia sẻ để nhận bé</span>
              </button>
              {/* Fallback: clipboard hay bị chặn trong webview (mở link trong app Zalo) → hiện ô text để copy tay */}
              <div id="share-link-fallback" style="display:none;" class="mt-3 text-left">
                <p class="text-xs text-mmp-ink/60 mb-1">Không copy được — bôi đen link rồi copy tay:</p>
                <input id="share-link-input" type="text" readonly value={shareProfileLink}
                  class="w-full px-3 py-2 rounded-lg border border-mmp-cream text-xs font-mono text-mmp-ink bg-mmp-cream/40 focus:outline-none focus:border-mmp-ink/30" />
              </div>
            </div>

            <div class="mt-4">
              <a href="/pets/new" class="text-xs text-mmp-ink/50 hover:text-mmp-ink underline">hoặc thêm bé của riêng bạn</a>
            </div>
          </section>
        ) : (
          <!-- Empty state — no pets yet -->
          <section class="bg-white rounded-3xl border border-mmp-cream p-10 text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-mmp-cream mb-4 text-mmp-ink/40">
              <FeatureIcon name="paw" class="w-10 h-10" />
            </div>
            <h2 class="text-xl font-bold text-mmp-ink mb-2">Chưa có pet nào</h2>
            <p class="text-sm text-mmp-ink/70 mb-6">Thêm bé đầu tiên để bắt đầu hành trình chăm sóc.</p>
            <a href="/pets/new" class="inline-flex items-center gap-2 bg-mmp-ink hover:bg-mmp-ink/90 text-white font-bold px-6 py-3 rounded-xl transition">
              <FeatureIcon name="plus" class="w-4 h-4" strokeWidth={2.5} />
              Thêm pet đầu tiên
            </a>
          </section>
        )
      ) : (
        <>
          <!-- ─── ZONE 1: Pet Hero (dark ink WOW, clean avatar no overlay) ─── -->
          {/* occupiedLinks = mọi destination đã render ở dashboard khác (QuestStrip + QuickAccess +
              /quests header) → PetHeroCard CTA sẽ pick action KHÔNG trùng */}
          <PetHeroCard
            pet={primaryPet}
            mood={moodInfo}
            occupiedLinks={[
              `/pets/${primaryPet.id}`,                                 // QuickAccess "Hồ sơ bé"
              `/pets/${primaryPet.id}/quests`,                          // QuestStrip header
              `/pets/${primaryPet.id}/diary`,                           // QuickAccess "Nhật ký"
              "/vaccines",                                              // QuickAccess "Vaccine"
              "/food-brands",                                           // QuickAccess "Dinh dưỡng"
              "/playdate",                                              // QuickAccess "Tìm bạn chơi"
              "/emergency",                                             // QuickAccess "Cấp cứu"
              // Quest CTA targets (questsInfo could route to these too)
              ...(questsInfo?.quests || []).map((q: any) => q.cta_link).filter(Boolean),
            ]}
          />

          <!-- ─── ZONE 2: Urgency (conditional) ─── -->
          {urgentList.length > 0 && <UrgencyBar alerts={urgentList} />}

          <!-- ─── ZONE 3: Quest (3 quests/day; trifecta bonus +50 when 3/3) ─── -->
          {questsInfo?.quests && questsInfo.quests.length > 0 && (
            <QuestStrip
              quests={questsInfo.quests}
              completed_count={questsInfo.completed_count || 0}
              petId={primaryPet.id}
              trifecta_bonus={questsInfo.trifecta_bonus || 50}
            />
          )}

          <!-- ─── ZONE 4: Pet Score CENTERPIECE (absorbs tier nudge as subtitle) ─── -->
          {scoreInfo && (
            <PetScoreCompact
              petId={primaryPet.id}
              score={scoreInfo.score}
              levelId={scoreInfo.level?.id || "bronze"}
              levelEmoji={scoreInfo.level?.emoji}
              levelNameVi={scoreInfo.level?.name_vi}
              breakdown={scoreInfo.breakdown}
              tierNudge={tierNudge}
            />
          )}

          <!-- ─── ZONE 5.5: Care Plan progress (Phase 2 of Care Plan WOW) ─── -->
          {carePlanSummary && (
            <CarePlanProgress
              petId={primaryPet.id}
              petName={primaryPet.name}
              completedCount={carePlanSummary.completed_count || 0}
              totalItems={carePlanTotalItems}
              trifectaGranted={!!carePlanSummary.trifecta_granted}
            />
          )}

          <!-- ─── ZONE 6: Quick access ─── -->
          <QuickAccess petId={primaryPet.id} />

          <!-- ─── ZONE 7: Community mini feed ─── -->
          {communityEvents.length > 0 && <CommunityMini events={communityEvents} />}

          <!-- Multi-pet switcher (if user has ≥2 pets) -->
          {pets.length >= 1 && (
            <section class="space-y-3">
              <div class="flex items-center justify-between">
                <h2 class="font-bold text-mmp-ink">Pet của bạn ({pets.length})</h2>
                <a href="/pets/new" class="text-xs font-semibold transition" style="color: var(--c-gold);">+ Thêm pet</a>
              </div>
              <div class="grid grid-cols-3 sm:grid-cols-4 gap-2 sm:gap-3">
                {pets.slice(0, 8).map((p: any) => (
                  <a href={`/pets/${p.id}`} class="block bg-white rounded-2xl border border-mmp-cream hover:border-mmp-ink hover:shadow transition overflow-hidden">
                    <div class="aspect-square bg-mmp-cream flex items-center justify-center text-mmp-ink/30">
                      {p.photo_url ? (
                        <img src={p.photo_url} alt={p.name} class="w-full h-full object-cover" loading="lazy" />
                      ) : (
                        <FeatureIcon name="paw" class="w-8 h-8" />
                      )}
                    </div>
                    <p class="text-xs font-medium text-mmp-ink text-center px-1 py-1.5 truncate">{p.name}</p>
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      )}

      {/* Chat hỗ trợ VowVet — entry point (support/foster chat, KHÁC telehealth) */}
      <button onclick="startSupportChat()" class="w-full flex items-center gap-3 p-4 bg-white rounded-2xl border border-gray-100 hover:border-[#d4a520] transition-colors text-left mt-4">
        <span class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center text-[#d4a520] flex-shrink-0">
          <FeatureIcon name="mail" class="w-5 h-5" strokeWidth={1.7} />
        </span>
        <div class="min-w-0">
          <p class="font-semibold text-sm text-gray-900">Nhắn tin với VowVet</p>
          <p class="text-xs text-gray-400">Hỗ trợ tính năng · Giải đáp thắc mắc</p>
        </div>
        <span class="ml-auto text-gray-300">→</span>
      </button>
      <script is:inline>
        async function startSupportChat() {
          try {
            var r = await fetch("/api/v1/conversations/support", { method: "POST", credentials: "include" });
            var j = await r.json();
            if (j.conversationId) window.location.href = "/messages/" + j.conversationId;
            else alert("Không tạo được hội thoại");
          } catch (e) { alert("Lỗi kết nối"); }
        }
      </script>

      <!-- ─── Ecosystem nav ─── -->
      <div class="pt-2">
        <EcosystemNav active="vowvet" />
      </div>

      <!-- Footer — emphasised quick access (Cấp cứu + FAQ) + secondary links -->
      <footer class="pt-6 pb-2">
        <!-- Row 1: 2 PROMINENT action pills (Cấp cứu red + FAQ gold) -->
        <div class="grid grid-cols-2 gap-3 mb-4">
          <a href="/emergency"
             class="flex items-center justify-center gap-2 px-4 py-3 rounded-2xl bg-red-50 border border-red-200 text-red-700 hover:bg-red-600 hover:text-white hover:border-red-600 font-semibold text-sm transition-all">
            <FeatureIcon name="siren" class="w-4 h-4" strokeWidth={2} />
            <span>Cấp cứu 24/7</span>
          </a>
          <a href="/faq"
             class="flex items-center justify-center gap-2 px-4 py-3 rounded-2xl bg-mmp-cream border border-amber-200 hover:border-mmp-ink hover:shadow-sm font-semibold text-sm transition-all"
             style="color: var(--c-gold);">
            <FeatureIcon name="search" class="w-4 h-4" strokeWidth={2} />
            <span class="text-mmp-ink">Câu hỏi thường gặp</span>
          </a>
        </div>

        <!-- Row 2: secondary links (smaller, muted) — NOTE: Cài đặt removed (already in top nav ⚙) -->
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-xs text-mmp-ink/55">
          <a href="/why-vowvet" class="hover:text-mmp-ink transition">Vì sao VowVet</a>
          <span class="text-mmp-ink/25">·</span>
          <a href="/insurance" class="hover:text-mmp-ink transition">Bảo hiểm</a>
          <span class="text-mmp-ink/25">·</span>
          <a href="https://bio.monminpet.com" target="_blank" rel="noopener" class="hover:text-mmp-ink transition inline-flex items-center gap-1">
            Tư vấn BSTY
            <FeatureIcon name="external" class="w-3 h-3" strokeWidth={2} />
          </a>
          <span class="text-mmp-ink/25">·</span>
          <a href="/logout" class="hover:text-mmp-ink transition">Đăng xuất</a>
        </div>

        <p class="text-center mt-3 text-[10px] text-mmp-ink/45">
          VowVet by Mon Min Pet · © 2026 CTY TNHH Duy Trường Phát
        </p>
      </footer>
    </div>
  </main>

  <!-- Auto-scroll to quest widget when ?focus=quests in URL (from /pets/[id]/quests redirect) -->
  <script is:inline>
    (() => {
      try {
        const params = new URLSearchParams(window.location.search);
        if (params.get("focus") !== "quests") return;
        // Defer to next tick so Alpine has time to hydrate the widget
        requestAnimationFrame(() => {
          const el = document.querySelector('[data-widget="quests"]');
          if (!el) return;
          el.scrollIntoView({ behavior: "smooth", block: "center" });
          // Brief gold flash to draw the eye (CSS animation already defined in global.css)
          el.classList.add("animate-progress-pulse");
          setTimeout(() => el.classList.remove("animate-progress-pulse"), 2400);
        });
      } catch (_) {}
    })();
  </script>

  <!-- FOSTER Hướng B — chủ cũ gửi yêu cầu lấy lại + tắt banner "đã duyệt" -->
  <script is:inline>
    (() => {
      document.addEventListener("click", async (ev) => {
        var t = ev.target;
        if (!t || !t.closest) return;

        // Nút "Yêu cầu lấy lại"
        var reqBtn = t.closest("[data-reclaim-pet]");
        if (reqBtn) {
          var petId = reqBtn.getAttribute("data-reclaim-pet");
          var name = reqBtn.getAttribute("data-reclaim-name") || "bé";
          if (!confirm("Gửi yêu cầu lấy lại bé " + name + "?")) return;
          var msg = document.querySelector('[data-reclaim-msg="' + petId + '"]');
          reqBtn.disabled = true;
          try {
            var r = await fetch("/api/v1/pets/" + petId + "/reclaim-request", { method: "POST", credentials: "include" });
            var j = await r.json().catch(function () { return {}; });
            if (r.ok && j.ok) {
              if (msg) { msg.textContent = "✅ Đã gửi yêu cầu. Admin sẽ xét duyệt sớm."; msg.style.color = "#047857"; msg.style.display = "block"; }
              reqBtn.remove();
            } else {
              var reason = (j.error && j.error.message) || ("Thất bại (" + r.status + ")");
              if (msg) { msg.textContent = "⚠️ " + reason; msg.style.color = "#dc2626"; msg.style.display = "block"; }
              reqBtn.disabled = false;
            }
          } catch (e) {
            if (msg) { msg.textContent = "⚠️ Lỗi kết nối"; msg.style.color = "#dc2626"; msg.style.display = "block"; }
            reqBtn.disabled = false;
          }
          return;
        }

        // Nút ✕ ẩn card "yêu cầu lấy lại" (sessionStorage, chỉ phiên này)
        var dp = t.closest("[data-dismiss-pet]");
        if (dp) {
          var pid = dp.getAttribute("data-dismiss-pet");
          try {
            var arr = JSON.parse(sessionStorage.getItem("dismissed_reclaims") || "[]");
            if (arr.indexOf(pid) === -1) { arr.push(pid); sessionStorage.setItem("dismissed_reclaims", JSON.stringify(arr)); }
          } catch (e) {}
          var c2 = dp.closest("[data-reclaim-card]");
          if (c2) { c2.style.transition = "opacity .2s"; c2.style.opacity = "0"; setTimeout(function () { c2.remove(); }, 200); }
          return;
        }

        // Nút ✕ tắt banner "đã duyệt"
        var dis = t.closest("[data-reclaim-dismiss]");
        if (dis) {
          var requestId = Number(dis.getAttribute("data-reclaim-dismiss"));
          var card = dis.closest("[data-reclaim-notif]");
          try {
            await fetch("/api/v1/users/me/notifications/mark-read", {
              method: "POST", credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ requestId: requestId }),
            });
          } catch (e) {}
          if (card) { card.style.transition = "opacity .2s"; card.style.opacity = "0"; setTimeout(function () { card.remove(); }, 200); }
          return;
        }
      });

      // On load: ẩn ngay card đã dismiss trong phiên này
      try {
        JSON.parse(sessionStorage.getItem("dismissed_reclaims") || "[]").forEach(function (pid) {
          var el = document.querySelector('[data-reclaim-card="' + pid + '"]');
          if (el) el.remove();
        });
      } catch (e) {}
    })();
  </script>

  <!-- FOSTER #3 — card "bé mới nhận" (receiver): mở chat foster (B1) + dismiss (sessionStorage, giống reclaim) -->
  <script is:inline>
    (() => {
      document.addEventListener("click", async (ev) => {
        var t = ev.target;
        if (!t || !t.closest) return;

        // Nút "Nhắn tin" → get-or-create foster conv (B1) → phòng chat
        var mb = t.closest("[data-foster-msg]");
        if (mb) {
          var hid = mb.getAttribute("data-foster-msg");
          mb.disabled = true;
          try {
            var r = await fetch("/api/v1/conversations/foster", {
              method: "POST", credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ handover_id: Number(hid) }),
            });
            var j = await r.json().catch(function () { return {}; });
            if (r.ok && j.conversationId) { window.location.href = "/messages/" + j.conversationId; }
            else { window.location.href = "/messages"; }
          } catch (e) { window.location.href = "/messages"; }
          return;
        }

        // Nút ✕ ẩn card "bé mới nhận" (sessionStorage, chỉ phiên này — giống dismissed_reclaims)
        var df = t.closest("[data-dismiss-foster]");
        if (df) {
          var fid = df.getAttribute("data-dismiss-foster");
          try {
            var arr = JSON.parse(sessionStorage.getItem("dismissed_fosters") || "[]");
            if (arr.indexOf(fid) === -1) { arr.push(fid); sessionStorage.setItem("dismissed_fosters", JSON.stringify(arr)); }
          } catch (e) {}
          var card = df.closest("[data-foster-card]");
          if (card) { card.style.transition = "opacity .2s"; card.style.opacity = "0"; setTimeout(function () { card.remove(); }, 200); }
          return;
        }
      });

      // On load: ẩn ngay card foster đã dismiss trong phiên này
      try {
        JSON.parse(sessionStorage.getItem("dismissed_fosters") || "[]").forEach(function (fid) {
          var el = document.querySelector('[data-foster-card="' + fid + '"]');
          if (el) el.remove();
        });
      } catch (e) {}
    })();
  </script>

  <!-- Chia sẻ link nhận bé (v346): copy vào clipboard; fallback ô text nếu clipboard bị chặn (webview Zalo) -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('share-link-btn');
      if (!btn) return;
      var label = document.getElementById('share-link-label');
      var fallback = document.getElementById('share-link-fallback');
      var input = document.getElementById('share-link-input');
      var link = btn.getAttribute('data-share-link') || '';
      var resetTimer = null;
      function showFallback() {
        if (fallback) fallback.style.display = 'block';
        if (input) { try { input.focus(); input.select(); } catch (e) {} }
      }
      btn.addEventListener('click', function () {
        if (!navigator.clipboard || !navigator.clipboard.writeText) { showFallback(); return; }
        navigator.clipboard.writeText(link).then(function () {
          if (label) label.textContent = 'Đã copy!';
          if (resetTimer) clearTimeout(resetTimer);
          resetTimer = setTimeout(function () { if (label) label.textContent = 'Chia sẻ để nhận bé'; }, 2000);
        }).catch(function () { showFallback(); });
      });
    })();
  </script>
</Layout>
