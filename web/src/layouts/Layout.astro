---
/**
 * Layout chính cho mọi trang VowVet.
 * Bao gồm: meta tags VN, Alpine.js, global CSS, PWA manifest tự inject.
 *
 * v207: Quick-nav floating đã gỡ — mỗi page dùng header ngữ cảnh (back+title),
 * dashboard dùng TopBar. Layout chỉ còn meta/PWA/SW shell.
 */
import BottomNav from "../components/BottomNav.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "VowVet — Người bạn đồng hành sức khỏe cho thú cưng",
  description = "Nền tảng chăm sóc sức khỏe thú cưng thông minh dành cho người Việt",
} = Astro.props;

const locale = Astro.locals.locale ?? "vi";

// v269: nút "Reset test" CHỈ hiện ở môi trường dev. `import.meta.env.DEV` được
// thay tĩnh lúc build → ở production build thành false và bị strip hoàn toàn.
// Thêm điều kiện đã đăng nhập (không hiện ở /login).
const showDevTools = import.meta.env.DEV && !!Astro.locals.user && import.meta.env.PUBLIC_ENABLE_DEVTOOLS === "true";

// v289: Bottom-nav app-style — chỉ hiện khi đã đăng nhập + KHÔNG ở trang public/auth/error.
// Gate:
//  - Error pages: Astro.routePattern '/404' | '/500' (bắt cả unknown-path fallback,
//    vì Astro.response.status đọc 200 trong Layout — adapter set 404 sau render).
//  - Public/auth exact: landing '/', /login, /onboarding, /offline.
//  - Public-share prefix: /login /p/ /memorial/ /personality-card/.
const navPath = Astro.url.pathname;
const routePattern = Astro.routePattern ?? "";
const NAV_HIDDEN_ROUTES = ["/404", "/500"];
const NAV_HIDDEN_EXACT = ["/", "/login", "/onboarding", "/offline"];
const NAV_HIDDEN_PREFIX = ["/login", "/p/", "/memorial/", "/personality-card/"];
const showBottomNav =
  !!Astro.locals.user &&
  !NAV_HIDDEN_ROUTES.includes(routePattern) &&
  !NAV_HIDDEN_EXACT.includes(navPath) &&
  !NAV_HIDDEN_PREFIX.some((p) => navPath.startsWith(p));
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />

    <!-- Brand icons: favicon (ink+gold V) + apple-touch-icon (full Mon Min Pet logo) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo-mmp.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Browser tab + PWA -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="VowVet" />
    <meta name="application-name" content="VowVet by Mon Min Pet" />

    <!-- Default Open Graph (per-page can override via head slot) -->
    <meta property="og:site_name" content="VowVet by Mon Min Pet" />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="vi_VN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og-image.svg" />

    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <slot name="head" />
  </head>
  <body class:list={[showBottomNav && "has-bottom-nav"]}>
    <slot />

    {showBottomNav && <BottomNav path={navPath} />}

    {showDevTools && (
      <button
        id="dev-reset-btn"
        type="button"
        title="DEV: Reset tài khoản test đang đăng nhập về mới toanh (xóa pet + onboarding). Không ảnh hưởng tài khoản khác."
        class="no-print"
        style="position:fixed;left:12px;bottom:12px;z-index:9999;display:inline-flex;align-items:center;gap:6px;padding:7px 12px;border-radius:9999px;background:#1f1147;color:#fff;font-size:12px;font-weight:700;border:1px solid rgba(255,255,255,.28);box-shadow:0 4px 14px rgba(0,0,0,.25);cursor:pointer;opacity:.82;font-family:system-ui,-apple-system,sans-serif"
      >
        🔄 Reset test
      </button>
    )}

    <!-- v136: SW update toast — hiển thị khi service worker activate phiên bản mới.
         Solve root cause "user kẹt SW cũ" (CONTEXT_SYNC #3.1). -->
    <div
      id="sw-update-toast"
      class="sw-update-toast no-print"
      role="status"
      aria-live="polite"
      hidden
    >
      <span class="sw-update-toast__icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
          <path d="M3 21v-5h5" />
          <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
          <path d="M21 3v5h-5" />
        </svg>
      </span>
      <span class="sw-update-toast__text">Đã có bản cập nhật mới</span>
      <button type="button" class="sw-update-toast__btn" id="sw-update-toast-btn" aria-label="Nhấn để cập nhật ngay">
        Cập nhật
      </button>
      <button type="button" class="sw-update-toast__close" id="sw-update-toast-close" aria-label="Đóng">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <!-- Alpine.js (defer cho perf) -->
    <!-- v58: Collapse plugin — load BEFORE Alpine core để auto-register x-collapse directive (Pet Detail accordions) -->
    <script
      is:inline
      defer
      src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.14.7/dist/cdn.min.js"></script>
    <script
      is:inline
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.7/dist/cdn.min.js"></script>

    <!-- M11: PWA service worker register + install prompt capture (global window.__pwa) -->
    <script is:inline>
      (() => {
        window.__pwa = { deferredPrompt: null, installed: false };
        if ("serviceWorker" in navigator) {
          window.addEventListener("load", () => {
            navigator.serviceWorker
              .register("/sw.js", { scope: "/" })
              .then((reg) => {
                // v136: Detect waiting SW (new version installed but not yet activated)
                if (reg.waiting) showSWToast();
                reg.addEventListener("updatefound", () => {
                  const newWorker = reg.installing;
                  if (!newWorker) return;
                  newWorker.addEventListener("statechange", () => {
                    if (
                      newWorker.state === "installed" &&
                      navigator.serviceWorker.controller
                    ) {
                      showSWToast();
                    }
                  });
                });
              })
              .catch((err) => console.warn("[sw] register failed:", err));
          });

          // v136: SW activate broadcast → show toast immediately
          navigator.serviceWorker.addEventListener("message", (event) => {
            if (event.data && event.data.type === "SW_UPDATED") {
              showSWToast();
            }
          });

          // v304: gộp — chống reload-loop khi NÂNG SW + giữ card scan (?scan=1).
          // hadController chụp TRƯỚC khi SW đổi → chỉ reload khi nâng cấp thật, bỏ qua fresh-install.
          const hadController = !!navigator.serviceWorker?.controller;
          let refreshing = false;
          navigator.serviceWorker?.addEventListener("controllerchange", () => {
            if (new URLSearchParams(location.search).get("scan") === "1") return; // vừa quét → giữ card
            if (refreshing) return;               // chống LOOP: reload đúng 1 lần
            refreshing = true;
            if (hadController) location.reload();  // chỉ reload khi nâng cấp thật
          });
        }

        // v136: Toast helpers — global so future Alpine components can dismiss/show
        function showSWToast() {
          const el = document.getElementById("sw-update-toast");
          if (!el) return;
          el.hidden = false;
          // Force reflow then add class for transition
          requestAnimationFrame(() => el.classList.add("is-visible"));
        }
        function hideSWToast() {
          const el = document.getElementById("sw-update-toast");
          if (!el) return;
          el.classList.remove("is-visible");
          setTimeout(() => {
            el.hidden = true;
          }, 240);
        }
        window.__swToast = { show: showSWToast, hide: hideSWToast };

        // Wire buttons after DOM ready
        document.addEventListener("DOMContentLoaded", () => {
          const btn = document.getElementById("sw-update-toast-btn");
          const close = document.getElementById("sw-update-toast-close");
          btn?.addEventListener("click", () => {
            // Tell waiting SW to activate immediately; controllerchange handler reloads
            navigator.serviceWorker
              ?.getRegistration()
              .then((reg) => {
                if (reg?.waiting) {
                  reg.waiting.postMessage({ type: "SKIP_WAITING" });
                } else {
                  // No waiting worker — just reload to grab fresh assets
                  window.location.reload();
                }
              })
              .catch(() => window.location.reload());
          });
          close?.addEventListener("click", hideSWToast);
        });

        // Capture beforeinstallprompt — show button trong /settings sau đó user click
        window.addEventListener("beforeinstallprompt", (e) => {
          e.preventDefault();
          window.__pwa.deferredPrompt = e;
          // Dispatch custom event để Alpine components subscribe
          window.dispatchEvent(new CustomEvent("pwa-installable"));
        });
        window.addEventListener("appinstalled", () => {
          window.__pwa.deferredPrompt = null;
          window.__pwa.installed = true;
          window.dispatchEvent(new CustomEvent("pwa-installed"));
        });
      })();
    </script>

    <!-- v269: DEV-only reset-test button wiring. No-op nếu nút không render (production). -->
    <script is:inline>
      (() => {
        const b = document.getElementById("dev-reset-btn");
        if (!b) return;
        b.addEventListener("click", async () => {
          if (!confirm("DEV — Reset tài khoản test này về MỚI TOANH?\n\n• Xóa toàn bộ pet của CHÍNH tài khoản đang đăng nhập\n• Reset onboarding (chạy lại từ màn \"Thêm bé đầu tiên\")\n\nKhông ảnh hưởng tài khoản khác. Tiếp tục?")) return;
          const old = b.textContent;
          b.disabled = true;
          b.textContent = "⏳ Đang reset…";
          try {
            const res = await fetch("/api/v1/dev/reset-onboarding", { method: "POST", credentials: "include" });
            if (!res.ok) {
              alert("Reset thất bại (HTTP " + res.status + "). Endpoint chỉ hoạt động ở môi trường dev/local.");
              b.disabled = false; b.textContent = old; return;
            }
            window.location.href = "/onboarding";
          } catch (e) {
            alert("Lỗi kết nối khi reset. Thử lại nhé.");
            b.disabled = false; b.textContent = old;
          }
        });
      })();
    </script>

    <!-- v276: SKELETON chuyển trang (perceived perf) — hiện khi tap link nội bộ, ẩn khi trang mới render. Tông brand cream/gold. -->
    <div id="nav-skeleton" class="nav-skeleton no-print" aria-hidden="true" hidden>
      <div class="nav-skeleton__inner">
        <div class="sk-bar"></div>
        <div class="sk-card sk-hero"></div>
        <div class="sk-card"></div>
        <div class="sk-grid">
          <div class="sk-tile"></div><div class="sk-tile"></div><div class="sk-tile"></div>
        </div>
        <div class="sk-card"></div>
      </div>
    </div>
    <script is:inline>
      (() => {
        const sk = document.getElementById("nav-skeleton");
        if (!sk) return;
        let showT = null, hideT = null;
        const hide = () => { clearTimeout(showT); clearTimeout(hideT); sk.hidden = true; };
        const show = () => { clearTimeout(hideT); sk.hidden = false; hideT = setTimeout(hide, 10000); };
        // Trang mới render / bfcache restore → ẩn skeleton
        window.addEventListener("pageshow", hide);
        // Tap link nội bộ → hiện skeleton sau 120ms (tránh nháy khi điều hướng tức thì)
        document.addEventListener("click", (e) => {
          const a = e.target && e.target.closest && e.target.closest("a[href]");
          if (!a || e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          if (a.getAttribute("target") === "_blank" || a.hasAttribute("download")) return;
          const href = a.getAttribute("href") || "";
          if (!href.startsWith("/") || href.startsWith("//") || href.startsWith("#")) return;
          if (href === location.pathname + location.search) return;
          clearTimeout(showT);
          showT = setTimeout(show, 120);
        }, true);
      })();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  /* v276: skeleton chuyển trang — tông brand cream/gold, shimmer; reduced-motion → tĩnh */
  .nav-skeleton { position: fixed; inset: 0; z-index: 9998; background: #faf6ee; overflow: hidden; padding: 16px; }
  .nav-skeleton[hidden] { display: none; }
  .nav-skeleton__inner { max-width: 640px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; padding-top: 10px; }
  .nav-skeleton .sk-bar { height: 44px; border-radius: 14px; }
  .nav-skeleton .sk-card { height: 92px; border-radius: 20px; }
  .nav-skeleton .sk-hero { height: 150px; }
  .nav-skeleton .sk-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .nav-skeleton .sk-tile { height: 78px; border-radius: 16px; }
  .nav-skeleton .sk-bar,
  .nav-skeleton .sk-card,
  .nav-skeleton .sk-tile {
    background: linear-gradient(100deg, rgba(180,134,8,.07) 30%, rgba(180,134,8,.17) 50%, rgba(180,134,8,.07) 70%);
    background-size: 200% 100%;
    animation: sk-shimmer 1.3s ease-in-out infinite;
  }
  @keyframes sk-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  @media (prefers-reduced-motion: reduce) {
    .nav-skeleton .sk-bar,
    .nav-skeleton .sk-card,
    .nav-skeleton .sk-tile { animation: none; background: rgba(180,134,8,.11); }
  }
</style>
