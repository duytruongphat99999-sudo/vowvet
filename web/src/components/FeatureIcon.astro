{/* ───────── Marketing ───────── */}
{name === "passport" && (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="12" cy="10" r="3"/><path d="M7 16h10"/><path d="M9 19h6"/>
