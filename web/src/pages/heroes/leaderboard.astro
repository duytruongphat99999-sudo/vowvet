---
/**
 * /heroes/leaderboard — Pet Heroes Hall of Fame (PUBLIC).
 *
 * 3 tab (sort mode, client-side): Tất cả / Cứu hộ / Nuôi tạm.
 * Podium "sân khấu" (spotlight + huy chương kim loại + vương miện + avatar ring xoay).
 */
import Layout from "../../layouts/Layout.astro";
import { getZaloLink } from "../../../../shared/contact-info.ts";

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// 3 tab là SORT MODE (client-side) — fetch 1 lần all-time, limit rộng.
let entries: any[] = [];
try {
  const r = await fetch(`${API_INTERNAL}/api/v1/heroes/leaderboard?period=all&limit=50`);
  if (r.ok) entries = (await r.json()).entries || [];
} catch (_) {}

const initialData = JSON.stringify({
  entries,
  zaloUrl: getZaloLink(),
});
---

<Layout title="Pet Heroes · VowVet" description="Bảng vinh danh những người đã giúp pet tìm về nhà">
  <main class="min-h-screen bg-mmp-cream px-4 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`heroesPage(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href="/dashboard" class="text-sm text-mmp-brown hover:text-mmp-ink">← Dashboard</a>
        <h1 class="text-lg font-bold text-mmp-ink">Pet Heroes</h1>
        <a href="/lost/nearby" class="text-xs bg-white border border-black/10 px-2.5 py-1 rounded-lg text-mmp-brown">Pet mất</a>
      </header>

      <!-- Hero banner -->
      <div class="text-center py-7 px-4 mb-5 rounded-3xl bg-white border border-black/5 shadow-sm">
        <span class="inline-block text-[11px] font-bold tracking-widest uppercase text-mmp-brown mb-2">Vinh danh</span>
        <h2 class="font-display italic text-3xl font-semibold text-mmp-ink">Hall of Fame</h2>
        <p class="text-sm text-mmp-brown mt-1.5">Những người đã giúp pet tìm về nhà</p>
      </div>

      <!-- Category tabs (sort mode) -->
      <div class="flex bg-white rounded-2xl p-1 mb-6 shadow-sm border border-black/5">
        <template x-for="t in [{key:'all',label:'Tất cả'},{key:'rescue',label:'Cứu hộ'},{key:'foster',label:'Nuôi tạm'}]" :key="t.key">
          <button @click="setMode(t.key)"
            :class="mode === t.key ? 'bg-mmp-gold text-mmp-ink shadow' : 'text-mmp-brown'"
            class="flex-1 py-2 rounded-xl text-sm font-bold transition">
            <span x-text="t.label"></span>
          </button>
        </template>
      </div>

      <!-- Empty -->
      <template x-if="list.length === 0">
        <div class="bg-white rounded-2xl p-8 text-center border border-black/5">
          <div class="w-12 h-12 rounded-full bg-mmp-cream mx-auto mb-3 flex items-center justify-center">
            <span class="w-3 h-3 rounded-full bg-mmp-gold"></span>
          </div>
          <p class="text-base font-bold text-mmp-ink" x-text="mode === 'foster' ? 'Chưa có người nuôi tạm' : 'Chưa có Hero nào'"></p>
          <p class="text-sm text-mmp-brown mt-1">Hãy là người đầu tiên — bật thông báo Pet Lost gần bạn.</p>
          <a href="/lost/nearby" class="inline-block mt-4 bg-mmp-ink hover:bg-mmp-ink/90 text-white font-bold px-4 py-2 rounded-xl text-sm">
            Xem pet đang mất →
          </a>
        </div>
      </template>

      <!-- Podium (top 3) — sân khấu -->
      <template x-if="list.length > 0">
        <div class="grid grid-cols-3 gap-2 mb-7 items-end">

          <!-- Rank 2 (left) -->
          <template x-if="podium[1]">
            <a :href="profileUrl(podium[1])" class="hp-pod text-center">
              <div class="bg-white rounded-2xl px-2 pt-4 pb-3 ring-1 ring-black/10 shadow-md min-h-[150px] flex flex-col items-center justify-end">
                <div class="relative w-14 h-14 mb-2">
                  <template x-if="podium[1].avatar_url">
                    <img :src="podium[1].avatar_url" alt="" class="relative w-full h-full rounded-full object-cover border-2 border-white shadow" />
                  </template>
                  <template x-if="!podium[1].avatar_url">
                    <div class="relative w-full h-full rounded-full bg-mmp-cream flex items-center justify-center text-lg font-extrabold text-mmp-ink border-2 border-white shadow"
                      x-text="(podium[1].name || '?').charAt(0).toUpperCase()"></div>
                  </template>
                  <div class="hp-medal hp-medal--silver absolute -bottom-1 left-1/2 -translate-x-1/2">2</div>
                </div>
                <p class="font-bold text-sm text-mmp-ink truncate w-full mt-1" x-text="podium[1].name"></p>
                <p class="text-xs text-mmp-brown" x-text="`${countFor(podium[1])} bé`"></p>
                <div class="flex flex-wrap items-center justify-center gap-1 mt-1.5" x-html="pillsHtml(podium[1])"></div>
              </div>
            </a>
          </template>
          <template x-if="!podium[1]"><div></div></template>

          <!-- Rank 1 (center, tallest) -->
          <template x-if="podium[0]">
            <a :href="profileUrl(podium[0])" class="hp-pod text-center">
              <div class="relative bg-white rounded-2xl px-2 pt-5 pb-4 ring-2 ring-mmp-gold shadow-xl min-h-[190px] flex flex-col items-center justify-end overflow-visible">
                <div class="hp-spotlight" aria-hidden="true"></div>
                <!-- crown -->
                <svg class="hp-crown relative w-7 h-7 mb-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3 8l3.5 3L12 5l5.5 6L21 8l-1.7 9.2a1 1 0 0 1-1 .8H5.7a1 1 0 0 1-1-.8L3 8z"/>
                </svg>
                <!-- avatar with spinning gold ring + halo -->
                <div class="relative w-20 h-20 mb-2">
                  <div class="hp-halo absolute -inset-3 rounded-full" aria-hidden="true"></div>
                  <div class="hp-ring-spin absolute -inset-1 rounded-full" aria-hidden="true"></div>
                  <template x-if="podium[0].avatar_url">
                    <img :src="podium[0].avatar_url" alt="" class="relative w-full h-full rounded-full object-cover border-2 border-white" />
                  </template>
                  <template x-if="!podium[0].avatar_url">
                    <div class="relative w-full h-full rounded-full bg-mmp-cream flex items-center justify-center text-2xl font-extrabold text-mmp-ink border-2 border-white"
                      x-text="(podium[0].name || '?').charAt(0).toUpperCase()"></div>
                  </template>
                  <div class="hp-medal hp-medal--gold absolute -bottom-1 left-1/2 -translate-x-1/2">1</div>
                </div>
                <p class="relative font-extrabold text-base text-mmp-ink truncate w-full mt-1" x-text="podium[0].name"></p>
                <p class="relative text-sm text-mmp-ink font-bold" x-text="`${countFor(podium[0])} bé`"></p>
                <div class="relative flex flex-wrap items-center justify-center gap-1 mt-1.5" x-html="pillsHtml(podium[0])"></div>
              </div>
            </a>
          </template>

          <!-- Rank 3 (right) -->
          <template x-if="podium[2]">
            <a :href="profileUrl(podium[2])" class="hp-pod text-center">
              <div class="bg-white rounded-2xl px-2 pt-4 pb-3 ring-1 ring-mmp-brown/30 shadow-md min-h-[130px] flex flex-col items-center justify-end">
                <div class="relative w-14 h-14 mb-2">
                  <template x-if="podium[2].avatar_url">
                    <img :src="podium[2].avatar_url" alt="" class="relative w-full h-full rounded-full object-cover border-2 border-white shadow" />
                  </template>
                  <template x-if="!podium[2].avatar_url">
                    <div class="relative w-full h-full rounded-full bg-mmp-cream flex items-center justify-center text-lg font-extrabold text-mmp-ink border-2 border-white shadow"
                      x-text="(podium[2].name || '?').charAt(0).toUpperCase()"></div>
                  </template>
                  <div class="hp-medal hp-medal--bronze absolute -bottom-1 left-1/2 -translate-x-1/2">3</div>
                </div>
                <p class="font-bold text-sm text-mmp-ink truncate w-full mt-1" x-text="podium[2].name"></p>
                <p class="text-xs text-mmp-brown" x-text="`${countFor(podium[2])} bé`"></p>
                <div class="flex flex-wrap items-center justify-center gap-1 mt-1.5" x-html="pillsHtml(podium[2])"></div>
              </div>
            </a>
          </template>
          <template x-if="!podium[2]"><div></div></template>
        </div>
      </template>

      <!-- Rest of list (rank 4+) -->
      <template x-if="rest.length > 0">
        <div class="space-y-2">
          <template x-for="hero in rest" :key="hero.user_id">
            <a :href="profileUrl(hero)"
              class="flex items-center gap-3 p-3 rounded-2xl bg-white border border-black/5 hover:shadow-md transition">
              <span class="font-bold text-mmp-ink/40 w-8 text-center text-sm" x-text="`#${hero._rank}`"></span>
              <template x-if="hero.avatar_url">
                <img :src="hero.avatar_url" alt="" class="w-10 h-10 rounded-full object-cover border-2 border-mmp-gold/30" />
              </template>
              <template x-if="!hero.avatar_url">
                <div class="w-10 h-10 rounded-full bg-mmp-cream flex items-center justify-center text-base font-bold text-mmp-ink"
                  x-text="(hero.name || '?').charAt(0).toUpperCase()"></div>
              </template>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-mmp-ink truncate" x-text="hero.name"></p>
                <div class="flex flex-wrap items-center gap-1 mt-0.5" x-html="pillsHtml(hero)"></div>
              </div>
              <div class="text-right">
                <p class="font-bold text-mmp-ink" x-text="`${countFor(hero)} bé`"></p>
                <template x-if="hero.total_rewards > 0">
                  <p class="text-[10px] text-mmp-brown" x-text="`+${(hero.total_rewards/1000).toFixed(0)}k`"></p>
                </template>
              </div>
            </a>
          </template>
        </div>
      </template>

      <!-- CTA -->
      <div class="mt-8 p-5 rounded-2xl bg-mmp-ink text-white text-center">
        <p class="font-bold mb-1">Bạn cũng muốn trở thành Pet Hero?</p>
        <p class="text-xs text-white/70 mb-3">Xem pet đang mất gần bạn — báo thấy bé giúp chủ tìm về nhà</p>
        <div class="grid grid-cols-2 gap-2">
          <a href="/lost/nearby" class="bg-mmp-gold hover:bg-mmp-gold/90 text-mmp-ink text-center text-sm font-bold py-2.5 rounded-xl">
            Pet mất gần bạn
          </a>
          <a :href="zaloUrl" target="_blank" rel="noopener" class="bg-white/10 hover:bg-white/20 text-white text-center text-sm font-bold py-2.5 rounded-xl">
            Chat Zalo
          </a>
        </div>
      </div>

      <!-- Tier legend -->
      <div class="mt-5 bg-white rounded-2xl border border-black/5 p-4 text-xs">
        <p class="font-bold text-mmp-ink mb-2">Cấp bậc Hero</p>
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-mmp-gold/30"></span><span class="text-mmp-brown"><span class="font-semibold text-mmp-ink">Helper</span> · 1+ bé</span></div>
          <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-mmp-gold/50"></span><span class="text-mmp-brown"><span class="font-semibold text-mmp-ink">Hero</span> · 3+ bé</span></div>
          <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-mmp-gold/70"></span><span class="text-mmp-brown"><span class="font-semibold text-mmp-ink">Legend</span> · 10+ bé</span></div>
          <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-mmp-gold"></span><span class="text-mmp-brown"><span class="font-semibold text-mmp-ink">Guardian</span> · 50+ bé</span></div>
        </div>
      </div>

    </div>
  </main>

  <style>
    /* Podium "sân khấu" — gold theatre. Decor mang nghĩa thứ hạng (1/2/3). */
    .hp-spotlight {
      position: absolute; top: -28px; left: 50%; transform: translateX(-50%);
      width: 190px; height: 190px; border-radius: 9999px; z-index: 0;
      background: radial-gradient(circle, rgba(236,185,33,0.5) 0%, transparent 65%);
      filter: blur(10px); pointer-events: none;
    }
    .hp-halo {
      background: radial-gradient(circle, rgba(236,185,33,0.45) 0%, transparent 70%);
      filter: blur(8px); pointer-events: none; z-index: 0;
    }
    .hp-ring-spin {
      z-index: 0; pointer-events: none;
      background: conic-gradient(from 0deg, #ecb921, rgba(236,185,33,0.12), #ecb921, rgba(236,185,33,0.12), #ecb921);
      animation: hp-spin 4s linear infinite;
    }
    .hp-crown { color: var(--c-gold, #ecb921); animation: hp-bob 2.4s ease-in-out infinite; }
    .hp-medal {
      width: 30px; height: 30px; border-radius: 9999px; z-index: 2;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 13px; line-height: 1; color: #3a2e0a;
      box-shadow: inset 0 1px 1px rgba(255,255,255,0.65), inset 0 -2px 3px rgba(0,0,0,0.28), 0 2px 5px rgba(0,0,0,0.22);
    }
    .hp-medal--gold   { background: linear-gradient(135deg, #f9e27a 0%, #ecb921 45%, #b8860b 100%); }
    .hp-medal--silver { background: linear-gradient(135deg, #fdfdfd 0%, #cfcfcf 45%, #9a9a9a 100%); color: #3a3a3a; }
    .hp-medal--bronze { background: linear-gradient(135deg, #f0cda0 0%, #cd7f32 50%, #824f20 100%); color: #fff7ee; }
    .hp-pod { transition: transform .2s ease; }
    .hp-pod:hover { transform: translateY(-3px); }
    @keyframes hp-spin { to { transform: rotate(360deg); } }
    @keyframes hp-bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    @media (prefers-reduced-motion: reduce) {
      .hp-ring-spin, .hp-crown, .hp-pod { animation: none !important; transition: none !important; }
    }
  </style>

  <script is:inline>
    function heroesPage(initial) {
      return {
        mode: 'all', // all | rescue | foster
        raw: initial.entries || [],
        zaloUrl: initial.zaloUrl,

        HERO_TIERS: {
          none:     { label_vi: '',             color_class: '' },
          helper:   { label_vi: 'Pet Helper',   color_class: 'bg-mmp-cream text-mmp-ink' },
          hero:     { label_vi: 'Pet Hero',     color_class: 'bg-mmp-cream text-mmp-ink' },
          legend:   { label_vi: 'Pet Legend',   color_class: 'bg-mmp-gold/15 text-mmp-ink' },
          guardian: { label_vi: 'Pet Guardian', color_class: 'bg-mmp-gold/25 text-mmp-ink' },
        },

        fosterLabel(v) {
          return ({
            foster_helper:  'Người nuôi tạm',
            foster_caring:  'Tận tâm',
            foster_devoted: 'Mái ấm tạm thời',
            foster_angel:   'Thiên thần nuôi tạm',
          })[v] || '';
        },

        rescueCount(h) { return Number(h.pet_heroes_count) || 0; },
        fosterCount(h) { return Number(h.foster_acts_count) || 0; },
        countFor(h) {
          if (this.mode === 'rescue') return this.rescueCount(h);
          if (this.mode === 'foster') return this.fosterCount(h);
          return this.rescueCount(h) + this.fosterCount(h);
        },

        get list() {
          let arr = (this.raw || []).slice();
          if (this.mode === 'rescue') {
            arr = arr.filter((h) => this.rescueCount(h) > 0).sort((a, b) => this.rescueCount(b) - this.rescueCount(a));
          } else if (this.mode === 'foster') {
            arr = arr.filter((h) => this.fosterCount(h) > 0).sort((a, b) => this.fosterCount(b) - this.fosterCount(a));
          } else {
            arr = arr.sort((a, b) => (this.rescueCount(b) + this.fosterCount(b)) - (this.rescueCount(a) + this.fosterCount(a)));
          }
          return arr.map((h, i) => ({ ...h, _rank: i + 1 }));
        },
        get podium() { return this.list.slice(0, 3); },
        get rest() { return this.list.slice(3); },

        // Pills: hero tier + foster tier (foster-only → chỉ pill foster).
        pillsHtml(h) {
          let out = '';
          const ht = this.HERO_TIERS[h.badge_tier];
          if (this.rescueCount(h) > 0 && ht && ht.label_vi) {
            out += `<span class="inline-block text-[10px] px-2 py-0.5 rounded-full font-bold ${ht.color_class}">${ht.label_vi}</span>`;
          }
          if (h.foster_badge_tier) {
            out += `<span class="inline-flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full font-bold bg-mmp-gold/15 text-mmp-ink border border-mmp-gold/40"><span class="w-1.5 h-1.5 rounded-full bg-mmp-gold"></span>${this.fosterLabel(h.foster_badge_tier)}</span>`;
          }
          return out;
        },

        profileUrl(h) {
          return h.public_slug ? `/heroes/profile/${h.user_id}?slug=${h.public_slug}` : `/heroes/profile/${h.user_id}`;
        },

        setMode(m) { this.mode = m; },
      };
    }
  </script>
</Layout>
