---
/**
 * /admin — Overview (redesign v2: sidebar AdminLayout).
 * Auth: phone ∈ ADMIN_PHONES HOẶC email ∈ ADMIN_EMAILS (isAdminIdentity, server-side). Non-admin → /dashboard.
 * Data: GET /admin/stats (đã mở rộng: transfers/pendingReclaims/recentActivity/transfersByWeek).
 */
import AdminLayout from "../layouts/AdminLayout.astro";

import { isAdminIdentity } from "../../../shared/admin.ts";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

if (!isAdminIdentity(user.phone, user.email)) {
  return Astro.redirect("/dashboard");
}

const cookieHeader = Astro.request.headers.get("cookie") || "";
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let stats: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/admin/stats`, { headers: { cookie: cookieHeader } });
  if (res.ok) stats = await res.json();
} catch (_) {}

const usersTotal = stats?.users?.total ?? 0;
const usersWeek = stats?.users?.recent_signups_7d ?? 0;
const petsTotal = stats?.pets?.total ?? 0;
const species = stats?.pets?.by_species ?? { cat: 0, dog: 0, other: 0 };
const transfersTotal = stats?.transfers?.total ?? 0;
const transfersWeek = stats?.transfers?.thisWeek ?? 0;
const pending = stats?.pendingReclaims ?? 0;
const weeks: number[] = stats?.transfersByWeek ?? [0, 0, 0, 0, 0, 0, 0, 0];
const activity: any[] = stats?.recentActivity ?? [];

const maxW = Math.max(...weeks, 1);
const speciesTotal = Math.max((species.cat || 0) + (species.dog || 0) + (species.other || 0), 1);

function timeAgo(iso: string): string {
  if (!iso) return "";
  const t = new Date(iso).getTime();
  if (!t) return "";
  const s = Math.floor((Date.now() - t) / 1000);
  if (s < 60) return `${s} giây trước`;
  const m = Math.floor(s / 60); if (m < 60) return `${m} phút trước`;
  const h = Math.floor(m / 60); if (h < 24) return `${h} giờ trước`;
  return `${Math.floor(h / 24)} ngày trước`;
}

const kpis = [
  { label: "Người dùng", value: usersTotal, sub: `+${usersWeek} tuần này`, red: false },
  { label: "Thú cưng", value: petsTotal, sub: `${species.cat || 0} mèo · ${species.dog || 0} chó`, red: false },
  { label: "Lượt trao bé", value: transfersTotal, sub: `+${transfersWeek} tuần này`, red: false },
  { label: "Chờ duyệt lấy lại", value: pending, sub: pending > 0 ? "cần xử lý" : "trống", red: pending > 0 },
];

const speciesRows = [
  { key: "Mèo", n: species.cat || 0, color: "#d4a520" },
  { key: "Chó", n: species.dog || 0, color: "#8b6f47" },
  { key: "Khác", n: species.other || 0, color: "#cbd5e1" },
];
---

<AdminLayout title="Tổng quan" currentPage="overview">
  {!stats && (
    <div class="bg-amber-50 border border-amber-200 text-amber-800 rounded-xl p-4 mb-6 text-sm">
      ⚠️ Không load được số liệu. Kiểm tra API logs.
    </div>
  )}

  <!-- KPI row -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {kpis.map((k) => (
      <div class:list={["rounded-2xl border p-5", k.red ? "bg-red-50 border-red-200" : "bg-white border-gray-100"]}>
        <p class="text-xs font-medium text-gray-400">{k.label}</p>
        <p class:list={["text-3xl font-bold mt-1 font-mono", k.red ? "text-red-600" : "text-gray-900"]}>{k.value}</p>
        <p class:list={["text-xs mt-1", k.red ? "text-red-500" : "text-gray-400"]}>{k.sub}</p>
      </div>
    ))}
  </div>

  <!-- Row 2: bar chart + species -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 p-6">
      <h3 class="text-sm font-bold text-gray-900 mb-4">Lượt trao bé theo tuần (8 tuần)</h3>
      <svg viewBox="0 0 336 140" class="w-full" style="height:150px" role="img" aria-label="Biểu đồ lượt trao bé 8 tuần">
        {weeks.map((w, i) => {
          const h = Math.round((w / maxW) * 108);
          const x = 8 + i * 40;
          return (
            <g>
              <rect x={x} y={118 - h} width="26" height={Math.max(h, 2)} rx="4" fill="#d4a520" opacity={i === 7 ? 1 : 0.5} />
              <text x={x + 13} y={132} text-anchor="middle" font-size="9" fill="#9ca3af">{i === 7 ? "nay" : `-${7 - i}`}</text>
              {w > 0 && <text x={x + 13} y={112 - h} text-anchor="middle" font-size="9" fill="#6b7280" font-weight="600">{w}</text>}
            </g>
          );
        })}
      </svg>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 p-6">
      <h3 class="text-sm font-bold text-gray-900 mb-4">Theo loài</h3>
      <div class="space-y-3">
        {speciesRows.map((s) => (
          <div>
            <div class="flex items-center justify-between text-xs mb-1">
              <span class="text-gray-600 font-medium">{s.key}</span>
              <span class="text-gray-900 font-mono font-bold">{s.n}</span>
            </div>
            <div class="h-2 rounded-full bg-gray-100 overflow-hidden">
              <div class="h-full rounded-full" style={`width:${Math.round((s.n / speciesTotal) * 100)}%;background:${s.color}`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Activity feed -->
  <div class="bg-white rounded-2xl border border-gray-100 p-6">
    <h3 class="text-sm font-bold text-gray-900 mb-4">Hoạt động gần nhất</h3>
    {activity.length === 0 ? (
      <p class="text-sm text-gray-400">Chưa có hoạt động nào.</p>
    ) : (
      <ul class="space-y-3">
        {activity.map((a) => (
          <li class="flex items-center gap-3">
            <span class:list={["w-2 h-2 rounded-full flex-shrink-0", a.type === "reclaim" ? "bg-emerald-500" : "bg-amber-500"]}></span>
            <p class="text-sm text-gray-700 flex-1 min-w-0 truncate">
              <span class="font-medium text-gray-900">{a.userName}</span>
              {a.type === "reclaim" ? " lấy lại bé " : " trao bé "}
              <span class="font-medium text-gray-900">{a.petName}</span>
            </p>
            <span class="text-xs text-gray-400 flex-shrink-0">{timeAgo(a.createdAt)}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
</AdminLayout>
