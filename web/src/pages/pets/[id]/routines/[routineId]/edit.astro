---
/**
 * /pets/[id]/routines/[routineId]/edit — Edit routine (M19).
 *
 * Same builder UI as /new, but skips Step 1 and pre-fills from existing routine.
 */
import Layout from "../../../../../layouts/Layout.astro";
import { fetchPet } from "../../../../../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const petId = Number(Astro.params.id);
const routineId = Number(Astro.params.routineId);
if (!Number.isFinite(routineId)) return Astro.redirect(`/pets/${petId}/routines`);

const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

let routine: any = null;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/routines/${routineId}`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) routine = await res.json();
} catch (_) {}

if (!routine) return Astro.redirect(`/pets/${petId}/routines`);

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name },
  routine,
});
---

<Layout title={`Sửa ${routine.name} · ${pet.name}`} description="Edit routine">
  <main class="min-h-screen bg-mmp-cream px-4 sm:px-6 py-6 pb-16">
    <div class="max-w-2xl mx-auto" x-data={`editRoutine(${initialData})`}>

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href={`/pets/${pet.id}/routines`} class="text-sm text-slate-500 hover:text-slate-700">← Routines</a>
        <h1 class="text-base font-bold text-slate-900">✏️ Sửa routine</h1>
        <span class="w-12"></span>
      </header>

      <div class="space-y-4">

        <div class="bg-white rounded-2xl border border-slate-100 p-5">
          <label class="block text-xs font-semibold text-slate-700 mb-1.5">Tên routine *</label>
          <input type="text" x-model="form.name" maxlength="80"
            class="w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-mmp-gold" />
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 p-5">
          <label class="block text-xs font-semibold text-slate-700 mb-2">Icon</label>
          <div class="flex flex-wrap gap-2">
            <template x-for="e in iconOptions" :key="e">
              <button type="button" @click="form.icon = e"
                :class="form.icon === e ? 'ring-2 ring-mmp-gold bg-mmp-cream' : 'bg-slate-50 hover:bg-mmp-cream'"
                class="text-2xl w-11 h-11 rounded-xl transition">
                <span x-text="e"></span>
              </button>
            </template>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 p-5">
          <label class="block text-xs font-semibold text-slate-700 mb-2">Màu</label>
          <div class="flex flex-wrap gap-2">
            <template x-for="c in colorOptions" :key="c">
              <button type="button" @click="form.color = c"
                :style="`background-color: ${c}`"
                :class="form.color === c ? 'ring-4 ring-offset-2 ring-slate-400' : ''"
                class="w-10 h-10 rounded-full transition shadow-sm"></button>
            </template>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 p-5">
          <label class="block text-xs font-semibold text-slate-700 mb-2">Lịch chạy</label>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
            <template x-for="s in scheduleOptions" :key="s.value">
              <button type="button" @click="form.schedule_type = s.value"
                :class="form.schedule_type === s.value ? 'bg-mmp-cream border-mmp-ink text-mmp-ink' : 'bg-white border-slate-200 text-slate-700'"
                class="border-2 rounded-xl px-3 py-2 text-xs font-semibold transition">
                <span x-text="s.label"></span>
              </button>
            </template>
          </div>
          <template x-if="form.schedule_type === 'custom'">
            <div class="mt-3 flex flex-wrap gap-1.5">
              <template x-for="d in weekdayKeys" :key="d.key">
                <button type="button" @click="toggleCustomDay(d.key)"
                  :class="form.custom_days.includes(d.key) ? 'bg-mmp-ink text-white' : 'bg-slate-100 text-slate-700'"
                  class="w-12 h-9 rounded-lg text-xs font-bold"
                  x-text="d.label"></button>
              </template>
            </div>
          </template>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 p-5">
          <label class="block text-xs font-semibold text-slate-700 mb-2">Giờ bắt đầu</label>
          <input type="time" x-model="form.start_time"
            class="w-full max-w-[180px] border border-slate-200 rounded-xl px-3 py-2 text-sm" />
        </div>

        <label class="bg-white rounded-2xl border border-slate-100 p-4 flex items-center justify-between cursor-pointer">
          <div>
            <p class="text-sm font-semibold text-slate-800">🔔 Push reminder 15 phút trước</p>
            <p class="text-xs text-slate-500 mt-0.5">Báo trên điện thoại trước khi đến giờ</p>
          </div>
          <input type="checkbox" x-model="form.push_reminder" class="w-5 h-5 accent-violet-600" />
        </label>

        <div class="bg-white rounded-2xl border border-slate-100 p-5">
          <h2 class="text-sm font-bold text-slate-900 mb-3">📌 Tasks</h2>
          <div class="space-y-3">
            <template x-for="(task, idx) in form.tasks" :key="task.id">
              <div class="bg-slate-50 rounded-xl p-3">
                <div class="flex items-start gap-2 mb-2">
                  <span class="text-2xl shrink-0" x-text="task.emoji"></span>
                  <input type="text" x-model="task.title" maxlength="100" placeholder="Tên task..."
                    class="flex-1 min-w-0 border border-slate-200 rounded-lg px-2 py-1.5 text-sm" />
                  <button @click="removeTask(idx)" class="shrink-0 text-red-500 text-base">🗑️</button>
                </div>
                <div class="flex flex-wrap gap-1 mb-2">
                  <template x-for="e in taskEmojiOptions" :key="e">
                    <button type="button" @click="task.emoji = e"
                      :class="task.emoji === e ? 'ring-2 ring-mmp-gold bg-mmp-cream' : 'bg-white hover:bg-mmp-cream'"
                      class="text-sm w-7 h-7 rounded">
                      <span x-text="e"></span>
                    </button>
                  </template>
                </div>
                <div class="grid grid-cols-3 gap-1.5">
                  <input type="number" min="1" max="180" x-model.number="task.duration_minutes"
                    class="border border-slate-200 rounded-lg px-2 py-1 text-xs" placeholder="phút" />
                  <select x-model.number="task.points" class="border border-slate-200 rounded-lg px-2 py-1 text-xs">
                    <option :value="1">1⭐</option><option :value="2">2⭐</option>
                    <option :value="3">3⭐</option><option :value="4">4⭐</option>
                    <option :value="5">5⭐</option>
                  </select>
                  <select x-model="task.category" class="border border-slate-200 rounded-lg px-2 py-1 text-xs">
                    <option value="food">🍴</option><option value="exercise">🏃</option>
                    <option value="grooming">🛁</option><option value="health">💊</option>
                    <option value="training">🎓</option><option value="play">🎾</option>
                    <option value="other">📌</option>
                  </select>
                </div>
              </div>
            </template>
          </div>
          <button @click="addTask()"
            class="w-full mt-3 bg-white border-2 border-dashed border-slate-300 hover:border-mmp-ink hover:bg-mmp-cream rounded-xl py-2.5 text-xs font-semibold text-slate-600">
            + Thêm task
          </button>
        </div>

        <template x-if="error">
          <p class="text-xs text-red-600 bg-red-50 border border-red-200 rounded-xl p-3" x-text="error"></p>
        </template>

        <div class="flex gap-2">
          <a :href="`/pets/${pet.id}/routines`"
            class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 text-center font-semibold py-3 rounded-xl text-sm">
            Huỷ
          </a>
          <button @click="save()" :disabled="saving"
            class="flex-[2] bg-gradient-to-r from-emerald-600 to-slate-800 hover:opacity-95 disabled:opacity-50 text-white font-bold py-3 rounded-xl text-sm shadow-lg">
            <span x-show="!saving">✅ Lưu thay đổi</span>
            <span x-show="saving">Đang lưu...</span>
          </button>
        </div>
      </div>

    </div>
  </main>

  <script is:inline>
    function genId() { return "t" + Math.random().toString(36).slice(2, 10); }

    function editRoutine(initial) {
      const r = initial.routine;
      return {
        pet: initial.pet,
        routineId: r.id,
        saving: false,
        error: null,

        form: {
          name: r.name || "",
          icon: r.icon || "📋",
          color: r.color || "#6366F1",
          schedule_type: r.schedule_type || "daily",
          custom_days: r.custom_days || [],
          start_time: r.start_time || "08:00",
          push_reminder: r.push_reminder !== false,
          tasks: (r.tasks || []).map((t) => ({ ...t, id: t.id || genId() })),
        },

        iconOptions: ["📋","🍴","🚶","🎾","🧠","🦷","🛁","💧","🎓","🌅","🌙","🏃","🪮","🎯","🎮","💊","📚","🏋️","🧘","🎨","🎭","🎵","🎬","🎤"],
        colorOptions: ["#F59E0B","#EF4444","#EC4899","#A855F7","#6366F1","#3B82F6","#06B6D4","#10B981","#84CC16","#F97316","#78716C","#0EA5E9"],
        scheduleOptions: [
          { value: "daily", label: "Hàng ngày" },
          { value: "weekdays", label: "T2-T6" },
          { value: "weekends", label: "T7-CN" },
          { value: "custom", label: "Tuỳ chỉnh" },
        ],
        weekdayKeys: [
          { key: "mon", label: "T2" }, { key: "tue", label: "T3" }, { key: "wed", label: "T4" },
          { key: "thu", label: "T5" }, { key: "fri", label: "T6" }, { key: "sat", label: "T7" },
          { key: "sun", label: "CN" },
        ],
        taskEmojiOptions: ["🍴","💧","🚶","🏃","🎾","🦷","🛁","🪮","💊","🧠","🎓","🎁","🎮","🎯","📚","🧘","🏋️","💤","🌅","🌙","💩","✂️","👂","📌"],

        toggleCustomDay(key) {
          const idx = this.form.custom_days.indexOf(key);
          if (idx >= 0) this.form.custom_days.splice(idx, 1);
          else this.form.custom_days.push(key);
        },

        addTask() {
          this.form.tasks.push({
            id: genId(),
            title: "",
            emoji: "📌",
            duration_minutes: 10,
            points: 1,
            category: "other",
          });
        },

        removeTask(idx) {
          this.form.tasks.splice(idx, 1);
        },

        async save() {
          this.error = null;
          if (!this.form.name.trim()) { this.error = "Cần tên routine"; return; }
          if (this.form.tasks.length === 0) { this.error = "Cần ít nhất 1 task"; return; }
          if (this.form.tasks.some((t) => !t.title.trim())) { this.error = "Tasks phải có tên"; return; }
          this.saving = true;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/routines/${this.routineId}`, {
              method: "PUT",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify(this.form),
            });
            if (!res.ok) {
              const j = await res.json().catch(() => ({}));
              this.error = j?.error?.message || "Lỗi lưu.";
              return;
            }
            window.location.href = `/pets/${this.pet.id}/routines`;
          } catch (err) {
            this.error = "Không kết nối server.";
          } finally {
            this.saving = false;
          }
        },
      };
    }
  </script>
</Layout>
