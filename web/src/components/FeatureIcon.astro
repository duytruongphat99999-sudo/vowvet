---
/**
 * FeatureIcon — inline SVG icon system (no npm dep).
 * Pattern: 1.5px stroke (configurable), rounded ends, currentColor, 24x24 viewbox.
 *
 * Marketing icons:   passport, ai, climate, syringe, nutrition, camera
 * Ecosystem icons:   shop, stethoscope, app
 * Action icons:      arrow, external, check, plus, close
 * Chrome (dashboard nav):  bell, message-circle, settings, search
 * Dashboard sections:      target, lightning, sparkles, star, paw
 * Tier badges:       trophy, medal-bronze, medal-silver, medal-gold, medal-platinum, medal-diamond
 * Nudge types:       rocket, flame, edit-pencil, clock
 * Quick access:      activity, bowl, image, handshake, alert-triangle
 * Community events:  cake, hero-cape, hearts, calendar
 * Misc:              thermometer, gift, eye, qr-code
 */
interface Props {
  name: string;
  class?: string;
  strokeWidth?: number;
}
const { name, class: className = "w-6 h-6", strokeWidth = 1.5 } = Astro.props;
const sw = strokeWidth;
