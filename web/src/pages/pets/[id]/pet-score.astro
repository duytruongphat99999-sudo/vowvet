              <span class="text-slate-500 text-xs">của <span x-text="percentile.total_opted_in"></span> pet HCM đã opt-in</span>
            </p>

            <div class="percentile-bar">
              <div class="percentile-avg-line" :style="`left: ${(percentile.community_avg/1000)*100}%`"></div>
              <div class="percentile-position"
                   :style="`left: ${Math.max(0, ((percentile.pet_score/1000)*100) - 2)}%`"
                   :title="`${percentile.pet_score} điểm`">
              </div>
            </div>

            <div class="flex justify-between text-[10px] text-slate-500 mt-1 px-1">
              <span>0</span>
              <span>TB HCM: <strong x-text="percentile.community_avg"></strong></span>
              <span>1000</span>
            </div>

            <template x-if="percentile.rank_in_lb">
              <a href="/leaderboard" class="leaderboard-cta">
                <span>Bạn hạng <strong x-text="`#${percentile.rank_in_lb}`"></strong> trên leaderboard công khai</span>
                <span aria-hidden="true">→</span>
              </a>
