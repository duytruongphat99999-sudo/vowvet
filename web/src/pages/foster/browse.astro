---
/**
 * /foster/browse — danh sách bé CẦN FOSTER để user xem/chọn (W-E foster-care epic).
 *
 * AUTH: page tự gated bởi web middleware (ngoài PUBLIC → chưa login = redirect /login).
 * DATA: client-side fetch /api/v1/pets/foster-browse (auth qua petsRoute.use requireAuth)
 *   → chỉ bé foster_public + is_public + foster_status="cần tài trợ" + chưa xoá.
 *   "Xem chi tiết" → /p/<public_slug> (chứng thư công khai — người ngoài xem được).
 */
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Bé cần foster · VowVet" description="Danh sách bé đang cần người tài trợ / nuôi tạm">
  <main class="min-h-screen bg-mmp-cream px-4 py-6 pb-20">
    <div class="max-w-2xl mx-auto" x-data="fosterBrowse()" x-init="load()">

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href="/dashboard" class="text-sm text-mmp-brown hover:text-mmp-ink">← Dashboard</a>
        <h1 class="text-lg font-bold text-mmp-ink">Bé cần foster</h1>
        <span aria-hidden="true"></span>
      </header>

      <div class="text-center py-6 px-4 mb-5 rounded-3xl bg-white border border-black/5 shadow-sm">
        <span class="inline-block text-[11px] font-bold tracking-widest uppercase text-mmp-brown mb-2">Cứu trợ</span>
        <h2 class="font-display italic text-2xl font-semibold text-mmp-ink">Những bé đang cần giúp</h2>
        <p class="text-sm text-mmp-brown mt-1.5">Xem hồ sơ bé, góp gói nuôi hoặc nhận nuôi tạm.</p>
      </div>

      <template x-if="loading">
        <p class="text-mmp-brown text-sm text-center py-6">Đang tải…</p>
      </template>

      <template x-if="!loading && err">
        <p class="text-sm text-red-600 text-center py-6" x-text="err"></p>
      </template>

      <template x-if="!loading && !err && pets.length === 0">
        <div class="bg-white border border-black/5 rounded-2xl p-8 text-center text-mmp-brown">
          Hiện chưa có bé nào cần foster. Quay lại sau nhé 💛
        </div>
      </template>

      <div x-show="!loading && !err && pets.length > 0" style="display:none;" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <template x-for="p in pets" :key="p.public_slug || p.name">
          <div class="bg-white border border-black/5 rounded-2xl overflow-hidden shadow-sm flex flex-col">
            <div class="aspect-[4/3] bg-mmp-cream overflow-hidden">
              <template x-if="p.photo_url">
                <img :src="p.photo_url" :alt="p.name" class="w-full h-full object-cover" loading="lazy" />
              </template>
              <template x-if="!p.photo_url">
                <div class="w-full h-full flex items-center justify-center text-4xl text-mmp-brown/40">🐾</div>
              </template>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <div class="flex items-center justify-between gap-2">
                <h3 class="font-display italic text-lg font-semibold text-mmp-ink truncate" x-text="p.name"></h3>
                <span class="shrink-0 text-[10px] font-bold px-2 py-0.5 rounded-full bg-mmp-cream text-mmp-brown border border-mmp-ink/10" x-text="p.foster_status"></span>
              </div>
              <p class="text-xs text-mmp-brown mt-0.5" x-text="speciesLabel(p.species) + (p.breed ? (' · ' + p.breed) : '')"></p>
              <p class="text-sm text-mmp-ink/70 mt-2 flex-1" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;" x-show="p.adoption_story" x-text="p.adoption_story"></p>
              <a :href="p.public_slug ? ('/p/' + p.public_slug) : '#'"
                 class="mt-3 inline-flex items-center justify-center gap-1 bg-mmp-ink text-white text-sm font-bold px-4 py-2 rounded-xl">
                Xem chi tiết →
              </a>
            </div>
          </div>
        </template>
      </div>
    </div>
  </main>

  <script is:inline>
    function fosterBrowse() {
      return {
        pets: [],
        loading: true,
        err: "",
        async load() {
          this.loading = true; this.err = "";
          try {
            const r = await fetch("/api/v1/pets/foster-browse", { credentials: "include" });
            if (r.status === 401) { window.location.href = "/login?return_to=/foster/browse"; return; }
            if (!r.ok) { this.err = "Lỗi tải (" + r.status + ")"; return; }
            const j = await r.json();
            this.pets = Array.isArray(j.pets) ? j.pets : [];
          } catch (e) {
            this.err = "Lỗi kết nối";
          } finally {
            this.loading = false;
          }
        },
        speciesLabel(s) {
          if (s === "dog") return "Chó";
          if (s === "cat") return "Mèo";
          return s || "Thú cưng";
        }
      };
    }
  </script>
</Layout>
