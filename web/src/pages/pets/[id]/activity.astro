---
/**
 * /pets/[id]/activity — unified activity timeline.
 *
 * Reads from `GET /api/v1/pets/:id/activity?days=N` which aggregates user-initiated
 * activity rows across pet_photos / daily_check_ins / pet_diary / bcs_assessments /
 * user_daily_quests / user_achievements / care_plan_completions.
 *
 * UX:
 *   - Ink hero stats (7-day count + total points earned)
 *   - Filter chips (?filter=all/photos/food/health/rewards) — SSR query param
 *   - Timeline grouped by date label (HÔM NAY / HÔM QUA / dd/MM/yyyy)
 *   - Each row: SVG icon chip + title + meta + time + +Nđ Pet Score badge
 *   - Empty state + "load more 30-day" hint
 *
 * Referer-aware back nav. Brand: ink/cream/gold. NO vv-gold (token doesn't exist).
 */
import Layout from "../../../layouts/Layout.astro";
import FeatureIcon from "../../../components/FeatureIcon.astro";
import { fetchPet } from "../../../lib/api-client.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login?return_to=" + Astro.url.pathname);

const petId = Number(Astro.params.id);
if (!Number.isFinite(petId) || petId <= 0) return Astro.redirect("/dashboard");

const { pet, status } = await fetchPet(petId, cookieHeader);
if (status === 401) return Astro.redirect("/login");
if (status === 404 || !pet) return Astro.redirect("/dashboard");
if (status === 403) return new Response("403 Forbidden", { status: 403 });

const filter = (Astro.url.searchParams.get("filter") || "all").toLowerCase();
const validFilters = ["all", "photos", "food", "health", "rewards"] as const;
type Filter = (typeof validFilters)[number];
const activeFilter: Filter = (validFilters as readonly string[]).includes(filter)
  ? (filter as Filter)
  : "all";

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// SSR fetch activity (7-day default)
let activities: any[] = [];
let totalPoints = 0;
let totalCount = 0;
try {
  const r = await fetch(`${API_INTERNAL}/api/v1/pets/${petId}/activity?days=7`, {
    headers: { cookie: cookieHeader },
  });
  if (r.ok) {
    const j = await r.json();
    activities = j.activities || [];
    totalPoints = j.total_points || 0;
    totalCount = j.total_count || activities.length;
  }
} catch (_) {}

// Filter buckets — keep activity types semantically grouped
const FILTER_TYPES: Record<Filter, Set<string>> = {
  all:     new Set(),
  photos:  new Set(["photo_upload"]),
  food:    new Set(["care_plan_item"]),  // currently only care-plan tracks feeding
  health:  new Set(["check_in", "bcs_check", "voice_diary"]),
  rewards: new Set(["quest_complete", "achievement_unlock", "trifecta_bonus"]),
};

const filteredActivities =
  activeFilter === "all"
    ? activities
    : activities.filter((a) => FILTER_TYPES[activeFilter].has(a.type));

// Group by date label
function dateLabel(iso: string): string {
  if (!iso) return "Khác";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "Khác";
  const today = new Date();
  const ymd = (x: Date) => x.toISOString().slice(0, 10);
  if (ymd(d) === ymd(today)) return "HÔM NAY";
  const yesterday = new Date(today);
  yesterday.setDate(today.getDate() - 1);
  if (ymd(d) === ymd(yesterday)) return "HÔM QUA";
  return d.toLocaleDateString("vi-VN", { weekday: "short", day: "2-digit", month: "2-digit" }).toUpperCase();
}

function formatTime(iso: string): string {
  if (!iso) return "—";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "—";
  return d.toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit" });
}

// Build ordered date groups
const groups: Array<{ label: string; key: string; items: any[] }> = [];
for (const a of filteredActivities) {
  const label = dateLabel(a.created_at);
  const last = groups[groups.length - 1];
  if (last && last.label === label) {
    last.items.push(a);
  } else {
    groups.push({ label, key: a.created_at.slice(0, 10), items: [a] });
  }
}

// Activity type → icon meta (must use FeatureIcon names that exist)
const ACTIVITY_META: Record<string, { icon: string; color: string; bg: string }> = {
  photo_upload:        { icon: "camera",           color: "text-mmp-ink",     bg: "bg-mmp-cream" },
  check_in:            { icon: "clipboard-check",  color: "text-emerald-600", bg: "bg-emerald-50" },
  voice_diary:         { icon: "mic",              color: "text-rose-600",   bg: "bg-rose-50" },
  bcs_check:           { icon: "ruler",            color: "text-mmp-ink",     bg: "bg-mmp-cream" },
  quest_complete:      { icon: "target",           color: "text-mmp-gold",   bg: "bg-mmp-gold/10" },
  achievement_unlock:  { icon: "award",            color: "text-mmp-gold",   bg: "bg-mmp-gold/10" },
  care_plan_item:      { icon: "check-square",     color: "text-emerald-600", bg: "bg-emerald-50" },
  trifecta_bonus:      { icon: "trophy",           color: "text-mmp-gold",   bg: "bg-mmp-gold/10" },
};
function getActivityMeta(type: string) {
  return ACTIVITY_META[type] || { icon: "info", color: "text-slate-600", bg: "bg-slate-50" };
}

// Filter chip labels
const FILTER_LABELS: Record<Filter, string> = {
  all: "Tất cả",
  photos: "Ảnh",
  food: "Care Plan",
  health: "Sức khoẻ",
  rewards: "Thưởng",
};

// Referer-aware back link
const referer = Astro.request.headers.get("referer") || "";
const backHref = referer.includes("/dashboard") ? "/dashboard"
              : referer.includes("/pet-score") ? `/pets/${petId}/pet-score`
              : `/pets/${petId}`;
const backLabel = referer.includes("/dashboard") ? "Dashboard"
               : referer.includes("/pet-score") ? "Pet Score"
               : (pet.name || "Pet");
---

<Layout title={`Hoạt động · ${pet.name} · VowVet`} description="Lịch sử hoạt động + điểm Pet Score">
  <main class="min-h-screen bg-mmp-cream pb-12">

    <!-- Sticky header -->
    <header class="sticky top-0 z-30 bg-white border-b border-slate-200">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-3">
        <a href={backHref} class="text-sm text-slate-500 hover:text-mmp-ink inline-flex items-center gap-1 transition">
          <FeatureIcon name="arrow" class="w-4 h-4 rotate-180" strokeWidth={2} />
          {backLabel}
        </a>
        <h1 class="font-display italic text-lg sm:text-xl font-semibold text-mmp-ink inline-flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-mmp-cream">
            <FeatureIcon name="trending-up" class="w-4 h-4" strokeWidth={2} style="color: var(--c-gold);" />
          </span>
          Hoạt động
        </h1>
        <span class="text-[10px] bg-mmp-cream text-mmp-ink border border-amber-200 px-2 py-0.5 rounded-full font-bold tabular-nums">
          7 ngày
        </span>
      </div>
    </header>

    <div class="max-w-2xl mx-auto px-4 sm:px-6 py-6 space-y-5">

      <!-- Hero stats (ink) -->
      <section class="relative bg-mmp-ink text-white rounded-3xl overflow-hidden shadow-lg">
        <div aria-hidden="true" class="absolute -top-16 -right-16 w-56 h-56 rounded-full blur-3xl"
             style="background: rgba(236, 185, 33, 0.18);"></div>
        <div aria-hidden="true" class="absolute -bottom-20 -left-20 w-48 h-48 rounded-full blur-3xl"
             style="background: rgba(236, 185, 33, 0.10);"></div>

        <div class="relative p-5 sm:p-6">
          <p class="text-[11px] uppercase tracking-[0.3em] font-bold mb-2" style="color: var(--c-gold);">
            7 ngày qua
          </p>
          <div class="grid grid-cols-2 gap-4 sm:gap-6 mt-2">
            <div>
              <p class="text-3xl sm:text-4xl font-bold tabular-nums">{totalCount}</p>
              <p class="text-xs text-white/65 mt-1">Hoạt động</p>
            </div>
            <div>
              <p class="text-3xl sm:text-4xl font-bold tabular-nums" style="color: var(--c-gold);">+{totalPoints}</p>
              <p class="text-xs text-white/65 mt-1">điểm Pet Score</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Filter chips -->
      <div class="flex items-center gap-2 overflow-x-auto no-scrollbar">
        {validFilters.map((f) => {
          const isActive = activeFilter === f;
          return (
            <a href={`?filter=${f}`}
               class={`shrink-0 inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border transition-all ${
                 isActive
                   ? "bg-mmp-ink text-white border-mmp-ink shadow-md"
                   : "bg-white border-slate-200 text-mmp-ink hover:border-mmp-ink"
               }`}>
              {FILTER_LABELS[f]}
            </a>
          );
        })}
      </div>

      <!-- Timeline -->
      {filteredActivities.length === 0 ? (
        <div class="bg-white rounded-3xl border border-slate-100 p-10 sm:p-12 text-center shadow-sm">
          <span class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-mmp-cream mx-auto mb-4">
            <FeatureIcon name="trending-up" class="w-8 h-8" strokeWidth={1.5} style="color: var(--c-gold);" />
          </span>
          <h2 class="font-display italic text-xl font-semibold text-mmp-ink mb-2">
            {activities.length === 0 ? "Chưa có hoạt động nào" : "Không có hoạt động khớp filter"}
          </h2>
          <p class="text-sm text-slate-500 max-w-xs mx-auto">
            {activities.length === 0
              ? "Check-in, upload ảnh, log meal, hoàn thành quest — mọi action sẽ xuất hiện ở đây."
              : "Thử chuyển sang filter khác hoặc xem 'Tất cả'."}
          </p>
        </div>
      ) : (
        groups.map((g) => (
          <section class="space-y-2">
            <div class="flex items-center gap-2 mt-1">
              <span class="text-[11px] uppercase tracking-[0.3em] font-bold" style="color: var(--c-gold);">
                {g.label}
              </span>
              <div class="flex-1 h-px bg-slate-200"></div>
              <span class="text-[11px] text-slate-500 tabular-nums">{g.items.length} hoạt động</span>
            </div>
            <div class="space-y-2">
              {g.items.map((a) => {
                const meta = getActivityMeta(a.type);
                return (
                  <article class="bg-white rounded-2xl border border-slate-100 p-4 flex items-start gap-3 hover:border-mmp-ink hover:shadow-sm transition">
                    <span class={`shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-xl ${meta.bg}`}>
                      <FeatureIcon name={meta.icon} class={`w-5 h-5 ${meta.color}`} strokeWidth={1.7} />
                    </span>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2 mb-1">
                        <p class="font-semibold text-mmp-ink text-sm leading-tight">{a.title}</p>
                        <time class="text-[11px] text-slate-400 shrink-0 tabular-nums">{formatTime(a.created_at)}</time>
                      </div>
                      {a.description && (
                        <p class="text-xs text-slate-600 leading-relaxed line-clamp-2">{a.description}</p>
                      )}
                      {a.points > 0 && (
                        <span class="inline-flex items-center gap-1 mt-2 text-[10px] font-bold px-2 py-0.5 rounded-full bg-mmp-cream border border-amber-200"
                              style="color: var(--c-gold);">
                          <FeatureIcon name="trending-up" class="w-3 h-3" strokeWidth={2.4} />
                          +{a.points}đ Pet Score
                        </span>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))
      )}

      <!-- Load-more hint when capped at 200 -->
      {totalCount >= 200 && (
        <p class="text-center text-xs text-slate-500 italic">
          Hiển thị 200 hoạt động gần nhất trong 7 ngày qua. Để xem dài hơn, dùng filter cụ thể hoặc liên hệ admin.
        </p>
      )}

      <!-- Footer hint -->
      <p class="text-center text-xs text-slate-500">
        Toàn bộ điểm cộng được tổng hợp tại
        <a href={`/pets/${petId}/pet-score`} class="font-semibold hover:underline" style="color: var(--c-gold);">Pet Score →</a>
      </p>
    </div>
  </main>

  <style is:global>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Layout>
