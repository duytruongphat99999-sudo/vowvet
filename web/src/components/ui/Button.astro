---
/**
 * Button — Mon Min Pet brand primitive.
 *
 * Variants:
 *   - primary  : ink fill, white text (default — main CTA across app)
 *   - secondary: white fill, ink border, ink text (less-important actions)
 *   - gold     : gold fill, ink text (premium / upgrade flows)
 *   - ghost    : transparent, ink text on hover-cream
 *   - danger   : red-600 fill, white text (destructive — use sparingly)
 *
 * Sizes: sm (h-9 text-xs), md (h-11 text-sm — default), lg (h-12 text-base)
 *
 * Renders <a> when `href` is set, otherwise <button>.
 *
 * Usage:
 *   <Button>Lưu</Button>
 *   <Button variant="gold" size="lg" href="/checkout">Nâng cấp →</Button>
 *   <Button variant="ghost" type="button">Huỷ</Button>
 */
interface Props {
  variant?: "primary" | "secondary" | "gold" | "ghost" | "danger";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  id?: string;
}
const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  disabled = false,
  fullWidth = false,
  class: extraClass = "",
  id,
} = Astro.props;

const VARIANTS: Record<string, string> = {
  primary:
    "bg-mmp-ink text-white hover:bg-slate-800 active:bg-black border border-mmp-ink",
  secondary:
    "bg-white text-mmp-ink hover:bg-mmp-cream border border-mmp-ink",
  gold:
    "bg-[#ecb921] text-mmp-ink hover:bg-[#d4a417] border border-[#ecb921] shadow-sm",
  ghost:
    "bg-transparent text-mmp-ink hover:bg-mmp-cream border border-transparent",
  danger:
    "bg-red-600 text-white hover:bg-red-700 border border-red-600",
};
const SIZES: Record<string, string> = {
  sm: "h-9 px-3 text-xs gap-1.5",
  md: "h-11 px-4 text-sm gap-2",
  lg: "h-12 px-5 text-base gap-2",
};

const base =
  "inline-flex items-center justify-center font-semibold rounded-xl transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-mmp-ink focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed";

const cls = [base, VARIANTS[variant], SIZES[size], fullWidth ? "w-full" : "", extraClass]
  .filter(Boolean)
  .join(" ");
---

{href ? (
  <a id={id} href={href} class={cls} aria-disabled={disabled || undefined}>
    <slot />
  </a>
) : (
  <button id={id} type={type} class={cls} disabled={disabled}>
    <slot />
  </button>
)}
