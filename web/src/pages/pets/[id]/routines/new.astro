// v101: Smart matcher (same logic as routines/index.astro)
function pickSmartBlueprints(p: any, prof: any): Blueprint[] {
  const speciesRaw = String((typeof p.species === "object" ? p.species?.value : p.species) || "").toLowerCase();
  const isDog = speciesRaw.includes("chó") || speciesRaw === "dog";
  const isCat = speciesRaw.includes("mèo") || speciesRaw === "cat";
  const breed = String(p.breed || prof.breed || "").toLowerCase();
  const dob = p.dob || prof.dob;
  let ageYears = 0;
  if (dob) {
    const d = new Date(dob);
    if (!isNaN(d.getTime())) ageYears = (Date.now() - d.getTime()) / (365.25 * 24 * 60 * 60 * 1000);
  }
  const isPuppy = ageYears > 0 && ageYears < 1;
  const isSenior = (isDog && ageYears >= 7) || (isCat && ageYears >= 10);
  const weight = Number(p.weight_kg) || 0;
  const isOverweight = (prof.body_condition_score || 0) >= 7 || (isCat && weight > 5.5) || (isDog && weight > 35);
  const isBrachy = ["frenchie", "pug", "bulldog", "persian", "shih"].some((b) => breed.includes(b));
  const hasJoint = breed.includes("tai cụp") || breed.includes("scottish fold") || breed.includes("munchkin");

  const tags = new Set<string>();
  if (isDog) tags.add("dog");
  if (isCat) tags.add("cat");
  if (isPuppy) { tags.add(isDog ? "puppy" : "kitten"); tags.add("training"); tags.add("social"); }
  if (isSenior) { tags.add("senior"); tags.add("joint"); }
  if (isOverweight) { tags.add("overweight"); tags.add("weight_loss"); }
  if (isBrachy) tags.add("brachycephalic");
  if (hasJoint) tags.add("joint");
  if (!isPuppy && !isSenior && !isOverweight && !isBrachy && !hasJoint) tags.add("adult");

  const scored = BLUEPRINTS.map((bp) => {
    let score = 0;
    if (bp.species === "any") score += 1;
    if (bp.species === "cat" && isCat) score += 4;
    if (bp.species === "dog" && isDog) score += 4;
    if (bp.species === "cat" && isDog) score -= 100;
    if (bp.species === "dog" && isCat) score -= 100;
    for (const tag of bp.matchTags) {
      if (tags.has(tag)) score += 5;
    }
    return { bp, score };
  });

  scored.sort((a, b) => b.score - a.score);
  return scored.filter((s) => s.score > 0).map((s) => s.bp);
}

const smartMatches = pickSmartBlueprints(pet, profile);
const TOP_BLUEPRINTS = smartMatches.slice(0, 4);
const REST_BLUEPRINTS = smartMatches.slice(4);

// Pet identity summary
const speciesValue = typeof pet.species === "object" ? (pet.species as any)?.value : pet.species;
const ageLabel = pet.dob ? formatAge(pet.dob) : null;
const weightLabel = pet.weight_kg ? `${Number(pet.weight_kg).toFixed(1)}kg` : null;
const petContextLine = [speciesValue, ageLabel, weightLabel].filter(Boolean).join(" · ");

function forecastPerDay(bp: Blueprint): number {
  return bp.tasks.reduce((s, t) => s + (t.points || 0), 0);
}

// Read URL ?template= for direct prefill (existing functionality from v95)
const urlTemplate = Astro.url.searchParams.get("template");
const prefillBlueprint = urlTemplate ? BLUEPRINTS.find((b) => b.id === urlTemplate) || null : null;

const initialData = JSON.stringify({
  pet: { id: pet.id, name: pet.name },
  editingRoutine: null,
  prefillBlueprint,
  blueprintId: prefillBlueprint ? urlTemplate : null,
});
