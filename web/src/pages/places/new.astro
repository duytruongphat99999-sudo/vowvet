---
/**
 * /places/new — User submits a new pet-friendly place (M26).
 * Auth required.
 */
import Layout from "../../layouts/Layout.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");
---

<Layout title="Thêm địa điểm · VowVet" description="Đề xuất địa điểm pet-friendly mới">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <style is:inline>
    #pick-map { height: 280px; width: 100%; border-radius: 16px; }
  </style>

  <main class="min-h-screen bg-slate-50 px-4 py-6 pb-16" x-data="newPlace()">
    <div class="max-w-2xl mx-auto">

      <header class="flex items-center justify-between mb-5 gap-3">
        <a href="/map" class="text-sm text-slate-500 hover:text-slate-700">← Bản đồ</a>
        <h1 class="text-lg font-bold text-slate-900">➕ Thêm địa điểm</h1>
        <span class="w-12"></span>
      </header>

      <div class="bg-mmp-cream border border-blue-200 rounded-xl p-3 mb-4 text-xs text-mmp-ink">
        💡 Địa điểm bạn submit sẽ được verify trước khi hiển thị công khai. Cảm ơn vì đóng góp!
      </div>

      <div class="bg-white rounded-2xl border border-slate-100 p-5 space-y-4">

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1.5">Tên địa điểm *</label>
          <input type="text" x-model="form.name" maxlength="200" placeholder="VD: Pet Cafe Saigon"
            class="w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-mmp-gold" />
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1.5">Địa chỉ *</label>
          <input type="text" x-model="form.address" maxlength="300" placeholder="Số nhà, đường, quận, thành phố"
            class="w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm" />
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-2">Loại *</label>
          <div class="grid grid-cols-3 gap-2">
            <template x-for="c in categories" :key="c.key">
              <button type="button" @click="form.category = c.key"
                :class="form.category === c.key ? 'border-mmp-ink bg-mmp-cream ring-2 ring-mmp-gold' : 'border-slate-200'"
                class="border-2 rounded-xl py-3 px-2 text-xs font-semibold flex flex-col items-center gap-1 transition">
                <span class="text-xl" x-text="c.emoji"></span>
                <span x-text="c.label"></span>
              </button>
            </template>
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-2">Chính sách pet</label>
          <select x-model="form.pet_policy"
            class="w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm bg-white">
            <option value="allowed">🐾 Welcome — pet được vào tự do</option>
            <option value="leash_only">🦮 Có dây xích</option>
            <option value="small_pets_only">🐱 Chỉ pet nhỏ (< 10kg)</option>
            <option value="private_only">🔒 Đặt trước / khu riêng</option>
            <option value="by_request">❓ Hỏi trước</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-2">Tiện ích (chọn nhiều)</label>
          <div class="grid grid-cols-2 gap-1.5">
            <template x-for="a in amenityOptions" :key="a.key">
              <label class="flex items-center gap-2 text-xs bg-slate-50 rounded-lg px-2.5 py-2 cursor-pointer">
                <input type="checkbox" :value="a.key" @change="toggleAmenity(a.key)"
                  :checked="form.amenities.includes(a.key)"
                  class="rounded text-mmp-ink" />
                <span x-text="a.label"></span>
              </label>
            </template>
          </div>
        </div>

        <!-- Photos (REQUIRED ≥1, max 5) -->
        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-1.5">
            📸 Ảnh thực tế <span class="text-red-500">*</span>
          </label>
          <p class="text-[11px] text-slate-500 mb-2">1-5 ảnh để admin verify + user khác tin tưởng (JPG/PNG/WebP · max 5MB/ảnh)</p>

          <label class="block w-full p-5 rounded-xl border-2 border-dashed border-mmp-cream hover:border-mmp-ink bg-mmp-cream hover:bg-mmp-cream cursor-pointer transition text-center"
            x-show="previews.length < 5">
            <input type="file" accept="image/jpeg,image/png,image/webp" multiple
              @change="handleFiles($event)" class="hidden" />
            <div class="text-2xl">📸</div>
            <p class="text-sm font-medium text-mmp-ink mt-1">Bấm để chọn ảnh</p>
            <p class="text-[11px] text-slate-500 mt-0.5">
              <span x-text="previews.length"></span>/5 ảnh
            </p>
          </label>

          <div x-show="previews.length > 0" class="grid grid-cols-3 gap-2 mt-2">
            <template x-for="(p, idx) in previews" :key="idx">
              <div class="relative group">
                <img :src="p.dataUrl" alt="" class="w-full aspect-square object-cover rounded-xl border border-slate-200" />
                <button type="button" @click="removePhoto(idx)"
                  class="absolute -top-1 -right-1 w-6 h-6 rounded-full bg-red-500 text-white text-xs flex items-center justify-center shadow-md">✕</button>
                <div x-show="p.uploading" class="absolute inset-0 bg-black/50 rounded-xl flex items-center justify-center">
                  <span class="text-white text-[10px] font-bold">⏳ Đang upload</span>
                </div>
                <div x-show="p.uploaded" class="absolute bottom-1 right-1 w-6 h-6 rounded-full bg-emerald-500 text-white text-xs flex items-center justify-center shadow">✓</div>
              </div>
            </template>
          </div>

          <p x-show="photoError" x-text="photoError" class="text-xs text-red-600 mt-2"></p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-700 mb-2">Vị trí trên bản đồ *</label>
          <p class="text-[11px] text-slate-500 mb-2">Click vào map để chọn vị trí chính xác, hoặc dùng nút "Vị trí hiện tại"</p>
          <button type="button" @click="useGeo()"
            class="text-xs bg-mmp-cream hover:bg-mmp-cream text-mmp-ink font-semibold px-3 py-1.5 rounded-lg mb-2">
            📍 Dùng vị trí hiện tại
          </button>
          <div id="pick-map"></div>
          <p class="text-[11px] text-slate-500 mt-2 font-mono" x-show="form.lat && form.lng">
            <span x-text="form.lat.toFixed(6)"></span>, <span x-text="form.lng.toFixed(6)"></span>
          </p>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-xs font-semibold text-slate-700 mb-1.5">SĐT liên hệ (tuỳ chọn)</label>
            <input type="tel" x-model="form.contact_phone" maxlength="20"
              class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-700 mb-1.5">Website (tuỳ chọn)</label>
            <input type="url" x-model="form.contact_website" maxlength="200"
              class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm" />
          </div>
        </div>

        <template x-if="error">
          <p class="bg-red-50 border border-red-200 rounded-xl p-3 text-sm text-red-700" x-text="error"></p>
        </template>

        <button @click="submit()" :disabled="saving || !canSubmit"
          class="w-full py-3 rounded-xl bg-mmp-ink hover:opacity-95 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold shadow-lg">
          <span x-show="!saving">📍 Gửi đề xuất</span>
          <span x-show="saving">Đang gửi...</span>
        </button>

      </div>

    </div>
  </main>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script is:inline>
    function newPlace() {
      return {
        form: {
          name: "", address: "", lat: 0, lng: 0,
          category: "park", pet_policy: "leash_only",
          amenities: [], contact_phone: "", contact_website: "",
        },
        previews: [], // [{dataUrl, file, uploading, uploaded, url}]
        photoError: "",
        saving: false,
        error: "",
        map: null, marker: null,

        categories: [
          { key: "park", label: "Công viên", emoji: "🌳" },
          { key: "cafe", label: "Cafe", emoji: "☕" },
          { key: "vet", label: "Vet", emoji: "🏥" },
          { key: "restaurant", label: "Nhà hàng", emoji: "🍽️" },
          { key: "hotel", label: "Khách sạn", emoji: "🏨" },
          { key: "grooming", label: "Grooming", emoji: "✂️" },
          { key: "pet_shop", label: "Pet shop", emoji: "🛒" },
          { key: "beach", label: "Bãi biển", emoji: "🏖️" },
          { key: "other", label: "Khác", emoji: "📍" },
        ],

        amenityOptions: [
          { key: "water_bowl", label: "💧 Bowl nước" },
          { key: "outdoor_seating", label: "🌤️ Ngoài trời" },
          { key: "indoor", label: "🏠 Trong nhà" },
          { key: "off_leash_area", label: "🦮 Off-leash" },
          { key: "shade", label: "🌳 Bóng mát" },
          { key: "poop_bag", label: "🛍️ Bag rác" },
        ],

        get canSubmit() {
          return this.form.name.trim() && this.form.address.trim() &&
                 this.form.lat !== 0 && this.form.lng !== 0 && this.form.category;
        },

        init() { setTimeout(() => this.initMap(), 50); },

        initMap() {
          this.map = L.map("pick-map").setView([10.7769, 106.7009], 13);
          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19, attribution: "© OSM" }).addTo(this.map);
          this.map.on("click", (e) => {
            this.form.lat = Number(e.latlng.lat.toFixed(6));
            this.form.lng = Number(e.latlng.lng.toFixed(6));
            if (this.marker) this.map.removeLayer(this.marker);
            this.marker = L.marker([this.form.lat, this.form.lng]).addTo(this.map);
          });
        },

        useGeo() {
          if (!navigator.geolocation) { this.error = "Trình duyệt không hỗ trợ vị trí"; return; }
          navigator.geolocation.getCurrentPosition((pos) => {
            this.form.lat = Number(pos.coords.latitude.toFixed(6));
            this.form.lng = Number(pos.coords.longitude.toFixed(6));
            this.map.setView([this.form.lat, this.form.lng], 16);
            if (this.marker) this.map.removeLayer(this.marker);
            this.marker = L.marker([this.form.lat, this.form.lng]).addTo(this.map);
          });
        },

        toggleAmenity(k) {
          const i = this.form.amenities.indexOf(k);
          if (i >= 0) this.form.amenities.splice(i, 1);
          else this.form.amenities.push(k);
        },

        // ============ Photos ============
        fileToDataUrl(file) {
          return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result);
            reader.onerror = reject;
            reader.readAsDataURL(file);
          });
        },

        async handleFiles(event) {
          this.photoError = "";
          const files = Array.from(event.target.files || []);
          if (this.previews.length + files.length > 5) {
            this.photoError = "Tối đa 5 ảnh";
            event.target.value = "";
            return;
          }
          for (const file of files) {
            if (file.size > 5 * 1024 * 1024) {
              this.photoError = `Ảnh "${file.name}" vượt 5MB`;
              continue;
            }
            if (!["image/jpeg", "image/png", "image/webp"].includes(file.type)) {
              this.photoError = `Ảnh "${file.name}" không phải JPG/PNG/WebP`;
              continue;
            }
            const dataUrl = await this.fileToDataUrl(file);
            const preview = { dataUrl, file, uploading: true, uploaded: false, url: null };
            this.previews.push(preview);

            // Upload async
            try {
              const fd = new FormData();
              fd.append("file", file);
              const res = await fetch("/api/v1/places/upload-image", {
                method: "POST",
                credentials: "include",
                body: fd,
              });
              if (!res.ok) {
                const j = await res.json().catch(() => ({}));
                throw new Error(j?.error?.message || `Upload ${res.status}`);
              }
              const j = await res.json();
              preview.url = j.url;
              preview.uploading = false;
              preview.uploaded = true;
            } catch (err) {
              this.photoError = `Upload "${file.name}" thất bại: ${err.message}`;
              this.previews = this.previews.filter((p) => p !== preview);
            }
          }
          event.target.value = "";
        },

        removePhoto(idx) {
          this.previews.splice(idx, 1);
        },

        async submit() {
          this.error = "";
          if (!this.canSubmit) { this.error = "Cần đủ tên + địa chỉ + vị trí trên map"; return; }

          // Validate photos: require at least 1 uploaded, none still uploading
          const uploaded = this.previews.filter((p) => p.uploaded && p.url);
          if (uploaded.length === 0) {
            this.error = "Cần upload ít nhất 1 ảnh thực tế của địa điểm";
            return;
          }
          if (this.previews.some((p) => p.uploading)) {
            this.error = "Đợi ảnh upload xong rồi submit";
            return;
          }

          this.saving = true;
          try {
            const res = await fetch("/api/v1/places", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "include",
              body: JSON.stringify({
                ...this.form,
                photo_urls: uploaded.map((p) => p.url),
              }),
            });
            const j = await res.json();
            if (!res.ok) {
              this.error = j?.error?.message || "Lỗi gửi";
              return;
            }
            alert(`✓ Đã gửi đề xuất "${j.name}". Admin sẽ verify trong 1-2 ngày.`);
            window.location.href = `/places/${j.id}`;
          } catch (err) {
            this.error = "Lỗi kết nối server.";
          } finally {
            this.saving = false;
          }
        },
      };
    }
  </script>
</Layout>
