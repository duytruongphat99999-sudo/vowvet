---
/**
 * /onboarding — Màn "Thêm bé đầu tiên 🐾" (welcome-empty, thân thiện).
 *
 * v269: User chưa có pet nào → middleware đưa về đây (chặn dashboard,
 * kể cả khi gõ /dashboard trực tiếp). Màn này KHÔNG có form — chỉ chào
 * hỏi + nút "Thêm bé" dẫn sang /pets/new (chào hỏi → certificate cam
 * kết → form). Đã có ≥1 bé → /dashboard.
 */
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;

// Auth gate (belt-and-suspenders — middleware đã lo phần lớn)
if (!user) {
  return Astro.redirect("/login?return_to=%2Fonboarding");
}
if (user.is_onboarded === true) {
  return Astro.redirect("/dashboard");
}
---

<Layout title="Thêm bé đầu tiên · VowVet" description="Thêm thú cưng đầu tiên vào VowVet">
  <main class="min-h-screen flex items-center justify-center px-4 sm:px-6 py-10 bg-mmp-cream">
    <div class="max-w-md mx-auto text-center">
      <div class="text-6xl mb-5 select-none inline-block animate-bounce" style="animation-duration: 2.5s">🐾</div>
      <p class="text-sm text-mmp-ink/60 mb-1">Chào mừng bạn đến với VowVet 🌸</p>
      <h1 class="font-display italic text-3xl sm:text-4xl font-semibold text-mmp-ink leading-tight">
        Thêm bé đầu tiên
      </h1>
      <p class="mt-4 text-mmp-ink/75 leading-relaxed">
        Có một sinh linh nhỏ đã chọn bạn làm cả thế giới của nó.
        Mỗi bé cưng là một câu chuyện — hãy cùng VowVet mở trang đầu tiên:
        <strong class="text-mmp-ink">Hồ sơ Trọn đời</strong>, nơi tình yêu thương được ghi lại trọn vẹn.
      </p>
      <a href="/pets/new"
         class="mt-8 inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-mmp-ink text-white font-bold text-base hover:bg-mmp-ink/90 shadow-lg transition">
        <span class="text-xl">🐶</span> Thêm bé
        <span>→</span>
      </a>
      <p class="mt-6">
        <a href="/logout" class="text-xs text-mmp-ink/40 hover:text-mmp-ink">← Đăng xuất</a>
      </p>
    </div>
  </main>
</Layout>
