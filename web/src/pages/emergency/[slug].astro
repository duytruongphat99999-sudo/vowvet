---
/**
 * /emergency/[slug] — First Aid article detail (M9.3).
 *
 * 6 sections: symptoms_to_check, do_now, do_not, transport, while_waiting, red_flags.
 * Sticky bottom: tel: clinic + /chat/new pre-filled subject.
 * Print-friendly CSS để screenshot/save offline.
 */
import Layout from "../../layouts/Layout.astro";
import { getClinicInfo } from "../../../../shared/clinic-info.ts";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const slug = Astro.params.slug;
if (!slug) return Astro.redirect("/emergency");

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";
const clinic = getClinicInfo();

let article: any = null;
let loadStatus = 0;
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/first-aid/articles/${slug}`, {
    headers: { cookie: cookieHeader },
  });
  loadStatus = res.status;
  if (res.ok) {
    const j = await res.json();
    article = j.article;
  }
} catch (_) {}

if (loadStatus === 401) return Astro.redirect("/login");
if (!article) return Astro.redirect("/emergency");

// Pre-fill chat subject = bài này
const chatSubject = `Sơ cứu — ${article.title_vi}`;
const chatLink = `/chat/new?subject=${encodeURIComponent(chatSubject)}`;

// Severity colors
const severityClass = {
  CRITICAL: "from-red-600 to-red-700 border-red-300",
  URGENT: "from-orange-500 to-orange-600 border-amber-200",
  IMPORTANT: "from-amber-500 to-amber-600 border-amber-300",
}[article.severity as "CRITICAL" | "URGENT" | "IMPORTANT"] || "from-slate-500 to-slate-600 border-slate-300";
---

<Layout title={`${article.title_vi} · Cấp cứu · VowVet`} description={article.preview}>
  <Fragment slot="head">
    <style is:inline>
      @media print {
        nav, .no-print, header > a, .sticky-cta { display: none !important; }
        main { background: white !important; padding: 0 !important; }
        section { break-inside: avoid; page-break-inside: avoid; }
        body { font-size: 11pt; }
        a { color: black !important; text-decoration: none !important; }
      }
    </style>
  </Fragment>

  <main class="min-h-screen bg-slate-50 pb-32">
    <!-- Header -->
    <header class="bg-white border-b border-slate-200 px-4 py-3 flex items-center justify-between gap-3 sticky top-0 z-30 no-print">
      <a href="/emergency" class="text-sm text-slate-500 hover:text-slate-700">← Cấp cứu</a>
      <h1 class="text-sm font-bold text-slate-900 truncate flex-1 text-center">{article.title_vi}</h1>
      <button onclick="window.print()" class="text-slate-500 hover:text-slate-700 text-lg" title="In / Lưu PDF">🖨️</button>
    </header>

    <div class="max-w-2xl mx-auto px-4 py-4">

      <!-- Severity banner -->
      <div class={`bg-gradient-to-r ${severityClass} text-white rounded-2xl p-4 mb-4 shadow-md`}>
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-xs uppercase tracking-wider opacity-90 font-bold">
              {article.severity_label_vi}
            </p>
            <h2 class="text-lg sm:text-xl font-bold mt-1">{article.title_vi}</h2>
            <p class="text-xs opacity-90 mt-1">
              {article.category_label_vi}
              {" · "}
              {article.species.includes("dog") && "🐶"}
              {article.species.includes("cat") && " 🐱"}
              {article.species.includes("both") && " 🐾"}
            </p>
          </div>
        </div>
        <p class="text-sm mt-3 leading-relaxed">{article.preview}</p>
      </div>

      <!-- Section 1: SYMPTOMS TO CHECK -->
      <section class="bg-white rounded-2xl border border-slate-200 p-5 mb-3">
        <h3 class="text-base font-bold text-slate-900 mb-3 flex items-center gap-2">
          ⚠️ Triệu chứng cần chú ý
        </h3>
        <ul class="space-y-1.5">
          {article.symptoms_to_check.map((s: string) => (
            <li class="flex items-start gap-2 text-sm text-slate-800">
              <span class="text-amber-500 shrink-0 mt-0.5">▸</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Section 2: DO NOW (ordered list, big numbers) -->
      <section class="bg-emerald-50 border-2 border-emerald-300 rounded-2xl p-5 mb-3">
        <h3 class="text-base font-bold text-emerald-900 mb-3 flex items-center gap-2">
          ✅ LÀM NGAY (theo thứ tự)
        </h3>
        <ol class="space-y-2.5">
          {article.do_now.map((step: string, i: number) => (
            <li class="flex items-start gap-3">
              <span class="bg-emerald-600 text-white font-bold text-sm w-7 h-7 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                {i + 1}
              </span>
              <span class="text-sm text-slate-900 flex-1 pt-0.5 leading-relaxed">{step}</span>
            </li>
          ))}
        </ol>
      </section>

      <!-- Section 3: DO NOT -->
      <section class="bg-red-50 border-2 border-red-300 rounded-2xl p-5 mb-3">
        <h3 class="text-base font-bold text-red-900 mb-3 flex items-center gap-2">
          ❌ TUYỆT ĐỐI KHÔNG
        </h3>
        <ul class="space-y-1.5">
          {article.do_not.map((d: string) => (
            <li class="flex items-start gap-2 text-sm text-slate-800">
              <span class="text-red-600 shrink-0 mt-0.5 font-bold">✕</span>
              <span>{d}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Section 4: TRANSPORT -->
      <section class="bg-white rounded-2xl border border-slate-200 p-5 mb-3">
        <h3 class="text-base font-bold text-slate-900 mb-2 flex items-center gap-2">
          🚑 Vận chuyển an toàn
        </h3>
        <p class="text-sm text-slate-800 leading-relaxed">{article.transport}</p>
      </section>

      <!-- Section 5: WHILE WAITING -->
      <section class="bg-white rounded-2xl border border-slate-200 p-5 mb-3">
        <h3 class="text-base font-bold text-slate-900 mb-3 flex items-center gap-2">
          ⏱️ Khi đợi đến vet
        </h3>
        <ul class="space-y-1.5">
          {article.while_waiting.map((w: string) => (
            <li class="flex items-start gap-2 text-sm text-slate-800">
              <span class="text-sky-500 shrink-0 mt-0.5">▸</span>
              <span>{w}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Section 6: RED FLAGS -->
      <section class="bg-red-600 text-white rounded-2xl p-5 mb-4 shadow-lg">
        <h3 class="text-base font-bold mb-3 flex items-center gap-2">
          🚨 RED FLAG — Cấp cứu ngay nếu thấy:
        </h3>
        <ul class="space-y-1.5">
          {article.red_flags.map((r: string) => (
            <li class="flex items-start gap-2 text-sm">
              <span class="shrink-0 mt-0.5">🚨</span>
              <span class="font-medium">{r}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Disclaimer -->
      <p class="text-xs text-slate-500 text-center mt-6 italic">
        Hướng dẫn này KHÔNG thay chẩn đoán của bác sĩ. Luôn liên hệ clinic ngay cả khi pet có vẻ ổn.
      </p>
    </div>

    <!-- Sticky bottom CTA -->
    <div class="sticky-cta fixed bottom-0 left-0 right-0 bg-white border-t-2 border-slate-200 px-3 py-2 shadow-2xl z-40 no-print">
      <div class="max-w-2xl mx-auto grid grid-cols-2 gap-2">
        <a href={`tel:${clinic.phone_tel_link}`}
           class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-xl text-center transition active:scale-95">
          📞 Gọi clinic
          <span class="block text-[10px] opacity-90 font-mono">{clinic.phone}</span>
        </a>
        <a href={chatLink}
           class="bg-sky-600 hover:bg-sky-700 text-white font-bold py-3 rounded-xl text-center transition active:scale-95">
          💬 Chat với bác sĩ
          <span class="block text-[10px] opacity-90">Giờ làm việc</span>
        </a>
      </div>
    </div>
  </main>
</Layout>
