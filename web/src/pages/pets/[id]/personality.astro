          <div aria-hidden="true" class="neuron" style="top:28%; right:9%;  animation: neuronFly2 7s ease-in-out infinite;"></div>
          <div aria-hidden="true" class="neuron" style="top:58%; left:6%;   animation: neuronFly3 5.5s ease-in-out infinite;"></div>
          <div aria-hidden="true" class="neuron" style="top:65%; right:10%; animation: neuronFly1 8s ease-in-out infinite reverse;"></div>
          <div aria-hidden="true" class="neuron" style="bottom:14%; left:25%; animation: neuronFly2 6.5s ease-in-out infinite;"></div>
          <div aria-hidden="true" class="neuron" style="top:46%; left:44%;  animation: neuronFly3 9s ease-in-out infinite reverse;"></div>
          <div aria-hidden="true" class="neuron" style="bottom:20%; right:25%; animation: neuronFly1 7.5s ease-in-out infinite;"></div>
          <div aria-hidden="true" class="neuron" style="top:10%; right:30%; animation: neuronFly2 5s ease-in-out infinite reverse;"></div>

          <!-- Scan beams: horizontal + vertical (gold blur) -->
          <div aria-hidden="true" class="ai-scan-h"></div>
          <div aria-hidden="true" class="ai-scan-v"></div>

          <!-- 3 expanding pulse rings from center -->
          <div aria-hidden="true" class="ai-pulse-ring"></div>
          <div aria-hidden="true" class="ai-pulse-ring delay-1"></div>
          <div aria-hidden="true" class="ai-pulse-ring delay-2"></div>

          <!-- ★ v135: ICONIC rotating radar sweep beam (360° continuous) -->
          <div aria-hidden="true" class="radar-sweep"></div>

          <div class="relative grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-4 items-center" style="z-index:2">
            <!-- v143 — LIVING RADAR (real SVG elements via x-effect + createElementNS).
                 ✓ Real <circle>/<line>/<text> trong DOM (devtools inspect được từng element)
                 ✓ Reactive: x-effect tracks dim6Dots/dim6Labels, rebuild khi result thay đổi
                 ✓ Không <template> trong SVG → no importNode error
                 ✓ Không <circle x-for> (Alpine không support — chỉ <template> support được x-for)
                 ✓ IntersectionObserver: hiệu ứng chỉ chạy khi card scroll vào view -->
            <div class="radar-living"
                 :class="radarVisible ? 'is-visible' : ''"
                 x-init="setupRadarObserver($el)">
              <svg viewBox="0 0 320 280"
                   class="w-full max-w-[380px] mx-auto block radar-svg"
                   x-effect="renderRadar6dSvg($el)"
                   aria-label="Radar 6 chiều tính cách">
