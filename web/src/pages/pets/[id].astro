        } catch (_) {
          this.care.weatherError = "Mạng lỗi";
        } finally {
          this.care.loading.weather = false;
        }
      },

      async fetchCheckIn() {
        this.care.loading.checkIn = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/check-in/today`);
          if (res.ok) {
            const json = await res.json();
            this.care.checkIn = json.check_in;
            if (json.check_in) {
              this.care.showCheckInForm = false;
              // Pre-populate form trong trường hợp user click "Cập nhật"
              this.care.form = {
                appetite: json.check_in.appetite || null,
                energy: json.check_in.energy || null,
                stool_quality: json.check_in.stool_quality || "",
                water_ml: json.check_in.water_ml || null,
                symptoms: json.check_in.symptoms || [],
                notes: json.check_in.notes || "",
              };
            } else {
              this.care.showCheckInForm = true;
            }
          }
        } catch (_) {} finally {
          this.care.loading.checkIn = false;
        }
      },

      openCheckInForm() { this.care.showCheckInForm = true; },

      async fetchCarePlan() {
        this.care.loading.plan = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/care-plan/today`);
          const json = await res.json();
          this.care.refresh = json.refresh || null;
          if (json.status === "no_checkin") {
            this.care.planStatus = "no_checkin";
            this.care.plan = null;
          } else if (json.status === "fresh" && json.care_plan) {
            this.care.planStatus = "fresh";
            this.care.plan = json.care_plan.plan;
            this.care.metadata = json.care_plan.metadata;
            this.care.feedback = json.care_plan.user_feedback || null;
          } else if (json.status === "processing") {
            this.care.planStatus = "processing";
            this.startPolling();
          } else {
            this.care.planStatus = "no_plan";
          }
        } catch (err) {
          this.care.planStatus = "error";
          this.care.planError = err.message || "Lỗi kết nối";
        } finally {
          this.care.loading.plan = false;
        }
      },

      startPolling() {
        this.stopPolling();
        this.care._pollAttempts = 0;
        this.care._pollTimer = setInterval(async () => {
          this.care._pollAttempts++;
          if (this.care._pollAttempts > 10) {
            this.stopPolling();
            this.care.planStatus = "error";
            this.care.planError = "Quá 30 giây vẫn chưa có kết quả. Thử lại nhé.";
            return;
          }
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/care-plan/today`);
            const json = await res.json();
            this.care.refresh = json.refresh || null;
            if (json.status === "fresh" && json.care_plan) {
              this.stopPolling();
              this.care.planStatus = "fresh";
              this.care.plan = json.care_plan.plan;
              this.care.metadata = json.care_plan.metadata;
              this.care.feedback = json.care_plan.user_feedback || null;
            }
          } catch (_) {}
        }, 3000);
      },
      stopPolling() {
        if (this.care._pollTimer) {
          clearInterval(this.care._pollTimer);
          this.care._pollTimer = null;
        }
      },

      async submitCheckIn() {
        this.care.checkInError = "";
        if (!this.care.form.appetite || !this.care.form.energy) {
          this.care.checkInError = "Cần nhập Thèm ăn và Năng lượng";
          return;
        }
        this.care.submittingCheckIn = true;
        try {
          const payload = {
            appetite: this.care.form.appetite,
            energy: this.care.form.energy,
            stool_quality: this.care.form.stool_quality || null,
            water_ml: this.care.form.water_ml || null,
            symptoms: this.care.form.symptoms,
            notes: this.care.form.notes || null,
          };
          const res = await fetch(`/api/v1/pets/${this.pet.id}/check-in`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const json = await res.json();
          if (!res.ok) {
            this.care.checkInError = json.error?.message || "Có lỗi xảy ra";
            return;
          }
          // Refetch check-in để có row mới + start polling
          await this.fetchCheckIn();
          this.care.planStatus = "processing";
          this.care.plan = null;
          this.startPolling();
        } catch (err) {
          this.care.checkInError = "Lỗi kết nối";
        } finally {
          this.care.submittingCheckIn = false;
        }
      },

      async refreshPlan() {
        this.care.refreshing = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/care-plan/refresh`, { method: "POST" });
          const json = await res.json();
          if (!res.ok) {
            this.care.planError = json.error?.message || "Không refresh được";
            this.care.refresh = json.refresh || this.care.refresh;
            return;
          }
          this.care.refresh = json.refresh || this.care.refresh;
          this.care.planStatus = "processing";
          this.startPolling();
        } catch (err) {
          // ignore
        } finally {
          this.care.refreshing = false;
        }
      },

      async sendFeedback(value) {
        const next = this.care.feedback === value ? null : value;
        this.care.feedbackPending = true;
        try {
          const res = await fetch(`/api/v1/pets/${this.pet.id}/care-plan/feedback`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ feedback: next }),
          });
          if (res.ok) this.care.feedback = next;
        } catch (_) {} finally {
          this.care.feedbackPending = false;
        }
      },

      async toggleHistory() {
        this.care.historyExpanded = !this.care.historyExpanded;
        if (this.care.historyExpanded && this.care.history.length === 0) {
          this.care.loading.history = true;
          try {
            const res = await fetch(`/api/v1/pets/${this.pet.id}/check-ins/history?days=30`);
            if (res.ok) {
              const json = await res.json();
              this.care.history = json.history || [];
            }
          } catch (_) {} finally {
            this.care.loading.history = false;
          }
        }
      },

      filteredHistory() {
        const f = this.care.historyFilter;
        if (f === "all") return this.care.history;
        if (f === "concern") return this.care.history.filter(h => h.plan && h.plan.urgency_level !== "normal");
        return this.care.history.filter(h => !h.plan || h.plan.urgency_level === "normal");
      },

