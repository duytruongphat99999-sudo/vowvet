      50% { box-shadow: inset 0 2px 4px rgba(255,255,255,0.5), inset 0 -2px 4px rgba(0,0,0,0.2), 0 0 36px rgba(236,185,33,0.9), 0 12px 28px -4px rgba(180,134,8,0.6); }
