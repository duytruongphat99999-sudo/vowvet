                  <h3 class="font-display italic font-semibold text-base text-mmp-ink truncate" x-text="r.name"></h3>
                  <p class="text-xs italic text-[var(--c-ink-54)] inline-flex items-center gap-1.5 mt-0.5">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span x-text="r.start_time"></span>
                    <span class="opacity-50">·</span>
                    <span x-text="`${r.tasks.length} task`"></span>
                  </p>
                </div>
                <div class="text-right">
                  <div class="font-display italic font-bold text-xl tabular-nums" style="color: #B48608;">
                    <span x-text="completedCount(r)"></span>/<span x-text="r.tasks.length"></span>
                  </div>
                  <p class="text-[10px] italic text-[var(--c-ink-54)] mt-0.5">
                    <span x-show="!r._expanded">Mở ▼</span>
                    <span x-show="r._expanded">Ẩn ▲</span>
                  </p>
                </div>
              </header>

              <div class="mt-3 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-700"
                  :style="`background: linear-gradient(90deg, #ecb921 0%, #B48608 100%); width: ${(completedCount(r) / r.tasks.length) * 100}%`"></div>
              </div>

              <div x-show="r._expanded" x-transition class="mt-3 space-y-1.5">
                <template x-for="task in r.tasks" :key="task.id">
                  <label class="task-check flex items-center gap-3 p-2.5 rounded-xl cursor-pointer hover:bg-mmp-cream/40 transition"
                    :class="isTaskDone(r, task.id) && 'checked'">
                    <input type="checkbox"
                      :checked="isTaskDone(r, task.id)"
                      @change="toggleTask(r, task.id)"
                      class="w-5 h-5 rounded shrink-0" style="accent-color: #B48608;" />
                    <span class="text-lg shrink-0" x-text="task.emoji"></span>
                    <span class="task-check__title flex-1 min-w-0 text-sm italic text-mmp-ink">
                      <span x-text="task.title"></span>
                    </span>
                    <span class="text-[11px] italic font-bold shrink-0 inline-flex items-center gap-0.5 tabular-nums" style="color: #B48608;">
                      +<span x-text="task.points"></span>
                      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15 8.5 22 9.3 17 14 18.2 21 12 17.8 5.8 21 7 14 2 9.3 9 8.5 12 2"/></svg>
                    </span>
                  </label>
                </template>

                <template x-if="r._saving">
                  <p class="text-[10px] italic text-[var(--c-ink-54)] text-center mt-2">Đang lưu…</p>
                </template>
              </div>
            </article>
          </template>
        </div>
      </section>

      <!-- ───── All routines ───── -->
      <section>
        <div class="flex items-end justify-between mb-3 gap-2">
          <div>
            <p class="text-[10px] uppercase italic tracking-[0.22em] font-bold" style="color: #B48608;">Quản lý</p>
            <h2 class="font-display italic text-lg sm:text-xl font-semibold text-mmp-ink leading-tight inline-flex items-center gap-2">
              <FeatureIcon name="book-open" class="w-5 h-5" />
