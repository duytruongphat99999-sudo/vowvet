    .hui-coin-wrapper { position: relative; z-index: 1; display: flex; justify-content: center; margin: 16px 0 12px 0; }
    .hui-coin {
      position: relative; width: 80px; height: 80px; border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #ffd56b 0%, #ecb921 40%, #B48608 100%);
      display: flex; align-items: center; justify-content: center; font-size: 36px;
      box-shadow: inset 0 2px 4px rgba(255,255,255,0.4), inset 0 -2px 4px rgba(0,0,0,0.2), 0 0 24px rgba(236,185,33,0.6), 0 8px 20px -4px rgba(180,134,8,0.5);
      animation: hui-coin-float 4s ease-in-out infinite, hui-coin-glow 3s ease-in-out infinite;
