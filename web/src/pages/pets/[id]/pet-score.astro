              </div>
            </foreignObject>
          </svg>
        </div>
        <div class="constellation-legend">
          <span><span class="legend-dot legend-bright"></span>Tốt</span>
          <span><span class="legend-dot legend-faint"></span>Bình thường</span>
          <span><span class="legend-dot legend-neutral"></span>Trung tính</span>
