    .hui-tagline { position: relative; z-index: 1; text-align: center; color: rgba(255,255,255,0.85); font-family: var(--font-display, 'Fraunces', serif); font-style: italic; font-size: 14px; line-height: 1.5; margin: 0 8px 16px 8px; }
