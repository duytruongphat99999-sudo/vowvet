---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Trạng thái hệ thống · VowVet">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <div class="text-center mb-12">
      <h1 class="text-5xl font-bold tracking-tight text-mmp-ink">
        VowVet
      </h1>
      <p class="mt-2 text-sm text-slate-500">Trạng thái hệ thống · Phiên bản 0.2.0</p>
    </div>

    <div
      x-data="healthCheck()"
      x-init="fetchHealth()"
      class="w-full max-w-md bg-white rounded-2xl shadow-lg border border-slate-100 p-6"
    >
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-slate-900">Dịch vụ phụ thuộc</h2>
        <button
          @click="fetchHealth()"
          :disabled="loading"
          class="text-sm text-sky-600 hover:text-sky-700 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span x-show="!loading">Kiểm tra lại</span>
          <span x-show="loading">Đang kiểm tra…</span>
        </button>
      </div>

      <div x-show="error" class="text-red-600 text-sm py-2" x-text="error"></div>

      <div x-show="!error && data" class="space-y-3">
        <div class="flex items-center justify-between py-2 border-b border-slate-100">
          <span class="text-slate-700 font-medium">Tổng quan</span>
          <span
            class="px-3 py-1 rounded-full text-xs font-semibold"
            :class="data?.status === 'ok' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'"
            x-text="data?.status === 'ok' ? 'Hoạt động' : 'Có sự cố'"
          ></span>
        </div>
        <div class="flex items-center justify-between py-2 border-b border-slate-100">
          <span class="text-slate-600">Baserow (CSDL)</span>
          <span
            class="px-3 py-1 rounded-full text-xs font-semibold"
            :class="data?.services?.baserow === 'ok' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'"
            x-text="data?.services?.baserow === 'ok' ? 'OK' : 'Lỗi'"
          ></span>
        </div>
        <div class="flex items-center justify-between py-2">
          <span class="text-slate-600">Cloudflare R2 (Lưu trữ)</span>
          <span
            class="px-3 py-1 rounded-full text-xs font-semibold"
            :class="data?.services?.r2 === 'ok' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'"
            x-text="data?.services?.r2 === 'ok' ? 'OK' : 'Lỗi'"
          ></span>
        </div>
        <p class="text-xs text-slate-400 pt-3" x-show="data?.timestamp">
          Cập nhật: <span x-text="new Date(data.timestamp).toLocaleString('vi-VN')"></span>
        </p>
      </div>
    </div>

    <a href="/" class="mt-8 text-sm text-slate-500 hover:text-slate-700">← Về trang chính</a>
  </main>
</Layout>

<script is:inline>
  function healthCheck() {
    return {
      loading: false,
      data: null,
      error: null,
      async fetchHealth() {
        this.loading = true;
        this.error = null;
        try {
          const res = await fetch("/api/v1/health");
          this.data = await res.json();
        } catch (err) {
          this.error = "Không kết nối được tới API: " + (err.message || err);
        } finally {
          this.loading = false;
        }
      },
    };
  }
</script>
