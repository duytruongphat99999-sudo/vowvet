              <div class="flex-1 min-w-0">
                <p class="text-[10px] uppercase tracking-[0.22em] font-bold" style="color:#ecb921">Tính cách của bé</p>
                <h2 class="text-xl sm:text-2xl font-black tracking-tight mt-1 leading-tight name-shine" x-text="`${pet.name} · ${existingResult?.type_meta?.name_vi || ''}`"></h2>
                <div class="flex items-center gap-2 mt-2">
