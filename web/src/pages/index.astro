---
/**
 * Landing page (M8) — public homepage.
 *
 * Mon Min Pet brand-aligned premium redesign:
 *   - Ink hero with gold accent (matches bio.monminpet.com)
 *   - Premium stats grid (no awkward "Cảnh báo gửi" label)
 *   - ALL-IN-ONE feature section with inline SVG icons (no emoji)
 *   - "Đối tác lâm sàng" dark section with founder card + WSAVA badge
 *   - 3-platform ecosystem with "Bạn đang ở đây" highlight
 *   - Accessible to anonymous + logged-in users (page adapts CTA per state)
 */
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import FeatureIcon from "../components/FeatureIcon.astro";
import LangSwitch from "../components/LangSwitch.astro";
import { makeTranslator } from "../../../shared/i18n.ts";
import { HEALTH_CONDITIONS } from "../../../shared/health-conditions.ts";

const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

// i18n
const locale = Astro.locals.locale ?? "vi";
const tt = makeTranslator(locale);

// Adapt CTA based on session
const session = Astro.locals.user;
const isLoggedIn = !!session;
const isOnboarded = session?.is_onboarded === true;
const dashboardHref = isLoggedIn ? (isOnboarded ? "/dashboard" : "/onboarding") : "/login";
const ctaPrimary = isLoggedIn
  ? (isOnboarded ? tt("home.cta_logged_in_onboarded") : tt("home.cta_logged_in_not_onboarded"))
  : tt("home.cta_anon");
const ctaSubLabel = isLoggedIn ? tt("home.cta_continue_existing") : tt("home.badge_setup_30s") + " · " + tt("home.badge_free");

// Public stats (10-min cache server-side)
let stats = { total_pets: 0, total_users: 0, total_alerts: 0, total_vaccines: 0, partner_clinics: 1 };
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/public/stats`);
  if (res.ok) {
    const j = await res.json();
    stats = { ...stats, ...j };
  }
} catch (_) {}

const pageUrl = "https://vowvet.monminpet.com/";

const features = [
  { slug: "ho-chieu-pet-24-7", icon: "passport" as const,  title: tt("home.features.passport_title"),  desc: tt("home.features.passport_desc")  },
  { slug: "ai-dong-hanh-y-khoa", icon: "ai" as const,       title: tt("home.features.ai_title"),        desc: tt("home.features.ai_desc")        },
  { slug: "canh-bao-khi-hau",  icon: "climate" as const,    title: tt("home.features.climate_title"),   desc: tt("home.features.climate_desc")   },
  { slug: "vaccine-wsava",     icon: "syringe" as const,    title: tt("home.features.syringe_title"),   desc: tt("home.features.syringe_desc")   },
  { slug: "dinh-duong-aafco",  icon: "nutrition" as const,  title: tt("home.features.nutrition_title"), desc: tt("home.features.nutrition_desc") },
  { slug: "album-nose-print",  icon: "camera" as const,     title: tt("home.features.camera_title"),    desc: tt("home.features.camera_desc")    },
];

// 7th card — Insurance (links to /insurance, NOT /articles/...)
const insuranceCard = {
  href: "/insurance",
  icon: "shield" as const,
  badge: tt("home.features.insurance_badge"),
  title: tt("home.features.insurance_title"),
  desc: tt("home.features.insurance_desc"),
};
---

<Layout
  title="VowVet by Mon Min Pet — Người bạn đồng hành sức khỏe thú cưng"
  description="AI + WSAVA + AAFCO chuẩn quốc tế tại Việt Nam. QR Passport, lịch tiêm tự động, cảnh báo khí hậu, dinh dưỡng cá nhân hoá. Miễn phí trọn đời."
>
  <Fragment slot="head">
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content="VowVet by Mon Min Pet — Chăm pet giỏi hơn chủ" />
    <meta property="og:description" content="AI + WSAVA + AAFCO chuẩn quốc tế. QR Passport, vaccine, dinh dưỡng, climate alerts. Miễn phí." />
    <meta name="keywords" content="chăm sóc thú cưng, AI thú y, lịch tiêm phòng chó mèo, hộ chiếu pet, dinh dưỡng pet, Mon Min Pet, VowVet, WSAVA, AAFCO" />
  </Fragment>

  <main class="min-h-screen bg-white">
    <!-- ═══════════════════════════════════════════════════════════
         TOP NAV (sticky, white, larger logo)
         ═══════════════════════════════════════════════════════════ -->
    <nav class="bg-white border-b border-mmp-ink/12 sticky top-0 z-30 backdrop-blur supports-[backdrop-filter]:bg-white/95">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 sm:h-18 flex items-center justify-between gap-3">
        <Logo variant="default" href="/" />
        <div class="flex items-center gap-2 sm:gap-4 text-sm">
          <a href="/why-vowvet" class="text-slate-600 hover:text-mmp-ink hidden sm:inline transition">Vì sao VowVet?</a>
          <a href="/food-brands" class="text-slate-600 hover:text-mmp-ink hidden md:inline transition">Dinh dưỡng</a>
          <a href={dashboardHref} class="bg-mmp-ink hover:bg-slate-800 text-white font-semibold px-5 py-2 rounded-lg transition">
            {isLoggedIn ? "Dashboard" : "Đăng nhập"}
          </a>
        </div>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════
         HERO — asymmetric 2-col: text left, floating preview cards right
         ═══════════════════════════════════════════════════════════ -->
    <section class="bg-mmp-ink text-white relative overflow-hidden">
      <!-- Ambient gold spotlight -->
      <div class="absolute inset-0 opacity-25 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 right-0 w-[700px] h-[700px] rounded-full"
             style="background: radial-gradient(circle, rgba(236,185,33,0.55) 0%, transparent 70%);"></div>
        <div class="absolute bottom-0 left-0 w-[500px] h-[500px] rounded-full"
             style="background: radial-gradient(circle, rgba(236,185,33,0.25) 0%, transparent 70%);"></div>
      </div>
      <!-- Decorative paw grid pattern (very subtle) -->
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" aria-hidden="true"
           style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20 lg:py-28">
        <div class="grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">

          <!-- ─── LEFT: WOW text content ─── -->
          <div class="text-center lg:text-left">
            <p class="hero-fade hero-fade-d1 eyebrow mb-6" style="color: var(--c-gold);">
              <span class="gold-dot"></span>Vì pet là gia đình
            </p>

            <!-- Big stacked Fraunces headline with creative typography -->
            <h1 class="hero-fade hero-fade-d2 font-display italic font-semibold leading-[0.95] tracking-tight mb-6">
              <span class="block text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white">Người bạn</span>
              <span class="block text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white/85 mt-1">đồng hành sức khoẻ</span>
              <span class="relative inline-block gold-sweep text-4xl sm:text-5xl md:text-6xl lg:text-7xl mt-3" style="color: var(--c-gold);">
                cho thú cưng
              </span>
            </h1>

            <p class="hero-fade hero-fade-d3 text-base sm:text-lg text-white/72 max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
              AI + <strong class="text-white">WSAVA</strong> + <strong class="text-white">AAFCO</strong> chuẩn quốc tế.
              Tất cả tiếng Việt, miễn phí trọn đời.
            </p>

            <!-- Mini trust badges row -->
            <div class="hero-fade hero-fade-d4 flex flex-wrap items-center justify-center lg:justify-start gap-2 mb-8">
              <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-white/10 backdrop-blur border border-white/15">
                <span class="w-1.5 h-1.5 rounded-full" style="background: var(--c-gold);"></span>
                <span class="text-white/90">AI tiếng Việt</span>
              </span>
              <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-white/10 backdrop-blur border border-white/15">
                <span class="w-1.5 h-1.5 rounded-full" style="background: var(--c-gold);"></span>
                <span class="text-white/90">100% Miễn phí</span>
              </span>
              <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full bg-white/10 backdrop-blur border border-white/15">
                <span class="w-1.5 h-1.5 rounded-full" style="background: var(--c-gold);"></span>
                <span class="text-white/90">30 giây setup</span>
              </span>
            </div>

            <!-- CTA -->
            <div class="hero-fade hero-fade-d5 flex flex-col sm:flex-row gap-3 justify-center lg:justify-start items-center">
              <a href={dashboardHref}
                 class="bg-mmp-gold text-mmp-ink hover:scale-[1.02] hover:shadow-lg hover:shadow-mmp-gold/40 font-bold px-8 py-4 rounded-xl shadow-md transition inline-flex items-center justify-center gap-2 text-base">
                {ctaPrimary}
                <FeatureIcon name="arrow" class="w-4 h-4" />
              </a>
              <a href="#features"
                 class="text-white/72 hover:text-white text-sm font-medium underline-offset-4 hover:underline transition">
                Xem 6 tính năng cốt lõi ↓
              </a>
            </div>
            <p class="hero-fade hero-fade-d5 text-xs text-white/60 mt-4">{ctaSubLabel}</p>
          </div>

          <!-- ─── RIGHT: Floating product preview cards (WOW visual) ─── -->
          <div class="relative h-[420px] sm:h-[480px] lg:h-[540px] mx-auto w-full max-w-md lg:max-w-none">
            <!-- Backdrop logo (very subtle, big) -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.07]">
              <img src="/logo-mmp.png" alt="" class="w-80 h-80 sm:w-96 sm:h-96 object-contain" />
            </div>

            <!-- Card 1: Pet Score gauge (top-left) -->
            <div class="float-y absolute top-2 left-2 sm:top-4 sm:left-0 w-44 sm:w-48 bg-white text-mmp-ink rounded-2xl shadow-2xl p-4 z-20 hero-fade hero-fade-d3">
              <div class="flex items-center justify-between mb-2">
                <p class="text-[10px] text-slate-500 uppercase tracking-widest font-semibold">Pet Score</p>
                <span class="text-base">🏆</span>
              </div>
              <p class="text-4xl font-bold leading-none" style="color: var(--c-gold);">850</p>
              <p class="text-[10px] text-slate-500 mt-1">/ 1000 · Tier Gold</p>
              <div class="mt-3 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width: 85%; background: linear-gradient(90deg, var(--c-gold), #fde68a);"></div>
              </div>
            </div>

            <!-- Card 2: Today's quest done (top-right) -->
            <div class="float-y-slow absolute top-8 right-0 sm:top-4 sm:right-2 w-48 sm:w-52 bg-white text-mmp-ink rounded-2xl shadow-2xl p-4 z-20 hero-fade hero-fade-d4">
              <div class="flex items-center justify-between mb-2">
                <p class="text-[10px] text-slate-500 uppercase tracking-widest font-semibold">Nhiệm vụ hôm nay</p>
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 text-xs">✓</span>
              </div>
              <p class="font-bold text-sm leading-tight">Check-in cảm xúc</p>
              <p class="text-xs text-slate-500 mt-1">+15 điểm Pet Score</p>
              <div class="mt-3 flex items-center gap-1">
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700 font-semibold">Hoàn thành</span>
                <span class="text-[10px] text-slate-400">2/3 hôm nay</span>
              </div>
            </div>

            <!-- Card 3: Vaccine reminder (middle, ink dark — anchor) -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-56 sm:w-64 bg-mmp-ink border border-white/15 rounded-2xl shadow-2xl p-5 z-30 hero-fade hero-fade-d2"
                 style="box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6), 0 0 30px -4px rgba(236,185,33,0.3);">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-xl bg-mmp-gold/15 flex items-center justify-center">
                  <FeatureIcon name="syringe" class="w-5 h-5" strokeWidth={1.8} />
                </div>
                <div>
                  <p class="text-[10px] uppercase tracking-widest font-semibold" style="color: var(--c-gold);">WSAVA</p>
                  <p class="text-xs text-white/60">Nhắc trước 14 ngày</p>
                </div>
              </div>
              <p class="font-bold text-sm text-white">Bé Mon — DHPP Booster</p>
              <p class="text-xs text-white/72 mt-1.5 mb-3">25/06 · còn 14 ngày</p>
              <div class="flex items-center gap-2 pt-3 border-t border-white/10">
                <span class="text-[10px] uppercase tracking-widest" style="color: var(--c-gold);">Lịch tiêm</span>
                <span class="ml-auto text-[10px] text-white/60">3/9 đã tiêm</span>
              </div>
            </div>

            <!-- Card 4: Climate alert (bottom-left, smaller) -->
            <div class="float-y-fast absolute bottom-4 left-0 sm:bottom-8 sm:left-4 w-40 sm:w-44 bg-white text-mmp-ink rounded-2xl shadow-2xl p-3.5 z-20 hero-fade hero-fade-d4">
              <div class="flex items-center justify-between">
                <span class="text-base">🌡️</span>
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-50 text-amber-700 font-semibold uppercase tracking-wider">Warning</span>
              </div>
              <p class="text-2xl font-bold leading-none mt-2 text-mmp-ink">35°C</p>
              <p class="text-[10px] text-slate-500 mt-1">HCM Quận 1 · AQI 78</p>
              <p class="text-[10px] mt-2 text-amber-700">⚠ Tránh dắt bé đi dạo trưa</p>
            </div>

            <!-- Card 5: QR Passport mini (bottom-right) -->
            <div class="float-y absolute bottom-0 right-2 sm:bottom-4 sm:right-0 w-36 sm:w-40 bg-mmp-gold text-mmp-ink rounded-2xl shadow-2xl p-3 z-20 hero-fade hero-fade-d5">
              <div class="flex items-center justify-between mb-2">
                <FeatureIcon name="passport" class="w-5 h-5" />
                <span class="text-[10px] font-semibold uppercase tracking-wider">QR · 24/7</span>
              </div>
              <!-- Mock QR grid -->
              <div class="bg-white p-2 rounded-lg">
                <div class="grid grid-cols-7 gap-px aspect-square">
                  {Array.from({ length: 49 }).map((_, i) => {
                    const isDark = (i * 7 + (i % 5) + Math.floor(i / 7)) % 3 === 0;
                    return <div class={isDark ? "bg-mmp-ink rounded-[1px]" : "bg-white"}></div>;
                  })}
                </div>
              </div>
              <p class="text-[10px] mt-2 font-semibold text-center">Hộ chiếu pet</p>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         TRUST MARQUEE — infinite horizontal scroll, pause on hover
         8 trust signals: pet count, vaccine count, climate monitor,
         WSAVA, AAFCO, vet trust, clinic trust, response time, etc.
         ═══════════════════════════════════════════════════════════ -->
    <section class="bg-mmp-cream border-y border-slate-200 py-8 sm:py-10 overflow-hidden">
      <p class="eyebrow text-center mb-5" style="color: var(--c-gold);">
        <span class="gold-dot"></span>Cộng đồng tin tưởng
      </p>
      <div class="marquee-wrapper relative overflow-hidden" aria-label="Số liệu tin cậy">
        <!-- Edge fade gradient mask -->
        <div class="absolute left-0 top-0 bottom-0 w-12 sm:w-24 bg-gradient-to-r from-mmp-cream to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-12 sm:w-24 bg-gradient-to-l from-mmp-cream to-transparent z-10 pointer-events-none"></div>

        <div class="marquee-track gap-6 sm:gap-10">
          {/* List repeated TWICE for seamless loop */}
          {[1, 2].map(() => (
            <div class="flex items-center gap-6 sm:gap-10 px-6 sm:px-10 shrink-0">
              {/* Stat 1 */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="text-3xl sm:text-4xl font-bold text-mmp-ink leading-none">{HEALTH_CONDITIONS.length}</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Bệnh lý phân tích</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 2 */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="text-3xl sm:text-4xl font-bold text-mmp-ink leading-none">QR Passport</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Hồ sơ thú cưng</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 3 — HIGHLIGHT: 24/7 commitment */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="stat-glow text-3xl sm:text-4xl font-bold leading-none" style="color: var(--c-gold);">24/7</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Giám sát khí hậu HCM</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 4 — HIGHLIGHT: WSAVA gold standard */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="stat-glow text-3xl sm:text-4xl font-bold leading-none" style="color: var(--c-gold);">WSAVA</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Chuẩn vet quốc tế</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 5 — HIGHLIGHT: AAFCO gold standard */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="stat-glow text-3xl sm:text-4xl font-bold leading-none" style="color: var(--c-gold);">AAFCO</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Chuẩn dinh dưỡng Hoa Kỳ</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 6 */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="text-3xl sm:text-4xl font-bold text-mmp-ink leading-none">AI Scan</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Nhãn thức ăn</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 7 */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="text-3xl sm:text-4xl font-bold text-mmp-ink leading-none">5<span style="color: var(--c-gold);">+</span></span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Năm chuyên môn</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 8 — HIGHLIGHT: 100% Miễn phí promise */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="stat-glow text-3xl sm:text-4xl font-bold leading-none" style="color: var(--c-gold);">100%</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Miễn phí gói cơ bản</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 9 */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="text-3xl sm:text-4xl font-bold text-mmp-ink leading-none">9<span style="color: var(--c-gold);">+</span></span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Mũi vaccine schedule</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>

              {/* Stat 10 */}
              <div class="flex items-baseline gap-2 shrink-0">
                <span class="text-3xl sm:text-4xl font-bold text-mmp-ink leading-none">30s</span>
                <span class="text-xs sm:text-sm text-slate-600 uppercase tracking-wider font-medium">Check-in mỗi sáng</span>
              </div>
              <span class="text-slate-300 text-2xl" aria-hidden="true">·</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         ALL-IN-ONE intro
         ═══════════════════════════════════════════════════════════ -->
    <section id="features" class="py-16 sm:py-20 bg-white scroll-mt-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <p class="eyebrow mb-4" style="color: var(--c-gold);">
          <span class="gold-dot"></span>Đồng hành trọn vòng đời pet
        </p>
        <h2 class="font-display italic text-4xl sm:text-5xl md:text-6xl font-semibold text-mmp-ink mb-6 tracking-tight">
          ALL-IN-ONE
        </h2>
        <p class="text-base sm:text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">
          Từ check-in hằng ngày đến lịch tiêm WSAVA chuẩn quốc tế —
          VowVet đồng hành cùng bé suốt đời.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════
         FEATURE CARDS — 6 cards with inline SVG icons + arrow link
         ═══════════════════════════════════════════════════════════ -->
    <section class="pb-20 sm:pb-24 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
          {features.map((f) => (
            <a href={`/articles/${f.slug}`}
               class="group block p-6 sm:p-7 bg-white border border-slate-200 rounded-2xl hover:border-mmp-ink hover:shadow-lg transition-all">
              <div class="w-12 h-12 rounded-xl bg-mmp-ink/5 flex items-center justify-center mb-5 group-hover:bg-mmp-gold/15 transition">
                <FeatureIcon name={f.icon} class="w-6 h-6 text-mmp-ink" />
              </div>
              <h3 class="font-bold text-lg text-mmp-ink mb-2 leading-snug">{f.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{f.desc}</p>
