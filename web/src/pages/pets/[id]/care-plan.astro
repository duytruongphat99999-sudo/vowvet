                const targetMl = pet.weight_kg ? Math.max(50, Math.round(pet.weight_kg * 55)) : 0;
                return (
                  <div class={`mt-2 flex items-center justify-between gap-3 rounded-xl p-3 border ${
                    waterDone ? "bg-emerald-50 border-emerald-200" : "bg-blue-50/40 border-blue-100"
                  }`}>
                    <div class="flex items-center gap-2 min-w-0">
                      <span class={`inline-flex items-center justify-center w-8 h-8 rounded-lg shrink-0 ${
                        waterDone ? "bg-emerald-500 text-white" : "bg-white text-blue-600 border border-blue-200"
