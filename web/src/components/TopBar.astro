---
/**
 * TopBar — thanh điều hướng app dùng chung.
 *
 * GĐ1-lite: chỉ dùng trên /dashboard. Logo (tái dùng Logo.astro, KHÔNG sửa)
 * + nav: pet-jump · alerts · chat · settings.
 *
 * Số đếm (chat unread + chấm cảnh báo) fetch CLIENT-SIDE bằng Alpine sau khi
 * load — Promise.allSettled + timeout 5s (AbortController), fail-soft:
 * endpoint nào lỗi/treo thì badge/dot đó ẩn (không kẹt loading).
 *
 * Brand: ink / gold / cream. Chấm cảnh báo = ĐỎ (functional exception đã duyệt).
 * Badge chat = GOLD. Style scoped trong component — KHÔNG ghi vào global.css.
 */
import Logo from "./Logo.astro";
import FeatureIcon from "./FeatureIcon.astro";

interface Props {
  pet?: { id: number | string; name?: string; photo_url?: string | null } | null;
  isAdmin?: boolean;
}
const { pet = null, isAdmin = false } = Astro.props;
---

<header class="tb sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-mmp-cream">
  <div class="max-w-screen-md mx-auto px-4 h-16 flex items-center justify-between gap-3">
    <Logo variant="default" href="/dashboard" />

    <nav class="flex items-center gap-1 sm:gap-1.5" x-data="topBar()" x-init="loadCounts()">
      {pet && (
        <a
          href={`/pets/${pet.id}`}
          class="tb-pet-jump"
          aria-label={`Đến hồ sơ ${pet.name || "thú cưng"}`}
          title={`Hồ sơ ${pet.name || "thú cưng"}`}
        >
          {pet.photo_url ? (
            <img src={pet.photo_url} alt={pet.name || "thú cưng"} loading="eager" decoding="async" />
          ) : (
            <span class="tb-pet-jump__fallback">{(pet.name || "?").charAt(0).toUpperCase()}</span>
          )}
          <span class="tb-pet-jump__ping" aria-hidden="true"></span>
        </a>
      )}

      <a
        href="/alerts"
        class="relative inline-flex items-center justify-center w-10 h-10 rounded-xl text-mmp-ink/65 hover:text-mmp-ink hover:bg-mmp-cream/60 transition"
        title="Cảnh báo"
        aria-label="Cảnh báo"
      >
        <FeatureIcon name="bell" class="w-5 h-5" strokeWidth={1.7} />
        <span class="tb-dot" x-cloak x-show="hasUrgentAlert" x-transition aria-hidden="true"></span>
      </a>

      <a
        href="/chat"
        class="relative inline-flex items-center justify-center w-10 h-10 rounded-xl text-mmp-ink/65 hover:text-mmp-ink hover:bg-mmp-cream/60 transition"
        title="Tin nhắn"
        aria-label="Tin nhắn"
      >
        <FeatureIcon name="message-circle" class="w-5 h-5" strokeWidth={1.7} />
        <span
          class="tb-badge"
          x-cloak
          x-show="chatUnread > 0"
          x-transition
          x-text="chatUnread > 99 ? '99+' : chatUnread"
        ></span>
      </a>

      <a
        href="/messages"
        class="relative flex flex-col items-center justify-center gap-0.5 h-10 px-1.5 rounded-xl text-mmp-ink/65 hover:text-mmp-ink hover:bg-mmp-cream/60 transition"
        title="Chat với hỗ trợ"
        aria-label="Chat với hỗ trợ"
      >
        <FeatureIcon name="mailbox" class="w-5 h-5" strokeWidth={1.7} />
        <span class="text-[10px] font-semibold leading-none text-amber-600">Hỗ trợ</span>
        <span
          x-cloak
          x-show="msgUnread > 0"
          x-transition
          x-text="msgUnread > 99 ? '99+' : msgUnread"
          class="absolute -top-1 -right-1 bg-red-500 text-white text-[9px] font-bold min-w-[16px] h-[16px] px-1 rounded-full inline-flex items-center justify-center"
        ></span>
      </a>

      {isAdmin && (
        <a
          href="/admin/foster-orders"
          class="inline-flex items-center justify-center w-10 h-10 rounded-xl text-mmp-ink/65 hover:text-mmp-ink hover:bg-mmp-cream/60 transition"
          title="Admin"
          aria-label="Admin"
        >
          <FeatureIcon name="shield-check" class="w-5 h-5" strokeWidth={1.7} />
        </a>
      )}

      <a
        href="/settings"
        class="inline-flex items-center justify-center w-10 h-10 rounded-xl text-mmp-ink/65 hover:text-mmp-ink hover:bg-mmp-cream/60 transition"
        title="Cài đặt"
        aria-label="Cài đặt"
      >
        <FeatureIcon name="settings" class="w-5 h-5" strokeWidth={1.7} />
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  function topBar() {
    return {
      chatUnread: 0,
      msgUnread: 0,
      hasUrgentAlert: false,
      async loadCounts() {
        const ctrl = new AbortController();
        const timer = setTimeout(() => ctrl.abort(), 5000);
        const opts = { credentials: "include", signal: ctrl.signal };

        const [chatRes, alertRes, msgRes] = await Promise.allSettled([
          fetch("/api/v1/chat/threads?limit=50", opts),
          fetch("/api/v1/alerts/today", opts),
          fetch("/api/v1/conversations/unread-count", opts),
        ]);
        clearTimeout(timer);

        // Support/foster chat unread (fail-soft)
        try {
          if (msgRes.status === "fulfilled" && msgRes.value.ok) {
            const d = await msgRes.value.json();
            this.msgUnread = d.count || 0;
          }
        } catch (_) {}

        // Chat unread — Σ unread_count_owner (fail-soft)
        try {
          if (chatRes.status === "fulfilled" && chatRes.value.ok) {
            const d = await chatRes.value.json();
            this.chatUnread = (d.threads || []).reduce(
              (sum, t) => sum + (t.unread_count_owner || 0),
              0,
            );
          }
        } catch (_) {}

        // Chấm cảnh báo — severity urgent/critical chưa dismissed (fail-soft)
        try {
          if (alertRes.status === "fulfilled" && alertRes.value.ok) {
            const d = await alertRes.value.json();
            this.hasUrgentAlert = (d.alerts || []).some((a) => {
              const sev = typeof a.severity === "object" ? a.severity?.value : a.severity;
              return (sev === "urgent" || sev === "critical") && !a.dismissed_at;
            });
          }
        } catch (_) {}
      },
    };
  }
</script>

<style>
  /* pet-jump avatar — gold ring + ping nhẹ (self-contained, KHÔNG global.css) */
  .tb-pet-jump {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    flex-shrink: 0;
    box-shadow: 0 0 0 2px var(--color-mmp-gold), 0 1px 3px rgba(10, 10, 10, 0.15);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .tb-pet-jump:hover {
    transform: scale(1.06);
    box-shadow: 0 0 0 2px var(--color-mmp-gold), 0 3px 10px rgba(180, 134, 8, 0.35);
  }
  .tb-pet-jump img {
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    object-fit: cover;
  }
  .tb-pet-jump__fallback {
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-mmp-ink);
    background: linear-gradient(135deg, #f6d877, var(--color-mmp-gold));
  }
  .tb-pet-jump__ping {
    position: absolute;
    bottom: -1px;
    right: -1px;
    width: 10px;
    height: 10px;
    border-radius: 9999px;
    background: var(--color-mmp-gold);
    box-shadow: 0 0 0 2px #fff;
  }
  .tb-pet-jump__ping::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: var(--color-mmp-gold);
    animation: tb-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes tb-ping {
    0% { transform: scale(1); opacity: 0.65; }
    70%, 100% { transform: scale(2.3); opacity: 0; }
  }

  /* chấm cảnh báo — ĐỎ functional (exception đã duyệt) */
  .tb-dot {
    position: absolute;
    top: 0.375rem;
    right: 0.375rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: #ef4444;
    box-shadow: 0 0 0 2px #fff;
  }

  /* badge chat unread — GOLD */
  .tb-badge {
    position: absolute;
    top: -0.125rem;
    right: -0.125rem;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9999px;
    background: var(--color-mmp-gold);
    color: var(--color-mmp-ink);
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 2px #fff;
  }

  @media (prefers-reduced-motion: reduce) {
    .tb-pet-jump { transition: none; }
    .tb-pet-jump:hover { transform: none; }
    .tb-pet-jump__ping::before { animation: none; }
  }
</style>
