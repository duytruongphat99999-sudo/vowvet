---
/**
 * /alerts — Cảnh báo khí hậu (M5) — Brand Sync Pass 3 WOW v2.
 *
 * Hero (ink): 2 decorative orbs + eyebrow "Real-time monitor" + Fraunces title +
 *             3 hero stat cards (Khẩn cấp [critical+urgent] / Chú ý [warning] / Theo dõi [active total])
 *             + status pill "Pet bạn đang an toàn" when safe.
 * Sticky filter bar: pill tabs with count badges + gold Tải lại.
 * Cards: severity left-stripe with pulse-strip (critical), icon container with ping-slow,
 *        temperature gauge mini-chart (clamped 0-100%), collapsible advisory with chevron rotate.
 * Empty: pulse-circle celebration + auto-update hint.
 *
 * Severity contract (4-tier, NO blue/cyan):
 *   info     → bg-mmp-cream  border-amber-100  strip mmp-ink  badge gold
 *   warning  → bg-amber-50   border-amber-200  strip amber-400 badge warning
 *   urgent   → bg-amber-50   border-amber-300  strip amber-500 badge warning + subtle pulse
 *   critical → bg-red-50     border-red-200    strip red-500 + pulse-strip + ping icon  badge danger
 *
 * Data: SSR pre-fetch 7-day history; filter via ?filter=all|active|read query.
 *   - active = !dismissed_at
 *   - read   = !!dismissed_at
 *   - all    = no filter
 *
 * API contract preserved: no climate.ts route created. Existing /api/v1/alerts/* used as-is.
 * data_points/advisory/location extracted client-side from weather_snapshot/pet_factors JSON.
 */
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import Badge from "../components/ui/Badge.astro";
import FeatureIcon from "../components/FeatureIcon.astro";

const cookieHeader = Astro.request.headers.get("cookie") || "";
const API_INTERNAL = process.env.API_INTERNAL_URL || "http://vowvet-api:3000";

const filter = (Astro.url.searchParams.get("filter") || "all").toLowerCase();
const validFilter = ["all", "active", "read"].includes(filter) ? filter : "all";

// SSR pre-fetch 7-day history (returns BOTH active + dismissed). Filter SSR-side.
let allAlerts: any[] = [];
try {
  const res = await fetch(`${API_INTERNAL}/api/v1/alerts/history?days=7`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) allAlerts = (await res.json()).alerts || [];
} catch (_) {}

const counts = {
  all: allAlerts.length,
  active: allAlerts.filter((a) => !a.dismissed_at).length,
  read: allAlerts.filter((a) => !!a.dismissed_at).length,
};

let alerts: any[] = allAlerts;
if (validFilter === "active") alerts = allAlerts.filter((a) => !a.dismissed_at);
else if (validFilter === "read") alerts = allAlerts.filter((a) => !!a.dismissed_at);

// Hero stats — combine critical+urgent under "Khẩn cấp" (Vietnamese label maps to urgent semantically)
const criticalCount = allAlerts.filter(
  (a) => !a.dismissed_at && (a.severity === "critical" || a.severity === "urgent")
).length;
const warningCount = allAlerts.filter(
  (a) => !a.dismissed_at && a.severity === "warning"
).length;
const safeStatus = criticalCount === 0 && warningCount === 0;

// ─── Severity → visual meta ──────────────────────────────────────────────
function getSeverityMeta(severity: string) {
  switch (severity) {
    case "critical":
      return {
        cardBg: "bg-red-50",
        cardBorder: "border-red-200",
        stripBg: "bg-red-500",
        iconBg: "bg-red-100",
        iconColor: "text-red-700",
        badgeVariant: "danger" as const,
        badgeLabel: "Nguy hiểm",
        pulse: true,
      };
    case "urgent":
      return {
        cardBg: "bg-amber-50",
        cardBorder: "border-amber-300",
        stripBg: "bg-amber-500",
        iconBg: "bg-amber-200",
        iconColor: "text-amber-800",
        badgeVariant: "warning" as const,
        badgeLabel: "Khẩn cấp",
        pulse: true,
      };
    case "warning":
      return {
        cardBg: "bg-amber-50",
        cardBorder: "border-amber-200",
        stripBg: "bg-amber-400",
        iconBg: "bg-amber-100",
        iconColor: "text-amber-700",
        badgeVariant: "warning" as const,
        badgeLabel: "Chú ý",
        pulse: false,
      };
    default:
      return {
        cardBg: "bg-mmp-cream",
        cardBorder: "border-amber-100",
        stripBg: "bg-mmp-ink",
        iconBg: "bg-white border border-amber-200",
        iconColor: "text-mmp-ink",
        badgeVariant: "gold" as const,
        badgeLabel: "Tham khảo",
        pulse: false,
      };
  }
}

function getAlertIcon(alertType: string): string {
  // Existing API uses *_warning suffix; mega-prompt assumed bare type. Map both.
  // Returns FeatureIcon name (SVG-only, no chrome emoji — matches homepage convention)
  const t = String(alertType || "").replace("_warning", "");
  const map: Record<string, string> = {
    heat: "flame",
    cold: "snowflake",
    aqi: "wind",
    storm: "cloud-lightning",
    sun: "sun",
    humidity: "droplet",
    wind: "wind",
    uv: "sun",
  };
  return map[t] || "thermometer";
}

const TYPE_LABEL_VI: Record<string, string> = {
  heat_warning: "Cảnh báo nóng",
  cold_warning: "Cảnh báo lạnh",
  aqi_warning: "Chất lượng không khí",
  storm_warning: "Bão và sấm sét",
  sun_warning: "Cảnh báo UV",
};

function typeLabel(t: string): string {
  return TYPE_LABEL_VI[t] || "Cảnh báo khí hậu";
}

function formatRelative(timestamp: string | null): string {
  if (!timestamp) return "—";
  const diff = (Date.now() - new Date(timestamp).getTime()) / 1000;
  if (diff < 60) return "vừa xong";
  if (diff < 3600) return `${Math.floor(diff / 60)} phút trước`;
  if (diff < 86400) return `${Math.floor(diff / 3600)} giờ trước`;
  if (diff < 604800) return `${Math.floor(diff / 86400)} ngày trước`;
  return new Date(timestamp).toLocaleDateString("vi-VN");
}

// ─── Data extractors (from weather_snapshot JSON parsed server-side in lib/alerts.ts) ─
function tempRange(w: any): { low: number; high: number; label: string } | null {
  if (!w) return null;
  if (w.temp_min != null && w.temp_max != null)
    return { low: w.temp_min, high: w.temp_max, label: `${Math.round(w.temp_min)}–${Math.round(w.temp_max)}°C` };
  if (w.temperature != null) {
    const v = w.temperature;
    return { low: v, high: v, label: `${Math.round(v)}°C` };
  }
  if (w.temp != null) {
    const v = w.temp;
    return { low: v, high: v, label: `${Math.round(v)}°C` };
  }
  return null;
}
function feelsLike(w: any): number | null {
  if (!w) return null;
  if (w.feels_like != null) return w.feels_like;
  if (w.heat_index != null) return w.heat_index;
  return null;
}
function aqiValue(w: any): string | null {
  if (!w) return null;
  if (w.aqi != null) return String(w.aqi);
  if (w.pm25 != null) return `PM2.5 ${Math.round(w.pm25)}`;
  return null;
}
function humidityValue(w: any): string | null {
  if (!w?.humidity) return null;
  return `${Math.round(w.humidity)}%`;
}
function locationLabel(w: any): string | null {
  if (!w) return null;
  return w.city_label || w.city || w.location || null;
}
function advisoryText(factors: any): string | null {
  if (!factors) return null;
  if (typeof factors === "string") return factors;
  return factors.recommendation || factors.advisory || factors.action || null;
}

// Pre-compute UI-ready alert rows (server-side — Astro components work in alerts.map below)
const alertRows = alerts.map((a) => {
  const w = a.weather_snapshot;
  const tr = tempRange(w);
  const fl = feelsLike(w);
  const aq = aqiValue(w);
  const hum = humidityValue(w);
  // Temperature gauge math (15-45°C scale, clamp 0-100)
  const GAUGE_MIN = 15;
  const GAUGE_MAX = 45;
  const span = GAUGE_MAX - GAUGE_MIN;
  const pct = (v: number) => Math.max(0, Math.min(100, ((v - GAUGE_MIN) / span) * 100));
  let gauge = null;
  if (tr && fl != null) {
    gauge = {
      lowPct: pct(tr.low),
      highPct: pct(tr.high),
      feelsPct: pct(fl),
      rangeLabel: tr.label,
      feelsLabel: `${Math.round(fl)}°C`,
      gaugeMin: GAUGE_MIN,
      gaugeMax: GAUGE_MAX,
    };
  } else if (tr) {
    gauge = {
      lowPct: pct(tr.low),
      highPct: pct(tr.high),
      feelsPct: null,
      rangeLabel: tr.label,
      feelsLabel: null,
      gaugeMin: GAUGE_MIN,
      gaugeMax: GAUGE_MAX,
    };
  }
  return {
    ...a,
    _meta: getSeverityMeta(a.severity),
    _icon: getAlertIcon(a.alert_type),
    _typeLabel: typeLabel(a.alert_type),
    _location: locationLabel(w),
    _aqi: aq,
    _humidity: hum,
    _gauge: gauge,
    _advisory: advisoryText(a.pet_factors),
    _timeAgo: formatRelative(a.triggered_at),
    _readTimeAgo: a.dismissed_at ? formatRelative(a.dismissed_at) : null,
  };
});
---

<Layout title="Cảnh báo khí hậu · VowVet" description="Cảnh báo thời tiết thông minh cho pet — real-time monitor">
  <main class="bg-mmp-cream min-h-screen pb-12">

    <!-- HERO HEADER (ink with decorative orbs) -->
    <header class="relative bg-mmp-ink text-white overflow-hidden">
      <!-- Decorative orbs -->
      <div aria-hidden="true" class="absolute top-0 right-0 w-64 h-64 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"
           style="background: rgba(236, 185, 33, 0.18);"></div>
      <div aria-hidden="true" class="absolute bottom-0 left-0 w-48 h-48 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"
           style="background: rgba(239, 68, 68, 0.16);"></div>

      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 pt-6 pb-7">
        <!-- Top nav -->
        <div class="flex items-center justify-between mb-6">
          <a href="/dashboard" class="text-sm text-white/60 hover:text-white inline-flex items-center gap-1 transition">
            <FeatureIcon name="arrow" class="w-4 h-4 rotate-180" strokeWidth={2} />
            Dashboard
          </a>
          <a href="/settings" aria-label="Cài đặt thông báo"
             class="text-white/60 hover:text-white transition">
            <FeatureIcon name="settings" class="w-5 h-5" strokeWidth={1.7} />
          </a>
        </div>

        <!-- Title -->
        <p class="text-[11px] uppercase tracking-[0.3em] font-bold mb-2" style="color: var(--c-gold);">
          Real-time monitor
        </p>
        <h1 class="font-display italic text-3xl sm:text-4xl font-semibold leading-tight mb-1.5">Cảnh báo khí hậu</h1>
        <p class="text-sm text-white/70 leading-relaxed">
          Cảnh báo dựa trên thời tiết hôm nay + profile pet của bạn
        </p>

        <!-- Hero stats — 3 numbers WOW (SVG icons, matches homepage convention) -->
        <div class="grid grid-cols-3 gap-2.5 sm:gap-3 mt-6">
          <!-- Khẩn cấp (critical + urgent) -->
          <div class={`rounded-2xl p-3 sm:p-4 border transition ${
            criticalCount > 0 ? "border-red-400/40" : "border-white/10"
          }`}
            style={criticalCount > 0 ? "background: rgba(239, 68, 68, 0.18);" : "background: rgba(255,255,255,0.05);"}>
            <div class="flex items-center gap-2 mb-1">
              <FeatureIcon name="siren" class={`w-4 h-4 sm:w-5 sm:h-5 ${criticalCount > 0 ? "text-red-300" : "text-white/50"}`} strokeWidth={2} />
              <span class="text-[10px] sm:text-xs uppercase tracking-wider text-white/60 font-semibold">Khẩn cấp</span>
            </div>
            <p class={`text-2xl sm:text-3xl font-bold tabular-nums ${
              criticalCount > 0 ? "text-red-200" : "text-white/40"
            }`}>{criticalCount}</p>
          </div>

          <!-- Chú ý (warning) -->
          <div class={`rounded-2xl p-3 sm:p-4 border transition ${
            warningCount > 0 ? "border-amber-400/40" : "border-white/10"
          }`}
            style={warningCount > 0 ? "background: rgba(245, 158, 11, 0.18);" : "background: rgba(255,255,255,0.05);"}>
            <div class="flex items-center gap-2 mb-1">
              <FeatureIcon name="alert-triangle" class={`w-4 h-4 sm:w-5 sm:h-5 ${warningCount > 0 ? "text-amber-300" : "text-white/50"}`} strokeWidth={2} />
              <span class="text-[10px] sm:text-xs uppercase tracking-wider text-white/60 font-semibold">Chú ý</span>
            </div>
            <p class={`text-2xl sm:text-3xl font-bold tabular-nums ${
              warningCount > 0 ? "text-amber-200" : "text-white/40"
            }`}>{warningCount}</p>
          </div>

          <!-- Theo dõi (active total) -->
          <div class="rounded-2xl p-3 sm:p-4 border border-white/10"
               style="background: rgba(255,255,255,0.05);">
            <div class="flex items-center gap-2 mb-1">
              <FeatureIcon name="radar" class="w-4 h-4 sm:w-5 sm:h-5" strokeWidth={2} style="color: var(--c-gold);" />
              <span class="text-[10px] sm:text-xs uppercase tracking-wider text-white/60 font-semibold">Theo dõi</span>
            </div>
            <p class="text-2xl sm:text-3xl font-bold tabular-nums" style="color: var(--c-gold);">{counts.active}</p>
          </div>
        </div>

        <!-- Safe status pill -->
        {safeStatus && counts.all > 0 && (
          <div class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-400/30"
               style="background: rgba(16, 185, 129, 0.18);">
            <span class="w-2 h-2 rounded-full bg-emerald-300 live-dot"></span>
            <span class="text-sm font-medium text-emerald-200">Pet của bạn đang an toàn</span>
          </div>
        )}
      </div>
    </header>

    <!-- STICKY FILTER BAR -->
    <div class="sticky top-0 z-30 backdrop-blur border-b border-amber-100" style="background: rgba(245, 241, 235, 0.95);">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-3">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2 overflow-x-auto no-scrollbar">
            <a href="?filter=all"
               class={`shrink-0 inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border transition-all ${
                 validFilter === "all"
                   ? "bg-mmp-ink text-white border-mmp-ink shadow-md"
                   : "bg-white border-slate-200 text-mmp-ink hover:border-mmp-ink"
               }`}>
              Tất cả
              {counts.all > 0 && (
                <span class={`text-[10px] tabular-nums font-bold ${validFilter === "all" ? "" : "text-slate-400"}`}
                      style={validFilter === "all" ? "color: var(--c-gold);" : ""}>
                  {counts.all}
                </span>
              )}
            </a>

            <a href="?filter=active"
               class={`shrink-0 inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border transition-all ${
                 validFilter === "active"
                   ? "bg-mmp-ink text-white border-mmp-ink shadow-md"
                   : "bg-white border-slate-200 text-mmp-ink hover:border-mmp-ink"
               }`}>
              Hoạt động
              {counts.active > 0 && (
                <span class={`text-[10px] tabular-nums font-bold ${validFilter === "active" ? "" : "text-slate-400"}`}
                      style={validFilter === "active" ? "color: var(--c-gold);" : ""}>
                  {counts.active}
                </span>
              )}
            </a>

            <a href="?filter=read"
               class={`shrink-0 inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border transition-all ${
                 validFilter === "read"
                   ? "bg-mmp-ink text-white border-mmp-ink shadow-md"
                   : "bg-white border-slate-200 text-mmp-ink hover:border-mmp-ink"
               }`}>
              Đã đọc
              {counts.read > 0 && (
                <span class={`text-[10px] tabular-nums font-bold ${validFilter === "read" ? "" : "text-slate-400"}`}
                      style={validFilter === "read" ? "color: var(--c-gold);" : ""}>
                  {counts.read}
                </span>
              )}
            </a>
          </div>

          <button id="alerts-reload-btn"
                  class="shrink-0 inline-flex items-center gap-1.5 text-sm font-semibold hover:underline px-2 py-1 transition"
                  style="color: var(--c-gold);">
            <svg id="alerts-reload-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 11-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/>
              <path d="M21 3v5h-5"/>
            </svg>
            <span class="hidden sm:inline">Tải lại</span>
          </button>
        </div>
      </div>
    </div>

    <!-- ALERTS LIST -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-6">

      {alerts.length === 0 ? (
        <!-- EMPTY STATE CELEBRATION -->
        <div class="bg-white rounded-3xl border border-slate-100 p-10 sm:p-12 text-center shadow-sm">
          <div class="relative w-20 h-20 mx-auto mb-5">
            <div class="absolute inset-0 bg-emerald-100 rounded-full animate-pulse"></div>
            <div class="relative w-full h-full rounded-full bg-emerald-50 border-2 border-emerald-200 flex items-center justify-center">
              <FeatureIcon name="sun" class="w-9 h-9 text-emerald-600" strokeWidth={1.8} />
            </div>
          </div>
          <h2 class="font-display italic text-xl font-semibold text-mmp-ink mb-2">
            {validFilter === "read"
              ? "Chưa có cảnh báo đã đọc"
              : counts.all === 0
              ? "Tất cả pet đang an toàn"
              : "Không còn cảnh báo nào"}
          </h2>
          <p class="text-sm text-slate-500 max-w-xs mx-auto leading-relaxed">
            {validFilter === "read"
              ? "Khi bạn đánh dấu cảnh báo đã đọc, chúng sẽ xuất hiện ở đây."
              : counts.all === 0
              ? "Thời tiết hôm nay an toàn cho bé. Cảnh báo sẽ tự động hiển thị khi có nguy cơ."
              : "Bạn đã xử lý hết các cảnh báo hoạt động trong 7 ngày qua."}
          </p>

          <div class="mt-6 inline-flex items-center gap-1.5 text-xs text-slate-400">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            Auto-update mỗi giờ
          </div>
        </div>
      ) : (
        <div class="space-y-3">
          {alertRows.map((a) => {
            const meta = a._meta;
            const isRead = !!a.dismissed_at;
            return (
              <article class={`relative rounded-3xl border overflow-hidden transition-all ${meta.cardBg} ${meta.cardBorder} ${isRead ? "opacity-60" : ""}`}
                       x-data="{ open: false }">

                {/* Severity strip left */}
                <div class={`absolute left-0 top-0 bottom-0 w-1.5 ${meta.stripBg} ${meta.pulse && !isRead ? "animate-pulse-strip" : ""}`}></div>

                <div class="pl-5 pr-5 py-5">
                  {/* Top row: icon + title + badge */}
                  <div class="flex items-start gap-3 mb-3">
                    <div class={`relative w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 ${meta.iconBg}`}>
                      <FeatureIcon name={a._icon} class={`relative z-10 w-6 h-6 ${meta.iconColor}`} strokeWidth={2} />
                      {meta.pulse && !isRead && (
                        <span class={`absolute inset-0 rounded-2xl ${meta.stripBg} opacity-30 animate-ping-slow`} aria-hidden="true"></span>
                      )}
                    </div>

                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-2 flex-wrap mb-1">
                        <h3 class="font-bold text-mmp-ink leading-tight">{a.title || a._typeLabel}</h3>
                        <Badge variant={meta.badgeVariant} size="sm" dot>{meta.badgeLabel}</Badge>
                      </div>

                      <div class="flex items-center gap-1.5 text-xs text-slate-600 flex-wrap">
                        {a.pet_name && (
                          <span class="inline-flex items-center gap-1">
                            <FeatureIcon name="paw" class="w-3.5 h-3.5 text-mmp-ink" strokeWidth={2} />
                            <strong class="text-mmp-ink">{a.pet_name}</strong>
                          </span>
                        )}
                        {a._location && (
                          <>
                            <span class="text-slate-300">·</span>
                            <span>{a._location}</span>
                          </>
                        )}
                        <span class="text-slate-300">·</span>
                        <time datetime={a.triggered_at}>{a._timeAgo}</time>
                      </div>
                    </div>
                  </div>

                  {/* Body */}
                  {a.message && (
                    <p class="text-sm text-slate-700 leading-relaxed mb-3">{a.message}</p>
                  )}

                  {/* Temperature gauge mini-chart */}
                  {a._gauge && (
                    <div class="rounded-xl bg-white/70 border border-slate-100 p-3 mb-3">
                      <div class="flex items-center justify-between mb-2 text-xs">
                        <span class="text-slate-500">Nhiệt độ hôm nay</span>
                        <span class="text-mmp-ink font-bold tabular-nums">{a._gauge.rangeLabel}</span>
                      </div>

                      {/* Gauge: gradient track + range bar + feels-like dot */}
                      <div class="relative h-2.5 rounded-full overflow-hidden"
                           style="background: linear-gradient(90deg, #bfdbfe 0%, #a7f3d0 33%, #fde68a 66%, #fca5a5 100%);">
                        {/* Range overlay (low → high) */}
                        <div class="absolute top-0 bottom-0 rounded-full"
                             style={`left: ${a._gauge.lowPct}%; width: ${a._gauge.highPct - a._gauge.lowPct}%; background: rgba(10, 10, 10, 0.22);`}></div>

                        {/* Feels-like marker */}
                        {a._gauge.feelsPct != null && (
                          <div class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-3.5 h-3.5 rounded-full bg-red-600 ring-2 ring-white shadow"
                               style={`left: ${a._gauge.feelsPct}%;`}
                               aria-label={`Cảm giác ${a._gauge.feelsLabel}`}></div>
                        )}
                      </div>

                      <div class="flex items-center justify-between mt-2 text-[10px] sm:text-xs">
                        <span class="text-slate-400 tabular-nums">{a._gauge.gaugeMin}°C</span>
                        {a._gauge.feelsLabel && (
                          <span class="inline-flex items-center gap-1 font-semibold text-red-700">
                            <span class="w-2 h-2 rounded-full bg-red-600"></span>
                            <span>Cảm giác {a._gauge.feelsLabel}</span>
                          </span>
                        )}
                        <span class="text-slate-400 tabular-nums">{a._gauge.gaugeMax}°C</span>
                      </div>

                      {(a._aqi || a._humidity) && (
                        <div class="flex items-center justify-between gap-4 mt-2.5 pt-2.5 border-t border-slate-100 text-xs">
                          {a._aqi && (
                            <div class="flex items-center gap-1.5">
                              <span class="text-slate-500">AQI:</span>
                              <span class="text-mmp-ink font-bold tabular-nums">{a._aqi}</span>
                            </div>
                          )}
                          {a._humidity && (
                            <div class="flex items-center gap-1.5">
                              <span class="text-slate-500">Độ ẩm:</span>
                              <span class="text-mmp-ink font-bold tabular-nums">{a._humidity}</span>
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  )}

                  {/* AQI-only data row (when no temp gauge) */}
                  {!a._gauge && (a._aqi || a._humidity) && (
                    <div class="rounded-xl bg-white/70 border border-slate-100 p-3 mb-3 flex items-center gap-4 text-xs flex-wrap">
                      {a._aqi && (
                        <div class="flex items-center gap-1.5">
                          <span class="text-slate-500">AQI:</span>
                          <span class="text-mmp-ink font-bold tabular-nums">{a._aqi}</span>
                        </div>
                      )}
                      {a._humidity && (
                        <div class="flex items-center gap-1.5">
                          <span class="text-slate-500">Độ ẩm:</span>
                          <span class="text-mmp-ink font-bold tabular-nums">{a._humidity}</span>
                        </div>
                      )}
                    </div>
                  )}

                  {/* Advisory collapsible (gold-tinted button + chevron rotate) */}
                  {a._advisory && (
                    <>
                      <button type="button" @click="open = !open"
                              class="w-full flex items-center justify-between gap-2 p-3 rounded-xl border transition mb-3 hover:shadow-sm"
                              style="background: rgba(236, 185, 33, 0.10); border-color: rgba(236, 185, 33, 0.35);">
                        <span class="flex items-center gap-2">
                          <span class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-lg bg-white border border-amber-200">
                            <svg class="w-4 h-4" style="color: var(--c-gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M9 18h6"/><path d="M10 22h4"/>
                              <path d="M12 2a7 7 0 00-4 12.74V17a1 1 0 001 1h6a1 1 0 001-1v-2.26A7 7 0 0012 2z"/>
                            </svg>
                          </span>
                          <span class="text-sm font-bold text-mmp-ink">Khuyến nghị từ Mon Min</span>
                        </span>
                        <svg class="w-4 h-4 text-mmp-ink transition-transform duration-200"
                             :class="open ? 'rotate-180' : ''"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="6 9 12 15 18 9"/>
                        </svg>
                      </button>

                      <div x-show="open" x-transition x-cloak class="mb-3 p-3 rounded-xl bg-white border border-slate-100">
                        <p class="text-sm text-slate-700 leading-relaxed">{a._advisory}</p>
                      </div>
                    </>
                  )}

                  {/* Actions */}
                  <div class="flex items-center gap-2 flex-wrap mt-1">
                    {a.pet_id && (
                      <Button variant="primary" size="sm" href={`/pets/${a.pet_id}`}>
                        {a.pet_name ? `Xem ${a.pet_name}` : "Xem pet"} →
                      </Button>
                    )}

                    {!isRead && (
                      <button type="button"
                              data-alert-id={a.id}
                              class="mark-read-btn inline-flex items-center justify-center h-9 px-3 text-xs font-semibold rounded-xl bg-white text-mmp-ink border border-slate-200 hover:border-mmp-ink hover:bg-mmp-cream transition gap-1.5">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Đánh dấu đã đọc
                      </button>
                    )}

                    {isRead && (
                      <span class="inline-flex items-center gap-1.5 text-xs text-slate-500 px-2 py-1.5">
                        <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        Đã đọc {a._readTimeAgo}
                      </span>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}

      <!-- Footer info card -->
      <div class="mt-8 p-5 rounded-2xl bg-white border border-slate-100 text-center shadow-sm">
        <p class="text-xs text-slate-500 mb-3 leading-relaxed">
          Cảnh báo dựa trên dữ liệu thời tiết real-time + AQI sensors +<br />
          profile pet (breed, tuổi, sức khoẻ) phân tích bởi Mon Min Pet.
        </p>
        <a href="/settings"
           class="inline-flex items-center gap-1.5 text-sm font-semibold hover:underline transition"
           style="color: var(--c-gold);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Cài đặt thông báo
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>
  </main>

  <!-- Quest hook: fire check_weather trigger -->
  <script is:inline>
    (() => {
      try {
        fetch("/api/v1/quests/track/check-weather", {
          method: "POST", credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: "{}",
        }).catch(() => {});
      } catch (_) {}
    })();
  </script>

  <!-- Mark-read AJAX + reload handler (vanilla, Alpine already global) -->
  <script is:inline>
    (() => {
      // Mark-read: POST /:id/dismiss + optimistic UI + haptic
      document.querySelectorAll(".mark-read-btn").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          e.preventDefault();
          const alertId = btn.getAttribute("data-alert-id");
          if (!alertId) return;
          try {
            const res = await fetch(`/api/v1/alerts/${alertId}/dismiss`, {
              method: "POST", credentials: "include",
            });
            if (res.ok) {
              const card = btn.closest("article");
              if (card) {
                card.style.transition = "opacity 0.3s";
                card.style.opacity = "0.6";
                btn.style.display = "none";
                if (navigator.vibrate) navigator.vibrate(10);
              }
            }
          } catch (err) {
            console.warn("[alerts] mark-read failed", err);
          }
        });
      });

      // Reload — spin icon then full page reload
      const reloadBtn = document.getElementById("alerts-reload-btn");
      const reloadIcon = document.getElementById("alerts-reload-icon");
      if (reloadBtn && reloadIcon) {
        reloadBtn.addEventListener("click", () => {
          reloadIcon.classList.add("animate-spin");
          window.location.reload();
        });
      }
    })();
  </script>
</Layout>

<style is:global>
  /* Severity strip slow pulse (critical/urgent only) */
  @keyframes pulse-strip {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }
  .animate-pulse-strip {
    animation: pulse-strip 2s ease-in-out infinite;
  }

  /* Icon container ping (subtle outward fade) */
  @keyframes ping-slow {
    0% { transform: scale(1); opacity: 0.4; }
    100% { transform: scale(1.35); opacity: 0; }
  }
  .animate-ping-slow {
    animation: ping-slow 2.5s ease-out infinite;
  }

  /* Hide horizontal scrollbar on filter tab strip */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  @media (prefers-reduced-motion: reduce) {
    .animate-pulse-strip,
    .animate-ping-slow { animation: none; }
  }
</style>
