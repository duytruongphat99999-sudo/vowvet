---
import Layout from "../layouts/Layout.astro";
---

<Layout title="500 — Có lỗi xảy ra · VowVet" description="VowVet đang khắc phục lỗi. Vui lòng thử lại sau.">
  <main class="min-h-screen bg-gradient-to-b from-red-50 to-orange-50 flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full text-center">
      <p class="text-7xl mb-2 select-none">🚧</p>
      <h1 class="text-6xl sm:text-7xl font-bold text-red-600 mb-3">500</h1>
      <p class="text-xl sm:text-2xl font-bold text-slate-900 mb-2">Có lỗi xảy ra</p>
      <p class="text-slate-600 mb-8">VowVet đang khắc phục. Thử lại sau vài giây nhé.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <button onclick="window.location.reload()" class="bg-sky-600 hover:bg-sky-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg transition">
          🔄 Thử lại
        </button>
        <a href="/" class="bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 font-semibold px-6 py-3 rounded-xl transition">
          🏠 Về trang chủ
        </a>
      </div>
      <p class="text-xs text-slate-400 mt-8">Lỗi tái diễn? Báo bác sĩ Mon Min qua <a href="/health" class="text-sky-600 hover:underline">/health</a></p>
    </div>
  </main>
</Layout>
