                stroke-dasharray={GAUGE_C2} stroke-dashoffset={GAUGE_C2}
                style="filter: drop-shadow(0 0 10px rgba(236,185,33,0.45));">
                <animate id="psGaugeAnim" attributeName="stroke-dashoffset"
                  from={GAUGE_C2} to={gaugeOffset} dur="1.8s" begin="indefinite"
                  fill="freeze" calcMode="spline" keyTimes="0;1" keySplines="0.25 0.1 0.25 1"/>
              </circle>
            </svg>
            <!-- center score -->
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-1.5">
              <p class="font-display italic font-bold text-[72px] sm:text-[80px] leading-none tabular-nums text-white text-glow"
                x-text="displayScore"></p>
              <p class="text-[10px] uppercase font-mono" style="letter-spacing: 0.35em; color: rgba(255,255,255,0.55)">/ 1000 PTS</p>
            </div>
          </div>

          <!-- Subtitle + name -->
          <div class="text-center mt-5">
            <p class="text-[10px] uppercase font-mono" style="letter-spacing: 0.3em; color: rgba(255,255,255,0.5)">Certified Health Score</p>
