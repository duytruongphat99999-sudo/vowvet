              <circle cx="120" cy="290" r="1" class="dust-12"/>
              <circle cx="280" cy="120" r="0.7" class="dust-13"/>
              <circle cx="60" cy="60" r="0.9" class="dust-14"/>
              <circle cx="220" cy="280" r="0.6" class="dust-15"/>
              <circle cx="180" cy="200" r="1" class="dust-16"/>
              <circle cx="100" cy="250" r="0.8" class="dust-17"/>
              <circle cx="250" cy="100" r="0.7" class="dust-18"/>
